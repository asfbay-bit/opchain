{
  "name": "opchain-site",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "opchain.dev marketing site (Astro 5 + Cloudflare adapter). Real content lands in Sprints 1-3.",
  "scripts": {
    "gen-flags": "node ../scripts/gen-flags.mjs",
    "predev": "npm run gen-flags",
    "prebuild": "npm run gen-flags",
    "precheck": "npm run gen-flags",
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "check": "astro check",
    "pretest:e2e": "PUBLIC_POSTHOG_KEY=phc_test_e2e PUBLIC_POSTHOG_HOST=http://127.0.0.1:9999 npm run gen-flags && astro build",
    "test:e2e": "playwright test",
    "test:e2e:install": "playwright install --with-deps chromium",
    "prelhci": "npm run gen-flags && astro build",
    "lhci": "lhci autorun --config=../lighthouserc.json"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.3.0",
    "@astrojs/sitemap": "^3.7.2",
    "astro": "^6.2.1",
    "dompurify": "^3.4.2",
    "isomorphic-dompurify": "^3.11.0",
    "marked": "^18.0.2"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@axe-core/playwright": "^4.11.2",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.2.4",
    "tailwindcss": "^4.2.2",
    "typescript": "^5.6.0"
  }
}
