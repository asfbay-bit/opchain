---
import Base from "../layouts/Base.astro";
import OnboardingTour from "../components/OnboardingTour.astro";
import { walkthroughs } from "../data/walkthroughs";
import { getSkillRole } from "../lib/skills";
import { renderSafeMarkdown } from "../lib/markdown";

/**
 * Demo — short tour summary + IDE workbench.
 *
 * The page opens with a small intro distilled from the OnboardingTour
 * first step, then drops the user straight into the IDE-style
 * workbench: top bar, activity rail, scenario sidebar, editor +
 * transcript, inspector, status bar.
 *
 * Each scenario has two editor views — a static summary card (title,
 * tagline, inputs, clickable output rows) and a transcript mode that
 * renders the full Claude-Code-styled chat. Output rows and inline
 * artifact chips both open a shared <dialog> lightbox with the
 * pre-rendered markdown body. The whole workbench has a fullscreen
 * toggle that promotes it to the viewport.
 */

const sidebar = walkthroughs.map((w, i) => ({
  num: String(i + 1).padStart(2, "0"),
  id: w.id,
  skills: w.skills.map((id) => ({ id, role: getSkillRole(id) })),
}));

/** Pre-rendered artifact bodies — avoids client-side markdown parsing. */
const artifacts = walkthroughs.flatMap((w) =>
  w.outputs.map((o) => ({
    scenarioId: w.id,
    artifactId: o.id,
    label: o.label,
    kind: o.kind ?? "",
    html: renderSafeMarkdown(o.body),
  }))
);

/** Per-scenario transcript steps with claude exchange bodies pre-rendered.
    Renders the Claude-Code terminal-styled stream of beats + user/claude
    exchanges in transcript mode. Inline artifact chips reference output
    ids and dispatch the same modal lightbox the summary's output rows do. */
const transcripts = walkthroughs.map((w) => ({
  id: w.id,
  title: w.title,
  stepCount: w.steps.length,
  steps: w.steps.map((step) => {
    if (step.type === "beat") {
      return {
        kind: "beat" as const,
        label: step.label,
        caption: step.caption ?? "",
        skills: (step.skills ?? []).map((id) => ({ id, role: getSkillRole(id) })),
      };
    }
    if (step.role === "user") {
      return { kind: "user" as const, content: step.content };
    }
    return {
      kind: "claude" as const,
      skill: step.skill ?? "",
      skillRole: step.skill ? getSkillRole(step.skill) : null,
      html: renderSafeMarkdown(step.content),
      artifacts: (step.artifacts ?? []).map((aid) => {
        const a = w.outputs.find((o) => o.id === aid);
        return { id: aid, label: a?.label ?? aid, kind: a?.kind ?? "" };
      }),
    };
  }),
}));
---

<Base
  title="Demo · opchain"
  description="Replay curated opchain skill conversations end-to-end — six scenarios, real transcripts, click to inspect."
  active="/demo"
>
  <!-- Page summary — distilled from the OnboardingTour modals, styled
       as a card with an ember eyebrow + side bar so it reads as a
       summary panel rather than a regular page heading. -->
  <section class="page-summary" aria-label="What this demo is">
    <span class="page-summary-eyebrow">demo · what this is</span>
    <h1>Watch a finished run.</h1>
    <p class="lede">
      A live walkthrough of six finished opchain sessions — from
      idea-in-a-chat to deployed-to-production, end to end. Every line
      below is actual transcript, not a faked-up demo. No live chat,
      no email gate, no install required.
    </p>
    <p class="lede">
      Each scenario tackles a different problem the skill ecosystem
      solves: shipping a new app from concept, rescuing a half-finished
      dashboard, hardening security before release, migrating a legacy
      stack, reviving abandoned code, and shipping Stripe billing.
      Pick one on the left to get started.
    </p>
  </section>

  <!-- 2 · IDE workbench -->
  <section class="workbench" id="workbench" aria-label="Workbench">
    <div class="ide">
      <!-- Top bar -->
      <div class="ide-topbar">
        <div class="ide-dots">
          <span class="ide-dot"></span>
          <span class="ide-dot"></span>
          <span class="ide-dot"></span>
        </div>
        <span class="ide-title">opchain · /demo</span>
        <span class="ide-sep">·</span>
        <span>scenarios.workspace</span>
        <span class="ide-spacer"></span>
        <span class="ide-meta">claude-opus-4-7 · auto-accept</span>
        <button
          class="help-btn fullscreen-btn"
          data-fullscreen-toggle
          type="button"
          aria-label="Expand workbench to full screen"
          aria-pressed="false"
        >
          <span data-fs-label-off>⛶ expand</span>
          <span data-fs-label-on hidden>⛶ exit</span>
        </button>
        <button class="help-btn" data-tour-trigger type="button" aria-label="Open intro tour">
          (?) tour
        </button>
      </div>

      <!-- Activity rail -->
      <nav class="ide-activity" aria-label="Activity">
        <div class="act is-active" title="Scenarios">▦</div>
        <div class="act" title="Search">⌕</div>
        <div class="act" title="Inputs / Outputs">⊞</div>
        <div class="act" title="Skills">●</div>
        <div class="act" title="Help">?</div>
      </nav>

      <!-- Sidebar — scenario tree -->
      <div class="ide-sidebar" role="region" aria-label="Scenarios">
        <div class="side-head">scenarios · 6</div>
        {sidebar.map((s) => (
          <div class="tree-group">
            <button
              type="button"
              class="tree-folder"
              data-scenario={s.id}
              aria-expanded="false"
            >
              <span class="tree-arrow">▸</span>
              <span class="tree-num">{s.num}</span>
              <span class="tree-name">{s.id}</span>
              <span class="tree-count">{s.skills.length}</span>
            </button>
            <div class="tree-children">
              {s.skills.map((sk) => (
                <div class="tree-skill">
                  <span class:list={["role-dot", `role-${sk.role}`]}></span>
                  {sk.id}
                </div>
              ))}
            </div>
          </div>
        ))}
      </div>

      <!-- Editor — per-scenario summary panes with two modes. Default
           shows the welcome prompt; opening a scenario in the sidebar
           swaps in that scenario's pane (data-pane-mode="summary").
           "▶ play transcript" flips the pane to data-pane-mode="transcript"
           and the inspector swaps to a compact side-summary copy. -->
      <div class="ide-editor" role="region" aria-label="Scenario editor">
        <div class="editor-prompt" data-editor-prompt>
          <div class="editor-prompt-eyebrow">scenario summary</div>
          <p class="editor-prompt-h">Pick a scenario on the left.</p>
          <p class="editor-prompt-sub">
            Each scenario shows a one-paragraph brief, the inputs the
            user brought, and the outputs Claude produced — each output
            opens to its full body.
          </p>
        </div>

        {walkthroughs.map((w, i) => {
          const t = transcripts[i];
          return (
            <article
              class="scenario-pane"
              data-scenario-pane={w.id}
              data-pane-mode="summary"
              aria-label={`${w.title}`}
              hidden
            >
              <!-- ── Summary view ── -->
              <div class="pane-view" data-view="summary">
                <header class="scenario-head">
                  <div class="scenario-num">scenario {String(i + 1).padStart(2, "0")}</div>
                  <h2 class="scenario-title">{w.title}</h2>
                  <p class="scenario-tagline">{w.tagline} · {w.runtime}</p>
                  <button
                    type="button"
                    class="play-btn"
                    data-play-transcript={w.id}
                    aria-label={`Play ${w.title} transcript`}
                  >
                    <span class="play-ico" aria-hidden="true">▶</span>
                    play transcript · {t.stepCount} steps
                  </button>
                </header>

                <p class="scenario-summary">{w.summary}</p>

                <div class="scenario-cols">
                  <section class="scenario-col">
                    <div class="col-head">inputs · {w.inputs.length}</div>
                    <ul class="col-list">
                      {w.inputs.map((line) => (
                        <li>{line}</li>
                      ))}
                    </ul>
                  </section>

                  <section class="scenario-col">
                    <div class="col-head">outputs · {w.outputs.length}</div>
                    <ul class="col-list outputs-list">
                      {w.outputs.map((o) => (
                        <li>
                          <button
                            type="button"
                            class="output-row"
                            data-output-scenario={w.id}
                            data-output-id={o.id}
                            aria-label={`Open ${o.label}`}
                          >
                            <span class="output-ico">⊞</span>
                            <span class="output-label">{o.label}</span>
                            {o.kind && <span class="output-kind">{o.kind}</span>}
                          </button>
                        </li>
                      ))}
                    </ul>
                  </section>
                </div>
              </div>

              <!-- ── Transcript view ── -->
              <div class="pane-view cc-stream" data-view="transcript" hidden>
                <header class="transcript-head">
                  <button
                    type="button"
                    class="back-btn"
                    data-back-to-summary={w.id}
                    aria-label="Back to scenario summary"
                  >
                    <span aria-hidden="true">←</span> back to summary
                  </button>
                  <div class="transcript-meta">
                    {t.stepCount} steps · {w.runtime}
                  </div>
                </header>

                {t.steps.map((step, si) => {
                  if (step.kind === "beat") {
                    return (
                      <div class="cc-beat" data-step-index={si}>
                        <div class="cc-beat-rule" aria-hidden="true"></div>
                        <div class="cc-beat-body">
                          <span class="cc-beat-label">{step.label}</span>
                          {step.caption && (
                            <span class="cc-beat-caption">· {step.caption}</span>
                          )}
                          {step.skills.length > 0 && (
                            <span class="cc-beat-skills">
                              {step.skills.map((sk) => (
                                <code class:list={["cc-chip", `role-${sk.role}`]}>{sk.id}</code>
                              ))}
                            </span>
                          )}
                        </div>
                      </div>
                    );
                  }
                  if (step.kind === "user") {
                    return (
                      <div class="cc-user" data-step-index={si}>
                        <span class="cc-user-mark" aria-hidden="true">&gt;</span>
                        <span class="cc-user-text">{step.content}</span>
                      </div>
                    );
                  }
                  return (
                    <div class="cc-assistant" data-step-index={si}>
                      <div class="cc-assistant-head">
                        <span class="cc-bullet cc-bullet--tool" aria-hidden="true">●</span>
                        <span class="cc-name">claude</span>
                        {step.skill && (
                          <>
                            <span class="cc-sep" aria-hidden="true">·</span>
                            <code class:list={[
                              "cc-chip",
                              step.skillRole && `role-${step.skillRole}`,
                            ]}>{step.skill}</code>
                          </>
                        )}
                      </div>
                      <div class="cc-assistant-body" set:html={step.html} />
                      {step.artifacts.length > 0 && (
                        <div class="cc-artifacts" aria-label="Outputs from this exchange">
                          {step.artifacts.map((a) => (
                            <button
                              type="button"
                              class="output-row cc-artifact-chip"
                              data-output-scenario={w.id}
                              data-output-id={a.id}
                              aria-label={`Open ${a.label}`}
                            >
                              <span class="output-ico" aria-hidden="true">⊞</span>
                              <span class="output-label">{a.label}</span>
                              {a.kind && <span class="output-kind">{a.kind}</span>}
                            </button>
                          ))}
                        </div>
                      )}
                    </div>
                  );
                })}
              </div>
            </article>
          );
        })}
      </div>

      <!-- Inspector — placeholder by default, swaps to a compact
           scenario summary when the editor enters transcript mode. -->
      <div class="ide-inspector" role="region" aria-label="Scenario inspector">
        <div class="ide-placeholder" data-inspector-placeholder>
          summary moves here in transcript mode
        </div>
        {walkthroughs.map((w, i) => (
          <aside
            class="inspector-pane"
            data-inspector-pane={w.id}
            aria-label={`${w.title} side summary`}
            hidden
          >
            <div class="ip-eyebrow">scenario {String(i + 1).padStart(2, "0")}</div>
            <h3 class="ip-title">{w.title}</h3>
            <p class="ip-tagline">{w.tagline}</p>
            <p class="ip-summary">{w.summary}</p>
            <div class="ip-section">
              <div class="ip-section-head">inputs · {w.inputs.length}</div>
              <ul class="ip-list">
                {w.inputs.map((line) => (<li>{line}</li>))}
              </ul>
            </div>
            <div class="ip-section">
              <div class="ip-section-head">outputs · {w.outputs.length}</div>
              <ul class="ip-list">
                {w.outputs.map((o) => (
                  <li>
                    <button
                      type="button"
                      class="output-row ip-output-row"
                      data-output-scenario={w.id}
                      data-output-id={o.id}
                      aria-label={`Open ${o.label}`}
                    >
                      <span class="output-ico" aria-hidden="true">⊞</span>
                      <span class="output-label">{o.label}</span>
                      {o.kind && <span class="output-kind">{o.kind}</span>}
                    </button>
                  </li>
                ))}
              </ul>
            </div>
          </aside>
        ))}
      </div>

      <!-- Status bar -->
      <div class="ide-status">
        <span>workbench</span>
        <span class="ide-sep">·</span>
        <span>workbench · summary + transcript + lightbox</span>
        <span class="ide-sep">·</span>
        <span class="ok">✓ {sidebar.length} scenarios loaded</span>
        <span class="right">
          <span class="fs-hint" data-fs-hint hidden>
            <span class="key">Esc</span> exit fullscreen ·
          </span>
          <span class="key">↵</span> play ·
          <span class="key">␣</span> skip ·
          <span class="key">R</span> restart
        </span>
      </div>
    </div>
  </section>

  <OnboardingTour />

  <!-- Hidden artifact store — pre-rendered markdown bodies, one div per artifact.
       The JS lightbox reads innerHTML from here and injects it into the modal. -->
  <div class="artifact-store" aria-hidden="true" hidden>
    {artifacts.map((a) => (
      <div
        data-artifact-scenario={a.scenarioId}
        data-artifact-id={a.artifactId}
        set:html={a.html}
      />
    ))}
  </div>

  <!-- Output modal lightbox — opened by the click handler below. -->
  <dialog
    class="output-modal"
    id="output-modal"
    aria-modal="true"
    aria-labelledby="modal-title"
  >
    <div class="modal-inner">
      <div class="modal-header">
        <div class="modal-title-row">
          <span class="modal-ico" aria-hidden="true">⊞</span>
          <h2 id="modal-title" class="modal-title">Output preview</h2>
          <span class="modal-kind"></span>
        </div>
        <button class="modal-close" aria-label="Close output" type="button">✕</button>
      </div>
      <div class="modal-body prose"></div>
    </div>
  </dialog>
</Base>

<style>
  /* ── 1. Summary block — distilled tour content above the IDE.
        Card surface + ember left bar so it reads as a deliberate
        summary panel, not a regular page heading. ── */
  .page-summary {
    max-width: 1100px;
    margin: clamp(1.6rem, 4vw, 2.4rem) auto 1.5rem;
    padding: clamp(1rem, 2.5vw, 1.4rem) clamp(1.1rem, 3vw, 1.8rem);
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--r-md);
    box-shadow: var(--shadow-sm);
  }
  /* Side gutters on smaller viewports — match the workbench's. */
  @media (max-width: 1100px) {
    .page-summary { margin-left: clamp(0.5rem, 2vw, 1.5rem); margin-right: clamp(0.5rem, 2vw, 1.5rem); }
  }
  .page-summary-eyebrow {
    display: inline-block;
    /* Inline ember pair so the small mono-cap eyebrow clears AA-Normal
       (4.5:1) on the surface card in both themes:
       - Dark:  #f5894d on --surface #2a2218 → 6.39:1
       - Light: #993505 on --surface #f4e5cf → 5.92:1 (overridden below)
       Site tokens didn't have a value that hit the threshold in both
       directions: var(--accent) was 4.26 dark / 3.32 light, var(--char)
       was 2.91 dark / 4.35 light. */
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.55rem;
  }
  :global([data-theme="light"]) .page-summary-eyebrow {
    color: #993505;
  }
  .page-summary h1 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.4rem, 3vw, 2rem);
    line-height: 1.15;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.7rem;
    color: var(--text);
  }
  .page-summary .lede {
    color: var(--muted);
    max-width: 60rem;
    margin: 0 0 0.6rem;
    line-height: var(--lh-base);
  }
  .page-summary .lede:last-child { margin-bottom: 0; }

  /* ── 2. IDE workbench section ── */
  .workbench {
    padding: clamp(1rem, 3vw, 2rem) clamp(0.5rem, 2vw, 1.5rem) 4rem;
    background: var(--bg);
  }
  .ide {
    max-width: 1320px;
    margin: 0 auto;
    height: min(78vh, 820px);
    min-height: 560px;
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: grid;
    grid-template-rows: 32px 1fr 24px;
    grid-template-columns: 44px 248px 1fr 288px;
    grid-template-areas:
      "topbar topbar topbar topbar"
      "activity sidebar editor inspector"
      "status status status status";
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
  }

  /* Top bar */
  .ide-topbar {
    grid-area: topbar;
    display: flex;
    align-items: center;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--border);
    padding: 0 14px;
    gap: 14px;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .ide-dots { display: flex; gap: 6px; }
  .ide-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--border);
  }
  .ide-dot:nth-child(1) { background: #ff5f57; }
  .ide-dot:nth-child(2) { background: #febc2e; }
  .ide-dot:nth-child(3) { background: #28c840; }
  .ide-title { color: var(--text); font-weight: 500; }
  .ide-sep   { color: var(--subtle); }
  .ide-meta  { color: var(--subtle); }
  .ide-spacer { flex: 1; }
  .help-btn {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 3px;
    cursor: pointer;
    transition: color 120ms, border-color 120ms;
  }
  .help-btn:hover { color: var(--accent); border-color: var(--accent); }

  /* Activity rail */
  .ide-activity {
    grid-area: activity;
    background: var(--ribbon);
    border-right: 0.5px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 10px;
    gap: 4px;
  }
  .act {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    color: var(--subtle);
    cursor: pointer;
    border-left: 2px solid transparent;
    margin-left: -2px;
    font-size: 14px;
    transition: color 120ms, border-color 120ms;
  }
  .act:hover { color: var(--text); }
  .act.is-active {
    color: var(--text);
    border-left-color: var(--accent);
  }

  /* Sidebar — scenario tree */
  .ide-sidebar {
    grid-area: sidebar;
    background: var(--surface);
    border-right: 0.5px solid var(--border);
    overflow-y: auto;
    font-size: 12px;
  }
  .side-head {
    position: sticky;
    top: 0;
    padding: 8px 12px;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--border);
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 10px;
    z-index: 1;
  }
  .tree-group { padding: 2px 0; }
  .tree-folder {
    display: flex;
    align-items: center;
    gap: 6px;
    width: 100%;
    padding: 4px 12px;
    background: transparent;
    border: 0;
    color: var(--muted);
    font: inherit;
    text-align: left;
    cursor: pointer;
    user-select: none;
    transition: color 120ms, background 120ms;
  }
  .tree-folder:not(.is-open):hover {
    color: var(--text);
    background: var(--card);
  }
  /* Selected scenario — ember bg + obsidian text. Light theme overrides
     to var(--ember) (brand-constant) so the contrast clears AA-Normal
     against --obsidian (var(--accent) = #d95010 in light only hits
     4.46:1, just below threshold). */
  .tree-folder.is-open {
    background: var(--accent);
    color: var(--obsidian);
    font-weight: 500;
  }
  :global([data-theme="light"]) .tree-folder.is-open {
    background: var(--ember);
  }
  .tree-folder.is-open .tree-arrow,
  .tree-folder.is-open .tree-num,
  .tree-folder.is-open .tree-count { color: var(--obsidian); }
  .tree-folder:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring-inset);
  }
  .tree-arrow {
    color: var(--subtle);
    width: 10px;
    flex: 0 0 auto;
    text-align: center;
    font-size: 9px;
    transition: transform 120ms var(--ease-standard);
  }
  .tree-folder.is-open .tree-arrow {
    transform: rotate(0deg);
  }
  .tree-num {
    color: var(--subtle);
    font-size: 10.5px;
    width: 1.4em;
    flex: 0 0 auto;
    font-variant-numeric: tabular-nums;
  }
  .tree-name { flex: 1; }
  .tree-count {
    color: var(--subtle);
    font-size: 10px;
    margin-left: auto;
  }
  .tree-children {
    display: none;
    padding: 1px 0 4px;
  }
  .tree-folder.is-open + .tree-children { display: block; }
  .tree-skill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 12px 2px 32px;
    color: var(--muted);
    cursor: pointer;
    transition: color 120ms, background 120ms;
  }
  .tree-skill:hover { color: var(--text); background: var(--card); }
  .role-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .role-workflow     { background: var(--workflow); }
  .role-tri-agent    { background: var(--tri-agent); }
  .role-audit-gate   { background: var(--rose, var(--audit-gate)); }
  .role-specialist   { background: var(--teal, var(--specialist)); }
  .role-advisor      { background: var(--advisor); }
  .role-orchestrator { background: var(--orchestrator); }
  .role-success      { background: var(--success); }

  /* Editor — per-scenario summary panes */
  .ide-editor {
    grid-area: editor;
    background: var(--bg);
    overflow-y: auto;
    font-family: var(--font-display);
  }
  .ide-inspector {
    grid-area: inspector;
    background: var(--surface);
    border-left: 0.5px solid var(--border);
    overflow-y: auto;
    font-size: 12px;
  }

  .editor-prompt {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    padding: clamp(1rem, 3vw, 2rem);
    height: 100%;
    color: var(--muted);
  }
  .editor-prompt[hidden] { display: none; }
  .editor-prompt-eyebrow {
    /* Brighter ember — see .page-summary-eyebrow comment for rationale. */
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.6rem;
  }
  :global([data-theme="light"]) .editor-prompt-eyebrow { color: #993505; }
  .editor-prompt-h {
    font-size: var(--fs-lg);
    color: var(--text);
    margin: 0 0 0.5rem;
    font-weight: 500;
  }
  .editor-prompt-sub {
    margin: 0;
    max-width: 36rem;
    line-height: var(--lh-base);
  }

  .scenario-pane {
    padding: clamp(1rem, 3vw, 1.8rem);
  }
  .scenario-pane[hidden] { display: none; }
  .scenario-head { margin-bottom: 1rem; }
  .scenario-num {
    /* Brighter ember — see .page-summary-eyebrow comment for rationale. */
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  :global([data-theme="light"]) .scenario-num,
  :global([data-theme="light"]) .col-head { color: #993505; }
  .scenario-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.2rem, 2.4vw, 1.6rem);
    line-height: 1.2;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.4rem;
    color: var(--text);
  }
  .scenario-tagline {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    margin: 0;
  }
  .scenario-summary {
    color: var(--text);
    font-size: var(--fs-md);
    line-height: var(--lh-base);
    margin: 0 0 1.4rem;
    max-width: 60rem;
  }

  .scenario-cols {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1.4rem;
  }
  .scenario-col { min-width: 0; }
  .col-head {
    /* Brighter ember — see .page-summary-eyebrow comment for rationale. */
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
    padding-bottom: 0.4rem;
    border-bottom: 0.5px solid var(--border);
  }
  .col-list {
    margin: 0;
    padding: 0;
    list-style: none;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }
  .col-list li {
    color: var(--muted);
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    padding-left: 1rem;
    position: relative;
  }
  .col-list li::before {
    content: "›";
    position: absolute;
    left: 0;
    color: var(--accent);
  }
  .outputs-list li { padding-left: 0; }
  .outputs-list li::before { content: none; }
  .output-row {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    color: var(--text);
    font-family: inherit;
    font-size: var(--fs-base);
    padding: 0.55rem 0.75rem;
    display: flex;
    align-items: center;
    gap: 0.6rem;
    width: 100%;
    cursor: pointer;
    text-align: left;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard);
  }
  .output-row:hover {
    border-color: var(--accent);
    background: var(--ember-dim);
  }
  .output-row:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }
  .output-ico { color: var(--accent); flex: 0 0 auto; }
  .output-label { flex: 1; }
  .output-kind {
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    flex: 0 0 auto;
  }

  /* Single column on narrow viewports inside the editor pane. */
  @media (max-width: 1100px) {
    .scenario-cols { grid-template-columns: 1fr; gap: 1rem; }
  }
  .ide-placeholder {
    color: var(--subtle);
    padding: 14px;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* Status bar */
  .ide-status {
    grid-area: status;
    background: var(--ribbon);
    border-top: 0.5px solid var(--border);
    color: var(--muted);
    font-size: 10.5px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 14px;
    letter-spacing: 0.04em;
  }
  .ide-status .ok { color: var(--teal, var(--specialist)); }
  .ide-status .right { margin-left: auto; }
  .ide-status .key { color: var(--accent); font-weight: 500; }

  /* Mobile: stack the IDE columns into a single column. The sidebar
     scrolls horizontally above the editor; inspector hides. */
  @media (max-width: 767px) {
    .ide {
      height: auto;
      min-height: 0;
      grid-template-rows: 32px auto auto 24px;
      grid-template-columns: 1fr;
      grid-template-areas:
        "topbar"
        "sidebar"
        "editor"
        "status";
    }
    .ide-activity { display: none; }
    .ide-sidebar { max-height: 220px; }
    .ide-inspector { display: none; }
  }

  /* ── Transcript mode ──
        The editor pane has two child views: the summary card and the
        terminal-styled chat stream below. Mode is driven by
        .scenario-pane[data-pane-mode] and a JS toggle. The inspector
        gets a compact side-summary when transcript is on so the user
        keeps brief context while reading the chat. */
  .pane-view[hidden] { display: none; }

  .play-btn {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--accent);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: 0.06em;
    text-transform: uppercase;
    padding: 5px 10px;
    margin-top: 0.7rem;
    border-radius: var(--r-xs);
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    transition: color 120ms, background 120ms, border-color 120ms;
  }
  .play-btn:hover { background: var(--ember-dim); }
  .play-btn:focus-visible { outline: none; box-shadow: var(--focus-ring); }
  .play-ico { font-size: 0.7em; }

  .transcript-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    padding: 0.5rem 0.9rem;
    margin-bottom: 0.4rem;
    border-bottom: 0.5px solid var(--cc-border);
    background: rgba(0, 0, 0, 0.2);
    font-family: var(--font-mono);
  }
  .back-btn {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--cc-border);
    color: var(--cc-fg);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    padding: 4px 9px;
    border-radius: var(--r-xs);
    cursor: pointer;
    transition: color 120ms, border-color 120ms;
  }
  .back-btn:hover { color: var(--accent); border-color: var(--accent); }
  .back-btn:focus-visible { outline: none; box-shadow: var(--focus-ring); }
  .transcript-meta {
    color: var(--cc-dim);
    font-size: 11px;
    letter-spacing: 0.04em;
  }

  /* Claude-Code terminal stream tokens.
     Scoped to .cc-stream so the rest of the editor isn't affected. */
  .cc-stream {
    --cc-bg:      #181818;
    --cc-fg:      #e8e8e8;
    --cc-dim:     #8a8a8a;
    --cc-subtle:  #5a5a5a;
    --cc-cyan:    #62afff;
    --cc-orange:  #d99155;
    --cc-purple:  #b294ff;
    --cc-green:   #9ece6a;
    --cc-red:     #f7768e;
    --cc-border:  #2a2a2a;

    background: var(--cc-bg);
    color: var(--cc-fg);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.55;
    padding: 0 0 1rem;
    height: 100%;
    overflow-y: auto;
  }
  .cc-stream > * { padding-left: 0.9rem; padding-right: 0.9rem; }
  .cc-stream > .transcript-head { padding-left: 0.9rem; padding-right: 0.9rem; }

  .cc-beat {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1.2rem 0 0.6rem;
    color: var(--cc-dim);
    font-size: 11px;
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .cc-beat-rule {
    flex: 0 0 1rem;
    border-top: 0.5px solid var(--cc-border);
    height: 0;
  }
  .cc-beat-body {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .cc-beat-label   { color: var(--cc-fg); font-weight: 500; }
  .cc-beat-caption { color: var(--cc-dim); }
  .cc-beat-skills  { display: inline-flex; gap: 0.35rem; }

  .cc-chip {
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.04em;
    background: rgba(255, 255, 255, 0.04);
    border: 0.5px solid var(--cc-border);
    border-radius: 3px;
    padding: 1px 6px;
    color: var(--cc-fg);
    text-transform: none;
  }
  /* role-* tints come from the role-dot palette, mapped onto chip text. */
  .cc-chip.role-workflow     { color: var(--workflow); }
  .cc-chip.role-tri-agent    { color: var(--tri-agent); }
  .cc-chip.role-audit-gate   { color: var(--rose, var(--audit-gate)); }
  .cc-chip.role-specialist   { color: var(--teal, var(--specialist)); }
  .cc-chip.role-advisor      { color: var(--advisor); }
  .cc-chip.role-orchestrator { color: var(--orchestrator); }
  .cc-chip.role-success      { color: var(--success); }

  .cc-user {
    display: flex;
    gap: 0.55rem;
    margin: 0.7rem 0 0.4rem;
    color: var(--cc-fg);
  }
  .cc-user-mark { color: var(--cc-cyan); flex: 0 0 auto; }
  .cc-user-text { white-space: pre-wrap; }

  .cc-assistant { margin: 0.7rem 0 0.9rem; }
  .cc-assistant-head {
    display: flex;
    align-items: center;
    gap: 0.45rem;
    margin-bottom: 0.4rem;
    color: var(--cc-dim);
    font-size: 11.5px;
  }
  .cc-bullet { color: var(--cc-orange); flex: 0 0 auto; }
  .cc-name   { color: var(--cc-fg); font-weight: 600; }
  .cc-sep    { color: var(--cc-subtle); }

  .cc-assistant-body {
    color: var(--cc-fg);
    padding-left: 1.05rem;
    border-left: 1px solid var(--cc-border);
    margin-left: 0.18rem;
  }
  .cc-assistant-body :global(p) { margin: 0 0 0.55rem; }
  .cc-assistant-body :global(p:last-child) { margin-bottom: 0; }
  .cc-assistant-body :global(strong) { color: #fff; font-weight: 600; }
  .cc-assistant-body :global(em) { color: var(--cc-fg); font-style: italic; }
  .cc-assistant-body :global(h1),
  .cc-assistant-body :global(h2),
  .cc-assistant-body :global(h3) {
    margin: 0.7rem 0 0.4rem;
    color: var(--cc-fg);
    font-family: var(--font-mono);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .cc-assistant-body :global(h1) { font-size: 14px; }
  .cc-assistant-body :global(h2) { font-size: 13px; }
  .cc-assistant-body :global(h3) { font-size: 12px; color: var(--cc-fg); }
  .cc-assistant-body :global(ul),
  .cc-assistant-body :global(ol) { margin: 0 0 0.55rem; padding-left: 1.1rem; }
  .cc-assistant-body :global(li) { margin: 0.1rem 0; }
  .cc-assistant-body :global(code) {
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--cc-cyan);
    background: rgba(98, 175, 255, 0.08);
    border-radius: 2px;
    padding: 0 4px;
  }
  .cc-assistant-body :global(pre) {
    background: rgba(255, 255, 255, 0.03);
    border: 0.5px solid var(--cc-border);
    border-radius: 3px;
    padding: 0.6rem 0.8rem;
    overflow-x: auto;
    margin: 0 0 0.6rem;
    font-size: 12px;
  }
  .cc-assistant-body :global(pre code) {
    background: none;
    padding: 0;
    color: var(--cc-fg);
  }
  .cc-assistant-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 0.55rem;
    font-size: 11.5px;
  }
  .cc-assistant-body :global(th),
  .cc-assistant-body :global(td) {
    border: 0.5px solid var(--cc-border);
    padding: 0.3rem 0.55rem;
    text-align: left;
  }
  .cc-assistant-body :global(th) {
    background: rgba(255, 255, 255, 0.03);
    color: var(--cc-fg);
    font-weight: 500;
  }
  .cc-assistant-body :global(blockquote) {
    border-left: 2px solid var(--cc-orange);
    margin: 0 0 0.55rem;
    padding: 0.2rem 0 0.2rem 0.7rem;
    color: var(--cc-dim);
  }
  .cc-assistant-body :global(a) {
    color: var(--cc-cyan);
    text-decoration: underline;
    text-underline-offset: 2px;
  }

  .cc-artifacts {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
    margin: 0.55rem 0 0;
    padding-left: 1.05rem;
  }
  .cc-artifact-chip {
    background: rgba(255, 255, 255, 0.03);
    border: 0.5px solid var(--cc-border);
    color: var(--cc-fg);
    font-size: 12px;
  }
  .cc-artifact-chip:hover {
    border-color: var(--cc-orange);
    background: rgba(217, 145, 85, 0.08);
  }
  .cc-artifact-chip .output-ico   { color: var(--cc-orange); }
  .cc-artifact-chip .output-kind  { color: var(--cc-dim); }

  /* Inspector side-summary. */
  .inspector-pane {
    padding: 0.9rem 1rem 1.2rem;
    color: var(--muted);
    font-family: var(--font-display);
    font-size: var(--fs-sm);
  }
  .inspector-pane[hidden] { display: none; }
  .ip-eyebrow {
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  :global([data-theme="light"]) .ip-eyebrow { color: #993505; }
  .ip-title {
    color: var(--text);
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-md);
    line-height: 1.25;
    margin: 0 0 0.3rem;
  }
  .ip-tagline {
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.03em;
    margin: 0 0 0.7rem;
  }
  .ip-summary {
    color: var(--text);
    font-size: var(--fs-sm);
    line-height: var(--lh-base);
    margin: 0 0 1rem;
  }
  .ip-section { margin-bottom: 0.9rem; }
  .ip-section-head {
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
    padding-bottom: 0.25rem;
    border-bottom: 0.5px solid var(--border);
  }
  :global([data-theme="light"]) .ip-section-head { color: #993505; }
  .ip-list { list-style: none; padding: 0; margin: 0; }
  .ip-list li {
    color: var(--muted);
    font-size: 11.5px;
    line-height: 1.45;
    padding: 0.18rem 0;
  }
  .ip-output-row { font-size: 11.5px; padding: 0.4rem 0.55rem; }
  .ip-output-row .output-ico { font-size: 11px; }

  /* The inspector placeholder + matching pane are toggled by JS based
     on whether the active scenario is in transcript mode. */
  [data-inspector-placeholder][hidden] { display: none; }

  /* ── Fullscreen workbench ──
        Toggle expands .workbench to fill the viewport. Implemented as
        a CSS class swap rather than the Fullscreen API — avoids the
        permission prompt + iframe edge cases, gives us full styling
        control, and degrades gracefully if JS is off (the button is
        hidden until JS wires it). Click .fullscreen-btn or press Esc
        to exit. The output-modal still owns its own Esc behavior since
        it's a native <dialog>; the global Esc handler bails when a
        modal is open. */
  .fullscreen-btn { letter-spacing: 0.06em; }
  .fs-hint { color: var(--accent); margin-right: 0.4rem; }
  .workbench.is-fullscreen {
    position: fixed;
    inset: 0;
    z-index: 100;
    padding: 0;
    margin: 0;
    background: var(--bg);
  }
  .workbench.is-fullscreen .ide {
    height: 100dvh;
    min-height: 0;
    max-width: none;
    margin: 0;
    border: none;
    border-radius: 0;
  }
  /* Hide page chrome behind the fullscreen workbench. */
  body:has(.workbench.is-fullscreen) {
    overflow: hidden;
  }
  /* Reposition the topbar mac-style dots so they double as a "minimize"
     hint — clicking the red dot also exits fullscreen. */
  .workbench.is-fullscreen .ide-dot:nth-child(1) {
    cursor: pointer;
  }

  /* ── Output modal lightbox ── */
  /* Base rule deliberately omits `display` — Astro's CSS scoping adds
     a data-astro-cid attribute that would bump specificity above the
     UA `dialog:not([open]) { display: none }` default and force the
     modal visible on page load. The [open] rule below provides the
     in-use layout. */
  .output-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(90vw, 820px);
    max-height: min(88vh, 900px);
    padding: 0;
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    background: var(--bg);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 2px 8px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    flex-direction: column;
  }
  .output-modal[open] { display: flex; }
  .output-modal::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(3px);
  }
  .modal-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  .modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem 0.75rem;
    background: var(--surface);
    border-bottom: 0.5px solid var(--border);
    flex: 0 0 auto;
  }
  .modal-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }
  .modal-ico {
    color: var(--accent);
    font-size: 1rem;
    flex: 0 0 auto;
  }
  .modal-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-md);
    line-height: 1.3;
    color: var(--text);
    margin: 0;
    min-width: 0;
  }
  .modal-kind {
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    flex: 0 0 auto;
    padding: 2px 6px;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
  }
  .modal-close {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 13px;
    width: 28px;
    height: 28px;
    border-radius: var(--r-xs);
    cursor: pointer;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    transition: color 120ms, border-color 120ms;
  }
  .modal-close:hover { color: var(--text); border-color: var(--text); }
  .modal-close:focus-visible { outline: none; box-shadow: var(--focus-ring); }
  .modal-body {
    padding: 1.5rem 1.6rem;
    overflow-y: auto;
    flex: 1 1 0;
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    color: var(--text);
  }
  /* Prose resets inside the modal body */
  .modal-body :global(h1),
  .modal-body :global(h2),
  .modal-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    margin: 1.4rem 0 0.5rem;
    line-height: 1.25;
  }
  .modal-body :global(h1) { font-size: clamp(1.1rem, 2vw, 1.4rem); }
  .modal-body :global(h2) { font-size: clamp(1rem, 1.8vw, 1.2rem); }
  .modal-body :global(h3) { font-size: var(--fs-md); }
  .modal-body :global(p)  { margin: 0 0 0.75rem; }
  .modal-body :global(ul),
  .modal-body :global(ol) { padding-left: 1.4rem; margin: 0 0 0.75rem; }
  .modal-body :global(li) { margin-bottom: 0.25rem; }
  .modal-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
    color: var(--accent);
  }
  .modal-body :global(pre) {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-sm);
    padding: 0.9rem 1rem;
    overflow-x: auto;
    margin: 0 0 1rem;
  }
  .modal-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .modal-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1rem;
    font-size: var(--fs-sm);
  }
  .modal-body :global(th),
  .modal-body :global(td) {
    border: 0.5px solid var(--border);
    padding: 0.45rem 0.75rem;
    text-align: left;
  }
  .modal-body :global(th) {
    background: var(--surface);
    color: var(--muted);
    font-weight: 500;
  }
  .modal-body :global(strong) { color: var(--text); font-weight: 600; }
  .modal-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .modal-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 0 0 1rem;
    padding: 0.4rem 0 0.4rem 1rem;
    color: var(--muted);
  }
  .modal-body :global(hr) {
    border: none;
    border-top: 0.5px solid var(--border);
    margin: 1.2rem 0;
  }
  @media (max-width: 600px) {
    .output-modal { width: 100vw; max-height: 100dvh; border-radius: 0; border-left: none; border-right: none; }
  }
</style>

<script is:inline>
  /* Sidebar + editor swap — accordion.

     Sidebar: folders start collapsed. Click opens the clicked folder
     and closes all others (single-select accordion). Active scenario
     tracks whichever folder is open; closing it clears the editor. */
  (() => {
    const folders        = document.querySelectorAll('.tree-folder[data-scenario]');
    const panes          = document.querySelectorAll('[data-scenario-pane]');
    const inspectorPanes = document.querySelectorAll('[data-inspector-pane]');
    const prompt         = document.querySelector('[data-editor-prompt]');
    const inspectorHint  = document.querySelector('[data-inspector-placeholder]');

    function setPaneMode(pane, mode) {
      pane.dataset.paneMode = mode;
      pane.querySelectorAll('.pane-view').forEach((v) => {
        if (v.dataset.view === mode) v.removeAttribute('hidden');
        else                          v.setAttribute('hidden', '');
      });
    }

    function syncInspector(activeId) {
      const activePane = activeId
        ? document.querySelector(`[data-scenario-pane="${CSS.escape(activeId)}"]`)
        : null;
      const transcriptOn = !!(activePane && activePane.dataset.paneMode === 'transcript');
      inspectorPanes.forEach((p) => {
        const on = transcriptOn && p.dataset.inspectorPane === activeId;
        if (on) p.removeAttribute('hidden');
        else    p.setAttribute('hidden', '');
      });
      if (inspectorHint) {
        if (transcriptOn) inspectorHint.setAttribute('hidden', '');
        else              inspectorHint.removeAttribute('hidden');
      }
    }

    function showEditor(activeId) {
      let any = false;
      panes.forEach((pane) => {
        const on = pane.dataset.scenarioPane === activeId;
        if (on) { pane.removeAttribute('hidden'); any = true; }
        else    {
          pane.setAttribute('hidden', '');
          if (pane.dataset.paneMode === 'transcript') setPaneMode(pane, 'summary');
        }
      });
      if (prompt) {
        if (any) prompt.setAttribute('hidden', '');
        else     prompt.removeAttribute('hidden');
      }
      syncInspector(activeId);
    }

    function closeFolder(folder) {
      folder.classList.remove('is-open');
      folder.setAttribute('aria-expanded', 'false');
      const arrow = folder.querySelector('.tree-arrow');
      if (arrow) arrow.textContent = '▸';
    }

    folders.forEach((folder) => {
      folder.addEventListener('click', () => {
        const wasOpen = folder.classList.contains('is-open');

        // Accordion: always close all folders first.
        folders.forEach(closeFolder);

        if (!wasOpen) {
          // Open the clicked one and make it the active editor scenario.
          folder.classList.add('is-open');
          folder.setAttribute('aria-expanded', 'true');
          const arrow = folder.querySelector('.tree-arrow');
          if (arrow) arrow.textContent = '▾';
          showEditor(folder.dataset.scenario);
        } else {
          // Was open — now all are closed, clear editor.
          showEditor(null);
        }
      });
    });

    /* Transcript mode toggle. */
    document.querySelectorAll('[data-play-transcript]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-play-transcript');
        const pane = document.querySelector(`[data-scenario-pane="${CSS.escape(id)}"]`);
        if (!pane) return;
        setPaneMode(pane, 'transcript');
        syncInspector(id);
        const stream = pane.querySelector('.pane-view[data-view="transcript"]');
        if (stream) stream.scrollTop = 0;
      });
    });

    document.querySelectorAll('[data-back-to-summary]').forEach((btn) => {
      btn.addEventListener('click', () => {
        const id = btn.getAttribute('data-back-to-summary');
        const pane = document.querySelector(`[data-scenario-pane="${CSS.escape(id)}"]`);
        if (!pane) return;
        setPaneMode(pane, 'summary');
        syncInspector(id);
      });
    });
  })();

  /* Output modal lightbox — event delegation.
     Single document listener catches clicks from any .output-row,
     including those in summary-page right columns that are dynamically
     shown/hidden. */
  (() => {
    const modal    = /** @type {HTMLDialogElement|null} */ (document.getElementById('output-modal'));
    const titleEl  = document.getElementById('modal-title');
    const kindEl   = modal && modal.querySelector('.modal-kind');
    const bodyEl   = modal && modal.querySelector('.modal-body');
    const closeBtn = modal && modal.querySelector('.modal-close');
    const store    = document.querySelector('.artifact-store');
    if (!modal || !titleEl || !kindEl || !bodyEl || !store) return;

    function openArtifact(btn) {
      const scenarioId = btn.dataset.outputScenario;
      const artifactId = btn.dataset.outputId;
      if (!scenarioId || !artifactId) return;
      const src = store.querySelector(
        `[data-artifact-scenario="${CSS.escape(scenarioId)}"][data-artifact-id="${CSS.escape(artifactId)}"]`
      );
      if (!src) return;

      const label = btn.querySelector('.output-label')
        ? btn.querySelector('.output-label').textContent.trim()
        : artifactId;
      const kind = btn.querySelector('.output-kind')
        ? btn.querySelector('.output-kind').textContent.trim()
        : '';

      titleEl.textContent = label;
      kindEl.textContent  = kind;
      bodyEl.innerHTML    = src.innerHTML;
      modal.showModal();
    }

    // Event delegation — catches every .output-row regardless of where it lives.
    document.addEventListener('click', (e) => {
      const btn = /** @type {HTMLElement|null} */ (
        e.target instanceof Element
          ? e.target.closest('.output-row[data-output-scenario]')
          : null
      );
      if (btn) openArtifact(/** @type {HTMLElement} */ (btn));
    });

    closeBtn && closeBtn.addEventListener('click', () => modal.close());

    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });
  })();

  /* Fullscreen workbench.
     Toggle button, red-dot, and Escape exit fullscreen. Clicking the
     workbench background (when not already fullscreen) enters it. */
  (() => {
    const workbench = document.querySelector('.workbench');
    const btn       = document.querySelector('[data-fullscreen-toggle]');
    const labelOff  = btn && btn.querySelector('[data-fs-label-off]');
    const labelOn   = btn && btn.querySelector('[data-fs-label-on]');
    const hint      = document.querySelector('[data-fs-hint]');
    const redDot    = document.querySelector('.ide-dots .ide-dot:nth-child(1)');
    if (!workbench || !btn) return;

    function setFullscreen(on) {
      workbench.classList.toggle('is-fullscreen', on);
      btn.setAttribute('aria-pressed', on ? 'true' : 'false');
      btn.setAttribute('aria-label', on ? 'Exit fullscreen workbench' : 'Expand workbench to full screen');
      if (labelOff) { if (on) labelOff.setAttribute('hidden', ''); else labelOff.removeAttribute('hidden'); }
      if (labelOn)  { if (on) labelOn.removeAttribute('hidden');     else labelOn.setAttribute('hidden', ''); }
      if (hint)     { if (on) hint.removeAttribute('hidden');        else hint.setAttribute('hidden', ''); }
    }

    function isFullscreen() {
      return workbench.classList.contains('is-fullscreen');
    }

    btn.addEventListener('click', () => setFullscreen(!isFullscreen()));

    // Click the workbench background (not an inner element) to enter fullscreen.
    workbench.addEventListener('click', (e) => {
      if (!isFullscreen() && e.target === workbench) setFullscreen(true);
    });

    if (redDot) {
      redDot.setAttribute('role', 'button');
      redDot.setAttribute('tabindex', '0');
      redDot.setAttribute('aria-label', 'Exit fullscreen workbench');
      redDot.addEventListener('click', () => { if (isFullscreen()) setFullscreen(false); });
    }

    document.addEventListener('keydown', (e) => {
      if (e.key !== 'Escape') return;
      if (!isFullscreen()) return;
      const openDialog = document.querySelector('dialog[open]');
      if (openDialog) return;
      setFullscreen(false);
    });
  })();

  /* Step-by-step transcript playback.
     On "▶ play transcript": all steps are hidden; ↵ reveals the next
     step, ␣ reveals all at once, R resets to the beginning. The mode
     is scoped to the currently-visible transcript pane. */
  (() => {
    let stepCursor = -1;   // index of last-revealed step in current playback
    let activeSteps = [];  // NodeList snapshot for the current transcript

    function getVisibleTranscript() {
      return document.querySelector(
        '[data-scenario-pane]:not([hidden]) .pane-view[data-view="transcript"]:not([hidden])'
      );
    }

    function startPlayback() {
      const transcript = getVisibleTranscript();
      if (!transcript) return;
      activeSteps = Array.from(transcript.querySelectorAll('[data-step-index]'));
      if (activeSteps.length === 0) return;
      stepCursor = -1;
      activeSteps.forEach((el) => el.setAttribute('hidden', ''));
      transcript.scrollTop = 0;
    }

    function revealNext() {
      if (activeSteps.length === 0) return;
      stepCursor = Math.min(stepCursor + 1, activeSteps.length - 1);
      const el = activeSteps[stepCursor];
      el.removeAttribute('hidden');
      el.scrollIntoView({ block: 'nearest', behavior: 'smooth' });
    }

    function revealAll() {
      activeSteps.forEach((el) => el.removeAttribute('hidden'));
      stepCursor = activeSteps.length - 1;
    }

    function resetPlayback() {
      if (activeSteps.length === 0) {
        // Re-init from whatever transcript is visible.
        startPlayback();
        return;
      }
      stepCursor = -1;
      activeSteps.forEach((el) => el.setAttribute('hidden', ''));
      const transcript = getVisibleTranscript();
      if (transcript) transcript.scrollTop = 0;
    }

    // Hook into the existing play-transcript buttons to start playback.
    document.querySelectorAll('[data-play-transcript]').forEach((playBtn) => {
      playBtn.addEventListener('click', () => {
        // Defer until the pane swap (above IIFE) has run.
        requestAnimationFrame(startPlayback);
      });
    });

    document.addEventListener('keydown', (e) => {
      // Only active when a transcript pane is visible.
      if (!getVisibleTranscript()) return;
      if (e.target instanceof HTMLInputElement || e.target instanceof HTMLTextAreaElement) return;

      if (e.key === 'Enter' && !e.shiftKey && !e.ctrlKey && !e.metaKey) {
        e.preventDefault();
        revealNext();
      } else if (e.key === ' ') {
        e.preventDefault();
        revealAll();
      } else if (e.key === 'r' || e.key === 'R') {
        e.preventDefault();
        resetPlayback();
      }
    });
  })();
</script>
