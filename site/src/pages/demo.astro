---
import Base from "../layouts/Base.astro";
import Replays from "../components/Replays.astro";
import OnboardingTour from "../components/OnboardingTour.astro";
import { walkthroughs } from "../data/walkthroughs";

/**
 * Demo — magazine-style intro + interactive workbench.
 *
 * The intro is a compact editorial "cover" capped at ~32vh. Its
 * headline rotates through all six walkthroughs on a deterministic
 * 2-minute slot tied to wall-clock time (12-min full cycle), so every
 * visitor in the same 2-minute window sees the same scenario. Server-
 * renders the first walkthrough; client JS overrides to whichever slot
 * is current and schedules the next swap on the slot boundary.
 *
 * The workbench below hosts <Replays /> — the real scenario engine.
 * Clicking inside it promotes the frame to a centered focus overlay;
 * clicking the backdrop / pressing Escape releases it.
 */

const covers = walkthroughs.map((w, i) => ({
  num: String(i + 1).padStart(2, "0"),
  id: w.id,
  title: w.title,
  tagline: w.tagline,
}));
const initial = covers[0];
---

<Base
  title="Demo · opchain"
  description="Replay curated opchain skill conversations end-to-end — six scenarios, real transcripts, click to inspect."
  active="/demo"
>
  <!-- 1 · Magazine cover — capped at ~32vh, rotates every 30 min -->
  <section class="stage" data-cover>
    <div class="stage-mid">
      <div class="stage-issue">
        opchain · scenario <span data-cover-num>{initial.num}</span>
      </div>
      <h1 class="stage-h" data-cover-title>{initial.title}</h1>
      <p class="stage-sub" data-cover-tagline>{initial.tagline}</p>
      <div class="stage-actions">
        <a class="btn btn-primary" href="#workbench">▶ open the workbench</a>
        <a class="btn btn-ghost" href="/install">install opchain</a>
      </div>
    </div>
  </section>

  <script is:inline type="application/json" id="cover-data" set:html={JSON.stringify(covers)} />

  <!-- 2 · Workbench -->
  <section class="workbench" id="workbench">
    <div class="work-head">
      <div class="work-eyebrow">workbench</div>
      <h2 class="work-h">Inspect the same run, end to end.</h2>
      <p class="work-sub">
        Pick a scenario. Step through, scrub, or jump to the payoff.
        <button class="help-btn" data-tour-trigger type="button" aria-label="Open intro tour">
          (?) tour
        </button>
      </p>
    </div>

    <div class="work-frame" data-workbench tabindex="-1">
      <button
        class="work-release"
        type="button"
        data-workbench-release
        aria-label="Exit workbench focus mode"
        title="Press Esc to exit"
      >
        ✕ exit
      </button>
      <Replays />
    </div>
  </section>

  <div class="workbench-backdrop" data-workbench-backdrop hidden></div>

  <OnboardingTour />
</Base>

<style>
  /* ── 1. Magazine cover — compact, data-driven, rotates every 30 min ── */
  .stage {
    position: relative;
    max-height: 32vh;
    min-height: 200px;
    overflow: hidden;
    padding: clamp(1.1rem, 2.5vw, 1.8rem) clamp(1rem, 4vw, 2.4rem);
    background:
      radial-gradient(640px 320px at 75% 30%, var(--ember-glow), transparent 70%),
      radial-gradient(420px 240px at 15% 80%, var(--ember-dim), transparent 70%),
      var(--bg);
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
  }
  .stage-mid {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  .stage-issue {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .stage-h {
    font-family: var(--font-display);
    font-weight: 600;
    /* Tighter cap than the old hero — the headline now feeds from
       walkthrough.title which is generally short and scannable. */
    font-size: clamp(1.15rem, 2.2vw, 1.7rem);
    line-height: 1.15;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.4rem;
    max-width: 36ch;
    color: var(--text);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage-sub {
    font-size: var(--fs-base);
    color: var(--muted);
    max-width: 44rem;
    margin: 0 0 0.85rem;
    line-height: var(--lh-snug);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage[data-swapping] .stage-h,
  .stage[data-swapping] .stage-sub,
  .stage[data-swapping] .stage-issue { opacity: 0; }
  .stage-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    border-radius: var(--r-xs);
    transition:
      transform var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--obsidian);
    border: 0;
    font-weight: 600;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--glow-md);
  }
  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 0.5px solid var(--border);
  }
  .btn-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── 2. Workbench section ── */
  .workbench {
    padding: clamp(1.5rem, 4vw, 3rem) clamp(1rem, 4vw, 2rem) 5rem;
    background: var(--bg);
  }
  .work-head {
    max-width: 1100px;
    margin: 0 auto 1.6rem;
  }
  .work-eyebrow {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.4rem;
  }
  .work-h {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.5rem;
    max-width: 40ch;
    color: var(--text);
  }
  .work-sub {
    color: var(--muted);
    font-size: var(--fs-md);
    max-width: 50rem;
    margin: 0;
    line-height: var(--lh-base);
  }
  .help-btn {
    margin-left: 0.4rem;
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    padding: 1px 8px;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .help-btn:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── 3. Workbench frame ── */
  .work-frame {
    position: relative;
    max-width: 1180px;
    margin: 0 auto;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.4rem;
    cursor: zoom-in;
    transition:
      transform var(--dur-base) var(--ease-emphasized),
      box-shadow var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard);
  }
  .work-frame:hover:not(.is-focused) {
    border-color: var(--accent);
    box-shadow: var(--glow-md);
  }
  .work-frame:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }

  .work-release {
    position: absolute;
    top: 0.75rem;
    right: 0.75rem;
    z-index: 2;
    display: none;
    appearance: none;
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    padding: 4px 10px;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .work-release:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── 4. Focus mode — locks the workbench centered until released ── */
  .work-frame.is-focused {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: min(96vw, 1280px);
    height: min(92vh, 900px);
    max-width: none;
    margin: 0;
    z-index: 100;
    cursor: default;
    overflow: auto;
    box-shadow: var(--shadow-xl), var(--glow-lg);
    border-color: var(--accent);
  }
  .work-frame.is-focused .work-release { display: inline-flex; }

  .workbench-backdrop {
    position: fixed;
    inset: 0;
    z-index: 90;
    background: rgba(12, 8, 4, 0.7);
    backdrop-filter: blur(4px);
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .workbench-backdrop.is-visible {
    opacity: 1;
    pointer-events: auto;
  }
  .workbench-backdrop[hidden] { display: none; }

  body.workbench-locked {
    overflow: hidden;
  }

  /* Don't trap mobile users in a fixed overlay — focus mode is
     desktop-only. On narrow viewports the workbench just stays in flow. */
  @media (max-width: 767px) {
    .work-frame { cursor: auto; }
    .work-frame.is-focused {
      position: static;
      transform: none;
      width: auto;
      height: auto;
      box-shadow: none;
    }
    .work-frame.is-focused .work-release { display: none; }
    .workbench-backdrop.is-visible {
      opacity: 0;
      pointer-events: none;
    }
  }
</style>

<script is:inline>
  (() => {
    const frame = document.querySelector('[data-workbench]');
    const backdrop = document.querySelector('[data-workbench-backdrop]');
    const release = document.querySelector('[data-workbench-release]');
    if (!frame || !backdrop || !release) return;

    const desktop = () => window.matchMedia('(min-width: 768px)').matches;
    let focused = false;

    function lock() {
      if (focused || !desktop()) return;
      focused = true;
      frame.classList.add('is-focused');
      backdrop.hidden = false;
      // Force layout so the transition fires from opacity:0.
      void backdrop.offsetWidth;
      backdrop.classList.add('is-visible');
      document.body.classList.add('workbench-locked');
      frame.focus({ preventScroll: true });
    }
    function unlock() {
      if (!focused) return;
      focused = false;
      frame.classList.remove('is-focused');
      backdrop.classList.remove('is-visible');
      document.body.classList.remove('workbench-locked');
      // Hide backdrop after the fade-out so it doesn't block clicks.
      setTimeout(() => { if (!focused) backdrop.hidden = true; }, 220);
    }

    frame.addEventListener('click', (e) => {
      if (focused) return;
      // Don't intercept link / button clicks inside the frame on first
      // engagement — but otherwise any click promotes to focus mode.
      const interactive = e.target.closest('a, button, [role="button"], input, textarea, select');
      if (interactive) return;
      lock();
    });

    backdrop.addEventListener('click', unlock);
    release.addEventListener('click', (e) => { e.stopPropagation(); unlock(); });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && focused) unlock();
    });
  })();

  /* Magazine cover — 2-minute slot rotation (6 covers × 2 min = 12 min
     cycle). The slot is keyed to wall-clock time (epoch ms / 2min) modulo
     the number of covers, so every visitor in the same 2-minute window
     sees the same headline.

     If the page is open across a slot boundary, the cover fades out, swaps
     content, and fades back in. */
  (() => {
    const stage = document.querySelector('[data-cover]');
    const dataNode = document.getElementById('cover-data');
    if (!stage || !dataNode) return;

    let covers;
    try { covers = JSON.parse(dataNode.textContent || '[]'); }
    catch { return; }
    if (!Array.isArray(covers) || covers.length === 0) return;

    const SLOT_MS = 2 * 60 * 1000;
    const numEl = stage.querySelector('[data-cover-num]');
    const titleEl = stage.querySelector('[data-cover-title]');
    const taglineEl = stage.querySelector('[data-cover-tagline]');

    function slotIndex() {
      return Math.floor(Date.now() / SLOT_MS) % covers.length;
    }
    function paint(c) {
      if (numEl) numEl.textContent = c.num;
      if (titleEl) titleEl.textContent = c.title;
      if (taglineEl) taglineEl.textContent = c.tagline;
    }
    function swap(animated) {
      const c = covers[slotIndex()];
      if (!animated) { paint(c); return; }
      stage.setAttribute('data-swapping', '');
      setTimeout(() => {
        paint(c);
        stage.removeAttribute('data-swapping');
      }, 200);
    }

    // Initial paint — overrides the SSR default with the current slot.
    swap(false);

    // Schedule the next swap at the slot boundary, then every SLOT_MS.
    const msUntilNext = SLOT_MS - (Date.now() % SLOT_MS);
    setTimeout(() => {
      swap(true);
      setInterval(() => swap(true), SLOT_MS);
    }, msUntilNext);
  })();
</script>
