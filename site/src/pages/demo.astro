---
import Base from "../layouts/Base.astro";
import DesktopWorkbench from "../components/DesktopWorkbench.astro";
import MobileWorkbench from "../components/MobileWorkbench.astro";
import WelcomePopup from "../components/WelcomePopup.astro";
import { walkthroughs } from "../data/walkthroughs";
import { renderSafeMarkdown } from "../lib/markdown";
import { buildSearchIndex } from "../lib/demo-search/index-build";
import { defaultFor } from "../lib/flags/build-defaults";

const demoEnabled = defaultFor("site.feature.demo-page") as boolean;
const searchEnabled = demoEnabled && (defaultFor("site.feature.demo-search") as boolean);

// Build-time search index, inlined into the page below as a JSON <script>.
// `<` is escaped so the JSON can't break out of the <script> element.
const searchIndex = searchEnabled ? buildSearchIndex(walkthroughs) : null;
const searchIndexJson = searchIndex ? JSON.stringify(searchIndex).replace(/</g, "\\u003c") : "";

/**
 * Demo — full-bleed workbench with a one-step welcome popup.
 *
 *   - DesktopWorkbench (≥768px viewport): the original 4-column IDE
 *   - MobileWorkbench  (<768px viewport): bottom-tab IDE for phones
 *
 * Both subtrees render server-side; a CSS breakpoint swap at 767px hides
 * the inactive one with `display: none` so layout cost is zero. No UA
 * sniffing, no separate route — same `/demo` URL, SEO and shared links
 * keep working everywhere.
 *
 * The welcome popup auto-opens on every page load unless the user checks
 * "Don't show again" (localStorage). Replaces the previous static
 * page-summary card and multi-step OnboardingTour.
 *
 * Pre-rendered artifact bodies live in `.artifact-store` (this file) and
 * are read by the shared <dialog> lightbox. Both workbenches expose
 * `.output-row[data-output-scenario][data-output-id]` buttons; the
 * delegated click handler below catches every one of them and opens the
 * modal — workbench-agnostic.
 */

const artifacts = walkthroughs.flatMap((w) =>
  w.outputs.map((o) => ({
    scenarioId: w.id,
    artifactId: o.id,
    label: o.label,
    kind: o.kind ?? "",
    html: renderSafeMarkdown(o.body),
  }))
);
---

<Base
  title="Demo · opchain"
  description="Replay curated opchain skill conversations end-to-end — twelve scenarios, real transcripts, click to inspect."
  active="/demo"
>
  {!demoEnabled && (
    <main class="demo-disabled">
      <h1>Demo unavailable</h1>
      <p>The interactive demo is currently turned off. Try the <a href="/skills">skill library</a> or <a href="/install">install opchain</a> to see it run locally.</p>
    </main>
  )}
  {demoEnabled && (
    <>
      <h1 class="visually-hidden">Watch a finished run.</h1>
      <div class="dw-desktop"><DesktopWorkbench search={searchEnabled} /></div>
      <div class="dw-mobile"><MobileWorkbench search={searchEnabled} /></div>
      <WelcomePopup />

      {searchIndex && (
        <script type="application/json" id="demo-search-index" is:inline set:html={searchIndexJson} />
      )}

      <div class="artifact-store" aria-hidden="true" hidden>
        {artifacts.map((a) => (
          <div
            data-artifact-scenario={a.scenarioId}
            data-artifact-id={a.artifactId}
            set:html={a.html}
          />
        ))}
      </div>

      <dialog
        class="output-modal"
        id="output-modal"
        aria-modal="true"
        aria-labelledby="modal-title"
      >
        <div class="modal-inner">
          <div class="modal-header">
            <div class="modal-title-row">
              <span class="modal-ico" aria-hidden="true">⊞</span>
              <h2 id="modal-title" class="modal-title">Output preview</h2>
              <span class="modal-kind"></span>
            </div>
            <button class="modal-close" aria-label="Close output" type="button">✕</button>
          </div>
          <div class="modal-content">
            <aside class="modal-toc" aria-label="Document outline" hidden>
              <details class="modal-toc-mobile" open>
                <summary>On this page</summary>
                <nav class="modal-toc-nav" aria-label="Sections"></nav>
              </details>
            </aside>
            <div class="modal-body prose"></div>
          </div>
        </div>
      </dialog>
    </>
  )}
</Base>

<style>
  /* ── Desktop / mobile workbench swap.
        Both subtrees server-render. The inactive one collapses to
        display:none so it costs nothing in layout, but the document-
        level click delegate below still reaches its `.output-row`
        buttons (display:none doesn't unmount). ── */
  .dw-mobile { display: none; }
  @media (max-width: 767px) {
    .dw-desktop { display: none; }
    .dw-mobile  { display: block; }
  }

  /* ── 3. Output modal lightbox ── */
  /* Base rule deliberately omits `display` — Astro's CSS scoping adds
     a data-astro-cid attribute that would bump specificity above the
     UA `dialog:not([open]) { display: none }` default and force the
     modal visible on page load. The [open] rule below provides the
     in-use layout. */
  .output-modal {
    position: fixed;
    inset: 0;
    margin: auto;
    width: min(90vw, 820px);
    max-height: min(88vh, 900px);
    padding: 0;
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    background: var(--bg);
    box-shadow:
      0 8px 32px rgba(0, 0, 0, 0.45),
      0 2px 8px rgba(0, 0, 0, 0.3);
    overflow: hidden;
    flex-direction: column;
  }
  /* When the long-form TOC is in play, widen the modal so the sidebar +
     reading column have room. The has-toc class is set by JS once the
     rendered artifact body crosses the heading-count threshold. */
  .output-modal.has-toc { width: min(95vw, 1180px); max-height: min(92vh, 960px); }
  /* height must be explicit (not just max-height) so that modal-inner's
     height:100% and modal-body's flex:1 have a definite reference. */
  .output-modal[open] { display: flex; height: min(88vh, 900px); }
  .output-modal[open].has-toc { height: min(92vh, 960px); }
  .output-modal::backdrop {
    background: rgba(0, 0, 0, 0.72);
    backdrop-filter: blur(3px);
  }
  .modal-inner {
    display: flex;
    flex-direction: column;
    height: 100%;
    overflow: hidden;
  }
  .modal-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 1rem;
    padding: 1rem 1.25rem 0.75rem;
    background: var(--surface);
    border-bottom: 0.5px solid var(--border);
    flex: 0 0 auto;
  }
  .modal-title-row {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    flex-wrap: wrap;
    min-width: 0;
  }
  .modal-ico {
    color: var(--accent);
    font-size: 1rem;
    flex: 0 0 auto;
  }
  .modal-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-md);
    line-height: 1.3;
    color: var(--text);
    margin: 0;
    min-width: 0;
  }
  .modal-kind {
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    flex: 0 0 auto;
    padding: 2px 6px;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
  }
  .modal-close {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 13px;
    width: 28px;
    height: 28px;
    border-radius: var(--r-xs);
    cursor: pointer;
    display: grid;
    place-items: center;
    flex: 0 0 auto;
    transition: color 120ms, border-color 120ms;
  }
  .modal-close:hover { color: var(--text); border-color: var(--text); }
  .modal-close:focus-visible { outline: none; box-shadow: var(--focus-ring); }

  /* ── Modal content layout: body alone, or TOC + body when long-form ── */
  .modal-content {
    display: flex;
    flex: 1 1 0;
    min-height: 0;
    overflow: hidden;
  }
  .modal-toc {
    flex: 0 0 240px;
    border-right: 0.5px solid var(--border);
    background: var(--surface);
    overflow-y: auto;
    padding: 1rem 0.75rem 1.5rem;
  }
  .modal-toc[hidden] { display: none; }
  .modal-toc-mobile > summary {
    display: none;
    cursor: pointer;
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--muted);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: 0.06em;
    padding: 0.25rem 0.5rem 0.5rem;
    list-style: none;
  }
  .modal-toc-mobile > summary::-webkit-details-marker { display: none; }
  .modal-toc-nav {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
  }
  .modal-toc-nav a {
    display: block;
    padding: 0.32rem 0.55rem;
    border-left: 2px solid transparent;
    color: var(--muted);
    font-size: var(--fs-sm);
    line-height: 1.35;
    text-decoration: none;
    transition: color 80ms, background 80ms, border-color 80ms;
    border-radius: 0 4px 4px 0;
  }
  .modal-toc-nav a[data-toc-level="2"] { padding-left: 1.1rem; font-size: 0.86em; }
  .modal-toc-nav a[data-toc-level="3"] { padding-left: 1.7rem; font-size: 0.82em; color: var(--subtle); }
  .modal-toc-nav a:hover { color: var(--text); background: rgba(255,255,255,0.03); }
  .modal-toc-nav a.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
    background: rgba(0, 0, 0, 0.18);
  }
  .modal-toc-nav a:focus-visible { outline: none; box-shadow: var(--focus-ring); border-radius: 4px; }

  .modal-body {
    padding: 1.5rem 1.6rem;
    overflow-y: auto;
    flex: 1 1 0;
    min-width: 0;
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    color: var(--text);
    scroll-behavior: smooth;
  }
  @media (prefers-reduced-motion: reduce) {
    .modal-body { scroll-behavior: auto; }
  }
  /* ── TOC-click heading flash.
        Adds an ember halo to a heading when the user clicks its TOC
        link. Bright-then-fade over 4s using existing token colors so it
        matches every other ember accent on the site. Under
        prefers-reduced-motion the keyframes are suppressed and the JS
        falls back to a static tint that clears at the same 4s mark
        (see flashHeading() below). ── */
  @keyframes oc-heading-ember-flash {
    0%   { background-color: var(--ember-glow); box-shadow: 0 0 0 6px var(--ember-dim); }
    100% { background-color: transparent;        box-shadow: 0 0 0 6px transparent; }
  }
  .modal-body :global(.is-flash-heading) {
    animation: oc-heading-ember-flash 4s ease-out forwards;
    border-radius: 4px;
    /* Inset the heading slightly so the halo box-shadow doesn't clip
       the column edge; counter-margin keeps the layout box unchanged. */
    padding-inline: 6px;
    margin-inline: -6px;
  }
  @media (prefers-reduced-motion: reduce) {
    .modal-body :global(.is-flash-heading) {
      animation: none;
      background-color: var(--ember-dim);
      border-radius: 4px;
      padding-inline: 6px;
      margin-inline: -6px;
    }
  }
  /* Prose resets inside the modal body */
  .modal-body :global(h1),
  .modal-body :global(h2),
  .modal-body :global(h3) {
    font-family: var(--font-display);
    font-weight: 600;
    color: var(--text);
    margin: 1.4rem 0 0.5rem;
    line-height: 1.25;
  }
  .modal-body :global(h1) { font-size: clamp(1.1rem, 2vw, 1.4rem); }
  .modal-body :global(h2) { font-size: clamp(1rem, 1.8vw, 1.2rem); }
  .modal-body :global(h3) { font-size: var(--fs-md); }
  .modal-body :global(p)  { margin: 0 0 0.75rem; }
  .modal-body :global(ul),
  .modal-body :global(ol) { padding-left: 1.4rem; margin: 0 0 0.75rem; }
  .modal-body :global(li) { margin-bottom: 0.25rem; }
  .modal-body :global(code) {
    font-family: var(--font-mono);
    font-size: 0.88em;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 3px;
    padding: 0.1em 0.35em;
    color: var(--accent);
  }
  .modal-body :global(pre) {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-sm);
    padding: 0.9rem 1rem;
    overflow-x: auto;
    margin: 0 0 1rem;
  }
  .modal-body :global(pre code) {
    background: none;
    border: none;
    padding: 0;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .modal-body :global(table) {
    width: 100%;
    border-collapse: collapse;
    margin: 0 0 1rem;
    font-size: var(--fs-sm);
  }
  .modal-body :global(th),
  .modal-body :global(td) {
    border: 0.5px solid var(--border);
    padding: 0.45rem 0.75rem;
    text-align: left;
  }
  .modal-body :global(th) {
    background: var(--surface);
    color: var(--muted);
    font-weight: 500;
  }
  .modal-body :global(strong) { color: var(--text); font-weight: 600; }
  .modal-body :global(a) {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
  .modal-body :global(blockquote) {
    border-left: 3px solid var(--accent);
    margin: 0 0 1rem;
    padding: 0.4rem 0 0.4rem 1rem;
    color: var(--muted);
  }
  .modal-body :global(hr) {
    border: none;
    border-top: 0.5px solid var(--border);
    margin: 1.2rem 0;
  }
  @media (max-width: 600px) {
    .output-modal { width: 100vw; max-height: 100dvh; border-radius: 0; border-left: none; border-right: none; }
    .output-modal[open],
    .output-modal[open].has-toc { height: 100dvh; max-height: 100dvh; }
  }
  /* Below 900px, the TOC stops being a sidebar and becomes a collapsible
     details element pinned above the body. Its summary clickable header
     becomes visible via the rule below. */
  @media (max-width: 900px) {
    .output-modal.has-toc .modal-content { flex-direction: column; }
    .output-modal.has-toc .modal-toc {
      flex: 0 0 auto;
      width: 100%;
      max-height: 40vh;
      border-right: 0;
      border-bottom: 0.5px solid var(--border);
      padding: 0.5rem 0.75rem;
    }
    .modal-toc-mobile > summary { display: block; }
    .modal-toc-mobile:not([open]) .modal-toc-nav { display: none; }
  }
</style>

<!-- ── Search & Filter (demo-search) — GLOBAL styles.
     The client injects result rows + facet chips as innerHTML; those nodes
     don't carry Astro's scoped data-cid, so every .ocs-* paint rule must be
     global. Class names are uniquely `ocs-` / `mw-find-` prefixed → no clash.
     Desktop sidebar shells vs. the mobile Find overlay are disambiguated by
     `.ide-sidebar` / `.mw-find` ancestors where their box model differs. ── -->
<style is:global>
  /* shared search-row shell (desktop sidebar) */
  .ide-sidebar .ocs-search-row {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 10px 12px;
    border-bottom: 0.5px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--ribbon);
    z-index: 1;
  }
  .ide-sidebar .ocs-search-row svg { width: 13px; height: 13px; color: var(--subtle); flex: 0 0 auto; }
  .ide-sidebar .ocs-input {
    flex: 1; min-width: 0;
    background: transparent; border: 0;
    color: var(--text); font-family: var(--font-mono); font-size: 12px; outline: none;
  }
  .ide-sidebar .ocs-input::placeholder { color: var(--subtle); }
  .ide-sidebar .ocs-x {
    appearance: none; background: transparent;
    border: 0.5px solid var(--border); color: var(--muted);
    width: 20px; height: 20px; border-radius: var(--r-xs);
    cursor: pointer; font-size: 11px; line-height: 1; flex: 0 0 auto;
  }
  .ide-sidebar .ocs-x:hover { color: var(--text); border-color: var(--text); }
  .ide-sidebar .ocs-x:focus-visible { outline: none; box-shadow: var(--focus-ring); }

  /* count + pills (shared; horizontal padding only in the desktop sidebar) */
  .ocs-count {
    color: var(--subtle); font-size: 10px; text-transform: uppercase;
    letter-spacing: var(--ls-wide); padding: 8px 0 2px;
  }
  .ide-sidebar .ocs-count { padding: 8px 12px 2px; }
  .ocs-pills { display: flex; flex-wrap: wrap; gap: 4px; }
  .ide-sidebar .ocs-pills { padding: 0 12px; }
  .ide-sidebar .ocs-pills:not(:empty) { padding-top: 6px; padding-bottom: 4px; }
  .ocs-pill {
    appearance: none; display: inline-flex; align-items: center; gap: 5px;
    font-family: var(--font-mono); font-size: 10px;
    background: var(--ember-dim); border: 0.5px solid var(--accent); color: var(--accent);
    border-radius: var(--r-pill); padding: 2px 8px; cursor: pointer;
  }
  .ocs-pill:focus-visible { outline: none; box-shadow: var(--focus-ring); }

  /* results */
  .ide-sidebar .ocs-results { padding: 4px 0 12px; }
  .ocs-res-group {
    padding: 8px 12px 3px; color: #f5894d; font-family: var(--font-mono);
    font-size: 10px; text-transform: uppercase; letter-spacing: var(--ls-wide);
  }
  [data-theme="light"] .ocs-res-group { color: #993505; }
  .ocs-res {
    appearance: none; display: block; width: 100%; text-align: left;
    background: transparent; border: 0; border-left: 2px solid transparent;
    color: var(--muted); font: inherit; padding: 6px 12px; cursor: pointer;
    transition: color 120ms, background 120ms, border-color 120ms;
  }
  .ocs-res:hover, .ocs-res:focus-visible {
    background: var(--card); border-left-color: var(--accent); color: var(--text); outline: none;
  }
  .ocs-snip { display: block; font-size: 11.5px; line-height: 1.45; color: inherit; }
  .ocs-snip mark { background: var(--ember-dim); color: var(--text); border-radius: 2px; padding: 0 1px; }
  .ocs-res-meta { display: flex; align-items: center; gap: 6px; margin-top: 3px; font-size: 10px; color: var(--subtle); }
  .ocs-chip-mini { font-family: var(--font-mono); font-size: 9.5px; border: 0.5px solid var(--border); border-radius: 3px; padding: 0 5px; }
  .ocs-chip-mini.role-workflow     { color: var(--workflow); }
  .ocs-chip-mini.role-tri-agent    { color: var(--tri-agent); }
  .ocs-chip-mini.role-audit-gate   { color: var(--rose, var(--audit-gate)); }
  .ocs-chip-mini.role-specialist   { color: var(--teal, var(--specialist)); }
  .ocs-chip-mini.role-advisor      { color: var(--advisor); }
  .ocs-chip-mini.role-orchestrator { color: var(--orchestrator); }
  .ocs-chip-mini.role-success      { color: var(--success); }
  .ocs-phase { text-transform: uppercase; letter-spacing: var(--ls-wide); }
  .ocs-step-id { margin-left: auto; font-family: var(--font-mono); }

  .ocs-empty { padding: 20px 14px; color: var(--muted); font-size: 12px; line-height: 1.5; text-align: center; }
  .ocs-empty strong { color: var(--accent); }
  .ocs-link {
    appearance: none; background: transparent; border: 0.5px solid var(--border);
    color: var(--muted); border-radius: var(--r-xs); padding: 1px 7px; cursor: pointer; font: inherit;
  }
  .ocs-link:hover { color: var(--text); border-color: var(--text); }

  /* facets */
  .ocs-facet-group { padding: 8px 12px 4px; }
  .ocs-facet-group h4 {
    margin: 0 0 6px; color: #f5894d; font-family: var(--font-mono);
    font-size: 10px; text-transform: uppercase; letter-spacing: var(--ls-wide); font-weight: 600;
  }
  [data-theme="light"] .ocs-facet-group h4 { color: #993505; }
  .ocs-chips { display: flex; flex-wrap: wrap; gap: 5px; }
  .ocs-chip {
    appearance: none; font-family: var(--font-mono); font-size: 10px;
    background: rgba(255, 255, 255, 0.02); border: 0.5px solid var(--border);
    color: var(--muted); border-radius: var(--r-pill); padding: 3px 8px; cursor: pointer;
    transition: color 120ms, border-color 120ms, background 120ms;
  }
  .ocs-chip .ocs-ct { color: var(--subtle); margin-left: 4px; }
  .ocs-chip[aria-pressed="true"] { background: var(--ember-dim); border-color: var(--accent); color: var(--accent); }
  .ocs-chip[aria-pressed="true"].role-workflow     { border-color: var(--workflow);     color: var(--workflow); }
  .ocs-chip[aria-pressed="true"].role-tri-agent    { border-color: var(--tri-agent);    color: var(--tri-agent); }
  .ocs-chip[aria-pressed="true"].role-audit-gate   { border-color: var(--rose, var(--audit-gate)); color: var(--rose, var(--audit-gate)); }
  .ocs-chip[aria-pressed="true"].role-specialist   { border-color: var(--teal, var(--specialist)); color: var(--teal, var(--specialist)); }
  .ocs-chip[aria-pressed="true"].role-advisor      { border-color: var(--advisor);      color: var(--advisor); }
  .ocs-chip[aria-pressed="true"].role-orchestrator { border-color: var(--orchestrator); color: var(--orchestrator); }
  .ocs-chip[aria-pressed="true"].role-success      { border-color: var(--success);      color: var(--success); }
  .ocs-chip:focus-visible { outline: none; box-shadow: var(--focus-ring); }
  .ocs-chip[disabled] { opacity: 0.35; cursor: not-allowed; }
  .ocs-clearall {
    appearance: none; margin: 10px 12px; background: transparent;
    border: 0.5px solid var(--border); color: var(--muted); border-radius: var(--r-sm);
    padding: 5px 10px; cursor: pointer; font-family: var(--font-mono); font-size: 11px;
  }
  .ocs-clearall:hover { color: var(--text); border-color: var(--text); }
  .ocs-clearall:focus-visible { outline: none; box-shadow: var(--focus-ring); }

  /* mobile Find overlay: head already pads 12px, so neutralize the desktop
     sidebar paddings and re-indent rows/results. */
  .mw-find .ocs-count, .mw-find .ocs-pills, .mw-find .ocs-facet-group, .mw-find .ocs-facets { padding-left: 0; padding-right: 0; }
  .mw-find .ocs-res, .mw-find .ocs-res-group { padding-left: 12px; padding-right: 12px; }
  .mw-find .ocs-clearall { margin-left: 0; margin-right: 0; }

  /* deep-link landing flash on the target exchange (desktop + mobile) */
  @keyframes ocs-flash {
    0%   { background-color: var(--ember-glow); box-shadow: 0 0 0 6px var(--ember-dim); }
    100% { background-color: transparent;       box-shadow: 0 0 0 6px transparent; }
  }
  .ocs-flash { animation: ocs-flash 3.4s ease-out forwards; border-radius: 4px; }
  @media (prefers-reduced-motion: reduce) {
    .ocs-flash { animation: none; background-color: var(--ember-dim); border-radius: 4px; }
  }
</style>

<script is:inline>
  /* Output modal lightbox — event delegation.
     Single document listener catches clicks from any .output-row in
     either workbench (desktop or mobile). */
  (() => {
    const modal    = /** @type {HTMLDialogElement|null} */ (document.getElementById('output-modal'));
    const titleEl  = document.getElementById('modal-title');
    const kindEl   = modal && modal.querySelector('.modal-kind');
    const bodyEl   = modal && modal.querySelector('.modal-body');
    const closeBtn = modal && modal.querySelector('.modal-close');
    const store    = document.querySelector('.artifact-store');
    const tocEl    = modal && modal.querySelector('.modal-toc');
    const tocNav   = modal && modal.querySelector('.modal-toc-nav');
    if (!modal || !titleEl || !kindEl || !bodyEl || !store) return;

    /* Threshold below which the TOC just adds noise — short artifacts
       stay tight, long ones get the sidebar. */
    const TOC_MIN_HEADINGS = 6;

    /** @type {IntersectionObserver|null} */
    let scrollSpy = null;

    function slugify(str) {
      return String(str || '')
        .toLowerCase()
        .trim()
        .replace(/[^\w\s-]/g, '')
        .replace(/\s+/g, '-')
        .slice(0, 64) || 'section';
    }

    function teardownToc() {
      if (scrollSpy) { scrollSpy.disconnect(); scrollSpy = null; }
      if (tocNav) tocNav.innerHTML = '';
      if (tocEl) tocEl.setAttribute('hidden', '');
      modal.classList.remove('has-toc');
    }

    /**
     * Apply an ember flash highlight to a heading so a TOC-driven scroll
     * lands with a 4-second visual confirmation. Force-reflow before
     * adding the class so re-clicking the same link restarts the
     * animation. Cleanup is belt-and-suspenders: an `animationend`
     * listener fires under normal conditions, and a setTimeout safety
     * net guarantees the class is cleared even in environments where
     * the animation is optimised out (headless browsers in CI, some
     * accessibility modes). Whichever fires first wins; the second
     * call is idempotent.
     */
    const FLASH_CLASS = 'is-flash-heading';
    const FLASH_DURATION_MS = 4000;
    /* Safety-net runs slightly after the animation so animationend gets
       a chance under normal conditions before the timeout intervenes. */
    const FLASH_CLEANUP_BUDGET_MS = FLASH_DURATION_MS + 150;

    function flashHeading(target) {
      if (!target) return;
      target.classList.remove(FLASH_CLASS);
      // Force a reflow so removing+re-adding the class restarts the
      // animation. Reading offsetWidth is the standard trick.
      void target.offsetWidth;
      target.classList.add(FLASH_CLASS);

      let cleared = false;
      const clear = () => {
        if (cleared) return;
        cleared = true;
        target.classList.remove(FLASH_CLASS);
      };
      target.addEventListener('animationend', clear, { once: true });
      window.setTimeout(clear, FLASH_CLEANUP_BUDGET_MS);
    }

    function buildToc() {
      if (!tocEl || !tocNav || !bodyEl) return;
      const headings = /** @type {HTMLElement[]} */ (
        Array.from(bodyEl.querySelectorAll('h1, h2, h3'))
      );
      if (headings.length < TOC_MIN_HEADINGS) {
        teardownToc();
        return;
      }

      /* Assign stable, collision-resistant ids and build nav links. */
      const seen = new Map();
      const frag = document.createDocumentFragment();
      headings.forEach((h) => {
        const base = slugify(h.textContent || '');
        const n = (seen.get(base) || 0) + 1;
        seen.set(base, n);
        const id = n === 1 ? base : `${base}-${n}`;
        h.id = id;

        const a = document.createElement('a');
        a.href = `#${id}`;
        a.textContent = h.textContent || '';
        a.setAttribute('data-toc-level', h.tagName.substring(1));
        a.addEventListener('click', (ev) => {
          ev.preventDefault();
          const target = document.getElementById(id);
          if (!target) return;
          /* Scroll within the modal body, not the page.
             Use getBoundingClientRect rather than offsetTop, because the
             heading's offsetParent walks up to the <dialog> (no positioned
             ancestor between target and dialog), which includes the modal
             header height + body padding-top — the previous formula
             therefore overshot. Rect math is viewport-relative and
             topology-agnostic. */
          const targetRect = target.getBoundingClientRect();
          const bodyRect = bodyEl.getBoundingClientRect();
          const desiredGap = 16;
          const delta = targetRect.top - bodyRect.top - desiredGap;
          bodyEl.scrollTo({ top: bodyEl.scrollTop + delta, behavior: 'smooth' });
          /* Update hash visually without jumping the page. */
          history.replaceState(null, '', `#${id}`);
          /* Ember flash to confirm the navigation. */
          flashHeading(target);
          /* On mobile, collapse the TOC after navigation. */
          const det = tocEl.querySelector('details.modal-toc-mobile');
          if (det && window.matchMedia('(max-width: 900px)').matches) {
            det.removeAttribute('open');
          }
        });
        frag.appendChild(a);
      });
      tocNav.innerHTML = '';
      tocNav.appendChild(frag);
      tocEl.removeAttribute('hidden');
      modal.classList.add('has-toc');

      /* Scrollspy — highlight whichever heading is nearest the top of
         the visible reading area. */
      const links = /** @type {HTMLAnchorElement[]} */ (
        Array.from(tocNav.querySelectorAll('a'))
      );
      const linkById = new Map(links.map((a) => [a.getAttribute('href').slice(1), a]));

      scrollSpy = new IntersectionObserver(
        (entries) => {
          /* Track which targets are above the threshold; the latest one
             above becomes active. */
          entries.forEach((entry) => {
            const link = linkById.get(entry.target.id);
            if (!link) return;
            if (entry.isIntersecting) {
              links.forEach((l) => l.classList.remove('is-active'));
              link.classList.add('is-active');
            }
          });
        },
        {
          root: bodyEl,
          /* Trigger when heading approaches the top quarter of the viewport. */
          rootMargin: '0px 0px -75% 0px',
          threshold: [0, 1],
        }
      );
      headings.forEach((h) => scrollSpy && scrollSpy.observe(h));

      /* Ensure first item starts active. */
      if (links[0]) links[0].classList.add('is-active');
    }

    function openArtifact(btn) {
      const scenarioId = btn.dataset.outputScenario;
      const artifactId = btn.dataset.outputId;
      if (!scenarioId || !artifactId) return;
      const src = store.querySelector(
        `[data-artifact-scenario="${CSS.escape(scenarioId)}"][data-artifact-id="${CSS.escape(artifactId)}"]`
      );
      if (!src) return;

      const label = btn.querySelector('.output-label')
        ? btn.querySelector('.output-label').textContent.trim()
        : artifactId;
      const kind = btn.querySelector('.output-kind')
        ? btn.querySelector('.output-kind').textContent.trim()
        : '';

      titleEl.textContent = label;
      kindEl.textContent  = kind;
      teardownToc();
      bodyEl.innerHTML    = src.innerHTML;
      bodyEl.scrollTop    = 0;
      modal.showModal();
      /* Defer TOC build until after the dialog is visible so layout is settled. */
      requestAnimationFrame(buildToc);
    }

    document.addEventListener('click', (e) => {
      const btn = /** @type {HTMLElement|null} */ (
        e.target instanceof Element
          ? e.target.closest('.output-row[data-output-scenario]')
          : null
      );
      if (btn) openArtifact(/** @type {HTMLElement} */ (btn));
    });

    closeBtn && closeBtn.addEventListener('click', () => modal.close());

    modal.addEventListener('click', (e) => {
      if (e.target === modal) modal.close();
    });

    modal.addEventListener('close', teardownToc);
  })();
</script>

<!-- Search & Filter controller. Bundled module; self-bails when the
     #demo-search-index JSON is absent (feature flag off), so it's safe to
     mount unconditionally. -->
<script>
  import "../lib/demo-search/demo-search.client";
</script>
