---
import Base from "../layouts/Base.astro";
import OnboardingTour from "../components/OnboardingTour.astro";
import { walkthroughs } from "../data/walkthroughs";
import { getSkillRole } from "../lib/skills";

/**
 * Demo — magazine-style intro + IDE workbench.
 *
 * The intro is a compact editorial "cover" capped at ~32vh. Its
 * headline rotates through all six walkthroughs on a deterministic
 * 2-minute slot tied to wall-clock time (12-min full cycle), so every
 * visitor in the same 2-minute window sees the same scenario. Server-
 * renders the first walkthrough; client JS overrides to whichever slot
 * is current and schedules the next swap on the slot boundary.
 *
 * Below the cover sits a VS Code-style workbench: top bar, activity
 * rail, scenario sidebar, editor + transcript, inspector with i/o/
 * skills/checkpoint, status bar. Ported from /dev-preview/demo-C-port
 * after sign-off across the 5 mockup pieces. Sidebar + tabs are
 * data-driven from the walkthroughs collection; the editor and
 * inspector are populated for scenario 01 in the first port chunk and
 * hydrated for 02–06 in a follow-up chunk.
 */

const covers = walkthroughs.map((w, i) => ({
  num: String(i + 1).padStart(2, "0"),
  id: w.id,
  title: w.title,
  tagline: w.tagline,
}));
const initial = covers[0];

const sidebar = walkthroughs.map((w, i) => ({
  num: String(i + 1).padStart(2, "0"),
  id: w.id,
  active: i === 0,
  open: i < 2,
  skills: w.skills.map((id) => ({ id, role: getSkillRole(id) })),
}));
---

<Base
  title="Demo · opchain"
  description="Replay curated opchain skill conversations end-to-end — six scenarios, real transcripts, click to inspect."
  active="/demo"
>
  <!-- 1 · Magazine cover — capped at ~32vh, rotates every 30 min -->
  <section class="stage" data-cover>
    <div class="stage-mid">
      <div class="stage-issue">
        opchain · scenario <span data-cover-num>{initial.num}</span>
      </div>
      <h1 class="stage-h" data-cover-title>{initial.title}</h1>
      <p class="stage-sub" data-cover-tagline>{initial.tagline}</p>
      <div class="stage-actions">
        <a class="btn btn-primary" href="#workbench">▶ open the workbench</a>
        <a class="btn btn-ghost" href="/install">install opchain</a>
      </div>
    </div>
  </section>

  <script is:inline type="application/json" id="cover-data" set:html={JSON.stringify(covers)} />

  <!-- 2 · IDE workbench -->
  <section class="workbench" id="workbench" aria-label="Workbench">
    <div class="ide">
      <!-- Top bar -->
      <div class="ide-topbar">
        <div class="ide-dots">
          <span class="ide-dot"></span>
          <span class="ide-dot"></span>
          <span class="ide-dot"></span>
        </div>
        <span class="ide-title">opchain · /demo</span>
        <span class="ide-sep">·</span>
        <span>scenarios.workspace</span>
        <span class="ide-spacer"></span>
        <span class="ide-meta">claude-opus-4-7 · auto-accept</span>
        <button class="help-btn" data-tour-trigger type="button" aria-label="Open intro tour">
          (?) tour
        </button>
      </div>

      <!-- Activity rail -->
      <nav class="ide-activity" aria-label="Activity">
        <div class="act is-active" title="Scenarios">▦</div>
        <div class="act" title="Search">⌕</div>
        <div class="act" title="Inputs / Outputs">⊞</div>
        <div class="act" title="Skills">●</div>
        <div class="act" title="Help">?</div>
      </nav>

      <!-- Sidebar — scenario tree -->
      <aside class="ide-sidebar" aria-label="Scenarios">
        <div class="side-head">scenarios · 6</div>
        {sidebar.map((s) => (
          <div class="tree-group">
            <div
              class:list={["tree-folder", { "is-open": s.open, "is-active": s.active }]}
              data-scenario={s.id}
            >
              <span class="tree-arrow">{s.open ? "▾" : "▸"}</span>
              <span class="tree-num">{s.num}</span>
              <span class="tree-name">{s.id}</span>
              <span class="tree-count">{s.skills.length}</span>
            </div>
            <div class="tree-children">
              {s.skills.map((sk) => (
                <div class="tree-skill">
                  <span class:list={["role-dot", `role-${sk.role}`]}></span>
                  {sk.id}
                </div>
              ))}
            </div>
          </div>
        ))}
      </aside>

      <!-- Editor — populated in chunk 2 -->
      <main class="ide-editor" aria-label="Transcript">
        <div class="ide-placeholder">editor &amp; transcript → port chunk 2</div>
      </main>

      <!-- Inspector — populated in chunk 3 -->
      <aside class="ide-inspector" aria-label="Scenario inspector">
        <div class="ide-placeholder">i / o / skills → port chunk 3</div>
      </aside>

      <!-- Status bar -->
      <div class="ide-status">
        <span>workbench</span>
        <span class="ide-sep">·</span>
        <span>port chunk 1 of 5 · IDE shell + sidebar</span>
        <span class="ide-sep">·</span>
        <span class="ok">✓ {sidebar.length} scenarios loaded</span>
        <span class="right">
          <span class="key">↵</span> play ·
          <span class="key">␣</span> skip ·
          <span class="key">R</span> restart
        </span>
      </div>
    </div>
  </section>

  <OnboardingTour />
</Base>

<style>
  /* ── 1. Magazine cover — compact, data-driven, rotates every 30 min ── */
  .stage {
    position: relative;
    max-height: 32vh;
    min-height: 200px;
    overflow: hidden;
    padding: clamp(1.1rem, 2.5vw, 1.8rem) clamp(1rem, 4vw, 2.4rem);
    background:
      radial-gradient(640px 320px at 75% 30%, var(--ember-glow), transparent 70%),
      radial-gradient(420px 240px at 15% 80%, var(--ember-dim), transparent 70%),
      var(--bg);
    border-bottom: 0.5px solid var(--border);
    display: flex;
    align-items: center;
  }
  .stage-mid {
    max-width: 1100px;
    margin: 0 auto;
    width: 100%;
  }
  .stage-issue {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .stage-h {
    font-family: var(--font-display);
    font-weight: 600;
    /* Tighter cap than the old hero — the headline now feeds from
       walkthrough.title which is generally short and scannable. */
    font-size: clamp(1.15rem, 2.2vw, 1.7rem);
    line-height: 1.15;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.4rem;
    max-width: 36ch;
    color: var(--text);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage-sub {
    font-size: var(--fs-base);
    color: var(--muted);
    max-width: 44rem;
    margin: 0 0 0.85rem;
    line-height: var(--lh-snug);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage[data-swapping] .stage-h,
  .stage[data-swapping] .stage-sub,
  .stage[data-swapping] .stage-issue { opacity: 0; }
  .stage-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    border-radius: var(--r-xs);
    transition:
      transform var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--obsidian);
    border: 0;
    font-weight: 600;
  }
  .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--glow-md);
  }
  .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 0.5px solid var(--border);
  }
  .btn-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* ── 2. IDE workbench section ── */
  .workbench {
    padding: clamp(1rem, 3vw, 2rem) clamp(0.5rem, 2vw, 1.5rem) 4rem;
    background: var(--bg);
  }
  .ide {
    max-width: 1320px;
    margin: 0 auto;
    height: min(78vh, 820px);
    min-height: 560px;
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    overflow: hidden;
    display: grid;
    grid-template-rows: 32px 1fr 24px;
    grid-template-columns: 44px 248px 1fr 288px;
    grid-template-areas:
      "topbar topbar topbar topbar"
      "activity sidebar editor inspector"
      "status status status status";
    background: var(--bg);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.5;
  }

  /* Top bar */
  .ide-topbar {
    grid-area: topbar;
    display: flex;
    align-items: center;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--border);
    padding: 0 14px;
    gap: 14px;
    color: var(--muted);
    font-size: 11px;
    letter-spacing: 0.04em;
  }
  .ide-dots { display: flex; gap: 6px; }
  .ide-dot {
    width: 11px; height: 11px; border-radius: 50%;
    background: var(--border);
  }
  .ide-dot:nth-child(1) { background: #ff5f57; }
  .ide-dot:nth-child(2) { background: #febc2e; }
  .ide-dot:nth-child(3) { background: #28c840; }
  .ide-title { color: var(--text); font-weight: 500; }
  .ide-sep   { color: var(--subtle); }
  .ide-meta  { color: var(--subtle); }
  .ide-spacer { flex: 1; }
  .help-btn {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--muted);
    font-family: var(--font-mono);
    font-size: 10.5px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    padding: 3px 9px;
    border-radius: 3px;
    cursor: pointer;
    transition: color 120ms, border-color 120ms;
  }
  .help-btn:hover { color: var(--accent); border-color: var(--accent); }

  /* Activity rail */
  .ide-activity {
    grid-area: activity;
    background: var(--ribbon);
    border-right: 0.5px solid var(--border);
    display: flex;
    flex-direction: column;
    align-items: center;
    padding-top: 10px;
    gap: 4px;
  }
  .act {
    width: 32px;
    height: 32px;
    display: grid;
    place-items: center;
    color: var(--subtle);
    cursor: pointer;
    border-left: 2px solid transparent;
    margin-left: -2px;
    font-size: 14px;
    transition: color 120ms, border-color 120ms;
  }
  .act:hover { color: var(--text); }
  .act.is-active {
    color: var(--text);
    border-left-color: var(--accent);
  }

  /* Sidebar — scenario tree */
  .ide-sidebar {
    grid-area: sidebar;
    background: var(--surface);
    border-right: 0.5px solid var(--border);
    overflow-y: auto;
    font-size: 12px;
  }
  .side-head {
    position: sticky;
    top: 0;
    padding: 8px 12px;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--border);
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: 0.16em;
    font-size: 10px;
    z-index: 1;
  }
  .tree-group { padding: 2px 0; }
  .tree-folder {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 3px 12px;
    color: var(--muted);
    cursor: pointer;
    user-select: none;
    transition: color 120ms, background 120ms;
  }
  .tree-folder:hover { color: var(--text); background: var(--card); }
  .tree-folder.is-active { color: var(--text); }
  .tree-arrow {
    color: var(--subtle);
    width: 10px;
    flex: 0 0 auto;
    text-align: center;
    font-size: 9px;
  }
  .tree-folder.is-open .tree-arrow { color: var(--accent); }
  .tree-num {
    color: var(--subtle);
    font-size: 10.5px;
    width: 1.4em;
    flex: 0 0 auto;
    font-variant-numeric: tabular-nums;
  }
  .tree-name { flex: 1; }
  .tree-count {
    color: var(--subtle);
    font-size: 10px;
    margin-left: auto;
  }
  .tree-children {
    display: none;
    padding: 1px 0 4px;
  }
  .tree-folder.is-open + .tree-children { display: block; }
  .tree-skill {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 2px 12px 2px 32px;
    color: var(--muted);
    cursor: pointer;
    transition: color 120ms, background 120ms;
  }
  .tree-skill:hover { color: var(--text); background: var(--card); }
  .role-dot {
    width: 7px;
    height: 7px;
    border-radius: 50%;
    flex: 0 0 auto;
  }
  .role-workflow     { background: var(--workflow); }
  .role-tri-agent    { background: var(--tri-agent); }
  .role-audit-gate   { background: var(--rose, var(--audit-gate)); }
  .role-specialist   { background: var(--teal, var(--specialist)); }
  .role-advisor      { background: var(--advisor); }
  .role-orchestrator { background: var(--orchestrator); }
  .role-success      { background: var(--success); }

  /* Editor + Inspector — placeholders for chunks 2 & 3 */
  .ide-editor {
    grid-area: editor;
    background: var(--bg);
    overflow-y: auto;
  }
  .ide-inspector {
    grid-area: inspector;
    background: var(--surface);
    border-left: 0.5px solid var(--border);
    overflow-y: auto;
    font-size: 12px;
  }
  .ide-placeholder {
    color: var(--subtle);
    padding: 14px;
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
  }

  /* Status bar */
  .ide-status {
    grid-area: status;
    background: var(--ribbon);
    border-top: 0.5px solid var(--border);
    color: var(--muted);
    font-size: 10.5px;
    display: flex;
    align-items: center;
    padding: 0 12px;
    gap: 14px;
    letter-spacing: 0.04em;
  }
  .ide-status .ok { color: var(--teal, var(--specialist)); }
  .ide-status .right { margin-left: auto; }
  .ide-status .key { color: var(--accent); font-weight: 500; }

  /* Mobile: stack the IDE columns into a single column. The sidebar
     scrolls horizontally above the editor; inspector hides. */
  @media (max-width: 767px) {
    .ide {
      height: auto;
      min-height: 0;
      grid-template-rows: 32px auto auto 24px;
      grid-template-columns: 1fr;
      grid-template-areas:
        "topbar"
        "sidebar"
        "editor"
        "status";
    }
    .ide-activity { display: none; }
    .ide-sidebar { max-height: 220px; }
    .ide-inspector { display: none; }
  }
</style>

<script is:inline>
  /* Magazine cover — 2-minute slot rotation (6 covers × 2 min = 12 min
     cycle). The slot is keyed to wall-clock time (epoch ms / 2min) modulo
     the number of covers, so every visitor in the same 2-minute window
     sees the same headline.

     If the page is open across a slot boundary, the cover fades out, swaps
     content, and fades back in. */
  (() => {
    const stage = document.querySelector('[data-cover]');
    const dataNode = document.getElementById('cover-data');
    if (!stage || !dataNode) return;

    let covers;
    try { covers = JSON.parse(dataNode.textContent || '[]'); }
    catch { return; }
    if (!Array.isArray(covers) || covers.length === 0) return;

    const SLOT_MS = 2 * 60 * 1000;
    const numEl = stage.querySelector('[data-cover-num]');
    const titleEl = stage.querySelector('[data-cover-title]');
    const taglineEl = stage.querySelector('[data-cover-tagline]');

    function slotIndex() {
      return Math.floor(Date.now() / SLOT_MS) % covers.length;
    }
    function paint(c) {
      if (numEl) numEl.textContent = c.num;
      if (titleEl) titleEl.textContent = c.title;
      if (taglineEl) taglineEl.textContent = c.tagline;
    }
    function swap(animated) {
      const c = covers[slotIndex()];
      if (!animated) { paint(c); return; }
      stage.setAttribute('data-swapping', '');
      setTimeout(() => {
        paint(c);
        stage.removeAttribute('data-swapping');
      }, 200);
    }

    // Initial paint — overrides the SSR default with the current slot.
    swap(false);

    // Schedule the next swap at the slot boundary, then every SLOT_MS.
    const msUntilNext = SLOT_MS - (Date.now() % SLOT_MS);
    setTimeout(() => {
      swap(true);
      setInterval(() => swap(true), SLOT_MS);
    }, msUntilNext);
  })();
</script>
