---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Button from "../components/ui/Button.astro";
import Input from "../components/ui/Input.astro";
import Pill from "../components/ui/Pill.astro";
import Alert from "../components/ui/Alert.astro";
import Icon from "../components/Icon.astro";
import { getTryablePrompts } from "../lib/skills";

const tryable = await getTryablePrompts();

// Optional ?skill= param to preselect a skill (used by the per-skill detail "try it" CTA).
const url = new URL(Astro.request.url);
const preselect = url.searchParams.get("skill") || tryable[0]?.id || "";
---

<Base
  title="Try It · opchain"
  description="Chat live with any opchain skill. Five free exchanges per email — no install, no API key."
  active="/tryit"
>
  <main class="page">
    <div class="page-head">
      <div>
        <Eyebrow>try it</Eyebrow>
        <h1>Five free exchanges.</h1>
      </div>
    </div>

    <p class="lede">
      Live AI chat with any opchain skill. Pick one below, describe what
      you're working on, and get a real response — no install required.
    </p>

    <Alert variant="info">
      <strong>Demo wiring lands in Sprint 4.</strong> The UI below is the
      Sprint 3 shell — same layout the live chat will use. Today the form
      sits dormant; the Sprint 4 PR ports the existing
      <code class="ic">/api/try/start</code> + <code class="ic">/api/try/chat</code>
      endpoints into the new components.
    </Alert>

    <!-- ───────────── Email gate ───────────── -->
    <section class="gate" id="tryit-gate">
      <p class="gate-label">Enter your email to start a free demo session.</p>
      <form class="gate-form" autocomplete="off">
        <Input
          type="email"
          name="email"
          placeholder="you@example.com"
          required
          autocomplete="email"
          ariaLabel="Email address"
        />
        <Button type="submit" variant="primary" disabled label="Start demo (Sprint 4)">
          start
        </Button>
      </form>
    </section>

    <!-- ───────────── Skill selector ───────────── -->
    <section class="picker">
      <div class="picker-head">
        <Eyebrow>pick a skill</Eyebrow>
      </div>
      <div class="skill-pills" role="group" aria-label="Select a skill">
        {tryable.map((s) => (
          <Pill pressed={s.id === preselect}>{s.displayName}</Pill>
        ))}
      </div>
    </section>

    <!-- ───────────── Chat shell ───────────── -->
    <section class="chat-shell" aria-label="Conversation preview">
      <div class="messages">
        <div class="msg msg--assistant">
          <div class="msg-label">{tryable.find((s) => s.id === preselect)?.displayName ?? "Assistant"}</div>
          <div class="msg-content">
            Demo wiring arrives in Sprint 4. When live, this skill will run a
            short discovery interview and return a structured response — up to
            5 exchanges per email.
          </div>
        </div>
      </div>
    </section>

    <div class="input-row">
      <Input placeholder="type your message…" disabled ariaLabel="Demo input (disabled — Sprint 4)" />
      <Button variant="primary" disabled label="Send (Sprint 4)">
        send
        <Icon name="arrow-right" size={12} />
      </Button>
    </div>

    <p class="counter">5 of 5 exchanges remaining</p>

    <p class="footnote">
      Looking for the live chat? It's at
      <a href="https://opchain.dev/tryit.html">opchain.dev/tryit.html</a> until
      Sprint 6 cuts the new site over.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }
  .page-head { margin-bottom: 1.25rem; }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0;
  }
  .lede { color: var(--muted); margin: 0 0 1.5rem; max-width: 42rem; }

  .ic {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }

  .gate {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.5rem;
    max-width: 30rem;
    margin: 1.5rem 0;
    box-shadow: var(--glow-md);
  }
  .gate-label {
    margin: 0 0 0.85rem;
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .gate-form {
    display: flex;
    gap: 0.5rem;
  }
  .gate-form > :first-child { flex: 1; }

  .picker { margin-top: 2.5rem; }
  .picker-head { margin-bottom: 0.75rem; }
  .skill-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .chat-shell {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.1rem;
    margin: 1rem 0 0.75rem;
    min-height: 9rem;
    box-shadow: var(--glow-md);
  }
  .messages {
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }
  .msg { max-width: 90%; }
  .msg--assistant { align-self: flex-start; }
  .msg-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--subtle);
    margin-bottom: 0.3rem;
  }
  .msg-content {
    background: var(--card);
    border: 0.5px solid var(--border);
    color: var(--text);
    padding: 0.7rem 0.95rem;
    border-radius: var(--r-md);
    border-bottom-left-radius: var(--r-xs);
    font-size: var(--fs-sm);
    line-height: var(--lh-base);
  }

  .input-row {
    display: flex;
    gap: 0.5rem;
  }
  .input-row > :first-child { flex: 1; }

  .counter {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
    letter-spacing: var(--ls-wide);
    margin: 0.75rem 0 0;
  }

  .footnote {
    color: var(--subtle);
    font-size: var(--fs-sm);
    margin-top: 2rem;
  }
  .footnote a { color: var(--accent); }
</style>
