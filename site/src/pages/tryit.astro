---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import TryIt from "../components/TryIt.astro";
import { getTryablePrompts } from "../lib/skills";

const tryable = await getTryablePrompts();
const url = new URL(Astro.request.url);
const preselect = url.searchParams.get("skill") || tryable[0]?.id || "";
---

<Base
  title="Try It · opchain"
  description="Chat live with any opchain skill. Five free exchanges per email — no install, no API key."
  active="/tryit"
>
  <main class="page">
    <div class="page-head">
      <div>
        <Eyebrow>try it</Eyebrow>
        <h1>Five free exchanges.</h1>
      </div>
    </div>

    <p class="lede">
      Live AI chat with any opchain skill. Pick one below, describe what
      you're working on, and get a real response — no install required.
    </p>

    <TryIt preselect={preselect} />

    <p class="footnote">
      Ready to go deeper?
      <a href="/install">install opchain</a> for unlimited use in your own Claude Code.
    </p>
  </main>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }
  .page-head { margin-bottom: 1.25rem; }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0;
  }
  .lede { color: var(--muted); margin: 0 0 1.5rem; max-width: 42rem; }
  .footnote {
    color: var(--subtle);
    font-size: var(--fs-sm);
    margin-top: 2rem;
  }
  .footnote a { color: var(--accent); }
</style>
