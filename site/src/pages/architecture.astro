                  <rect x="99" y="76" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="99" y="76" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#orch-rt-glow)"/>
