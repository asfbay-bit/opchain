    <div class="container">
      <div class="header">
        <div class="header-eyebrow">SKILLS · ARCHITECTURE · v2 · RELEASE v1.8</div>
        <h1>opchain skills ecosystem</h1>
        <p class="subtitle">Checkpoint-driven pipeline · 29 skills · 6 phases · 8 tri-agent · 3 audit gates · spine ordinals · <span class="subtitle-packs">v1.5 pack fabric ({packCounts.total})</span> · <span class="subtitle-inst">v1.6 instrument rail</span> · <span style="color:var(--sig)">v1.7 Seams &amp; Signals</span> · <span style="color:var(--docs)">v1.8 quality-gate rail</span></p>
      </div>

      <div class="diagram-container">
        <div class="bands-wrap" id="bands-wrap">
          <canvas class="lines-canvas" id="lines-canvas"></canvas>

          <!-- ══ FOUNDATION HEADER STRIP (CP + oc-orchestrator) ══ -->
          <div class="foundation" id="foundation" aria-label="Foundation layer: oc-checkpoint-protocol and oc-orchestrator">
            <div class="foundation-pill foundation-pill-trigger"
                 id="cp-toggle"
                 role="button"
                 tabindex="0"
                 aria-expanded="false"
                 aria-controls="cp-detail-top cp-grid-section">
              <span class="fp-tag">PROTOCOL</span>
              <span class="fp-name">oc-checkpoint-protocol</span>
              <span class="fp-desc">JSON schema · phase · progress · blockers · next_actions</span>
            </div>
            <div class="foundation-pill foundation-pill-trigger"
                 id="orch-toggle"
                 role="button"
                 tabindex="0"
                 aria-expanded="false"
                 aria-controls="orch-detail-top">
