                <g class="cp-anim-orch">
                  <rect x="20" y="70" width="140" height="60" rx="5" fill="rgba(224,92,24,.20)" stroke="#e05c18" stroke-width="1.2" filter="url(#cp-orch-glow)"/>
                  <text x="90" y="98" fill="#f6f0e8" font-size="9" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">oc-orchestrator</text>
                  <text x="90" y="114" fill="#e05c18" font-size="7.5" font-weight="500" font-family="JetBrains Mono,monospace" text-anchor="middle">/oc-ops · routing · sync</text>
                </g>

                <g class="cp-anim-box-1">
                  <rect x="190" y="20" width="160" height="60" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="259" y="26" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="259" y="26" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="270" y="35.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
