---
import Base from "../layouts/Base.astro";
import MobileArchitecture from "../components/MobileArchitecture.astro";

import packsCatalog from "../../../src/generated/packs-catalog.json";

type PackData = {
  id: string;
  displayName: string;
  kind: "language" | "framework" | "deploy-target" | "mobile" | "vector-db";
  status: string;
};

const allPacks = packsCatalog as PackData[];
const packLanguages    = allPacks.filter((p) => p.kind === "language").map((p) => p.id);
const packFrameworks   = allPacks.filter((p) => p.kind === "framework").map((p) => p.id);
const packMobile       = allPacks.filter((p) => p.kind === "mobile").map((p) => p.id);
const packDeployTargets = allPacks.filter((p) => p.kind === "deploy-target").map((p) => p.id);
const packVectorDb     = allPacks.filter((p) => p.kind === "vector-db").map((p) => p.id);
const packCounts = {
  total: allPacks.length,
  language: packLanguages.length,
  framework: packFrameworks.length,
  mobile: packMobile.length,
  deploy: packDeployTargets.length,
  vector: packVectorDb.length,
};
---

<Base
  title="Architecture · opchain"
  description="Checkpoint-driven pipeline of 24 opchain skills across 6 phases — interactive diagram of how skills chain through .checkpoints/<skill>.json."
  active="/architecture"
>
  <!-- Mobile-only static architecture (≤767px). Hidden on desktop via the
       CSS swap at the bottom of <style is:global>. -->
  <div class="arch-mobile"><MobileArchitecture /></div>

  <main class="arch-v2 arch-desktop">
    <!-- Shared SVG defs (filters + arrowhead markers) -->
    <svg class="arch-v2-defs" aria-hidden="true">
      <defs>
        <filter id="glow-ember" x="-80%" y="-80%" width="260%" height="260%">
          <feGaussianBlur stdDeviation="10" result="b"/>
          <feFlood flood-color="#e05c18" flood-opacity="0.9" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-orch" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="6" result="b"/>
          <feFlood flood-color="#e05c18" flood-opacity="0.4" result="c"/>
