    const ARROWS = ['ba-0','ba-1','ba-1b','ba-1c','ba-2','ba-3'];
    let activePhase = null, leaveTimeout = null;
    let cpActive = false, cpLeaveTimeout = null;
    let orchActive = false, orchLeaveTimeout = null;
    let legendActive = false, legendLeaveTimeout = null;

    /* Skill coordinate map: cross-band canvas line endpoints */
    const SKILLS = {
      'oc-reverse-spec':          { band: 'discover', x: 298, y: 14,  w: 165, h: 52,  vbW: 760, vbH: 80  },
      'oc-scale-ops':             { band: 'plan',     x: 20,  y: 14,  w: 118, h: 48,  vbW: 760, vbH: 150 },
      'oc-stack-forge':           { band: 'plan',     x: 20,  y: 84,  w: 118, h: 48,  vbW: 760, vbH: 150 },
      'oc-app-architect':         { band: 'plan',     x: 240, y: 22,  w: 280, h: 122, vbW: 760, vbH: 150 },
      'oc-migration-ops':         { band: 'plan',     x: 610, y: 50,  w: 130, h: 50,  vbW: 760, vbH: 150 },
      'oc-claude-api':            { band: 'ai',       x: 14,  y: 22,  w: 170, h: 76,  vbW: 760, vbH: 120 },
      'oc-rag-forge':             { band: 'ai',       x: 206, y: 22,  w: 160, h: 76,  vbW: 760, vbH: 120 },
      'oc-agent-forge':           { band: 'ai',       x: 388, y: 22,  w: 170, h: 76,  vbW: 760, vbH: 120 },
      'oc-prompt-ops':            { band: 'ai',       x: 580, y: 22,  w: 160, h: 76,  vbW: 760, vbH: 120 },
      'oc-ux-engineer':           { band: 'build',    x: 14,  y: 22,  w: 170, h: 76,  vbW: 760, vbH: 120 },
      'oc-dash-forge':            { band: 'build',    x: 206, y: 22,  w: 160, h: 76,  vbW: 760, vbH: 120 },
      'oc-api-dev':               { band: 'build',    x: 388, y: 22,  w: 170, h: 76,  vbW: 760, vbH: 120 },
      'oc-integrations-engineer': { band: 'build',    x: 580, y: 22,  w: 160, h: 76,  vbW: 760, vbH: 120 },
      'oc-bug-check':             { band: 'ship',     x: 50,  y: 104, w: 140, h: 72,  vbW: 760, vbH: 190 },
      'oc-git-ops':               { band: 'ship',     x: 20,  y: 14,  w: 140, h: 50,  vbW: 760, vbH: 190 },
      'oc-release-ops':           { band: 'ship',     x: 200, y: 14,  w: 170, h: 64,  vbW: 760, vbH: 190 },
      'oc-code-auditor':          { band: 'ship',     x: 240, y: 104, w: 170, h: 72,  vbW: 760, vbH: 190 },
      'oc-security-auditor':      { band: 'ship',     x: 460, y: 104, w: 200, h: 72,  vbW: 760, vbH: 190 },
      'oc-deploy-ops':            { band: 'ship',     x: 430, y: 14,  w: 190, h: 50,  vbW: 760, vbH: 190 },
      'oc-monitoring-ops':        { band: 'monitor',  x: 280, y: 14,  w: 200, h: 52,  vbW: 760, vbH: 80  }
    };

    function drawConnectionLines() {
      const canvas = document.getElementById('lines-canvas');
      const wrap = document.getElementById('bands-wrap');
      if (!canvas || !wrap) return;
      const wr = wrap.getBoundingClientRect();
      const dpr = window.devicePixelRatio || 1;
      canvas.width = wr.width * dpr;
      canvas.height = wr.height * dpr;
      canvas.style.width = wr.width + 'px';
      canvas.style.height = wr.height + 'px';
      const ctx = canvas.getContext('2d');
      ctx.scale(dpr, dpr);
      ctx.clearRect(0, 0, wr.width, wr.height);

      function pt(skill, edge) {
        const s = SKILLS[skill];
        const svg = document.querySelector('#band-' + s.band + ' .band-content svg');
        if (!svg) return null;
        const sr = svg.getBoundingClientRect();
        const sx = sr.width / s.vbW, sy = sr.height / s.vbH;
        const cx = sr.left + (s.x + s.w / 2) * sx;
        const cy = sr.top  + (s.y + s.h / 2) * sy;
        let x, y;
        switch (edge) {
          case 'top':    x = cx;                                   y = sr.top + s.y * sy;             break;
          case 'bottom': x = cx;                                   y = sr.top + (s.y + s.h) * sy;     break;
          case 'left':   x = sr.left + s.x * sx;                   y = cy;                            break;
          case 'right':  x = sr.left + (s.x + s.w) * sx;           y = cy;                            break;
        }
        return { x: x - wr.left, y: y - wr.top };
      }

      function arrowMidY(arrowId) {
        const el = document.getElementById(arrowId);
        if (!el) return null;
        const r = el.getBoundingClientRect();
        return r.top + r.height / 2 - wr.top;
      }

      function drawArrowhead(fromX, fromY, toX, toY, color, alpha, size) {
        const angle = Math.atan2(toY - fromY, toX - fromX);
        const sz = size || 5;
        ctx.save();
        ctx.fillStyle = color;
        ctx.globalAlpha = alpha;
        ctx.translate(toX, toY);
        ctx.rotate(angle);
        ctx.beginPath();
        ctx.moveTo(0, 0);
        ctx.lineTo(-sz * 1.6, -sz * 0.55);
        ctx.lineTo(-sz * 1.6,  sz * 0.55);
        ctx.closePath();
        ctx.fill();
        ctx.restore();
      }

      function drawPath(points, color, width, dash, alpha, arrowEnd, arrowSize) {
        if (points.length < 2 || points.some(p => !p)) return;
        const a = (alpha == null) ? 0.85 : alpha;
        const aSz = arrowSize || 5;
        const pts = points.map(p => ({ x: p.x, y: p.y }));
        if (arrowEnd && pts.length >= 2) {
          const p = pts[pts.length - 2], q = pts[pts.length - 1];
          const dx = q.x - p.x, dy = q.y - p.y, len = Math.sqrt(dx*dx + dy*dy);
          const back = aSz * 1.6;
          if (len > back) pts[pts.length - 1] = { x: q.x - (dx/len)*back, y: q.y - (dy/len)*back };
        }
        ctx.beginPath();
        ctx.strokeStyle = color;
        ctx.lineWidth = width;
        ctx.globalAlpha = a;
        ctx.setLineDash(dash ? [5, 4] : []);
        ctx.lineCap = 'round';
        ctx.lineJoin = 'round';
        ctx.moveTo(pts[0].x, pts[0].y);
        for (let i = 1; i < pts.length; i++) ctx.lineTo(pts[i].x, pts[i].y);
        ctx.stroke();
        ctx.setLineDash([]);
        if (arrowEnd) {
          const p = points[points.length - 2], q = points[points.length - 1];
          drawArrowhead(p.x, p.y, q.x, q.y, color, a, aSz);
        }
      }

      function labelPill(text, x, y, color) {
        ctx.save();
        ctx.font = '500 7.5px "JetBrains Mono", ui-monospace, monospace';
        const m = ctx.measureText(text);
        const padX = 6, padY = 3;
        const w = m.width + padX * 2;
        const h = 9 + padY * 2;
        const rx = 3;
        ctx.fillStyle = '#1c1710';
        ctx.globalAlpha = 0.96;
        if (ctx.roundRect) {
          ctx.beginPath(); ctx.roundRect(x - w/2, y - h/2, w, h, rx); ctx.fill();
        } else {
          ctx.fillRect(x - w/2, y - h/2, w, h);
        }
        ctx.strokeStyle = color;
        ctx.lineWidth = 0.6;
        ctx.globalAlpha = 0.45;
        if (ctx.roundRect) {
          ctx.beginPath(); ctx.roundRect(x - w/2, y - h/2, w, h, rx); ctx.stroke();
        } else {
          ctx.strokeRect(x - w/2, y - h/2, w, h);
        }
        ctx.globalAlpha = 0.95;
        ctx.fillStyle = color;
        ctx.textAlign = 'center';
        ctx.textBaseline = 'middle';
        ctx.fillText(text, x, y);
        ctx.restore();
      }

      function ortho(srcSkill, srcEdge, tgtSkill, tgtEdge, midY, color, width, dash, alpha, arrowSize) {
        const s = pt(srcSkill, srcEdge);
        const t = pt(tgtSkill, tgtEdge);
        if (!s || !t) return null;
        const points = [s];
        if (Math.abs(s.x - t.x) >= 0.5) {
          points.push({ x: s.x, y: midY });
          points.push({ x: t.x, y: midY });
        }
        points.push(t);
        drawPath(points, color, width, dash, alpha, true, arrowSize);
        return { s, t, midY };
      }

      function orthoSkip(srcSkill, srcEdge, tgtSkill, tgtEdge, midY1, midY2, safeX, color, width, dash, alpha, arrowSize) {
        const s = pt(srcSkill, srcEdge);
        const t = pt(tgtSkill, tgtEdge);
        if (!s || !t) return null;
        const points = [
          s,
          { x: s.x,    y: midY1 },
          { x: safeX,  y: midY1 },
          { x: safeX,  y: midY2 },
          { x: t.x,    y: midY2 },
          t
        ];
        drawPath(points, color, width, dash, alpha, true, arrowSize);
        return { s, t, midY1, midY2, safeX };
      }

      function busFanOut(srcSkill, tgtSkills, midY, color, width, dash, alpha, arrowSize) {
        const s = pt(srcSkill, 'bottom');
        const targets = tgtSkills.map(n => ({ name: n, p: pt(n, 'top') })).filter(o => o.p);
        if (!s || !targets.length) return null;
        const xs = targets.map(o => o.p.x).concat([s.x]);
        const busL = Math.min.apply(null, xs);
        const busR = Math.max.apply(null, xs);
        drawPath([s, { x: s.x, y: midY }], color, width, dash, alpha, false);
        drawPath([{ x: busL, y: midY }, { x: busR, y: midY }], color, width, dash, alpha, false);
        for (const o of targets) {
          drawPath([{ x: o.p.x, y: midY }, o.p], color, width, dash, alpha, true, arrowSize);
        }
        return { s, targets: targets.map(o => o.p), midY, busL, busR };
      }

      function busFanIn(srcSkills, tgtSkill, midY, color, width, dash, alpha, arrowSize) {
        const sources = srcSkills.map(n => pt(n, 'bottom')).filter(Boolean);
        const t = pt(tgtSkill, 'top');
        if (!sources.length || !t) return null;
        const xs = sources.map(p => p.x).concat([t.x]);
        const busL = Math.min.apply(null, xs);
        const busR = Math.max.apply(null, xs);
        for (const s of sources) {
          drawPath([s, { x: s.x, y: midY }], color, width, dash, alpha, false);
        }
        drawPath([{ x: busL, y: midY }, { x: busR, y: midY }], color, width, dash, alpha, false);
        drawPath([{ x: t.x, y: midY }, t], color, width, dash, alpha, true, arrowSize);
        return { sources, t, midY, busL, busR };
      }

      const W_PRIMARY = 1.8, W_SECONDARY = 1.2, W_ADVISORY = 1.0;
      const O_PRIMARY = 0.95, O_SECONDARY = 0.78, O_ADVISORY = 0.55;
      const A_PRIMARY = 7, A_SECONDARY = 5, A_ADVISORY = 4;

      const LANE_HANDOFF = -10, LANE_AUTO = -3, LANE_ADVISORY = +4, LANE_GATE = +11;

      const safeXL = 32, safeXR = wr.width - 32;

      const SUCC = '#0D9488', EMB = '#e05c18', SAND = '#c4b89e';

      const mY_dp = arrowMidY('ba-0');
      const mY_pb = arrowMidY('ba-1c');
      const mY_bs = arrowMidY('ba-2');
      const mY_sm = arrowMidY('ba-3');

      if (mY_dp == null || mY_pb == null || mY_bs == null || mY_sm == null) return;

      /* Plan → Build: app-arch BUS fan-out (auto-invoke) */
      const r2 = busFanOut('oc-app-architect',
                           ['oc-ux-engineer', 'oc-api-dev', 'oc-integrations-engineer'],
                           mY_pb + LANE_AUTO, EMB, W_SECONDARY, true, O_SECONDARY, A_SECONDARY);
      if (r2) labelPill('auto-invoke', (r2.busL + r2.busR) / 2, mY_pb + LANE_AUTO, EMB);

      /* Build → Ship: oc-api-dev → oc-security-auditor (advisory, around oc-deploy-ops) */
      const _dpR  = pt('oc-deploy-ops', 'right');
      const _dpB  = pt('oc-deploy-ops', 'bottom');
      const _saT2 = pt('oc-security-auditor', 'top');
      const safeX_sec = _dpR ? _dpR.x + 30 : (wr.width - 100);
      const midY2_sec = (_dpB && _saT2) ? (_dpB.y + _saT2.y) / 2 : (mY_bs + LANE_ADVISORY + 60);
      const r4 = orthoSkip('oc-api-dev', 'bottom', 'oc-security-auditor', 'top',
                           mY_bs + LANE_ADVISORY, midY2_sec, safeX_sec,
                           SAND, W_ADVISORY, true, O_ADVISORY, A_ADVISORY);
      if (r4) labelPill('advisory', r4.safeX, (r4.midY1 + r4.midY2) / 2, SAND);

      /* Build → Monitor long-jump: oc-api-dev → oc-monitoring-ops (advisory, right gutter) */
      const r7 = orthoSkip('oc-api-dev', 'bottom', 'oc-monitoring-ops', 'top',
                           mY_bs + LANE_ADVISORY, mY_sm + LANE_ADVISORY, safeXR,
                           SAND, W_ADVISORY, true, O_ADVISORY, A_ADVISORY);
      if (r7) labelPill('SLO + drift', r7.safeX, (r7.midY1 + r7.midY2) / 2, SAND);
    }

    function bandEnter(phase) {
      clearTimeout(leaveTimeout);
      if (cpActive || legendActive) return;
      if (activePhase === phase) return;
      activePhase = phase;
      PHASES.forEach(p => {
        const b = document.getElementById('band-' + p);
        if (!b) return;
        if (p === phase) { b.classList.add('active'); b.classList.remove('dimmed'); }
        else { b.classList.add('dimmed'); b.classList.remove('active'); }
      });
      ARROWS.forEach(id => { const el = document.getElementById(id); if (el) el.classList.add('dimmed'); });
      const lc = document.getElementById('lines-canvas'); if (lc) lc.classList.add('dimmed');
      const fd = document.getElementById('foundation'); if (fd) fd.classList.add('dimmed');
    }
    function bandLeave() {
      leaveTimeout = setTimeout(() => {
        activePhase = null;
        PHASES.forEach(p => { const b = document.getElementById('band-' + p); if (b) b.classList.remove('active', 'dimmed'); });
        ARROWS.forEach(id => { const el = document.getElementById(id); if (el) el.classList.remove('dimmed'); });
        const lc = document.getElementById('lines-canvas'); if (lc) lc.classList.remove('dimmed');
        const fd = document.getElementById('foundation'); if (fd) fd.classList.remove('dimmed');
        setTimeout(() => drawConnectionLines(), 550);
      }, 200);
    }
    function arrowEnter() { clearTimeout(leaveTimeout); }
    function arrowLeave() { bandLeave(); }

    function cpEnter() {
      clearTimeout(cpLeaveTimeout);
      if (cpActive) return;
      if (orchActive) {
        document.getElementById('bands-wrap').classList.remove('orch-mode');
        document.getElementById('orch-toggle').setAttribute('aria-expanded', 'false');
        orchActive = false;
        clearTimeout(orchLeaveTimeout);
      }
      cpActive = true; activePhase = null;
      PHASES.forEach(p => { const b = document.getElementById('band-' + p); if (b) b.classList.remove('active', 'dimmed'); });
      ARROWS.forEach(id => { const el = document.getElementById(id); if (el) el.classList.remove('dimmed'); });
      document.getElementById('bands-wrap').classList.add('cp-mode');
      document.getElementById('cp-toggle').setAttribute('aria-expanded', 'true');
    }
    function cpLeave() {
      cpLeaveTimeout = setTimeout(() => {
        cpActive = false;
        document.getElementById('bands-wrap').classList.remove('cp-mode');
        document.getElementById('cp-toggle').setAttribute('aria-expanded', 'false');
        setTimeout(() => drawConnectionLines(), 550);
      }, 300);
    }
    function cpKeep() { clearTimeout(cpLeaveTimeout); }
    function cpToggle() {
      if (cpActive) { cpLeave(); }
      else { cpEnter(); }
    }

    function orchEnter() {
      clearTimeout(orchLeaveTimeout);
      if (orchActive) return;
      if (cpActive) {
        document.getElementById('bands-wrap').classList.remove('cp-mode');
        document.getElementById('cp-toggle').setAttribute('aria-expanded', 'false');
        cpActive = false;
        clearTimeout(cpLeaveTimeout);
      }
      orchActive = true; activePhase = null;
      PHASES.forEach(p => { const b = document.getElementById('band-' + p); if (b) b.classList.remove('active', 'dimmed'); });
      ARROWS.forEach(id => { const el = document.getElementById(id); if (el) el.classList.remove('dimmed'); });
      document.getElementById('bands-wrap').classList.add('orch-mode');
      document.getElementById('orch-toggle').setAttribute('aria-expanded', 'true');
    }
    function orchLeave() {
      orchLeaveTimeout = setTimeout(() => {
        orchActive = false;
        document.getElementById('bands-wrap').classList.remove('orch-mode');
        document.getElementById('orch-toggle').setAttribute('aria-expanded', 'false');
        setTimeout(() => drawConnectionLines(), 550);
      }, 300);
    }
    function orchKeep() { clearTimeout(orchLeaveTimeout); }
    function orchToggle() { if (orchActive) { orchLeave(); } else { orchEnter(); } }

    function legendEnter(el) {
      clearTimeout(legendLeaveTimeout);
      if (cpActive) return;
      legendActive = true;
      document.querySelectorAll('.arch-v2 .legend-item').forEach(li => {
        if (li === el) {
          li.classList.remove('dimmed');
          const c = li.querySelector('.legend-card'); if (c) c.classList.add('visible');
        } else {
          li.classList.add('dimmed');
          const c = li.querySelector('.legend-card'); if (c) c.classList.remove('visible');
        }
      });
    }
    function legendLeave() {
      legendLeaveTimeout = setTimeout(() => {
        legendActive = false;
        document.querySelectorAll('.arch-v2 .legend-item').forEach(li => {
          li.classList.remove('dimmed');
          const c = li.querySelector('.legend-card'); if (c) c.classList.remove('visible');
        });
      }, 200);
    }

    /* Wire DOM events. Inline on*="..." attributes were removed because the
       site's CSP (Sprint 7c: script-src 'self' 'nonce-...' 'strict-dynamic')
       blocks event handler attributes — only nonce-blessed <script> tags
       run, which is why this whole block executes. addEventListener has
       no such restriction. */
    function wireArchEvents() {
      const cpToggleEl = document.getElementById('cp-toggle');
      if (cpToggleEl) {
        cpToggleEl.addEventListener('mouseenter', cpEnter);
        cpToggleEl.addEventListener('mouseleave', cpLeave);
        cpToggleEl.addEventListener('focus', cpEnter);
        cpToggleEl.addEventListener('blur', cpLeave);
        cpToggleEl.addEventListener('click', cpToggle);
        cpToggleEl.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); cpToggle(); }
        });
      }
      const orchToggleEl = document.getElementById('orch-toggle');
      if (orchToggleEl) {
        orchToggleEl.addEventListener('mouseenter', orchEnter);
        orchToggleEl.addEventListener('mouseleave', orchLeave);
        orchToggleEl.addEventListener('focus', orchEnter);
        orchToggleEl.addEventListener('blur', orchLeave);
        orchToggleEl.addEventListener('click', orchToggle);
        orchToggleEl.addEventListener('keydown', (e) => {
          if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); orchToggle(); }
        });
      }
      ['cp-detail-top', 'cp-grid-section'].forEach((id) => {
        const el = document.getElementById(id);
        if (!el) return;
        el.addEventListener('mouseenter', cpKeep);
        el.addEventListener('mouseleave', cpLeave);
      });
      const orchDetail = document.getElementById('orch-detail-top');
      if (orchDetail) {
        orchDetail.addEventListener('mouseenter', orchKeep);
        orchDetail.addEventListener('mouseleave', orchLeave);
      }
      PHASES.forEach((phase) => {
        const band = document.getElementById('band-' + phase);
        if (!band) return;
        const enter = () => bandEnter(phase);
        band.addEventListener('mouseenter', enter);
        band.addEventListener('mouseleave', bandLeave);
        band.addEventListener('focus', enter);
        band.addEventListener('blur', bandLeave);
      });
      ARROWS.forEach((id) => {
        const a = document.getElementById(id);
        if (!a) return;
        a.addEventListener('mouseenter', arrowEnter);
        a.addEventListener('mouseleave', arrowLeave);
      });
      document.querySelectorAll('.arch-v2 .legend-item').forEach((li) => {
        const enter = () => legendEnter(li);
        li.addEventListener('mouseenter', enter);
        li.addEventListener('mouseleave', legendLeave);
        li.addEventListener('focus', enter);
        li.addEventListener('blur', legendLeave);
      });
    }

    /* One-shot auto-cycle on page load: open the CP panel and let the
       6-box clockwise build animate, then open the orch panel and let
       the routing-decision animation play one cycle, then settle.
       Cancels on first user interaction (mouse, focus, scroll, key). */
    function autoCycleArch() {
      const wrap = document.getElementById('bands-wrap');
      if (!wrap) return;
      // Honour prefers-reduced-motion: skip the cycle entirely.
      if (window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches) return;

      let cancelled = false;
      const timeouts = [];
      const schedule = (fn, delay) => {
        const t = setTimeout(() => { if (!cancelled) fn(); }, delay);
        timeouts.push(t);
      };
      const cancel = () => {
        if (cancelled) return;
        cancelled = true;
        timeouts.forEach(clearTimeout);
      };
      // First user-initiated interaction inside the diagram cancels the cycle.
      ['pointerdown', 'pointerover', 'focusin', 'keydown', 'wheel'].forEach((ev) => {
        wrap.addEventListener(ev, cancel, { once: true, capture: true, passive: true });
      });
      // Scrolling away also cancels.
      window.addEventListener('scroll', cancel, { once: true, capture: true, passive: true });

      /* Timing:
         t=0     +1000ms settle (let layout + fonts settle)
         t=1000  cpEnter — CP panel transitions open (0.6s)
                 6 boxes × 1.0s stagger + 0.5s anim each, lines run
                 0.5–7.5s. Hold ~7.5s so the last line completes.
         t=8500  cpLeave — panel collapses (~0.9s with the 300ms guard)
         t=9600  orchEnter — orch panel transitions open
         t=11000 routing animation peaks — let one full 5s cycle run
         t=15100 orchLeave — panel collapses
       */
      schedule(() => cpEnter(),                               1000);
      schedule(() => { if (cpActive)   cpLeave();   },        8500);
      schedule(() => orchEnter(),                             9600);
      schedule(() => { if (orchActive) orchLeave(); },       15100);
    }

    if (document.readyState === 'loading') {
      window.addEventListener('DOMContentLoaded', () => { wireArchEvents(); drawConnectionLines(); autoCycleArch(); });
    } else {
      wireArchEvents();
      drawConnectionLines();
      autoCycleArch();
    }
    window.addEventListener('load', () => drawConnectionLines());
    window.addEventListener('resize', () => drawConnectionLines());

    /* ══ Upgrade .bd-tag spans into anchors → /skills/<id>.
       The band-detail "skills:" chips list the skills involved in each
       phase but were rendered as inert <span>. Convert each one whose
       text matches a known skill id into a real link so visitors can
       jump from the architecture overview straight into the per-skill
       page. `integrations-eng` is a display truncation of the real
       `oc-integrations-engineer` id; map it explicitly. */
    (() => {
      const knownIds = new Set(Object.keys(SKILLS));
      const aliases = { 'integrations-eng': 'oc-integrations-engineer' };
      document.querySelectorAll('.bd-tag').forEach((el) => {
        const txt = (el.textContent || '').trim();
        const id = aliases[txt] || txt;
        if (!knownIds.has(id)) return;
        const a = document.createElement('a');
        a.href = `/skills/${id}`;
        a.className = el.className;
        a.setAttribute('style', el.getAttribute('style') || '');
        a.setAttribute('aria-label', `View ${id} skill`);
        a.textContent = el.textContent;
        // Keep the chip looking identical; just add a hover affordance.
        a.style.textDecoration = 'none';
        a.style.cursor = 'pointer';
        el.replaceWith(a);
      });
    })();

    /* ══ Instrument rail (v1.6) — drives BOTH the desktop .irail meter rows
       and the mobile .ma-meter chips from one place (same page DOM). Runs a
       single illustrative sample pass on load (perf-safe: no infinite loop),
       then stops at the totals. prefers-reduced-motion renders final totals
       with no streaming. Guarded so a missing element never throws. Selectors
       are scoped to .irow / .ma-meter so the existing data-phase bands are
       never touched. Numbers are a representative sample, not live spend. ══ */
    (() => {
      const PH = [
        { k: 'discover', cost: 0.04, use: 12 },
        { k: 'plan',     cost: 0.38, use: 41 },
        { k: 'build',    cost: 1.12, use: 88 },
        { k: 'ship',     cost: 0.21, use: 30 },
        { k: 'monitor',  cost: 0.06, use: 19 }
      ];
      const MAXU = 88;
      if (!document.querySelector('.irow[data-phase] .rm-cost, .ma-meter[data-phase] .mm-cost')) return;
      const st = PH.map(() => ({ c: 0, u: 0, s: 'pending' }));
      const fmt = (c) => '$' + c.toFixed(2);
      const setT = (id, t) => { const e = document.getElementById(id); if (e) e.textContent = t; };
      function paint() {
        let tc = 0, tu = 0;
        PH.forEach((p, i) => {
          const c = st[i]; tc += c.c; tu += c.u;
          document.querySelectorAll('.irow[data-phase="' + p.k + '"], .ma-meter[data-phase="' + p.k + '"]').forEach((el) => {
            el.classList.toggle('streaming', c.s === 'active');
            const cost = el.querySelector('.rm-cost') || el.querySelector('.mm-cost');
            if (cost) cost.textContent = fmt(c.c);
            const use = el.querySelector('.rm-use') || el.querySelector('.mm-use');
            if (use) use.textContent = String(Math.round(c.u));
            const bar = el.querySelector('.rm-bar > i');
            if (bar) bar.style.transform = 'scaleX(' + (c.u / MAXU) + ')';
          });
        });
        setT('irail-total-cost', fmt(tc)); setT('irail-total-use', Math.round(tu) + ' events');
        setT('mm-total-cost', fmt(tc));    setT('mm-total-use', Math.round(tu) + ' ev');
      }
      const reduce = window.matchMedia && window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (reduce) {
        st.forEach((c, i) => { c.c = PH[i].cost; c.u = PH[i].use; c.s = 'done'; });
        paint();
        return;
      }
      let idx = 0;
      function step() {
        if (idx >= PH.length) { paint(); return; }
        const p = PH[idx], c = st[idx];
        c.s = 'active';
        c.c = Math.min(p.cost, c.c + p.cost * 0.18);
        c.u = Math.min(p.use, c.u + Math.max(1, p.use * 0.16));
        paint();
        if (c.c >= p.cost - 0.0005 && c.u >= p.use) { c.c = p.cost; c.u = p.use; c.s = 'done'; idx++; }
        if (idx < PH.length) setTimeout(step, 80);
      }
      setTimeout(step, 500);
    })();
  </script>
</Base>

