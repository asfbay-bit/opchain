                <g class="cp-anim-box-4">
                  <rect x="540" y="120" width="160" height="60" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="609" y="126" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="609" y="126" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
