                           mY_pb + LANE_AUTO, EMB, W_SECONDARY, true, O_SECONDARY, A_SECONDARY);
      if (r2) labelPill('auto-invoke', (r2.busL + r2.busR) / 2, mY_pb + LANE_AUTO, EMB);

      /* Build → Ship: api-dev → security-auditor (advisory, around deploy-ops) */
      const _dpR  = pt('deploy-ops', 'right');
      const _dpB  = pt('deploy-ops', 'bottom');
      const _saT2 = pt('security-auditor', 'top');
      const safeX_sec = _dpR ? _dpR.x + 30 : (wr.width - 100);
      const midY2_sec = (_dpB && _saT2) ? (_dpB.y + _saT2.y) / 2 : (mY_bs + LANE_ADVISORY + 60);
      const r4 = orthoSkip('api-dev', 'bottom', 'security-auditor', 'top',
                           mY_bs + LANE_ADVISORY, midY2_sec, safeX_sec,
                           SAND, W_ADVISORY, true, O_ADVISORY, A_ADVISORY);
      if (r4) labelPill('advisory', r4.safeX, (r4.midY1 + r4.midY2) / 2, SAND);

      /* Build → Monitor long-jump: api-dev → monitoring-ops (advisory, right gutter) */
      const r7 = orthoSkip('api-dev', 'bottom', 'monitoring-ops', 'top',
                           mY_bs + LANE_ADVISORY, mY_sm + LANE_ADVISORY, safeXR,
                           SAND, W_ADVISORY, true, O_ADVISORY, A_ADVISORY);
      if (r7) labelPill('SLO + drift', r7.safeX, (r7.midY1 + r7.midY2) / 2, SAND);
