---
import Base from "../layouts/Base.astro";
---

<Base
  title="Architecture · opchain"
  description="Checkpoint-driven pipeline of 17 opchain skills across 5 phases — interactive diagram of how skills chain through .checkpoints/<skill>.json."
  active="/architecture"
>
  <main class="arch-v2">
    <!-- Shared SVG defs (filters + arrowhead markers) -->
    <svg class="arch-v2-defs" aria-hidden="true">
      <defs>
        <filter id="glow-ember" x="-80%" y="-80%" width="260%" height="260%">
          <feGaussianBlur stdDeviation="10" result="b"/>
          <feFlood flood-color="#e05c18" flood-opacity="0.9" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-orch" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="6" result="b"/>
          <feFlood flood-color="#e05c18" flood-opacity="0.4" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-yellow" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="7" result="b"/>
          <feFlood flood-color="#f59e0b" flood-opacity="0.5" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-deep-violet" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="7" result="b"/>
          <feFlood flood-color="#0EA5E9" flood-opacity="0.6" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-mint" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="7" result="b"/>
          <feFlood flood-color="#0D9488" flood-opacity="0.45" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <filter id="glow-rose" x="-40%" y="-40%" width="180%" height="180%">
          <feGaussianBlur stdDeviation="7" result="b"/>
          <feFlood flood-color="#F43F5E" flood-opacity="0.5" result="c"/>
          <feComposite in="c" in2="b" operator="in" result="s"/>
          <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
        </filter>
        <marker id="ah-success" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
          <polygon points="0 0, 8 3, 0 6" fill="#0D9488"/>
        </marker>
        <marker id="ah-success-sm" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
          <polygon points="0 0, 6 2, 0 4" fill="#0D9488"/>
        </marker>
        <marker id="ah-ember" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
          <polygon points="0 0, 6 2, 0 4" fill="#e05c18"/>
        </marker>
        <marker id="ah-ember-rev" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto-start-reverse">
          <polygon points="0 0, 6 2, 0 4" fill="#e05c18"/>
        </marker>
        <marker id="ah-sand" markerWidth="5" markerHeight="3.5" refX="4.5" refY="1.75" orient="auto">
          <polygon points="0 0, 5 1.75, 0 3.5" fill="#c4b89e"/>
        </marker>
        <marker id="ah-sand-rev" markerWidth="5" markerHeight="3.5" refX="4.5" refY="1.75" orient="auto-start-reverse">
          <polygon points="0 0, 5 1.75, 0 3.5" fill="#c4b89e"/>
        </marker>
        <marker id="ah-error" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
          <polygon points="0 0, 6 2, 0 4" fill="#ef4444"/>
        </marker>
      </defs>
    </svg>

    <div class="container">
      <div class="header">
        <div class="header-eyebrow">SKILLS · ARCHITECTURE · v2</div>
        <h1>opchain skills ecosystem</h1>
        <p class="subtitle">Checkpoint-driven pipeline · 17 skills · 5 phases · 5 tri-agent · 3 audit gates · spine ordinals</p>
      </div>

      <div class="diagram-container">
        <div class="bands-wrap" id="bands-wrap">
          <canvas class="lines-canvas" id="lines-canvas"></canvas>

          <!-- ══ FOUNDATION HEADER STRIP (CP + orchestrator) ══ -->
          <div class="foundation" id="foundation" aria-label="Foundation layer: checkpoint-protocol and orchestrator">
            <div class="foundation-pill foundation-pill-trigger"
                 id="cp-toggle"
                 role="button"
                 tabindex="0"
                 aria-expanded="false"
                 aria-controls="cp-detail-top cp-grid-section"
                 onmouseenter="cpEnter()" onmouseleave="cpLeave()"
                 onfocus="cpEnter()" onblur="cpLeave()"
                 onclick="cpToggle()"
                 onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();cpToggle();}">
              <span class="fp-tag">PROTOCOL</span>
              <span class="fp-name">checkpoint-protocol</span>
              <span class="fp-desc">JSON schema · phase · progress · blockers · next_actions</span>
            </div>
            <div class="foundation-pill foundation-pill-trigger"
                 id="orch-toggle"
                 role="button"
                 tabindex="0"
                 aria-expanded="false"
                 aria-controls="orch-detail-top"
                 onmouseenter="orchEnter()" onmouseleave="orchLeave()"
                 onfocus="orchEnter()" onblur="orchLeave()"
                 onclick="orchToggle()"
                 onkeydown="if(event.key==='Enter'||event.key===' '){event.preventDefault();orchToggle();}">
              <span class="fp-tag">ORCH</span>
              <span class="fp-name">orchestrator</span>
              <span class="fp-desc">/ops · routing · cross-project status · gate enforcement</span>
            </div>
          </div>

          <!-- ── CP detail card (overlay reveals this) ── -->
          <div class="cp-detail-expand" id="cp-detail-top"
               onmouseenter="cpKeep()" onmouseleave="cpLeave()">
            <div class="cpd-inner">
              <p class="cpd-intro">Every skill writes a JSON checkpoint after each state change. Single source of truth — any skill can read any other's to rebuild context. Plain JSON on disk · no database · no vendor lock-in.</p>
              <div class="cpd-json">
                &#123;<br>
                &nbsp;&nbsp;<span class="k">"skill"</span>: <span class="s">"app-architect"</span>,<br>
                &nbsp;&nbsp;<span class="k">"phase"</span>: <span class="s">"build"</span>,<br>
                &nbsp;&nbsp;<span class="k">"progress_table"</span>: &#123; <span class="s">"discover"</span>: <span class="s">"complete"</span>, <span class="s">"spec"</span>: <span class="s">"in_progress"</span> &#125;,<br>
                &nbsp;&nbsp;<span class="k">"context_primer"</span>: <span class="s">"2-sentence summary..."</span>,<br>
                &nbsp;&nbsp;<span class="k">"blockers"</span>: [<span class="s">"waiting on API key"</span>],<br>
                &nbsp;&nbsp;<span class="k">"next_actions"</span>: [<span class="s">"/git-sync"</span>]<br>
                &#125;
              </div>
            </div>
          </div>

          <!-- ── Orchestrator → 6 checkpoint sync diagram (clockwise build animation) ── -->
          <div class="cp-grid-section" id="cp-grid-section"
               onmouseenter="cpKeep()" onmouseleave="cpLeave()">
            <div class="cp-grid-inner">
              <svg class="orch-sync-svg" viewBox="0 0 720 240" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Orchestrator bidirectional sync to 6 checkpoints, animated clockwise">
                <defs>
                  <marker id="cp-sync-end" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
                    <polygon points="0 0, 6 2, 0 4" fill="#e05c18"/>
                  </marker>
                  <marker id="cp-sync-start" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto-start-reverse">
                    <polygon points="0 0, 6 2, 0 4" fill="#e05c18"/>
                  </marker>
                  <filter id="cp-orch-glow" x="-30%" y="-30%" width="160%" height="160%">
                    <feGaussianBlur stdDeviation="3" result="b"/>
                    <feFlood flood-color="#e05c18" flood-opacity="0.55" result="c"/>
                    <feComposite in="c" in2="b" operator="in" result="s"/>
                    <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                </defs>

                <line class="cp-anim-line-1" x1="290" y1="98" x2="165" y2="70" stroke="#e05c18" stroke-width="1.1" stroke-dasharray="3,3" opacity="0" marker-start="url(#cp-sync-start)" marker-end="url(#cp-sync-end)"/>
                <line class="cp-anim-line-2" x1="360" y1="98" x2="360" y2="70" stroke="#e05c18" stroke-width="1.1" stroke-dasharray="3,3" opacity="0" marker-start="url(#cp-sync-start)" marker-end="url(#cp-sync-end)"/>
                <line class="cp-anim-line-3" x1="430" y1="98" x2="555" y2="70" stroke="#e05c18" stroke-width="1.1" stroke-dasharray="3,3" opacity="0" marker-start="url(#cp-sync-start)" marker-end="url(#cp-sync-end)"/>
                <line class="cp-anim-line-4" x1="430" y1="142" x2="555" y2="170" stroke="#e05c18" stroke-width="1.1" stroke-dasharray="3,3" opacity="0" marker-start="url(#cp-sync-start)" marker-end="url(#cp-sync-end)"/>
                <line class="cp-anim-line-5" x1="360" y1="142" x2="360" y2="170" stroke="#e05c18" stroke-width="1.1" stroke-dasharray="3,3" opacity="0" marker-start="url(#cp-sync-start)" marker-end="url(#cp-sync-end)"/>
                <line class="cp-anim-line-6" x1="290" y1="142" x2="165" y2="170" stroke="#e05c18" stroke-width="1.1" stroke-dasharray="3,3" opacity="0" marker-start="url(#cp-sync-start)" marker-end="url(#cp-sync-end)"/>

                <g class="cp-anim-orch">
                  <rect x="290" y="98" width="140" height="44" rx="5" fill="rgba(224,92,24,.20)" stroke="#e05c18" stroke-width="1.2" filter="url(#cp-orch-glow)"/>
                  <text x="360" y="118" fill="#f6f0e8" font-size="11" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">orchestrator</text>
                  <text x="360" y="132" fill="#e05c18" font-size="7.5" font-weight="500" font-family="JetBrains Mono,monospace" text-anchor="middle">/ops · routing · sync</text>
                </g>

                <g class="cp-anim-box-1">
                  <rect x="35" y="20" width="130" height="50" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="89" y="26" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="89" y="26" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="100" y="35.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="100" y="58" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">reverse-spec</text>
                </g>
                <g class="cp-anim-box-2">
                  <rect x="295" y="20" width="130" height="50" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="349" y="26" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="349" y="26" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="360" y="35.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="360" y="58" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">app-architect</text>
                </g>
                <g class="cp-anim-box-3">
                  <rect x="555" y="20" width="130" height="50" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="609" y="26" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="609" y="26" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="620" y="35.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="620" y="58" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">stack-forge</text>
                </g>
                <g class="cp-anim-box-4">
                  <rect x="555" y="170" width="130" height="50" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="609" y="176" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="609" y="176" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="620" y="185.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="620" y="208" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">api-dev</text>
                </g>
                <g class="cp-anim-box-5">
                  <rect x="295" y="170" width="130" height="50" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="349" y="176" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="349" y="176" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="360" y="185.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="360" y="208" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">dash-forge</text>
                </g>
                <g class="cp-anim-box-6">
                  <rect x="35" y="170" width="130" height="50" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="89" y="176" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="89" y="176" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                  <text x="100" y="185.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="100" y="208" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">ux-engineer</text>
                </g>
              </svg>
            </div>
          </div>

          <!-- ── Orchestrator detail card with routing-decision animation ── -->
          <div class="orch-detail-expand" id="orch-detail-top"
               onmouseenter="orchKeep()" onmouseleave="orchLeave()">
            <div class="cpd-inner">
              <p class="cpd-intro">The orchestrator routes every skill invocation across projects. Tracks which checkpoint is current, enforces audit gates before deploys, and answers <code>/ops</code> queries. Reads all 17 checkpoints; writes its own pipeline state.</p>
              <svg class="orch-route-svg" viewBox="0 0 720 110" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Orchestrator routing decision: app-architect checkpoint update routed to ux-engineer">
                <defs>
                  <marker id="orch-rt-end" markerWidth="6" markerHeight="4" refX="5" refY="2" orient="auto">
                    <polygon points="0 0, 6 2, 0 4" fill="#e05c18"/>
                  </marker>
                  <filter id="orch-rt-glow" x="-30%" y="-30%" width="160%" height="160%">
                    <feGaussianBlur stdDeviation="3" result="b"/>
                    <feFlood flood-color="#e05c18" flood-opacity="0.55" result="c"/>
                    <feComposite in="c" in2="b" operator="in" result="s"/>
                    <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
                  </filter>
                </defs>

                <line class="orch-rt-line orch-rt-line-1" x1="180" y1="48" x2="290" y2="48" stroke="#e05c18" stroke-width="1.2" stroke-dasharray="3,3" opacity="0.3" marker-end="url(#orch-rt-end)" fill="none"/>
                <line class="orch-rt-line orch-rt-line-2" x1="430" y1="48" x2="540" y2="48" stroke="#e05c18" stroke-width="1.2" stroke-dasharray="3,3" opacity="0.3" marker-end="url(#orch-rt-end)" fill="none"/>

                <g class="orch-rt-src">
                  <rect class="orch-rt-rect" x="40" y="18" width="140" height="60" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="99" y="24" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="99" y="24" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#orch-rt-glow)"/>
                  <text x="110" y="33.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="110" y="56" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,sans-serif" text-anchor="middle">app-architect</text>
                  <text class="orch-rt-src-cap" x="110" y="71" fill="#e05c18" font-size="6.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle" letter-spacing=".1em" opacity="0">checkpoint update</text>
                </g>

                <g class="orch-rt-orch">
                  <rect class="orch-rt-orch-rect" x="290" y="18" width="140" height="60" rx="5" fill="rgba(224,92,24,.20)" stroke="#e05c18" stroke-width="1.2" filter="url(#orch-rt-glow)"/>
                  <text x="360" y="38" fill="#f6f0e8" font-size="11" font-weight="600" font-family="Outfit,sans-serif" text-anchor="middle">orchestrator</text>
                  <text class="orch-rt-orch-base" x="360" y="56" fill="#e05c18" font-size="7.5" font-weight="500" font-family="JetBrains Mono,monospace" text-anchor="middle">/ops · routing</text>
                  <text class="orch-rt-decision" x="360" y="56" fill="#f59e0b" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle" opacity="0">→ /uxe sprint</text>
                  <text class="orch-rt-orch-cap" x="360" y="71" fill="#e05c18" font-size="6.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle" letter-spacing=".1em" opacity="0">deciding</text>
                </g>

                <g class="orch-rt-tgt">
                  <rect class="orch-rt-rect" x="540" y="18" width="140" height="60" rx="5" fill="rgba(224,92,24,.10)" stroke="#e05c18" stroke-width="0.7"/>
                  <rect x="599" y="24" width="22" height="13" rx="3" fill="#1c1710"/>
                  <rect x="599" y="24" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#orch-rt-glow)"/>
                  <text x="610" y="33.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                  <text x="610" y="56" fill="#f6f0e8" font-size="9.5" font-weight="500" font-family="Outfit,sans-serif" text-anchor="middle">ux-engineer</text>
                  <text class="orch-rt-tgt-cap" x="610" y="71" fill="#e05c18" font-size="6.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle" letter-spacing=".1em" opacity="0">activating</text>
                </g>
              </svg>
            </div>
          </div>

          <div style="height: 24px;"></div>

          <!-- ══ BAND 1: DISCOVER ══ -->
          <div class="band" id="band-discover" data-phase="discover"
               tabindex="0"
               onmouseenter="bandEnter('discover')" onmouseleave="bandLeave()"
               onfocus="bandEnter('discover')" onblur="bandLeave()">
            <div class="band-label">
              <div class="band-label-bar" style="background:var(--slag)"></div>
              <span class="band-label-text">DISCOVER</span>
            </div>
            <div class="band-content">
              <svg viewBox="0 0 760 80" role="img" aria-label="Discover phase: reverse-spec">
                <rect x="298" y="14" width="165" height="52" rx="5" fill="#1c1710" stroke="#0D9488" stroke-width="1" opacity="0.97"><title>reverse-spec — standalone specialist; reverse-engineers existing code into spec docs</title></rect>
                <rect x="298" y="14" width="165" height="52" rx="5" fill="rgba(13,148,136,0.06)" stroke="#0D9488" stroke-width="0.5"/>
                <text x="381" y="30" fill="#e8dfd0" font-size="7.5" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">reverse-spec</text>
                <text x="381" y="42" fill="#c4b89e" font-size="7.5" font-family="JetBrains Mono,monospace" text-anchor="middle">Specialist · Workflow</text>
                <text x="381" y="56" fill="#0D9488" font-size="7.5" font-family="JetBrains Mono,monospace" text-anchor="middle">/rev-spec · /rev-full</text>
                <rect x="426" y="7" width="22" height="13" rx="3" fill="#1c1710"/>
                <rect x="426" y="7" width="22" height="13" rx="3" fill="rgba(224,92,24,.10)" stroke="rgba(224,92,24,0.6)" stroke-width="0.5" filter="url(#glow-ember)"/>
                <text x="437" y="16.5" fill="#e05c18" font-size="7.5" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">CP</text>
                <rect x="452" y="7" width="22" height="13" rx="3" fill="#1c1710"/>
