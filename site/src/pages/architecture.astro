            <div class="cp-grid-inner">
              <svg class="orch-sync-svg" viewBox="0 0 720 200" preserveAspectRatio="xMidYMid meet" xmlns="http://www.w3.org/2000/svg" role="img" aria-label="Orchestrator bidirectional sync to 6 checkpoints, animated clockwise">
