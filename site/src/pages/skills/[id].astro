---
import { render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Card from "../../components/ui/Card.astro";
import Icon from "../../components/Icon.astro";
import CaptureModal from "../../components/CaptureModal.astro";
import { getAllSkills, getSkill, getSkillRole, getSkillUpdatedAt, type Role } from "../../lib/skills";
import { defaultFor } from "../../lib/flags/build-defaults";
import { isCapabilityEnabled, isCommandEnabled } from "../../lib/flags/build-defaults";
import packsCatalog from "../../../../src/generated/packs-catalog.json";

export async function getStaticPaths() {
  const skills = await getAllSkills();
  return skills.map((s) => ({ params: { id: s.data.name } }));
}

const { id } = Astro.params;
const skill = await getSkill(id!);
if (!skill) {
  return Astro.redirect("/skills");
}

const { Content } = await render(skill);

const phaseLabel = skill.data.phases.join(" + ");
const description = `${skill.data.displayName} — ${skill.data.shortDesc}`;

// Skill→role lookup shipped to the client as a small JSON island so a
// post-render script can paint inline `<code>` mentions of known skills
// with their role colour. Same map every other surface uses.
const allSkills = await getAllSkills();
const skillRolesJson = JSON.stringify(
  Object.fromEntries(
    allSkills.map((s) => [s.data.name, getSkillRole(s.data.name) as Role]),
  ),
);

// Reading-time estimate, computed at build time from the SKILL.md body.
// 220 wpm is the conservative end of adult silent-reading speed for
// technical prose (range 200–250). Ceil so a 30-second skill still
// reads "1 min" instead of "0 min".
const wordCount = (skill.body || "").trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 220));

// Last-touched date for the skill, derived from `git log` over
// skills/<id>/. The frontmatter `version` is a coarse signal and rarely
// gets bumped on small fixes, so the badge gives visitors a precise
// "is this fresh?" answer alongside the semver pill.
const updatedIso = getSkillUpdatedAt(skill.data.name);
const updatedLabel = updatedIso
  ? new Date(updatedIso).toLocaleDateString("en-US", {
      year: "numeric",
      month: "short",
      day: "numeric",
    })
  : null;

const isStackForge = skill.data.name === "oc-stack-forge";
const packCount = isStackForge ? (packsCatalog as unknown[]).length : 0;

const triAgentEnabled = isCapabilityEnabled("tri-agent");
const checkpointProtocolEnabled = isCapabilityEnabled("checkpoint-protocol");
const installZipEnabled = defaultFor("site.feature.install-zip-download") as boolean;
const demoEnabled = defaultFor("site.feature.demo-page") as boolean;
const visibleCommands = (skill.data.commands as string[]).filter(isCommandEnabled);

// 18 — Prev / next skill nav. Catalog ordered by role (the same
// ROLE_ORDER used on /architecture) then by skill name within group,
// so siblings sit together and you can fan through a category quickly.
const ROLE_ORDER: Role[] = [
  "workflow", "tri-agent", "audit-gate", "specialist", "advisor", "orchestrator", "success",
];
const orderedSkills = [...allSkills].sort((a, b) => {
  const ra = ROLE_ORDER.indexOf(getSkillRole(a.data.name));
  const rb = ROLE_ORDER.indexOf(getSkillRole(b.data.name));
  if (ra !== rb) return ra - rb;
  return a.data.name.localeCompare(b.data.name);
});
const currentIdx = orderedSkills.findIndex((s) => s.data.name === id);
const prevSkill  = currentIdx > 0 ? orderedSkills[currentIdx - 1] : null;
const nextSkill  = currentIdx >= 0 && currentIdx < orderedSkills.length - 1
  ? orderedSkills[currentIdx + 1]
  : null;

// 20 — Foundational empty state. oc-checkpoint-protocol (and any other
// success-role skill) is consumed BY other skills, not invoked
// directly. Surface a few of those consumers so the page shows what
// the protocol actually drives.
const isFoundational = getSkillRole(skill.data.name) === "success";
const consumers = isFoundational
  ? allSkills
      .filter((s) => s.data.name !== skill.data.name)
      .map((s) => ({ name: s.data.name, role: getSkillRole(s.data.name) }))
      .slice(0, 8)
  : [];
---

<Base
  title={`${skill.data.displayName} · opchain skill`}
  description={description}
  active="/skills"
>
  <main class="page">
    <a href="/skills" class="back">
      <Icon name="arrow-left" size={12} /> all skills
    </a>

    <header class="head">
      <Eyebrow>{phaseLabel}</Eyebrow>
      <h1>{skill.data.displayName}</h1>
      <p class="lede">{skill.data.shortDesc}</p>
      <div class="tags">
        {skill.data.phases.map((p: string) => <Badge variant="accent">{p}</Badge>)}
        {skill.data.triAgent && triAgentEnabled && <Badge variant="accent">Tri-agent</Badge>}
        <Badge variant="neutral">v{skill.data.version}</Badge>
        {updatedLabel && updatedIso && (
          <Badge variant="neutral">
            <time datetime={updatedIso}>Updated {updatedLabel}</time>
          </Badge>
        )}
      </div>
    </header>

    <!-- ───────────── Quick facts + actions ───────────── -->
    <section class="quick">
      {visibleCommands.length > 0 && (
        <Card variant="surface" glow={false}>
          <div class="quick-head">Commands</div>
          <div class="cmds">
            {visibleCommands.map((c: string) => <code class="cmd">{c}</code>)}
          </div>
        </Card>
      )}

      <Card variant="surface" glow={false}>
        <div class="quick-head">Pipeline phase</div>
        <p class="quick-body">
          <strong>{phaseLabel}</strong>
          {skill.data.triAgent && triAgentEnabled && <span> · runs as a tri-agent loop (Planner / Generator / Evaluator)</span>}
        </p>
      </Card>

      <Card variant="surface" glow={false}>
        <div class="quick-head">Get this skill</div>
        {isFoundational && checkpointProtocolEnabled && (
          <>
            <p class="quick-body">
              Foundational protocol — every other opchain skill reads / writes its checkpoint contract.
            </p>
            {consumers.length > 0 && (
              <div class="protocol-consumers" aria-label="Skills that implement this protocol">
                {consumers.map((c) => (
                  <a href={`/skills/${c.name}`} class="protocol-consumer-pill" data-role={c.role}>
                    {c.name}
                  </a>
                ))}
              </div>
            )}
          </>
        )}
        {(!isFoundational || !checkpointProtocolEnabled) && (
          <p class="quick-body">
            Drop the bundle into <code class="ic">.claude/skills/</code> and Claude Code auto-discovers it on the next session — or point Codex / any MCP agent at the hosted <code class="ic">opchain.dev/mcp</code> endpoint.
          </p>
        )}
        {installZipEnabled && (
          <div class="try-actions">
            <Button
              variant="outline"
              size="sm"
              href={`/skills/${skill.data.name}.zip`}
              {...{ "data-capture-trigger": true, "data-capture-source": "skill-download" } as any}
            >
              <Icon name="download" size={12} />
              download skill
            </Button>
          </div>
        )}
        <div class="related-row">
          {isStackForge && (
            <a class="related-link" href="/coverage">
              <Icon name="puzzle" size={12} />
              browse {packCount} packs on /coverage
            </a>
          )}
          {demoEnabled && (
            <a class="related-link" href={`/demo?skill=${skill.data.name}#workbench`}>
              <Icon name="sparkles" size={12} />
              see it run in the demo
            </a>
          )}
          <a class="related-link" href={`/changelog#${skill.data.name}`}>
            <Icon name="refresh-cw" size={12} />
            what changed in this skill
          </a>
        </div>
      </Card>
    </section>

    <!-- ───────────── How you'll use it (human-facing) ───────────── -->
    <section id="usage" class="usage">
      <h2>How you'll use it</h2>
      <p class="usage-desc">{skill.data.description}</p>
      {visibleCommands.length > 0 && (
        <>
          <p class="usage-label">Trigger with natural language or a slash command:</p>
          <div class="usage-cmds">
            {visibleCommands.slice(0, 6).map((c: string) => (
              <code class="cmd">{c}</code>
            ))}
            {visibleCommands.length > 6 && (
              <span class="cmd-more">+{visibleCommands.length - 6} more</span>
            )}
          </div>
        </>
      )}
    </section>

    <!-- ───────────── Full SKILL.md (model-facing) ───────────── -->
    <section class="prose-wrap">
      <div class="prose-head">
        <div class="prose-head-row">
          <span class="prose-eyebrow">SKILL.md</span>
          <span class="prose-readtime" title={`${wordCount.toLocaleString()} words`}>
            ≈ {readingMinutes} min read
          </span>
        </div>
        <span class="prose-note">
          Below is the file Claude reads on invocation. It's written in
          the model's voice — "read this", "do that" — not a user guide.
          The <a href="#usage">How you'll use it</a> section above is
          the one for you.
        </span>
      </div>

      <!-- 11 — Mobile TOC (≤1279px). Built client-side from h2 / h3. -->
      <details class="toc-collapse" id="toc-collapse">
        <summary>
          <span>On this page</span>
          <span class="toc-collapse-chev" aria-hidden="true">▾</span>
        </summary>
        <ol class="toc-list" id="toc-list-mobile" aria-label="Table of contents"></ol>
      </details>

      <section class="prose" id="skill-md">
        <Content />
      </section>
    </section>

    <!-- 11 — Desktop sticky TOC rail (≥1280px). Floats in the right
         margin alongside the centered .page column. Hidden on narrow
         viewports; the .toc-collapse <details> above takes over. -->
    <aside class="toc-rail" aria-label="Table of contents">
      <div class="toc-rail-inner">
        <span class="toc-rail-eyebrow">on this page</span>
        <ol class="toc-list" id="toc-list-desktop"></ol>
      </div>
    </aside>

    <!-- 5. Progress rail — fixed to the right edge of the viewport,
         tracks scroll position through the SKILL.md body. -->
    <div class="progress-rail" id="progress-rail" aria-hidden="true">
      <div class="progress-rail-fill" id="progress-rail-fill"></div>
    </div>

    <script is:inline id="skill-roles-data" type="application/json" set:html={skillRolesJson}></script>
    <script>
      // Post-render UX pass on the SKILL.md prose. Runs once on load.
      // Tags inline elements with semantic data-* attributes so CSS owns
      // every visual decision; this script never sets inline styles.
      type Role = "workflow" | "tri-agent" | "audit-gate" | "specialist" | "advisor" | "orchestrator" | "success";

      const rolesEl = document.getElementById("skill-roles-data");
      const skillRoles: Record<string, Role> = rolesEl
        ? JSON.parse(rolesEl.textContent || "{}")
        : {};

      const PHASE_ROLE: Record<string, Role> = {
        discover:  "advisor",
        spec:      "advisor",
        design:    "tri-agent",
        build:     "workflow",
        audit:     "audit-gate",
        ship:      "orchestrator",
        monitor:   "specialist",
        migrate:   "specialist",
        scale:     "advisor",
      };

      const STATUS_TOKENS: Array<[RegExp, string]> = [
        [/^(critical|blocker|fail|failed|rejected|error)$/i, "danger"],
        [/^(warning|caution|warn)$/i,                        "warn"],
        [/^(verified|complete|completed|success|passed|ok|approved|ready)$/i, "ok"],
        [/^(in[_\s-]?progress|wip|pending|queued|blocked|paused)$/i,          "progress"],
      ];

      const prose = document.getElementById("skill-md");
      if (prose) wireProse(prose);

      function wireProse(root: HTMLElement) {
        // 1 + 8 — inline <code> classification.
        root.querySelectorAll<HTMLElement>("code").forEach((el) => {
          if (el.closest("pre")) return;
          const text = (el.textContent || "").trim();

          // a) Slash commands: /oc-audit, /oc-deploy, /oc-uxe …
          if (/^\/[a-z][\w-]*(\s|$)/i.test(text)) {
            el.setAttribute("data-cmd", "true");
            return;
          }
          // b) Skill mentions — exact match against the catalog.
          if (skillRoles[text]) {
            el.setAttribute("data-role", skillRoles[text]);
            return;
          }
          // c) Phase keywords.
          if (PHASE_ROLE[text.toLowerCase()]) {
            el.setAttribute("data-phase", text.toLowerCase());
            el.setAttribute("data-role", PHASE_ROLE[text.toLowerCase()]);
            return;
          }
          // d) Status / severity verbs in inline code (e.g. `CRITICAL`).
          for (const [pat, status] of STATUS_TOKENS) {
            if (pat.test(text)) {
              el.setAttribute("data-status", status);
              return;
            }
          }
        });

        // 6 — Status / severity verbs in plain prose. Walk text nodes,
        // wrap matched tokens in <mark data-status="…"> so CSS can paint
        // them. Skip headings, code blocks (Shiki wraps tokens in nested
        // <span>s, so a parentElement-only check walks straight in — use
        // closest() to climb the ancestor chain), links, and prior marks.
        const SKIP_SEL = "code, pre, a, mark, h1, h2, h3, h4";
        const STATUS_PROSE = [
          { rx: /\b(CRITICAL|BLOCKER|FAIL(?:ED)?|REJECTED|ERROR)\b/g,           status: "danger"   },
          { rx: /\b(WARNING|CAUTION)\b/g,                                       status: "warn"     },
          { rx: /\b(VERIFIED|COMPLETE(?:D)?|SUCCESS|PASSED|APPROVED|READY)\b/g, status: "ok"       },
          { rx: /\b(IN[_\s-]?PROGRESS|WIP|PENDING|BLOCKED|PAUSED)\b/g,          status: "progress" },
        ];
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
        const replacements: Array<{ node: Text; html: string }> = [];
        let node: Node | null;
        while ((node = walker.nextNode())) {
          const t = node as Text;
          if (!t.parentElement || t.parentElement.closest(SKIP_SEL)) continue;
          const original = t.nodeValue || "";
          if (!/[A-Z]/.test(original)) continue; // status tokens are uppercase
          let html = escapeHtml(original);
          let dirty = false;
          for (const { rx, status } of STATUS_PROSE) {
            if (rx.test(html)) {
              html = html.replace(new RegExp(rx.source, rx.flags), (m) => {
                dirty = true;
                return `<mark data-status="${status}">${m}</mark>`;
              });
            }
          }
          if (dirty) replacements.push({ node: t, html });
        }
        for (const { node, html } of replacements) {
          const span = document.createElement("span");
          span.innerHTML = html;
          node.replaceWith(...Array.from(span.childNodes));
        }

        // 7 — Typed callout blockquotes. Detect the leading "Note:" /
        // "Warning:" / "Critical:" / "Tip:" / "Principle:" marker on
        // the first paragraph and stamp the blockquote with data-callout.
        const CALLOUT_PAT = /^(Note|Tip|Hint|Warning|Caution|Critical|Danger|Important|Principle|Rule|Constraint)\s*:\s*/i;
        const CALLOUT_KIND: Record<string, string> = {
          note:        "info",   tip:       "info",  hint:        "info",
          warning:     "warn",   caution:   "warn",
          critical:    "danger", danger:    "danger", important:  "danger",
          principle:   "ok",     rule:      "ok",     constraint: "ok",
        };
        root.querySelectorAll<HTMLElement>("blockquote").forEach((bq) => {
          const first = bq.querySelector("p, li");
          if (!first) return;
          const text = (first.textContent || "").trim();
          const m = text.match(CALLOUT_PAT);
          if (!m) return;
          const word = m[1].toLowerCase();
          const kind = CALLOUT_KIND[word] || "info";
          bq.setAttribute("data-callout", kind);
          // Replace the leading marker with a styled label span so the
          // colon doesn't render as plain prose.
          first.innerHTML = first.innerHTML.replace(
            CALLOUT_PAT,
            `<span class="callout-label" data-kind="${kind}">${m[1]}</span> `,
          );
        });

        // 9 — Cross-skill links: <a href="/skills/<id>">…</a> picks up
        // the destination skill's role colour.
        root.querySelectorAll<HTMLAnchorElement>("a[href^='/skills/']").forEach((a) => {
          const m = a.getAttribute("href")?.match(/^\/skills\/([^/?#]+)/);
          if (!m) return;
          const role = skillRoles[m[1]];
          if (role) a.setAttribute("data-role", role);
        });

        // 10 — Failure-mode / blocker line prefixes. Scan paragraphs
        // and list items for a leading "BLOCKER:" / "FAIL:" / "WARNING:"
        // and wrap the prefix in <strong data-status="…"> so only the
        // prefix gets the role colour, not the whole sentence.
        const PREFIX_PAT = /^(BLOCKER|FAIL(?:ED)?|WARNING|CRITICAL|REJECTED)\s*:/;
        const PREFIX_STATUS: Record<string, string> = {
          BLOCKER:   "danger",
          FAIL:      "danger",
          FAILED:    "danger",
          CRITICAL:  "danger",
          REJECTED:  "danger",
          WARNING:   "warn",
        };
        root.querySelectorAll<HTMLElement>("p, li").forEach((el) => {
          // Skip elements inside callouts (already labelled) and tables.
          if (el.closest("blockquote[data-callout], table")) return;
          const first = el.firstChild;
          if (!first || first.nodeType !== Node.TEXT_NODE) return;
          const txt = (first.nodeValue || "").trimStart();
          const m = txt.match(PREFIX_PAT);
          if (!m) return;
          const status = PREFIX_STATUS[m[1]] || "danger";
          const after = txt.slice(m[0].length);
          const label = document.createElement("strong");
          label.dataset.status = status;
          label.className = "prefix-label";
          label.textContent = m[0];
          first.nodeValue = "";
          el.insertBefore(label, first);
          if (after) el.insertBefore(document.createTextNode(after), label.nextSibling);
        });

        // 4 + 12 — Anchor links + numbered h2 eyebrows. Walk h2 / h3
        // once and emit (a) a slug-derived id when missing, (b) a "#"
        // anchor that reveals on hover/focus, and (c) for h2s, a small
        // mono "01 / 02 / …" prefix so sections gain a visual rhythm.
        let anchorIdx = 0;
        let h2Counter = 0;
        root.querySelectorAll<HTMLElement>("h2, h3").forEach((h) => {
          if (!h.id) {
            const slug = (h.textContent || "")
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "")
              || `section-${++anchorIdx}`;
            h.id = slug;
          }
          if (h.tagName === "H2") {
            h2Counter += 1;
            const num = document.createElement("span");
            num.className = "h-num";
            num.setAttribute("aria-hidden", "true");
            num.textContent = String(h2Counter).padStart(2, "0");
            h.insertBefore(num, h.firstChild);
          }
          const a = document.createElement("a");
          a.className = "heading-anchor";
          a.href = `#${h.id}`;
          a.setAttribute("aria-label", `Link to ${h.textContent}`);
          a.textContent = "#";
          a.addEventListener("click", (ev) => {
            ev.preventDefault();
            const url = `${location.origin}${location.pathname}#${h.id}`;
            history.replaceState(null, "", `#${h.id}`);
            navigator.clipboard?.writeText(url).catch(() => {});
            a.classList.add("is-copied");
            setTimeout(() => a.classList.remove("is-copied"), 1200);
          });
          h.appendChild(a);
        });

        // 13 — Pattern cards. Headings whose text matches a known
        // reference-pattern (Inputs / Outputs / Failure modes / etc.)
        // get the section from heading→next-h2/h3 wrapped in a
        // bordered card with a role-coloured accent stripe.
        const PATTERNS: Array<{ rx: RegExp; kind: string; role: Role }> = [
          { rx: /^inputs?$/i,                     kind: "inputs",   role: "advisor"      },
          { rx: /^outputs?$/i,                    kind: "outputs",  role: "tri-agent"    },
          { rx: /^(failure modes?|when (it|this) fails)$/i,
                                                  kind: "failure",  role: "audit-gate"   },
          { rx: /^(when to use|use cases?)$/i,    kind: "use",      role: "success"      },
          { rx: /^(not suitable for|do not use|when not to use|anti[- ]patterns?)$/i,
                                                  kind: "antiuse",  role: "audit-gate"   },
          { rx: /^examples?$/i,                   kind: "examples", role: "specialist"   },
          { rx: /^principles?$/i,                 kind: "principles", role: "advisor"    },
          { rx: /^(constraints?|guarantees?)$/i,  kind: "constraints", role: "orchestrator" },
        ];
        const headings = Array.from(root.querySelectorAll<HTMLElement>("h2, h3"));
        for (const h of headings) {
          const txt = (h.firstChild?.nodeValue || h.textContent || "").trim();
          // Strip the numeric prefix we just inserted so we match on the
          // semantic heading text only.
          const semantic = txt.replace(/^\d{2}\s+/, "").trim();
          const match = PATTERNS.find((p) => p.rx.test(semantic));
          if (!match) continue;

          const card = document.createElement("section");
          card.className = "pattern-card";
          card.setAttribute("data-pattern", match.kind);
          card.setAttribute("data-role", match.role);

          // Move the heading into the card and follow with siblings until
          // we hit the next heading of the same or higher level.
          const stopAtLevel = h.tagName === "H2" ? 2 : 3;
          const stopRx = stopAtLevel === 2 ? /^H[12]$/ : /^H[123]$/;
          const parent = h.parentElement!;
          parent.insertBefore(card, h);
          card.appendChild(h);
          while (card.nextSibling) {
            const next = card.nextSibling as HTMLElement;
            if (next.nodeType === Node.ELEMENT_NODE && stopRx.test(next.tagName || "")) break;
            card.appendChild(next);
          }
        }

        // 14 — Code-block toolbar: language label (top-left) + copy
        // button (top-right) on every <pre>. Language is sniffed from
        // the first child <code class="language-…"> (Astro's renderer
        // emits these from the fence info-string).
        // 15 — ASCII-diagram surface. If the pre body contains
        // box-drawing characters, mark it data-ascii so CSS can
        // swap to the blueprint surface.
        const ASCII_RX = /[─━│┃┌┍┎┏┐┑┒┓└┕┖┗┘┙┚┛├┝┞┟┠┡┢┣┤┥┦┧┨┩┪┫┬┭┮┯┰┱┲┳┴┵┶┷┸┹┺┻┼┽┾┿╀╁╂╃╄╅╆╇╈╉╊╋▶▼◀▲]/;
        root.querySelectorAll<HTMLPreElement>("pre").forEach((pre) => {
          const code = pre.querySelector("code");
          const text = pre.textContent || "";
          if (ASCII_RX.test(text)) pre.setAttribute("data-ascii", "true");

          const cls = code?.getAttribute("class") || "";
          const langMatch = cls.match(/language-([\w+-]+)/i);
          const lang = langMatch ? langMatch[1] : "";

          const bar = document.createElement("div");
          bar.className = "code-bar";
          bar.setAttribute("aria-hidden", "false");

          if (lang) {
            const tag = document.createElement("span");
            tag.className = "code-bar-lang";
            tag.textContent = lang;
            bar.appendChild(tag);
          }
          // Spacer so copy is anchored to the right even when no lang tag.
          const spacer = document.createElement("span");
          spacer.className = "code-bar-spacer";
          bar.appendChild(spacer);

          const copy = document.createElement("button");
          copy.type = "button";
          copy.className = "code-bar-copy";
          copy.setAttribute("aria-label", "Copy code");
          copy.textContent = "copy";
          copy.addEventListener("click", () => {
            navigator.clipboard?.writeText(text).then(
              () => {
                copy.textContent = "copied";
                copy.classList.add("is-copied");
                setTimeout(() => {
                  copy.textContent = "copy";
                  copy.classList.remove("is-copied");
                }, 1200);
              },
              () => {
                copy.textContent = "failed";
                setTimeout(() => (copy.textContent = "copy"), 1200);
              },
            );
          });
          bar.appendChild(copy);

          // Wrap pre in a relative container so the bar can be positioned
          // and the pre can keep its overflow scrolling.
          const wrap = document.createElement("div");
          wrap.className = "code-block";
          if (pre.getAttribute("data-ascii")) wrap.setAttribute("data-ascii", "true");
          pre.parentNode?.insertBefore(wrap, pre);
          wrap.appendChild(bar);
          wrap.appendChild(pre);
        });

        // 16 — Smart quotes. Walk text nodes (already filtered above
        // for code/pre/a/heading skips) and replace ASCII quotes with
        // proper typographic glyphs. Apostrophes are matched on word
        // boundaries to avoid mangling `'foo'` quoted strings inside
        // narrative prose. Use closest() so nested Shiki spans inside
        // <pre> still count as "inside code".
        const QUOTE_SKIP_SEL = "code, pre, a, mark, h1, h2, h3, h4, kbd";
        const qWalker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
        const qReplacements: Array<{ node: Text; text: string }> = [];
        let qNode: Node | null;
        while ((qNode = qWalker.nextNode())) {
          const t = qNode as Text;
          if (!t.parentElement || t.parentElement.closest(QUOTE_SKIP_SEL)) continue;
          const v = t.nodeValue || "";
          if (!/["']/.test(v)) continue;
          const next = v
            // Apostrophes inside words: don't / it's / we're.
            .replace(/(\w)'(\w)/g, "$1’$2")
            // Trailing apostrophes: ops' / sessions'.
            .replace(/(\w)'(?=\s|[.,;:!?])/g, "$1’")
            // Opening single quote at word start.
            .replace(/(^|[\s(\[{])'(\w)/g, "$1‘$2")
            // Closing single quote at word end.
            .replace(/(\w)'(?=$|[\s).,;:!?])/g, "$1’")
            // Double quotes — open after whitespace / start, close otherwise.
            .replace(/(^|[\s(\[{])"(\w)/g, "$1“$2")
            .replace(/(\w)"(?=$|[\s).,;:!?])/g, "$1”")
            // Symmetric pairs not caught by the heuristics above.
            .replace(/"([^"]+?)"/g, "“$1”");
          if (next !== v) qReplacements.push({ node: t, text: next });
        }
        for (const { node, text } of qReplacements) node.nodeValue = text;

        // 17 — Compact tables. Tables with ≤4 body rows render with
        // tighter padding and no zebra; longer tables keep the existing
        // generous spacing.
        root.querySelectorAll<HTMLTableElement>("table").forEach((tbl) => {
          const bodyRows = tbl.querySelectorAll("tbody > tr").length
                        || tbl.querySelectorAll("tr").length - 1; // header-less tables
          if (bodyRows > 0 && bodyRows <= 4) {
            tbl.setAttribute("data-density", "compact");
          } else {
            tbl.setAttribute("data-density", "comfortable");
          }
        });

        // 19 — Section TL;DR. Auto-detect the explicit prefix
        // "TL;DR:" / "Summary:" / "tl;dr:" on the first paragraph
        // immediately after an <h2>. Strip the marker, wrap the
        // paragraph in <aside class="section-tldr"> with a small
        // pill label.
        const TLDR_PAT = /^(TL;?DR|Summary)\s*:\s*/i;
        root.querySelectorAll<HTMLElement>("h2").forEach((h) => {
          const p = h.nextElementSibling as HTMLElement | null;
          if (!p || p.tagName !== "P") return;
          const txt = (p.textContent || "").trim();
          const m = txt.match(TLDR_PAT);
          if (!m) return;
          // Replace the leading marker with an inline label span and
          // class the <p>; CSS does the rest.
          p.classList.add("section-tldr");
          p.innerHTML = p.innerHTML.replace(
            TLDR_PAT,
            `<span class="tldr-label">tl;dr</span> `,
          );
        });

        // 11 — Build the table of contents. After all headings have IDs
        // (set above), walk h2 / h3 and emit a nested <ol>. Render into
        // both the desktop rail and the mobile <details>; both share the
        // same active-section IntersectionObserver.
        buildTOC(root);
      }

      function buildTOC(root: HTMLElement) {
        const headings = Array.from(root.querySelectorAll<HTMLElement>("h2, h3"));
        if (headings.length === 0) return;
        const desktop = document.getElementById("toc-list-desktop") as HTMLOListElement | null;
        const mobile  = document.getElementById("toc-list-mobile")  as HTMLOListElement | null;
        if (!desktop && !mobile) return;

        // Click-to-flash. When the user clicks a TOC entry, the matching
        // heading gets a `.is-flash` class — CSS handles the bump + 10s
        // ember→cream fade. We let the browser's native href#id
        // navigation handle the scroll; the flash sits on top of that.
        // A single timer is shared across all TOC links so a rapid
        // second click cancels the prior flash cleanly.
        let flashTimer: number | undefined;
        function flash(h: HTMLElement) {
          if (flashTimer !== undefined) {
            window.clearTimeout(flashTimer);
            root.querySelectorAll<HTMLElement>("h2.is-flash, h3.is-flash")
              .forEach((el) => el.classList.remove("is-flash"));
          }
          // Force a reflow so re-adding the class restarts the animations
          // even when the user re-clicks the same entry.
          void h.offsetWidth;
          h.classList.add("is-flash");
          flashTimer = window.setTimeout(() => {
            h.classList.remove("is-flash");
            flashTimer = undefined;
          }, 10100);
        }

        // Render a flat list with .toc-h3 visually indenting the level-3
        // entries. Two clones so each TOC has its own DOM (active
        // highlighting needs distinct nodes).
        function render(into: HTMLOListElement) {
          // Astro's scoped CSS adds data-astro-cid-XXX to every template
          // element; selectors like `.toc-list li` compile to require the
          // attribute on BOTH sides. Elements built here in JS would
          // otherwise miss the attribute and inherit none of the rail's
          // styling (min-height for target-size, padding, color). Copy
          // the attribute from the <ol> parent so the rules match.
          const scopeAttr = Array.from(into.attributes)
            .map((a) => a.name)
            .find((n) => n.startsWith("data-astro-cid-"));
          const applyScope = (el: HTMLElement) => {
            if (scopeAttr) el.setAttribute(scopeAttr, "");
          };
          headings.forEach((h) => {
            const li = document.createElement("li");
            applyScope(li);
            li.className = h.tagName === "H3" ? "toc-h3" : "toc-h2";
            const a = document.createElement("a");
            applyScope(a);
            a.href = `#${h.id}`;
            // Keep the leading number on h2 entries so numbered sections
            // appear as headers in the ToC; strip only for h3 sub-items.
            a.textContent = (h.textContent || "")
              .replace(/#$/, "")
              .replace(/\s+$/, "")
              .replace(/^\s+/, "");
            if (h.tagName === "H3") {
              a.textContent = a.textContent.replace(/^\d{2}\s+/, "");
            }
            a.dataset.tocId = h.id;
            // Don't preventDefault — let the native anchor navigation
            // run the scroll. requestAnimationFrame queues the flash for
            // the next frame so the bump lands during/after the scroll
            // start, not before.
            a.addEventListener("click", () => {
              requestAnimationFrame(() => flash(h));
            });
            li.appendChild(a);
            into.appendChild(li);
          });
        }
        if (desktop) render(desktop);
        if (mobile)  render(mobile);

        // Active-section highlighting. Observe each heading's vertical
        // position; the topmost heading inside the viewport wins.
        const active = new Set<string>();
        const io = new IntersectionObserver((entries) => {
          for (const e of entries) {
            const id = (e.target as HTMLElement).id;
            if (e.isIntersecting) active.add(id);
            else active.delete(id);
          }
          // Pick the first heading (in document order) that's currently
          // intersecting; if none, fall back to the last one we passed.
          const topId = headings.map((h) => h.id).find((id) => active.has(id));
          const allLinks = document.querySelectorAll<HTMLAnchorElement>(".toc-list a[data-toc-id]");
          allLinks.forEach((a) => a.classList.toggle("is-active", a.dataset.tocId === topId));
        }, { rootMargin: "-30% 0px -55% 0px", threshold: 0 });
        headings.forEach((h) => io.observe(h));
      }

      // Progress rail (5). Fills from 0% → 100% as the user scrolls
      // through the SKILL.md section. Uses requestAnimationFrame to keep
      // the scroll handler cheap on long pages.
      const rail = document.getElementById("progress-rail");
      const fill = document.getElementById("progress-rail-fill");
      if (rail && fill && prose) {
        let pending = false;
        function update() {
          pending = false;
          if (!prose || !fill) return;
          const top = prose.getBoundingClientRect().top + window.scrollY;
          const height = prose.offsetHeight;
          const viewportBottom = window.scrollY + window.innerHeight;
          const progress = Math.max(0, Math.min(1, (viewportBottom - top) / height));
          fill.style.height = `${progress * 100}%`;
        }
        function onScroll() {
          if (pending) return;
          pending = true;
          requestAnimationFrame(update);
        }
        update();
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
      }

      function escapeHtml(s: string): string {
        return s
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }
    </script>

    <!-- 18 — Prev / next skill nav. Sticky bottom strip with the
         catalog-adjacent skills (ordered by role group → name). -->
    <nav class="skill-nav" aria-label="Adjacent skills">
      {prevSkill ? (
        <a href={`/skills/${prevSkill.data.name}`} class="skill-nav-link skill-nav-prev" data-role={getSkillRole(prevSkill.data.name)}>
          <span class="skill-nav-eyebrow">← previous</span>
          <span class="skill-nav-name">{prevSkill.data.displayName}</span>
        </a>
      ) : <span class="skill-nav-empty"></span>}
      {nextSkill ? (
        <a href={`/skills/${nextSkill.data.name}`} class="skill-nav-link skill-nav-next" data-role={getSkillRole(nextSkill.data.name)}>
          <span class="skill-nav-eyebrow">next →</span>
          <span class="skill-nav-name">{nextSkill.data.displayName}</span>
        </a>
      ) : <span class="skill-nav-empty"></span>}
    </nav>

    <!-- ───────────── Footer CTA ───────────── -->
    <section class="cta">
      <h2>Use {skill.data.displayName} in your project</h2>
      <p>
        Drop the SKILL.md into <code class="ic">.claude/skills/</code> or
        <code class="ic">.codex/skills/</code>, download the bundle, or reach
        it over the hosted MCP endpoint.
      </p>
      <div class="cta-row">
        <Button variant="primary" href="/install">
          <Icon name="download" />
          install opchain
        </Button>
        <Button variant="outline" href="/architecture">
          <Icon name="layers" />
          how it chains
        </Button>
      </div>
    </section>
  </main>

  <CaptureModal />
</Base>

