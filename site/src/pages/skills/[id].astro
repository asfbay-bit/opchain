---
import { render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Card from "../../components/ui/Card.astro";
import Icon from "../../components/Icon.astro";
import { getAllSkills, getSkill, getSkillRole, type Role } from "../../lib/skills";

export async function getStaticPaths() {
  const skills = await getAllSkills();
  return skills.map((s) => ({ params: { id: s.data.name } }));
}

const { id } = Astro.params;
const skill = await getSkill(id!);
if (!skill) {
  return Astro.redirect("/skills");
}

const { Content } = await render(skill);

const phaseLabel = skill.data.phases.join(" + ");
const description = `${skill.data.displayName} — ${skill.data.shortDesc}`;

// Skill→role lookup shipped to the client as a small JSON island so a
// post-render script can paint inline `<code>` mentions of known skills
// with their role colour. Same map every other surface uses.
const allSkills = await getAllSkills();
const skillRolesJson = JSON.stringify(
  Object.fromEntries(
    allSkills.map((s) => [s.data.name, getSkillRole(s.data.name) as Role]),
  ),
);
---

<Base
  title={`${skill.data.displayName} · opchain skill`}
  description={description}
  active="/skills"
>
  <main class="page">
    <a href="/skills" class="back">
      <Icon name="arrow-left" size={12} /> all skills
    </a>

    <header class="head">
      <Eyebrow>{phaseLabel}</Eyebrow>
      <h1>{skill.data.displayName}</h1>
      <p class="lede">{skill.data.shortDesc}</p>
      <div class="tags">
        {skill.data.phases.map((p: string) => <Badge variant="accent">{p}</Badge>)}
        {skill.data.triAgent && <Badge variant="accent">Tri-agent</Badge>}
        {skill.data.tryable && <Badge variant="success">Tryable</Badge>}
        <Badge variant="neutral">v{skill.data.version}</Badge>
      </div>
    </header>

    <!-- ───────────── Quick facts + actions ───────────── -->
    <section class="quick">
      {skill.data.commands.length > 0 && (
        <Card variant="surface" glow={false}>
          <div class="quick-head">Commands</div>
          <div class="cmds">
            {skill.data.commands.map((c: string) => <code class="cmd">{c}</code>)}
          </div>
        </Card>
      )}

      <Card variant="surface" glow={false}>
        <div class="quick-head">Pipeline phase</div>
        <p class="quick-body">
          <strong>{phaseLabel}</strong>
          {skill.data.triAgent && <span> · runs as a tri-agent loop (Planner / Generator / Evaluator)</span>}
        </p>
      </Card>

      <Card variant="surface" glow={false}>
        <div class="quick-head">Try it</div>
        {skill.data.tryable ? (
          <>
            <p class="quick-body">5 free exchanges with this skill — no install needed.</p>
            <div class="try-actions">
              <Button variant="primary" size="sm" href={`/demo?skill=${skill.data.name}#live`}>
                <Icon name="sparkles" size={12} />
                try {skill.data.displayName}
              </Button>
              <Button variant="outline" size="sm" href={`/skills/${skill.data.name}.zip`}>
                <Icon name="download" size={12} />
                download skill
              </Button>
            </div>
          </>
        ) : (
          <>
            <p class="quick-body">
              This skill is a foundational protocol — not invoked directly. Every
              other opchain skill implements its checkpoint contract.
            </p>
            <div class="try-actions">
              <Button variant="outline" size="sm" href={`/skills/${skill.data.name}.zip`}>
                <Icon name="download" size={12} />
                download skill
              </Button>
            </div>
          </>
        )}
      </Card>
    </section>

    <!-- ───────────── How you'll use it (human-facing) ───────────── -->
    <section id="usage" class="usage">
      <h2>How you'll use it</h2>
      <p class="usage-desc">{skill.data.description}</p>
      {skill.data.commands.length > 0 && (
        <>
          <p class="usage-label">Trigger with natural language or a slash command:</p>
          <div class="usage-cmds">
            {skill.data.commands.slice(0, 6).map((c: string) => (
              <code class="cmd">{c}</code>
            ))}
            {skill.data.commands.length > 6 && (
              <span class="cmd-more">+{skill.data.commands.length - 6} more</span>
            )}
          </div>
        </>
      )}
    </section>

    <!-- ───────────── Full SKILL.md (model-facing) ───────────── -->
    <section class="prose-wrap">
      <div class="prose-head">
        <span class="prose-eyebrow">SKILL.md</span>
        <span class="prose-note">
          Below is the file Claude reads on invocation. It's written in
          the model's voice — "read this", "do that" — not a user guide.
          The <a href="#usage">How you'll use it</a> section above is
          the one for you.
        </span>
      </div>
      <section class="prose" id="skill-md">
        <Content />
      </section>
    </section>

    <script is:inline id="skill-roles-data" type="application/json" set:html={skillRolesJson}></script>
    <script>
      // Post-render UX pass on the SKILL.md prose:
      //   · inline <code> matching a skill name → role-coloured pill
      //   · inline <code> starting with `/`     → ember command pill
      // Runs once on load; the prose is static, so no re-runs needed.
      const rolesEl = document.getElementById("skill-roles-data");
      const skillRoles: Record<string, string> = rolesEl
        ? JSON.parse(rolesEl.textContent || "{}")
        : {};

      const prose = document.getElementById("skill-md");
      if (prose) {
        prose.querySelectorAll<HTMLElement>("code").forEach((el) => {
          // Skip code inside <pre> — those are full code blocks, not inline mentions.
          if (el.closest("pre")) return;
          const text = (el.textContent || "").trim();

          // 1. Slash commands: /audit, /deploy, /git, /uxe ...
          if (/^\/[a-z][\w-]*(\s|$)/i.test(text)) {
            el.setAttribute("data-cmd", "true");
            return;
          }

          // 2. Skill mentions — exact match against the catalog.
          if (skillRoles[text]) {
            el.setAttribute("data-role", skillRoles[text]);
            return;
          }
        });
      }
    </script>

    <!-- ───────────── Footer CTA ───────────── -->
    <section class="cta">
      <h2>Use {skill.data.displayName} in your project</h2>
      <p>
        Drop the SKILL.md into <code class="ic">.claude/skills/</code> or
        download the bundle.
      </p>
      <div class="cta-row">
        <Button variant="primary" href="/install">
          <Icon name="download" />
          install opchain
        </Button>
        <Button variant="outline" href="/architecture">
          <Icon name="layers" />
          how it chains
        </Button>
      </div>
    </section>
  </main>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    color: var(--muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .back:hover { color: var(--accent); }

  .head {
    margin: 1.25rem 0 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 0.5px solid var(--border);
  }
  .head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0.75rem;
  }
  .lede {
    color: var(--muted);
    font-size: var(--fs-md);
    margin: 0 0 1rem;
  }
  .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .quick {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }
  .quick-head {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .quick-body {
    font-size: var(--fs-sm);
    color: var(--muted);
    margin: 0 0 0.65rem;
  }
  .cmds { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .cmd {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text);
    background: var(--card);
    border: 0.5px solid var(--border);
    padding: 1px 6px;
    border-radius: var(--r-xs);
  }
  /* Stack the Try-It primary + outline download buttons. */
  .try-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .usage {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--border);
  }
  .usage h2 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.75rem;
    letter-spacing: var(--ls-tight);
  }
  .usage-desc {
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin: 0 0 1.1rem;
  }
  .usage-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: var(--subtle);
    margin: 0 0 0.5rem;
  }
  .usage-cmds {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }
  .cmd-more {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
  }

  .prose-wrap { margin-top: 1rem; }
  .prose-head {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-bottom: 0;
    border-top-left-radius: var(--r-md);
    border-top-right-radius: var(--r-md);
    margin-bottom: 0;
  }
  .prose-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    flex: 0 0 auto;
    padding-top: 0.1rem;
  }
  .prose-note {
    font-size: var(--fs-xs);
    line-height: 1.5;
    color: var(--subtle);
  }
  .prose-note a { color: var(--accent); }
  .prose {
    padding: 1rem 1.25rem 0.5rem;
    border: 0.5px solid var(--border);
    border-top: 0;
    border-bottom-left-radius: var(--r-md);
    border-bottom-right-radius: var(--r-md);
    background: var(--bg);
    font-size: var(--fs-base);
    color: var(--muted);
    line-height: var(--lh-base);
  }
  .prose :global(h1) { display: none; } /* SKILL.md repeats the title */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 2rem 0 0.6rem;
    letter-spacing: var(--ls-tight);
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--text);
    margin: 1.5rem 0 0.5rem;
  }
  .prose :global(p) { margin: 0 0 0.85rem; max-width: 42rem; color: var(--muted); }
  .prose :global(ul), .prose :global(ol) {
    margin: 0.5rem 0 1rem;
    padding-left: 1.25rem;
  }
  .prose :global(li) { margin-bottom: 0.3rem; color: var(--muted); }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }
  /* UX pass — inline code is post-classified by client script:
       · [data-cmd]   → ember pill for slash commands (/audit, /deploy, …)
       · [data-role=…] → role-coloured pill for skill-name mentions
     Same outline + 15% colour-mix language used everywhere else on the
     site. Works in both themes via the design tokens. */
  .prose :global(code[data-cmd]) {
    color: var(--ember);
    border-color: color-mix(in srgb, var(--ember) 50%, transparent);
    background: color-mix(in srgb, var(--ember) 12%, transparent);
    font-weight: 500;
  }
  .prose :global(code[data-role]) {
    --pill-color: var(--specialist);
    color: var(--pill-color);
    border-color: color-mix(in srgb, var(--pill-color) 50%, transparent);
    background: color-mix(in srgb, var(--pill-color) 12%, transparent);
  }
  .prose :global(code[data-role="workflow"])     { --pill-color: var(--workflow); }
  .prose :global(code[data-role="tri-agent"])    { --pill-color: var(--tri-agent); }
  .prose :global(code[data-role="audit-gate"])   { --pill-color: var(--audit-gate); }
  .prose :global(code[data-role="specialist"])   { --pill-color: var(--specialist); }
  .prose :global(code[data-role="advisor"])      { --pill-color: var(--advisor); }
  .prose :global(code[data-role="orchestrator"]) { --pill-color: var(--orchestrator); }
  .prose :global(code[data-role="success"])      { --pill-color: var(--success); }
  /* Code blocks pick up theme-aware tokens so light mode gets a parchment
     surface with dark text instead of the brand obsidian + linen pair —
     punchlist 3.4. The dark default is unchanged. */
  .prose :global(pre) {
    background: var(--card);
    color: var(--text);
    border: 0.5px solid var(--border);
    padding: 0.85rem 1.1rem;
    border-radius: var(--r-md);
    overflow-x: auto;
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: var(--lh-base);
    margin: 0.75rem 0;
  }
  :root[data-theme="light"] .prose :global(pre) {
    /* Lighter parchment surface, darker border so the block reads as a
       distinct code panel rather than a subtle inset. */
    background: var(--parchment);
    border-color: var(--sand);
  }
  .prose :global(pre code) {
    background: transparent;
    border: 0;
    padding: 0;
    color: inherit;
  }
  .prose :global(table) {
    width: 100%;
    border-collapse: collapse;
    font-size: var(--fs-sm);
    margin: 1rem 0;
  }
  .prose :global(th), .prose :global(td) {
    border: 0.5px solid var(--border);
    padding: 0.45rem 0.65rem;
    text-align: left;
  }
  .prose :global(th) {
    background: var(--surface);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    font-weight: 500;
    letter-spacing: var(--ls-wide);
  }
  .prose :global(blockquote) {
    border-left: 2px solid var(--accent);
    padding: 0.25rem 0 0.25rem 1rem;
    margin: 1rem 0;
    color: var(--muted);
    font-style: italic;
  }
  .prose :global(hr) {
    border: 0;
    border-top: 0.5px solid var(--border);
    margin: 2rem 0;
  }
  .prose :global(a) { color: var(--accent); }

  .cta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 0.5px solid var(--border);
  }
  .cta h2 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .cta p { color: var(--muted); margin: 0 0 1.25rem; }
  .cta-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }

  .ic {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }
</style>
