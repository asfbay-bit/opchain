---
import { render } from "astro:content";
import Base from "../../layouts/Base.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Badge from "../../components/ui/Badge.astro";
import Button from "../../components/ui/Button.astro";
import Card from "../../components/ui/Card.astro";
import Icon from "../../components/Icon.astro";
import { getAllSkills, getSkill, getSkillRole, type Role } from "../../lib/skills";

export async function getStaticPaths() {
  const skills = await getAllSkills();
  return skills.map((s) => ({ params: { id: s.data.name } }));
}

const { id } = Astro.params;
const skill = await getSkill(id!);
if (!skill) {
  return Astro.redirect("/skills");
}

const { Content } = await render(skill);

const phaseLabel = skill.data.phases.join(" + ");
const description = `${skill.data.displayName} — ${skill.data.shortDesc}`;

// Skill→role lookup shipped to the client as a small JSON island so a
// post-render script can paint inline `<code>` mentions of known skills
// with their role colour. Same map every other surface uses.
const allSkills = await getAllSkills();
const skillRolesJson = JSON.stringify(
  Object.fromEntries(
    allSkills.map((s) => [s.data.name, getSkillRole(s.data.name) as Role]),
  ),
);

// Reading-time estimate, computed at build time from the SKILL.md body.
// 220 wpm is the conservative end of adult silent-reading speed for
// technical prose (range 200–250). Ceil so a 30-second skill still
// reads "1 min" instead of "0 min".
const wordCount = (skill.body || "").trim().split(/\s+/).filter(Boolean).length;
const readingMinutes = Math.max(1, Math.ceil(wordCount / 220));
---

<Base
  title={`${skill.data.displayName} · opchain skill`}
  description={description}
  active="/skills"
>
  <main class="page">
    <a href="/skills" class="back">
      <Icon name="arrow-left" size={12} /> all skills
    </a>

    <header class="head">
      <Eyebrow>{phaseLabel}</Eyebrow>
      <h1>{skill.data.displayName}</h1>
      <p class="lede">{skill.data.shortDesc}</p>
      <div class="tags">
        {skill.data.phases.map((p: string) => <Badge variant="accent">{p}</Badge>)}
        {skill.data.triAgent && <Badge variant="accent">Tri-agent</Badge>}
        {skill.data.tryable && <Badge variant="success">Tryable</Badge>}
        <Badge variant="neutral">v{skill.data.version}</Badge>
      </div>
    </header>

    <!-- ───────────── Quick facts + actions ───────────── -->
    <section class="quick">
      {skill.data.commands.length > 0 && (
        <Card variant="surface" glow={false}>
          <div class="quick-head">Commands</div>
          <div class="cmds">
            {skill.data.commands.map((c: string) => <code class="cmd">{c}</code>)}
          </div>
        </Card>
      )}

      <Card variant="surface" glow={false}>
        <div class="quick-head">Pipeline phase</div>
        <p class="quick-body">
          <strong>{phaseLabel}</strong>
          {skill.data.triAgent && <span> · runs as a tri-agent loop (Planner / Generator / Evaluator)</span>}
        </p>
      </Card>

      <Card variant="surface" glow={false}>
        <div class="quick-head">Try it</div>
        {skill.data.tryable ? (
          <>
            <p class="quick-body">5 free exchanges with this skill — no install needed.</p>
            <div class="try-actions">
              <Button variant="primary" size="sm" href={`/demo?skill=${skill.data.name}#live`}>
                <Icon name="sparkles" size={12} />
                try {skill.data.displayName}
              </Button>
              <Button variant="outline" size="sm" href={`/skills/${skill.data.name}.zip`}>
                <Icon name="download" size={12} />
                download skill
              </Button>
            </div>
          </>
        ) : (
          <>
            <p class="quick-body">
              This skill is a foundational protocol — not invoked directly. Every
              other opchain skill implements its checkpoint contract.
            </p>
            <div class="try-actions">
              <Button variant="outline" size="sm" href={`/skills/${skill.data.name}.zip`}>
                <Icon name="download" size={12} />
                download skill
              </Button>
            </div>
          </>
        )}
      </Card>
    </section>

    <!-- ───────────── How you'll use it (human-facing) ───────────── -->
    <section id="usage" class="usage">
      <h2>How you'll use it</h2>
      <p class="usage-desc">{skill.data.description}</p>
      {skill.data.commands.length > 0 && (
        <>
          <p class="usage-label">Trigger with natural language or a slash command:</p>
          <div class="usage-cmds">
            {skill.data.commands.slice(0, 6).map((c: string) => (
              <code class="cmd">{c}</code>
            ))}
            {skill.data.commands.length > 6 && (
              <span class="cmd-more">+{skill.data.commands.length - 6} more</span>
            )}
          </div>
        </>
      )}
    </section>

    <!-- ───────────── Full SKILL.md (model-facing) ───────────── -->
    <section class="prose-wrap">
      <div class="prose-head">
        <div class="prose-head-row">
          <span class="prose-eyebrow">SKILL.md</span>
          <span class="prose-readtime" title={`${wordCount.toLocaleString()} words`}>
            ≈ {readingMinutes} min read
          </span>
        </div>
        <span class="prose-note">
          Below is the file Claude reads on invocation. It's written in
          the model's voice — "read this", "do that" — not a user guide.
          The <a href="#usage">How you'll use it</a> section above is
          the one for you.
        </span>
      </div>
      <section class="prose" id="skill-md">
        <Content />
      </section>
    </section>

    <!-- 5. Progress rail — fixed to the right edge of the viewport,
         tracks scroll position through the SKILL.md body. -->
    <div class="progress-rail" id="progress-rail" aria-hidden="true">
      <div class="progress-rail-fill" id="progress-rail-fill"></div>
    </div>

    <script is:inline id="skill-roles-data" type="application/json" set:html={skillRolesJson}></script>
    <script>
      // Post-render UX pass on the SKILL.md prose. Runs once on load.
      // Tags inline elements with semantic data-* attributes so CSS owns
      // every visual decision; this script never sets inline styles.
      type Role = "workflow" | "tri-agent" | "audit-gate" | "specialist" | "advisor" | "orchestrator" | "success";

      const rolesEl = document.getElementById("skill-roles-data");
      const skillRoles: Record<string, Role> = rolesEl
        ? JSON.parse(rolesEl.textContent || "{}")
        : {};

      const PHASE_ROLE: Record<string, Role> = {
        discover:  "advisor",
        spec:      "advisor",
        design:    "tri-agent",
        build:     "workflow",
        audit:     "audit-gate",
        ship:      "orchestrator",
        monitor:   "specialist",
        migrate:   "specialist",
        scale:     "advisor",
      };

      const STATUS_TOKENS: Array<[RegExp, string]> = [
        [/^(critical|blocker|fail|failed|rejected|error)$/i, "danger"],
        [/^(warning|caution|warn)$/i,                        "warn"],
        [/^(verified|complete|completed|success|passed|ok|approved|ready)$/i, "ok"],
        [/^(in[_\s-]?progress|wip|pending|queued|blocked|paused)$/i,          "progress"],
      ];

      const prose = document.getElementById("skill-md");
      if (prose) wireProse(prose);

      function wireProse(root: HTMLElement) {
        // 1 + 8 — inline <code> classification.
        root.querySelectorAll<HTMLElement>("code").forEach((el) => {
          if (el.closest("pre")) return;
          const text = (el.textContent || "").trim();

          // a) Slash commands: /audit, /deploy, /uxe …
          if (/^\/[a-z][\w-]*(\s|$)/i.test(text)) {
            el.setAttribute("data-cmd", "true");
            return;
          }
          // b) Skill mentions — exact match against the catalog.
          if (skillRoles[text]) {
            el.setAttribute("data-role", skillRoles[text]);
            return;
          }
          // c) Phase keywords.
          if (PHASE_ROLE[text.toLowerCase()]) {
            el.setAttribute("data-phase", text.toLowerCase());
            el.setAttribute("data-role", PHASE_ROLE[text.toLowerCase()]);
            return;
          }
          // d) Status / severity verbs in inline code (e.g. `CRITICAL`).
          for (const [pat, status] of STATUS_TOKENS) {
            if (pat.test(text)) {
              el.setAttribute("data-status", status);
              return;
            }
          }
        });

        // 6 — Status / severity verbs in plain prose. Walk text nodes,
        // wrap matched tokens in <mark data-status="…"> so CSS can paint
        // them. Skip headings, code blocks, links, and table cells (we
        // don't want to double-emphasise things that already pop).
        const SKIP = new Set(["CODE", "PRE", "A", "MARK", "H1", "H2", "H3", "H4"]);
        const STATUS_PROSE = [
          { rx: /\b(CRITICAL|BLOCKER|FAIL(?:ED)?|REJECTED|ERROR)\b/g,           status: "danger"   },
          { rx: /\b(WARNING|CAUTION)\b/g,                                       status: "warn"     },
          { rx: /\b(VERIFIED|COMPLETE(?:D)?|SUCCESS|PASSED|APPROVED|READY)\b/g, status: "ok"       },
          { rx: /\b(IN[_\s-]?PROGRESS|WIP|PENDING|BLOCKED|PAUSED)\b/g,          status: "progress" },
        ];
        const walker = document.createTreeWalker(root, NodeFilter.SHOW_TEXT);
        const replacements: Array<{ node: Text; html: string }> = [];
        let node: Node | null;
        while ((node = walker.nextNode())) {
          const t = node as Text;
          if (!t.parentElement || SKIP.has(t.parentElement.tagName)) continue;
          const original = t.nodeValue || "";
          if (!/[A-Z]/.test(original)) continue; // status tokens are uppercase
          let html = escapeHtml(original);
          let dirty = false;
          for (const { rx, status } of STATUS_PROSE) {
            if (rx.test(html)) {
              html = html.replace(new RegExp(rx.source, rx.flags), (m) => {
                dirty = true;
                return `<mark data-status="${status}">${m}</mark>`;
              });
            }
          }
          if (dirty) replacements.push({ node: t, html });
        }
        for (const { node, html } of replacements) {
          const span = document.createElement("span");
          span.innerHTML = html;
          node.replaceWith(...Array.from(span.childNodes));
        }

        // 7 — Typed callout blockquotes. Detect the leading "Note:" /
        // "Warning:" / "Critical:" / "Tip:" / "Principle:" marker on
        // the first paragraph and stamp the blockquote with data-callout.
        const CALLOUT_PAT = /^(Note|Tip|Hint|Warning|Caution|Critical|Danger|Important|Principle|Rule|Constraint)\s*:\s*/i;
        const CALLOUT_KIND: Record<string, string> = {
          note:        "info",   tip:       "info",  hint:        "info",
          warning:     "warn",   caution:   "warn",
          critical:    "danger", danger:    "danger", important:  "danger",
          principle:   "ok",     rule:      "ok",     constraint: "ok",
        };
        root.querySelectorAll<HTMLElement>("blockquote").forEach((bq) => {
          const first = bq.querySelector("p, li");
          if (!first) return;
          const text = (first.textContent || "").trim();
          const m = text.match(CALLOUT_PAT);
          if (!m) return;
          const word = m[1].toLowerCase();
          const kind = CALLOUT_KIND[word] || "info";
          bq.setAttribute("data-callout", kind);
          // Replace the leading marker with a styled label span so the
          // colon doesn't render as plain prose.
          first.innerHTML = first.innerHTML.replace(
            CALLOUT_PAT,
            `<span class="callout-label" data-kind="${kind}">${m[1]}</span> `,
          );
        });

        // 9 — Cross-skill links: <a href="/skills/<id>">…</a> picks up
        // the destination skill's role colour.
        root.querySelectorAll<HTMLAnchorElement>("a[href^='/skills/']").forEach((a) => {
          const m = a.getAttribute("href")?.match(/^\/skills\/([^/?#]+)/);
          if (!m) return;
          const role = skillRoles[m[1]];
          if (role) a.setAttribute("data-role", role);
        });

        // 10 — Failure-mode / blocker line prefixes. Scan paragraphs
        // and list items for a leading "BLOCKER:" / "FAIL:" / "WARNING:"
        // and wrap the prefix in <strong data-status="…"> so only the
        // prefix gets the role colour, not the whole sentence.
        const PREFIX_PAT = /^(BLOCKER|FAIL(?:ED)?|WARNING|CRITICAL|REJECTED)\s*:/;
        const PREFIX_STATUS: Record<string, string> = {
          BLOCKER:   "danger",
          FAIL:      "danger",
          FAILED:    "danger",
          CRITICAL:  "danger",
          REJECTED:  "danger",
          WARNING:   "warn",
        };
        root.querySelectorAll<HTMLElement>("p, li").forEach((el) => {
          // Skip elements inside callouts (already labelled) and tables.
          if (el.closest("blockquote[data-callout], table")) return;
          const first = el.firstChild;
          if (!first || first.nodeType !== Node.TEXT_NODE) return;
          const txt = (first.nodeValue || "").trimStart();
          const m = txt.match(PREFIX_PAT);
          if (!m) return;
          const status = PREFIX_STATUS[m[1]] || "danger";
          const after = txt.slice(m[0].length);
          const label = document.createElement("strong");
          label.dataset.status = status;
          label.className = "prefix-label";
          label.textContent = m[0];
          first.nodeValue = "";
          el.insertBefore(label, first);
          if (after) el.insertBefore(document.createTextNode(after), label.nextSibling);
        });

        // 4 — Anchor link affordance on h2 / h3. We render an "#" glyph
        // that's invisible by default and reveals on heading hover; click
        // copies the absolute URL to the clipboard.
        let anchorIdx = 0;
        root.querySelectorAll<HTMLElement>("h2, h3").forEach((h) => {
          if (!h.id) {
            const slug = (h.textContent || "")
              .toLowerCase()
              .replace(/[^a-z0-9]+/g, "-")
              .replace(/^-+|-+$/g, "")
              || `section-${++anchorIdx}`;
            h.id = slug;
          }
          const a = document.createElement("a");
          a.className = "heading-anchor";
          a.href = `#${h.id}`;
          a.setAttribute("aria-label", `Link to ${h.textContent}`);
          a.textContent = "#";
          a.addEventListener("click", (ev) => {
            ev.preventDefault();
            const url = `${location.origin}${location.pathname}#${h.id}`;
            history.replaceState(null, "", `#${h.id}`);
            navigator.clipboard?.writeText(url).catch(() => {});
            a.classList.add("is-copied");
            setTimeout(() => a.classList.remove("is-copied"), 1200);
          });
          h.appendChild(a);
        });
      }

      // Progress rail (5). Fills from 0% → 100% as the user scrolls
      // through the SKILL.md section. Uses requestAnimationFrame to keep
      // the scroll handler cheap on long pages.
      const rail = document.getElementById("progress-rail");
      const fill = document.getElementById("progress-rail-fill");
      if (rail && fill && prose) {
        let pending = false;
        function update() {
          pending = false;
          if (!prose || !fill) return;
          const top = prose.getBoundingClientRect().top + window.scrollY;
          const height = prose.offsetHeight;
          const viewportBottom = window.scrollY + window.innerHeight;
          const progress = Math.max(0, Math.min(1, (viewportBottom - top) / height));
          fill.style.height = `${progress * 100}%`;
        }
        function onScroll() {
          if (pending) return;
          pending = true;
          requestAnimationFrame(update);
        }
        update();
        window.addEventListener("scroll", onScroll, { passive: true });
        window.addEventListener("resize", onScroll);
      }

      function escapeHtml(s: string): string {
        return s
          .replace(/&/g, "&amp;")
          .replace(/</g, "&lt;")
          .replace(/>/g, "&gt;")
          .replace(/"/g, "&quot;")
          .replace(/'/g, "&#39;");
      }
    </script>

    <!-- ───────────── Footer CTA ───────────── -->
    <section class="cta">
      <h2>Use {skill.data.displayName} in your project</h2>
      <p>
        Drop the SKILL.md into <code class="ic">.claude/skills/</code> or
        download the bundle.
      </p>
      <div class="cta-row">
        <Button variant="primary" href="/install">
          <Icon name="download" />
          install opchain
        </Button>
        <Button variant="outline" href="/architecture">
          <Icon name="layers" />
          how it chains
        </Button>
      </div>
    </section>
  </main>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 2rem 1.5rem 6rem;
  }

  .back {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    color: var(--muted);
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    gap: 0.35rem;
  }
  .back:hover { color: var(--accent); }

  .head {
    margin: 1.25rem 0 2rem;
    padding-bottom: 1.5rem;
    border-bottom: 0.5px solid var(--border);
  }
  .head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0.75rem;
  }
  .lede {
    color: var(--muted);
    font-size: var(--fs-md);
    margin: 0 0 1rem;
  }
  .tags { display: flex; gap: 0.35rem; flex-wrap: wrap; }

  .quick {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.6rem;
    margin-bottom: 2.5rem;
  }
  .quick-head {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    font-weight: 500;
    margin-bottom: 0.5rem;
  }
  .quick-body {
    font-size: var(--fs-sm);
    color: var(--muted);
    margin: 0 0 0.65rem;
  }
  .cmds { display: flex; flex-wrap: wrap; gap: 0.3rem; }
  .cmd {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text);
    background: var(--card);
    border: 0.5px solid var(--border);
    padding: 1px 6px;
    border-radius: var(--r-xs);
  }
  /* Stack the Try-It primary + outline download buttons. */
  .try-actions {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
    margin-top: 0.25rem;
  }

  .usage {
    margin-bottom: 2.5rem;
    padding-bottom: 2rem;
    border-bottom: 0.5px solid var(--border);
  }
  .usage h2 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.75rem;
    letter-spacing: var(--ls-tight);
  }
  .usage-desc {
    font-size: var(--fs-base);
    line-height: var(--lh-base);
    color: var(--muted);
    margin: 0 0 1.1rem;
  }
  .usage-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: var(--subtle);
    margin: 0 0 0.5rem;
  }
  .usage-cmds {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem;
    align-items: center;
  }
  .cmd-more {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
  }

  .prose-wrap { margin-top: 1rem; }
  .prose-head {
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
    padding: 0.75rem 1rem;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-bottom: 0;
    border-top-left-radius: var(--r-md);
    border-top-right-radius: var(--r-md);
    margin-bottom: 0;
  }
  .prose-head-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .prose-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    flex: 0 0 auto;
  }
  /* 3 — Reading time, computed at build time. Help-text via title attr. */
  .prose-readtime {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    color: var(--subtle);
    cursor: help;
  }
  .prose-note {
    font-size: var(--fs-xs);
    line-height: 1.5;
    color: var(--subtle);
  }
  .prose-note a { color: var(--accent); }

  /* 1 — Body measure tuning. Bumped to 16px / 1.7 line-height with a
     tighter character measure (~70ch) so long technical paragraphs
     don't outrun the eye. */
  .prose {
    padding: 1.5rem 1.6rem 1rem;
    border: 0.5px solid var(--border);
    border-top: 0;
    border-bottom-left-radius: var(--r-md);
    border-bottom-right-radius: var(--r-md);
    background: var(--bg);
    font-size: var(--fs-md);
    color: var(--muted);
    line-height: 1.7;
  }
  .prose :global(h1) { display: none; } /* SKILL.md repeats the title */
  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 2.25rem 0 0.6rem;
    letter-spacing: var(--ls-tight);
    position: relative;
    scroll-margin-top: 1rem;
  }
  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--text);
    margin: 1.6rem 0 0.5rem;
    position: relative;
    scroll-margin-top: 1rem;
  }
  .prose :global(p) {
    margin: 0 0 0.95rem;
    max-width: 70ch;
    color: var(--muted);
  }
  /* 2 — Drop intro. The first paragraph after every h2 reads slightly
     larger and brighter so each section has a visible lead-in. */
  .prose :global(h2 + p) {
    font-size: 1.05em;
    color: var(--text);
  }
  .prose :global(ul), .prose :global(ol) {
    margin: 0.5rem 0 1rem;
    padding-left: 1.4rem;
  }
  .prose :global(li) { margin-bottom: 0.4rem; color: var(--muted); }

  /* 4 — Heading anchor links. Visible only on hover/focus of the
     containing heading; click copies the absolute URL. */
  .prose :global(.heading-anchor) {
    margin-left: 0.5rem;
    font-family: var(--font-mono);
    font-weight: 400;
    font-size: 0.75em;
    color: var(--subtle);
    text-decoration: none;
    opacity: 0;
    transition: opacity var(--dur-fast) var(--ease-standard),
                color var(--dur-fast) var(--ease-standard);
  }
  .prose :global(h2:hover .heading-anchor),
  .prose :global(h2:focus-within .heading-anchor),
  .prose :global(h3:hover .heading-anchor),
  .prose :global(h3:focus-within .heading-anchor),
  .prose :global(.heading-anchor:focus-visible) {
    opacity: 1;
    color: var(--accent);
  }
  .prose :global(.heading-anchor.is-copied) {
    color: var(--success);
    opacity: 1;
  }
  .prose :global(.heading-anchor.is-copied)::after {
    content: " copied";
    font-size: 0.85em;
  }
  .prose :global(code) {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
