    font-weight: 600;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--callout-color);
  }
  .prose :global(blockquote[data-callout]) :global(.callout-label) {
    color: var(--callout-color);
  }

  .prose :global(hr) {
    border: 0;
    border-top: 0.5px solid var(--border);
    margin: 2rem 0;
  }

  /* Plain links — accent-coloured by default. */
  .prose :global(a) { color: var(--accent); }
  /* 9 — Cross-skill links pick up the destination skill's role colour
     (set by the post-render script). Underline added so they read as
     links, not pill mentions. */
  .prose :global(a[data-role]) {
    --link-color: var(--specialist);
    color: var(--link-color);
    text-decoration: underline;
    text-decoration-color: color-mix(in srgb, var(--link-color) 50%, transparent);
    text-underline-offset: 0.18em;
  }
  .prose :global(a[data-role="workflow"])     { --link-color: var(--workflow); }
  .prose :global(a[data-role="tri-agent"])    { --link-color: var(--tri-agent); }
  .prose :global(a[data-role="audit-gate"])   { --link-color: var(--audit-gate); }
  .prose :global(a[data-role="specialist"])   { --link-color: var(--specialist); }
  .prose :global(a[data-role="advisor"])      { --link-color: var(--advisor); }
  .prose :global(a[data-role="orchestrator"]) { --link-color: var(--orchestrator); }
  .prose :global(a[data-role="success"])      { --link-color: var(--success); }

  /* 6 — Status / severity verbs in plain prose. <mark data-status="…">
     wraps tokens detected by the client script. Background-less so they
     don't flag-bait the page; colour + small letter-spacing gets the job
     done. */
  .prose :global(mark[data-status]) {
    --status-color: var(--accent);
    background: transparent;
    color: var(--status-color);
    font-weight: 600;
    letter-spacing: 0.02em;
  }
  .prose :global(mark[data-status="danger"])    { --status-color: var(--audit-gate); }
  .prose :global(mark[data-status="warn"])      { --status-color: var(--in-progress); }
  .prose :global(mark[data-status="ok"])        { --status-color: var(--success); }
  .prose :global(mark[data-status="progress"])  { --status-color: var(--advisor); }

  /* Inline <code data-status="…"> — like a status verb in a code span.
     Painted as a coloured pill (matches the data-cmd / data-role
     treatment above). */
  .prose :global(code[data-status]) {
    --pill-color: var(--accent);
    color: var(--pill-color);
    border-color: color-mix(in srgb, var(--pill-color) 50%, transparent);
    background: color-mix(in srgb, var(--pill-color) 12%, transparent);
    font-weight: 500;
  }
  .prose :global(code[data-status="danger"])   { --pill-color: var(--audit-gate); }
  .prose :global(code[data-status="warn"])     { --pill-color: var(--in-progress); }
  .prose :global(code[data-status="ok"])       { --pill-color: var(--success); }
  .prose :global(code[data-status="progress"]) { --pill-color: var(--advisor); }

  /* 8 — Phase-keyword <code data-phase="…"> already styled by the
     existing data-role rule (the script sets both attributes). The
     small letter-spacing tweak below makes phases read as a vocabulary
     class, not a one-off pill. */
  .prose :global(code[data-phase]) {
    text-transform: lowercase;
    letter-spacing: 0.02em;
  }

  /* 10 — Failure-mode line prefixes. <strong data-status="…"> appears
     at the start of paragraphs / list items. Slightly chunkier letter
     spacing + monospace so the prefix reads as a tag, not bold prose. */
  .prose :global(.prefix-label) {
    --prefix-color: var(--audit-gate);
    display: inline-block;
    margin-right: 0.4em;
    padding: 0 0.4em;
    border-radius: var(--r-xs);
    font-family: var(--font-mono);
    font-size: 0.78em;
    font-weight: 700;
    letter-spacing: 0.05em;
    color: var(--prefix-color);
    background: color-mix(in srgb, var(--prefix-color) 12%, transparent);
    border: 0.5px solid color-mix(in srgb, var(--prefix-color) 40%, transparent);
    vertical-align: 0.05em;
  }
  .prose :global(.prefix-label[data-status="warn"])     { --prefix-color: var(--in-progress); }
  .prose :global(.prefix-label[data-status="ok"])       { --prefix-color: var(--success); }
  .prose :global(.prefix-label[data-status="progress"]) { --prefix-color: var(--advisor); }

  /* 5 — Progress rail. Fixed to the right edge of the viewport, only
     visible while the user is looking at a SKILL detail page. The fill
     element grows from 0% → 100% as the user scrolls through the prose. */
  .progress-rail {
    position: fixed;
    top: 0;
    right: 0;
    width: 2px;
    height: 100vh;
    pointer-events: none;
    z-index: 30;
    background: color-mix(in srgb, var(--accent) 12%, transparent);
  }
  .progress-rail-fill {
    width: 100%;
    height: 0;
    background: var(--accent);
    transition: height 80ms linear;
  }
  @media (prefers-reduced-motion: reduce) {
    .progress-rail-fill { transition: none; }
  }

  /* 12 — Numbered h2 eyebrow. A small mono "01" prefix that hangs in
     the gutter on desktop and sits inline at narrower widths. */
  .prose :global(.h-num) {
    display: inline-block;
    margin-right: 0.6em;
    font-family: var(--font-mono);
    font-size: 0.55em;
    font-weight: 500;
    letter-spacing: 0.12em;
    color: var(--accent);
    vertical-align: 0.35em;
  }
  @media (min-width: 768px) {
    .prose :global(h2) > :global(.h-num) {
      position: absolute;
      left: -3.2em;
      margin-right: 0;
      vertical-align: baseline;
    }
  }

  /* 13 — Pattern cards: bordered panels around recognized reference
     sections. Role colour drives the accent stripe + heading hue. */
  .prose :global(.pattern-card) {
    --pc-color: var(--accent);
    margin: 1.6rem 0;
    padding: 0.85rem 1.1rem 0.4rem;
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--pc-color);
    border-radius: var(--r-xs);
    background: color-mix(in srgb, var(--pc-color) 5%, transparent);
  }
  .prose :global(.pattern-card[data-role="workflow"])     { --pc-color: var(--workflow); }
  .prose :global(.pattern-card[data-role="tri-agent"])    { --pc-color: var(--tri-agent); }
  .prose :global(.pattern-card[data-role="audit-gate"])   { --pc-color: var(--audit-gate); }
  .prose :global(.pattern-card[data-role="specialist"])   { --pc-color: var(--specialist); }
  .prose :global(.pattern-card[data-role="advisor"])      { --pc-color: var(--advisor); }
  .prose :global(.pattern-card[data-role="orchestrator"]) { --pc-color: var(--orchestrator); }
  .prose :global(.pattern-card[data-role="success"])      { --pc-color: var(--success); }
  .prose :global(.pattern-card) > :global(h2),
  .prose :global(.pattern-card) > :global(h3) {
    margin-top: 0;
    color: var(--pc-color);
  }
  .prose :global(.pattern-card) > :global(h2) > :global(.h-num) {
    color: var(--pc-color);
  }

  /* 14 — Code-block toolbar. Wraps each <pre> in a code-block container
     with a thin top bar containing a language tag and a copy button. */
  .prose :global(.code-block) {
    position: relative;
    margin: 0.85rem 0;
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    overflow: hidden;
    background: var(--card);
  }
  :root[data-theme="light"] .prose :global(.code-block) {
    background: var(--parchment);
    border-color: var(--sand);
  }
  .prose :global(.code-block) > :global(pre) {
    margin: 0;
    border: 0;
    border-radius: 0;
    background: transparent;
  }
  .prose :global(.code-bar) {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.35rem 0.75rem;
    background: color-mix(in srgb, var(--accent) 6%, transparent);
    border-bottom: 0.5px solid var(--border);
    font-family: var(--font-mono);
    font-size: 11px;
  }
  .prose :global(.code-bar-lang) {
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    color: var(--accent);
    font-weight: 500;
  }
  .prose :global(.code-bar-spacer) { flex: 1; }
  .prose :global(.code-bar-copy) {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    color: var(--muted);
    font: inherit;
    padding: 1px 8px;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .prose :global(.code-bar-copy:hover) {
    color: var(--accent);
    border-color: var(--accent);
  }
  .prose :global(.code-bar-copy.is-copied) {
    color: var(--success);
    border-color: var(--success);
  }

  /* 15 — ASCII-diagram surface. Pre blocks containing box-drawing
     characters get a blueprint surface: subtle grid background, a hint
     more padding, and the language/copy bar tinted with --tri-agent so
     the diagram reads as "art" instead of "code to copy". */
  .prose :global(.code-block[data-ascii]) {
    background: var(--card);
    background-image:
      linear-gradient(0deg, color-mix(in srgb, var(--tri-agent) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in srgb, var(--tri-agent) 6%, transparent) 1px, transparent 1px);
    background-size: 16px 16px;
    border-color: color-mix(in srgb, var(--tri-agent) 25%, var(--border));
  }
  .prose :global(.code-block[data-ascii]) > :global(.code-bar) {
    background: color-mix(in srgb, var(--tri-agent) 8%, transparent);
    border-bottom-color: color-mix(in srgb, var(--tri-agent) 25%, var(--border));
  }
  .prose :global(.code-block[data-ascii]) :global(.code-bar-lang) {
    color: var(--tri-agent);
  }
  .prose :global(.code-block[data-ascii]) > :global(pre) {
    padding: 1.1rem 1.25rem;
    line-height: 1.5;
  }

  /* 11 — Table of contents.
     Mobile (<1280px): top-of-prose <details> collapse.
     Desktop (≥1280px): fixed sticky rail in the right margin. */
  .toc-collapse {
    margin: 0.6rem 0 1rem;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
  }
  .toc-collapse > summary {
    list-style: none;
    cursor: pointer;
    padding: 0.6rem 0.85rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--muted);
    display: flex;
    align-items: center;
    justify-content: space-between;
  }
  .toc-collapse > summary::-webkit-details-marker { display: none; }
  .toc-collapse-chev {
    transition: transform var(--dur-fast) var(--ease-standard);
  }
  .toc-collapse[open] .toc-collapse-chev { transform: rotate(180deg); }

  .toc-list {
    margin: 0;
    padding: 0.4rem 0.4rem 0.6rem 1.5rem;
    list-style: none;
    counter-reset: toc;
  }
  .toc-collapse[open] .toc-list { padding-top: 0.4rem; }
  .toc-list li {
    margin: 0.2rem 0;
    font-size: var(--fs-sm);
    line-height: 1.4;
  }
  .toc-list li.toc-h3 { padding-left: 1.2rem; }
  /* Default state: faded just-above-obsidian (subtle) so the TOC blends
     into the page surface. Hovering anywhere over the TOC region
     brightens every entry to the cream text color so the rail acts as
     a unit; pointing at a specific link then turns it ember to mark
     the user's intent. Active (in-viewport) entry stays ember. */
  .toc-list a {
    color: var(--subtle);
    text-decoration: none;
    border-left: 2px solid transparent;
    /* LHCI target-size (ADEV-339): prior attempts (inline-block 4px,
       then block 6px) gave a ~31.6px-tall box — over WCAG 2.5.8 AA's
       24x24 threshold, but Lighthouse still flagged the links. The
       defensive fix targets 2.5.5 AAA (44x44): explicit min-height
       with flex centering so the click target is unambiguously 44px
       tall regardless of how the audit measures it. The text's
       visual weight doesn't change — only the hit area grows. */
    display: flex;
    align-items: center;
    min-height: 44px;
    padding: 4px 0 4px 0.55rem;
    transition:
      color var(--dur-base) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .toc-rail:hover .toc-list a,
  .toc-rail:focus-within .toc-list a,
  .toc-collapse:hover .toc-list a,
  .toc-collapse:focus-within .toc-list a { color: var(--text); }
  /* Per-link hover wins over the region-hover override. */
  .toc-list a:hover,
  .toc-list a:focus-visible { color: var(--accent); }
  .toc-list a.is-active {
    color: var(--accent);
    border-left-color: var(--accent);
  }

  /* Click-to-flash: when the user clicks a TOC entry, the matching
     heading in the prose gets a brief scale "bump" plus an ember tint
     that slowly fades back to the cream text color over 10 seconds.
     The class is added in JS on click and removed when both animations
     finish. Honors prefers-reduced-motion (no animation, no flash). */
  .prose :global(h2.is-flash),
  .prose :global(h3.is-flash) {
    animation:
      toc-flash-bump 320ms var(--ease-emphasized, var(--ease-standard)) 1,
      toc-flash-fade 10s linear 1;
    /* Lock the resting color while the fade animation runs so the final
       frame matches the body color (avoids a snap when the animation
       releases). */
    color: var(--text);
  }
  @keyframes toc-flash-bump {
    0%   { transform: translateY(0)    scale(1); }
    35%  { transform: translateY(-2px) scale(1.025); }
    100% { transform: translateY(0)    scale(1); }
  }
  @keyframes toc-flash-fade {
    0%   { color: var(--accent); }
    8%   { color: var(--accent); }
    100% { color: var(--text); }
  }
  @media (prefers-reduced-motion: reduce) {
    .prose :global(h2.is-flash),
    .prose :global(h3.is-flash) { animation: none; }
  }

  .toc-rail {
    display: none;
  }
  @media (min-width: 1280px) {
    .toc-rail {
      display: block;
      position: fixed;
      top: 5.5rem;
      left: calc(50% + 360px + 1.5rem);
      width: 220px;
      max-height: calc(100vh - 7rem);
      overflow-y: auto;
      pointer-events: auto;
      z-index: 20;
    }
    .toc-rail-inner {
      padding: 0.75rem 0.5rem 0.75rem 0.85rem;
      border-left: 0.5px solid var(--border);
    }
    .toc-rail-eyebrow {
      display: block;
      margin: 0 0 0.5rem 0.55rem;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--subtle);
    }
    .toc-rail .toc-list {
      padding: 0;
    }
    .toc-collapse {
      display: none;
    }
  }

  /* 17 — Density-aware table styling. Compact for ≤4 body rows
     (matches the homepage phase-card density), comfortable otherwise.
     The tag is set by the post-render walker. */
  .prose :global(table[data-density="compact"]) :global(th),
  .prose :global(table[data-density="compact"]) :global(td) {
    padding: 0.3rem 0.5rem;
    font-size: var(--fs-sm);
    line-height: 1.45;
  }
  .prose :global(table[data-density="comfortable"]) :global(tbody tr:nth-child(even)) {
    background: color-mix(in srgb, var(--accent) 4%, transparent);
  }

  /* 19 — Section TL;DR pill. Tiny mono label leading the paragraph,
     plus a slightly larger / brighter paragraph so the summary reads
     as the section's takeaway. */
  .prose :global(p.section-tldr) {
    font-size: 1.05em;
    color: var(--text);
    background: color-mix(in srgb, var(--accent) 5%, transparent);
    border-left: 2px solid var(--accent);
    padding: 0.55rem 0.85rem;
    border-radius: 0 var(--r-xs) var(--r-xs) 0;
    margin-top: 0;
  }
  .prose :global(.tldr-label) {
    display: inline-block;
    margin-right: 0.4em;
    padding: 0 0.45em;
    font-family: var(--font-mono);
    font-size: 0.7em;
    font-weight: 600;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--accent);
    border: 0.5px solid var(--accent);
    border-radius: var(--r-xs);
    vertical-align: 0.1em;
  }

  /* 20 — Foundational empty state. The "consumers" pill grid in the
     Try-it card on /skills/oc-checkpoint-protocol etc. lists the skills
     that read / write the protocol's checkpoint contract. */
  .protocol-consumers {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin: 0.4rem 0 0.65rem;
  }
  .protocol-consumer-pill {
    --pill-color: var(--specialist);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.02em;
    padding: 1px 7px;
    color: var(--pill-color);
    background: color-mix(in srgb, var(--pill-color) 12%, transparent);
    border: 0.5px solid color-mix(in srgb, var(--pill-color) 40%, transparent);
    border-radius: var(--r-xs);
    text-decoration: none;
    transition:
      background var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .protocol-consumer-pill:hover {
    background: color-mix(in srgb, var(--pill-color) 22%, transparent);
    border-color: var(--pill-color);
  }
  .protocol-consumer-pill[data-role="workflow"]     { --pill-color: var(--workflow); }
  .protocol-consumer-pill[data-role="tri-agent"]    { --pill-color: var(--tri-agent); }
  .protocol-consumer-pill[data-role="audit-gate"]   { --pill-color: var(--audit-gate); }
  .protocol-consumer-pill[data-role="specialist"]   { --pill-color: var(--specialist); }
  .protocol-consumer-pill[data-role="advisor"]      { --pill-color: var(--advisor); }
  .protocol-consumer-pill[data-role="orchestrator"] { --pill-color: var(--orchestrator); }
  .protocol-consumer-pill[data-role="success"]      { --pill-color: var(--success); }

  /* 18 — Prev / next skill nav strip. Sticky at the bottom of the
     viewport on tall screens, wraps to two cards on narrow screens. */
  .skill-nav {
    margin: 2.5rem 0 0;
    padding: 0;
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0.6rem;
  }
  .skill-nav-empty { display: block; }
  .skill-nav-link {
    --pill-color: var(--accent);
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    padding: 0.65rem 0.85rem;
    border: 0.5px solid var(--border);
    border-left: 2px solid var(--pill-color);
    border-radius: var(--r-xs);
    background: var(--surface);
    color: var(--text);
    text-decoration: none;
    transition:
      background var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .skill-nav-link:hover {
    background: color-mix(in srgb, var(--pill-color) 6%, var(--surface));
    border-color: var(--pill-color);
  }
  .skill-nav-prev { text-align: left; }
  .skill-nav-next { text-align: right; align-items: flex-end; }
  .skill-nav-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--pill-color);
  }
  .skill-nav-name {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--text);
  }
  .skill-nav-link[data-role="workflow"]     { --pill-color: var(--workflow); }
  .skill-nav-link[data-role="tri-agent"]    { --pill-color: var(--tri-agent); }
  .skill-nav-link[data-role="audit-gate"]   { --pill-color: var(--audit-gate); }
  .skill-nav-link[data-role="specialist"]   { --pill-color: var(--specialist); }
  .skill-nav-link[data-role="advisor"]      { --pill-color: var(--advisor); }
  .skill-nav-link[data-role="orchestrator"] { --pill-color: var(--orchestrator); }
  .skill-nav-link[data-role="success"]      { --pill-color: var(--success); }

  .cta {
    margin-top: 3rem;
    padding-top: 2rem;
    border-top: 0.5px solid var(--border);
  }
  .cta h2 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.5rem;
  }
  .cta p { color: var(--muted); margin: 0 0 1.25rem; }
  .cta-row { display: flex; gap: 0.6rem; flex-wrap: wrap; }

  .ic {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }
</style>
