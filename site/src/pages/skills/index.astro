---
import Base from "../../layouts/Base.astro";
import Eyebrow from "../../components/ui/Eyebrow.astro";
import Card from "../../components/ui/Card.astro";
import Pill from "../../components/ui/Pill.astro";
import Input from "../../components/ui/Input.astro";
import Button from "../../components/ui/Button.astro";
import Icon from "../../components/Icon.astro";
import {
  getAllSkills,
  getSkillRole,
  getRoleLabel,
  phaseLabel,
} from "../../lib/skills";
import { defaultFor, isCommandEnabled } from "../../lib/flags/build-defaults";

const skills = await getAllSkills();
const installZipEnabled = defaultFor("site.feature.install-zip-download") as boolean;
const visibleCommandsFor = (cmds: string[]) => cmds.filter(isCommandEnabled);

const phaseFilters = [
  { id: "all",        label: "All" },
  { id: "foundation", label: "Foundation" },
  { id: "plan",       label: "Plan" },
  { id: "plan-build", label: "Plan + build" },
  { id: "build",      label: "Build" },
];
---

<Base
  title="Skill Library · opchain"
  description="Browse every opchain skill, filter by pipeline phase, see trigger commands. Download any skill or the complete bundle."
  active="/skills"
>
  <main class="page">
    <div class="page-head">
      <div>
        <Eyebrow>skill library</Eyebrow>
        <h1>Every skill, filterable.</h1>
      </div>
      {installZipEnabled && (
        <Button variant="outline" href="/opchain-skills.zip">
          <Icon name="download" />
          download all skills
        </Button>
      )}
    </div>

    <p class="lede">
      Prompt packages — a shared checkpoint protocol plus one skill per
      phase of the pipeline. Click any card for the full
      <code class="ic">SKILL.md</code>, trigger commands, and a
      per-skill download bundle.
    </p>

    <a class="release-callout" href="/changelog" aria-label="See what's new in opchain v1.3">
      <span class="release-callout-tag">v1.3 · NEW</span>
      <span class="release-callout-text">
        Runtime PM-MCP loop · Django / Rails / Go / Rust support · <code>oc-release-ops</code>
      </span>
      <span class="release-callout-link">
        see what changed →
      </span>
    </a>

    <section class="filter-panel" aria-labelledby="lib-heading">
      <h2 id="lib-heading" class="visually-hidden">Filters</h2>
      <Input
        type="search"
        id="skill-search"
        placeholder="search skills…"
        autocomplete="off"
        ariaLabel="Search skills"
      />

      <div class="phase-pills" id="phase-pills" role="group" aria-label="Filter by pipeline phase">
        {phaseFilters.map((p, i) => (
          <Pill pressed={i === 0} {...({ "data-phase": p.id } as any)}>{p.label}</Pill>
        ))}
      </div>

      <label class="tri-row">
        <input type="checkbox" id="tri-only" />
        <span>Tri-agent only</span>
      </label>

      <p id="skill-count" class="meta" aria-live="polite">
        Showing {skills.length} of {skills.length} skills
      </p>
    </section>

    <div id="skill-list" class="skill-list">
      {skills.map((s) => {
        const role = getSkillRole(s.data.name);
        return (
          <Card
            variant="surface"
            href={`/skills/${s.data.name}`}
            class="skill-card"
            {...({
              "data-skill": s.data.name,
              "data-phases": s.data.phases.join(","),
              "data-tri": String(s.data.triAgent),
              "data-search": `${s.data.displayName} ${s.data.shortDesc} ${s.data.name} ${s.data.description}`.toLowerCase(),
            } as any)}
          >
            <div class="card-head">
              <h3>{s.data.displayName}</h3>
              <div class="card-head-meta">
                <span class="card-role-tag" data-role={role}>{getRoleLabel(role)}</span>
                <span class="card-phase-tag">{phaseLabel(s.data.phases)}</span>
                <span class="version">v{s.data.version}</span>
              </div>
            </div>
            <p class="short">
              <span class="short-lead">{s.data.shortDesc}</span>
              <br />
              <span class="short-body">{s.data.description}</span>
            </p>
            {(() => {
              const visible = visibleCommandsFor(s.data.commands as string[]);
              return visible.length > 0 ? (
                <div class="commands">
                  {visible.map((c: string) => (
                    <code class="cmd">{c}</code>
                  ))}
                </div>
              ) : null;
            })()}
            <div class="card-foot">
              <span class="link">View docs <Icon name="arrow-right" size={12} /></span>
            </div>
          </Card>
        );
      })}
    </div>

    <p id="empty" class="empty" hidden>No skills match these filters.</p>
  </main>

  <script>
    /**
     * Client-side filter for the Skill Library. Reads data-* attributes off
     * the rendered cards so we don't ship a copy of the catalog as JSON.
     * Filter state never leaves the page; nothing persists to URL or storage
     * (kept simple — Sprint 4 can add URL params if useful).
     */
    const list   = document.getElementById("skill-list")!;
    const cards  = Array.from(list.querySelectorAll<HTMLElement>("[data-skill]"));
    const search = document.getElementById("skill-search") as HTMLInputElement | null;
    const triOnly= document.getElementById("tri-only")    as HTMLInputElement | null;
    const pillsEl= document.getElementById("phase-pills");
    const count  = document.getElementById("skill-count");
    const empty  = document.getElementById("empty");

    let phase: string = "all";
    const total = cards.length;

    function phaseMatch(card: HTMLElement): boolean {
      if (phase === "all") return true;
      const phases = (card.dataset.phases || "").split(",");
      const hasPlan  = phases.includes("plan");
      const hasBuild = phases.includes("build");
      if (phase === "foundation") return phases.includes("foundation");
      if (phase === "plan")       return hasPlan && !hasBuild;
      if (phase === "build")      return hasBuild && !hasPlan;
      if (phase === "plan-build") return hasPlan && hasBuild;
      return true;
    }

    function render() {
      const q   = (search?.value || "").trim().toLowerCase();
      const tri = !!triOnly?.checked;
      let visible = 0;
      cards.forEach((card) => {
        const matches =
          phaseMatch(card) &&
          (!tri || card.dataset.tri === "true") &&
          (!q || (card.dataset.search || "").includes(q));
        card.hidden = !matches;
        if (matches) visible++;
      });
      if (count)  count.textContent  = `Showing ${visible} of ${total} skills`;
      if (empty)  empty.hidden       = visible !== 0;
    }

    function setPhase(next: string) {
      phase = next;
      pillsEl?.querySelectorAll<HTMLButtonElement>("[data-phase]").forEach((p) => {
        p.setAttribute("aria-pressed", p.dataset.phase === next ? "true" : "false");
      });
      render();
    }

    pillsEl?.querySelectorAll<HTMLButtonElement>("[data-phase]").forEach((p) => {
      p.addEventListener("click", () => setPhase(p.dataset.phase || "all"));
    });
    search?.addEventListener("input", render);
    triOnly?.addEventListener("change", render);
  </script>
</Base>

<style>
  .page {
    max-width: 960px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }
  .page-head {
    display: flex;
    flex-wrap: wrap;
    align-items: flex-end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 2rem;
  }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0;
  }
  .lede {
    color: var(--muted);
    margin: 0.75rem 0 1.5rem;
    max-width: 42rem;
    line-height: var(--lh-base);
  }
  .ic {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }

  .filter-panel {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.25rem;
    margin-bottom: 1.5rem;
    box-shadow: var(--glow-md);
    display: flex;
    flex-direction: column;
    gap: 0.85rem;
  }

  .phase-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.4rem;
  }

  .tri-row {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--fs-sm);
    color: var(--muted);
    cursor: pointer;
  }
  /* Custom checkbox: page-background fill when unchecked, ember when
     checked. Native accent-color only paints the checked state, so we
     redraw it. The unchecked colour uses --bg (themed) so light mode
     gets the parchment fill instead of staying brand-obsidian. */
  .tri-row input[type="checkbox"] {
    appearance: none;
    -webkit-appearance: none;
    width: 14px;
    height: 14px;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    background: var(--bg);
    cursor: pointer;
    display: inline-grid;
    place-content: center;
    margin: 0;
    transition:
      background var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .tri-row input[type="checkbox"]:hover { border-color: var(--accent); }
  .tri-row input[type="checkbox"]:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .tri-row input[type="checkbox"]:checked {
    background: var(--accent);
    border-color: var(--accent);
  }
  /* Checkmark drawn with two borders, rotated. Stays obsidian for AA
     contrast against the ember fill in both themes. */
  .tri-row input[type="checkbox"]:checked::after {
    content: "";
    width: 7px;
    height: 3.5px;
    border-left: 1.5px solid var(--obsidian);
    border-bottom: 1.5px solid var(--obsidian);
    transform: rotate(-45deg) translate(0, -1px);
  }

  .meta {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    color: var(--subtle);
    margin: 0;
  }

  .skill-list {
    display: flex;
    flex-direction: column;
    gap: 0.7rem;
  }

  .skill-card { display: block; }

  .card-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
    margin-bottom: 0.55rem;
    flex-wrap: wrap;
  }
  .card-head h3 {
    margin: 0;
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--text);
    letter-spacing: -0.005em;
  }
  /* Right side of the card head: role tag + phase tag + version, in line. */
  .card-head-meta {
    display: flex;
    align-items: center;
    gap: 0.4rem;
    flex-wrap: wrap;
  }
  .version {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
    letter-spacing: var(--ls-wide);
  }

  /* Role tag — outline + 15% fill in the role color. Same visual language
     as the homepage skill pills. */
  .card-role-tag {
    --pill-color: var(--specialist);
    display: inline-flex;
    align-items: center;
    padding: 2px 7px;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.5;
    color: var(--pill-color);
    border: 0.5px solid var(--pill-color);
    background: color-mix(in srgb, var(--pill-color) 15%, transparent);
    white-space: nowrap;
    text-transform: lowercase;
  }
  .card-role-tag[data-role="workflow"]     { --pill-color: var(--workflow); }
  .card-role-tag[data-role="tri-agent"]    { --pill-color: var(--tri-agent); }
  .card-role-tag[data-role="audit-gate"]   { --pill-color: var(--audit-gate); }
  .card-role-tag[data-role="specialist"]   { --pill-color: var(--specialist); }
  .card-role-tag[data-role="advisor"]      { --pill-color: var(--advisor); }
  .card-role-tag[data-role="orchestrator"] { --pill-color: var(--orchestrator); }
  .card-role-tag[data-role="success"]      { --pill-color: var(--success); }
  /* B-10/B-11: Axe can't evaluate color-mix() when operands are CSS custom
     properties (two-level chain: --pill-color → --role-token → hex). Light
     mode: pre-computed equivalents of color-mix(role 15%, --surface #f4e5cf).
     The generic fallback covers any unlisted roles; per-role rules give Axe
     a static value it can evaluate without traversing the var() chain. */
  :global([data-theme="light"]) .card-role-tag {
    background: color-mix(in srgb, var(--pill-color) 15%, var(--surface));
  }
  :global([data-theme="light"]) .card-role-tag[data-role="workflow"]     { background: #e4cbb2; }
  :global([data-theme="light"]) .card-role-tag[data-role="tri-agent"]    { background: #e2cfb1; }
  :global([data-theme="light"]) .card-role-tag[data-role="audit-gate"]   { background: #e7c6b9; }
  :global([data-theme="light"]) .card-role-tag[data-role="specialist"]   { background: #d1d1bd; }
  :global([data-theme="light"]) .card-role-tag[data-role="advisor"]      { background: #d1cfc3; }
  :global([data-theme="light"]) .card-role-tag[data-role="orchestrator"] { background: #e0c9d1; }
  :global([data-theme="light"]) .card-role-tag[data-role="success"]      { background: #d0d1ba; }

  /* Phase tag — neutral, distinguishes from role visually. */
  .card-phase-tag {
    display: inline-flex;
    align-items: center;
    padding: 2px 7px;
    border-radius: 0;
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.5;
    color: var(--muted);
    border: 0.5px solid var(--border);
    background: color-mix(in srgb, var(--muted) 8%, transparent);
    text-transform: lowercase;
    white-space: nowrap;
  }

  .short {
    color: var(--muted);
    font-size: var(--fs-sm);
    margin: 0 0 0.7rem;
    line-height: var(--lh-base);
  }
  .short-lead { color: var(--text); font-weight: 500; }
  .short-body { color: var(--muted); }

  .commands {
    display: flex;
    gap: 0.35rem;
    flex-wrap: wrap;
    align-items: center;
    margin-bottom: 0.6rem;
  }
  .cmd {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--text);
    background: var(--card);
    border: 0.5px solid var(--border);
    padding: 1px 6px;
    border-radius: var(--r-xs);
  }

  .card-foot {
    margin-top: 0.5rem;
  }
  .link {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    color: var(--accent);
    display: inline-flex;
    align-items: center;
    gap: 0.3rem;
  }
  /* B-10: --accent on light --surface = 3.05:1 ✗. --accent-hover = 4.55:1 ✓. */
  :global([data-theme="light"]) .link { color: var(--accent-hover); }

  .empty {
    text-align: center;
    color: var(--subtle);
    font-style: italic;
    margin-top: 2rem;
  }

  /* ── Release callout — surfaces the latest /changelog headline above the
        filter panel. Links the Skill Library to the version history so a
        first-time visitor browsing skills doesn't have to dig for what
        moved in the latest release. ── */
  .release-callout {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.65rem 0.85rem 0.65rem 0.7rem;
    margin: 0 0 1.5rem;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-left: 2px solid var(--accent);
    border-radius: var(--r-xs);
    color: var(--muted);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
    flex-wrap: wrap;
  }
  .release-callout:hover {
    color: var(--text);
    border-color: var(--accent);
  }
  .release-callout-tag {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    border: 0.5px solid var(--accent);
    padding: 2px 8px;
    border-radius: var(--r-xs);
    flex-shrink: 0;
  }
  .release-callout-text {
    flex: 1 1 auto;
    font-size: var(--fs-sm);
    line-height: 1.4;
  }
  .release-callout-text code {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--card);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }
  .release-callout-link {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    color: var(--accent);
    text-transform: uppercase;
    flex-shrink: 0;
  }
  :global([data-theme="light"]) .release-callout-link { color: var(--accent-hover); }
</style>
