---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Button from "../components/ui/Button.astro";
import Card from "../components/ui/Card.astro";
import Icon from "../components/Icon.astro";
import CaptureModal from "../components/CaptureModal.astro";
import { defaultFor } from "../lib/flags/build-defaults";

const installZipEnabled = defaultFor("site.feature.install-zip-download") as boolean;
const codexInstallEnabled = defaultFor("site.feature.codex-install") as boolean;

const installDesc = codexInstallEnabled
  ? "Install opchain in Claude Code, Claude.ai, Claude Desktop, or Codex / any MCP agent — drop-in SKILL.md files or a hosted MCP endpoint. No API keys required."
  : "Install opchain in Claude Code, Claude.ai, or Claude Desktop. Three flows, one directory of SKILL.md files. No API keys required.";

const cliCmd = `curl -L https://opchain.dev/opchain-skills.zip -o opchain-skills.zip
unzip opchain-skills.zip -d .claude/skills/
claude
> /oc-discover`;

const teamCmd = `git add .claude/skills/
git commit -m "chore: add opchain skills"
git push`;

const upgradeCmd = `# .checkpoints/ is a sibling of .claude/ — never touched by this swap
rm -rf .claude/skills/
curl -L https://opchain.dev/opchain-skills.zip -o opchain-skills.zip
unzip opchain-skills.zip -d .claude/skills/
rm opchain-skills.zip`;

const versionCmd = `curl -sS https://opchain.dev/api/health | jq .version`;

// SessionStart update check: compares the installed SKILL.md frontmatter
// version (project install first, then global) against the lockstep
// `catalogVersion` in /skills.json. Prints one line when an update exists;
// silent — no output, exit 0 — when current, offline, or opchain isn't
// installed. Serialized with JSON.stringify so the snippet users copy is
// guaranteed-valid settings.json.
const updateHookCmd = `f=$(ls "\${CLAUDE_PROJECT_DIR:-.}"/.claude/skills/oc-*/SKILL.md "$HOME"/.claude/skills/oc-*/SKILL.md 2>/dev/null | head -n1); [ -n "$f" ] || exit 0; installed=$(sed -n 's/^version:[[:space:]]*//p' "$f" | head -n1); [ -n "$installed" ] || exit 0; latest=$(curl -sf --max-time 3 "https://opchain.dev/skills.json?u=$(date +%s)" | sed -n 's/.*"catalogVersion": *"\\([^"]*\\)".*/\\1/p' | head -n1); [ -n "$latest" ] && [ "$installed" != "$latest" ] && echo "opchain skills v$latest is available (installed: v$installed). Update guide: https://opchain.dev/install#update"; exit 0`;
const updateHookJson = JSON.stringify(
  {
    hooks: {
      SessionStart: [
        {
          matcher: "startup",
          hooks: [{ type: "command", command: updateHookCmd }],
        },
      ],
    },
  },
  null,
  2,
);

const codexMcpCmd = `# ~/.codex/config.toml
[mcp_servers.opchain]
url = "https://opchain.dev/mcp"`;

const codexSkillsCmd = `curl -L https://opchain.dev/opchain-skills.zip -o opchain-skills.zip
unzip opchain-skills.zip -d .codex/skills/
codex`;
---

<Base
  title="Install · opchain"
  description={installDesc}
  active="/install"
>
  <main class="page">
    <div class="page-head">
      <div>
        <Eyebrow>install</Eyebrow>
        <h1>{codexInstallEnabled ? "Four" : "Three"} flows.</h1>
      </div>
      {installZipEnabled && (
        <Button
          variant="primary"
          href="/opchain-skills.zip"
          {...{ "data-capture-trigger": true, "data-capture-source": "bundle-download" } as any}
        >
          <Icon name="download" />
          download bundle
        </Button>
      )}
    </div>

    <p class="lede">
      Every skill is a single <code class="ic">SKILL.md</code> file. Install
      the full set or just the ones you want. No API keys, no package
      manager, no build step.
    </p>

    <!-- ───────────── Flow 1 — Claude Code ───────────── -->
    <section class="flow">
      <div class="flow-num">01</div>
      <div class="flow-body">
        <h2><Icon name="terminal" /> Claude Code CLI</h2>
        <p>
          Need the CLI first?
          <a href="https://claude.com/claude-code" rel="noopener">
            Install Claude Code
          </a>, open a terminal at your project root, then drop the skills
          into <code class="ic">.claude/skills/</code>. Claude Code
          auto-discovers them on the next session.
        </p>
        <div class="code-row">
          <pre class="codeblock"><code>{cliCmd}</code></pre>
          <button class="copy" type="button" data-copy={cliCmd} data-flow="cli" aria-label="Copy command">
            <Icon name="copy" size={12} />
            <span class="copy-label">copy</span>
          </button>
        </div>
        <p class="verify">
          <strong>Verify it worked.</strong> In that session, type
          <code class="ic">/oc-discover</code>. If oc-app-architect starts an
          interview ("Who's the primary user? Sync or async? …"), you're
          set. If not, re-check that the files landed in
          <code class="ic">.claude/skills/&lt;name&gt;/SKILL.md</code>.
        </p>
      </div>
    </section>

    <!-- ───────────── Flow 2 — Claude.ai / Desktop ───────────── -->
    <section class="flow">
      <div class="flow-num">02</div>
      <div class="flow-body">
        <h2><Icon name="layers" /> Claude.ai / Claude Desktop</h2>
        <ol class="steps">
          <li>
            {installZipEnabled ? (
              <>Download the full <a href="/opchain-skills.zip">bundle ZIP</a> or individual <code class="ic">SKILL.md</code> files from the <a href="/skills">Skill Library</a>.</>
            ) : (
              <>Download individual <code class="ic">SKILL.md</code> files from the <a href="/skills">Skill Library</a>.</>
            )}
          </li>
          <li>Open Claude → <strong>Settings → Customize → Skills</strong>.</li>
          <li>Click <strong>Upload skill</strong> and pick the <code class="ic">.md</code> file.</li>
          <li>
            Start a new conversation and trigger by name
            (<em>"I have an app idea"</em> auto-invokes oc-app-architect) or by
            slash command (<code class="ic">/oc-discover</code>).
          </li>
        </ol>
      </div>
    </section>

    <!-- ───────────── Flow 3 — Team / git ───────────── -->
    <section class="flow">
      <div class="flow-num">03</div>
      <div class="flow-body">
        <h2><Icon name="github" /> Team (check into git)</h2>
        <p>Commit the skills directory so every teammate uses the same prompt pipeline.</p>
        <div class="code-row">
          <pre class="codeblock"><code>{teamCmd}</code></pre>
          <button class="copy" type="button" data-copy={teamCmd} data-flow="team" aria-label="Copy command">
            <Icon name="copy" size={12} />
            <span class="copy-label">copy</span>
          </button>
        </div>
      </div>
    </section>

    <!-- ───────────── Flow 4 — Codex / any MCP agent ───────────── -->
    {codexInstallEnabled && (
      <section class="flow">
        <div class="flow-num">04</div>
        <div class="flow-body">
          <h2><Icon name="terminal" /> Codex / any MCP agent</h2>
          <p>
            Codex — and any MCP-aware agent (Claude Desktop, Cursor, Windsurf) —
            reaches opchain two ways, over the
            <a href="https://modelcontextprotocol.io" rel="noopener">Model Context Protocol</a>
            or as drop-in skills. The drop-in path is the closest match to Claude
            Code: Codex Agent Skills auto-trigger by description, so the pipeline
            fires on its own. The hosted MCP endpoint needs no install, but relies
            on the model choosing to call opchain's tools.
          </p>
          <p class="flow-sub">
            <strong>Drop the skills in (recommended)</strong> — Codex Agent Skills
            use the same <code class="ic">SKILL.md</code> format and auto-trigger by
            description, the same way Claude Code does:
          </p>
          <div class="code-row">
            <pre class="codeblock"><code>{codexSkillsCmd}</code></pre>
            <button class="copy" type="button" data-copy={codexSkillsCmd} data-flow="codex-skills" aria-label="Copy Codex skills install">
              <Icon name="copy" size={12} />
              <span class="copy-label">copy</span>
            </button>
          </div>
          <p class="flow-sub">
            <strong>Or point Codex at the hosted MCP server</strong> — nothing to
            install; works for any MCP client:
          </p>
          <div class="code-row">
            <pre class="codeblock"><code>{codexMcpCmd}</code></pre>
            <button class="copy" type="button" data-copy={codexMcpCmd} data-flow="codex-mcp" aria-label="Copy Codex MCP config">
              <Icon name="copy" size={12} />
              <span class="copy-label">copy</span>
            </button>
          </div>
          <p class="verify">
            <strong>Verify it worked.</strong> Run <code class="ic">codex</code>
            and ask "build me an app" — a drop-in skill match (or, over the hosted
            server, opchain's <code class="ic">route</code> tool) hands you to
            oc-app-architect's discovery interview. Note: Codex doesn't surface MCP
            prompts, so opchain's <code class="ic">/oc-*</code> verbs aren't slash
            commands in Codex — just describe what you want ("build me an app",
            "audit this") and the matching skill triggers.
          </p>
        </div>
      </section>
    )}

    <!-- ───────────── Upgrade ───────────── -->
    <section class="upgrade" id="update">
      <Eyebrow>upgrade</Eyebrow>
      <h2><Icon name="refresh-cw" /> Update an existing install</h2>
      <p>
        Already running opchain in a project? Replace the skills in place.
        Your <code class="ic">.checkpoints/</code> directory lives
        <em>outside</em> <code class="ic">.claude/skills/</code>, so every
        skill's session state — phase, step, next actions, decisions — is
        preserved across the swap. The new skills pick up the existing
        checkpoints on their next invocation.
      </p>

      <h3><Icon name="terminal" /> Claude Code CLI</h3>
      <p>
        Run from your project root. This wipes the old skills directory
        and replaces it with the latest bundle.
      </p>
      <div class="code-row">
        <pre class="codeblock"><code>{upgradeCmd}</code></pre>
        <button class="copy" type="button" data-copy={upgradeCmd} data-flow="upgrade-cli" aria-label="Copy upgrade command">
          <Icon name="copy" size={12} />
          <span class="copy-label">copy</span>
        </button>
      </div>
      <p class="verify">
        <strong>Verify the new version is live.</strong> Check what the
        site is currently shipping with
        <code class="ic">curl https://opchain.dev/api/health</code> (the
        <code class="ic">version</code> field is the build SHA), then
        start a new Claude Code session and run
        <code class="ic">/oc-ops</code> — the orchestrator should report your
        existing checkpoints exactly where you left them.
      </p>

      <h3><Icon name="layers" /> Claude.ai / Claude Desktop</h3>
      <ol class="steps">
        <li>
          {installZipEnabled ? (
            <>Download the latest <a href="/opchain-skills.zip">bundle ZIP</a> or the individual <code class="ic">SKILL.md</code> files you use from the <a href="/skills">Skill Library</a>.</>
          ) : (
            <>Download the latest <code class="ic">SKILL.md</code> files from the <a href="/skills">Skill Library</a>.</>
          )}
        </li>
        <li>Open Claude → <strong>Settings → Customize → Skills</strong>.</li>
        <li>For each skill you've installed, click the existing entry and choose <strong>Replace</strong> (or delete and re-upload). Skills are matched by name, so the new file overrides the old one.</li>
        <li>Checkpoints in Claude.ai live in the project, not the skill, so they survive the upload.</li>
      </ol>

      <h3><Icon name="github" /> Team (git-tracked install)</h3>
      <p>
        If you committed <code class="ic">.claude/skills/</code> with the
        team flow, do the upgrade on a branch so the skill diff lands in
        review:
      </p>
      <div class="code-row">
        <pre class="codeblock"><code>{`git checkout -b chore/upgrade-opchain
rm -rf .claude/skills/
curl -L https://opchain.dev/opchain-skills.zip -o opchain-skills.zip
unzip opchain-skills.zip -d .claude/skills/
rm opchain-skills.zip
git add .claude/skills/
git commit -m "chore: upgrade opchain skills"`}</code></pre>
        <button class="copy" type="button" data-copy={`git checkout -b chore/upgrade-opchain
rm -rf .claude/skills/
curl -L https://opchain.dev/opchain-skills.zip -o opchain-skills.zip
unzip opchain-skills.zip -d .claude/skills/
rm opchain-skills.zip
git add .claude/skills/
git commit -m "chore: upgrade opchain skills"`} data-flow="upgrade-team" aria-label="Copy team upgrade command">
          <Icon name="copy" size={12} />
          <span class="copy-label">copy</span>
        </button>
      </div>
      <p>
        Reviewers see exactly which skills changed, and
        <code class="ic">.checkpoints/</code> is untouched because it's a
        separate top-level directory.
      </p>

      <h3><Icon name="target" /> Check which version you're on</h3>
      <div class="code-row">
        <pre class="codeblock"><code>{versionCmd}</code></pre>
        <button class="copy" type="button" data-copy={versionCmd} data-flow="upgrade-version" aria-label="Copy version-check command">
          <Icon name="copy" size={12} />
          <span class="copy-label">copy</span>
        </button>
      </div>
      <p>
        Returns the build SHA currently published at
        <code class="ic">opchain.dev</code>. Re-run after upgrading and
        confirm a fresh Claude session sees the new skills under
        <code class="ic">.claude/skills/&lt;name&gt;/SKILL.md</code>.
      </p>

      <h3><Icon name="zap" /> Get notified automatically</h3>
      <p>
        Skills don't phone home, so a stale install stays stale silently.
        This <a href="https://docs.claude.com/en/docs/claude-code/hooks" rel="noopener">Claude Code
        hook</a> checks at session start: it reads the
        <code class="ic">version</code> from your installed skills'
        frontmatter, compares it against the live catalog's
        <code class="ic">catalogVersion</code> at
        <code class="ic">opchain.dev/skills.json</code>, and drops a
        one-line notice into the session when a newer release is out.
        Merge it into <code class="ic">~/.claude/settings.json</code> (or a
        project's <code class="ic">.claude/settings.json</code>) — if you
        already have a <code class="ic">hooks</code> block, add the
        <code class="ic">SessionStart</code> entry to it rather than
        pasting the whole object.
      </p>
      <div class="code-row">
        {/* The hook command is one long line, so this block scrolls horizontally —
            it needs keyboard focus (axe: scrollable-region-focusable). */}
        <pre class="codeblock" tabindex="0" role="region" aria-label="Update-check hook for settings.json"><code>{updateHookJson}</code></pre>
        <button class="copy" type="button" data-copy={updateHookJson} data-flow="upgrade-hook" aria-label="Copy update-check hook settings">
          <Icon name="copy" size={12} />
          <span class="copy-label">copy</span>
        </button>
      </div>
      <p>
        It checks, it never installs — releases can carry breaking changes
        (see the <a href="/changelog">changelog</a>), so the swap stays a
        deliberate step: run the upgrade command above when you see the
        notice. When you're current, offline, or opchain isn't installed,
        the hook prints nothing and gets out of the way. It fires only on
        <code class="ic">startup</code> — not on resume or compact — and
        gives the network three seconds before giving up.
      </p>
    </section>

    <!-- ───────────── Configuration table ───────────── -->
    <section class="config">
      <h2>Configuration</h2>
      <Card variant="surface" glow={false}>
        <div class="kv">
          <div class="key"><code class="ic">.claude/skills/</code></div>
          <div class="val">Where Claude Code looks for skills.</div>
        </div>
        <div class="kv">
          <div class="key"><code class="ic">.checkpoints/</code></div>
          <div class="val">Skills write JSON session state here. Add to .gitignore.</div>
        </div>
        <div class="kv">
          <div class="key"><code class="ic">orchestrator.md</code></div>
          <div class="val">Shared welcome protocol + pipeline map. Bundled with every skill.</div>
        </div>
        {codexInstallEnabled && (
          <>
            <div class="kv">
              <div class="key"><code class="ic">.codex/skills/</code></div>
              <div class="val">Where Codex looks for drop-in skills — same SKILL.md format as Claude Code.</div>
            </div>
            <div class="kv">
              <div class="key"><code class="ic">~/.codex/config.toml</code></div>
              <div class="val">Register the hosted MCP server under <code class="ic">[mcp_servers.opchain]</code>.</div>
            </div>
          </>
        )}
      </Card>
    </section>

    <!-- ───────────── What you get ───────────── -->
    <section class="what">
      <h2>What you get</h2>
      <ul>
        <li><strong>One skill per pipeline phase</strong> covering discover · spec · design · build · audit · ship · monitor · migrate · scale</li>
        <li><strong>Session persistence</strong> — JSON checkpoints in <code class="ic">.checkpoints/</code>; pick up exactly where you left off, next chat or next week</li>
        <li><strong>Active chaining</strong> — skills invoke each other automatically at phase boundaries; no manual handoffs</li>
        <li><strong>Natural-language triggers</strong> — type "build me an app" or "audit this before Friday" and opchain routes you to the right skill</li>
      </ul>
      <p style="margin-top: 1.5rem;">
        Want a preview first? The <a href="/demo">demo</a> walks you
        through six end-to-end opchain sessions, end to end.
      </p>
    </section>

    <!-- ───────────── What next — starter paths ───────────── -->
    <section class="whatnext">
      <Eyebrow>what next</Eyebrow>
      <h2><Icon name="arrow-right" /> Your first 30 minutes</h2>
      <p class="whatnext-lede">
        Skills are inert until you trigger one. Here are three starter
        paths — pick whichever matches the moment.
      </p>

      <div class="paths">
        <article class="path">
          <div class="path-head">
            <span class="path-num">01</span>
            <h3>Starting fresh</h3>
          </div>
          <p class="path-sub">No code yet · greenfield project</p>
          <ol class="path-steps">
            <li>Trigger <code class="ic">/oc-discover</code> — <a href="/skills/oc-app-architect">oc-app-architect</a> runs the spec interview</li>
            <li>Let <a href="/skills/oc-stack-forge">oc-stack-forge</a> pick the platform; review and confirm</li>
            <li><a href="/skills/oc-ux-engineer">oc-ux-engineer</a> generates a style book and screens</li>
            <li>Sprint loop produces a working prototype</li>
            <li><a href="/skills/oc-git-ops">oc-git-ops</a> + <a href="/skills/oc-deploy-ops">oc-deploy-ops</a> ship it</li>
          </ol>
        </article>

        <article class="path">
          <div class="path-head">
            <span class="path-num">02</span>
            <h3>Joining an existing repo</h3>
          </div>
          <p class="path-sub">Code already on disk · no opchain history</p>
          <ol class="path-steps">
            <li>Run <code class="ic">/oc-rev-spec</code> — <a href="/skills/oc-reverse-spec">oc-reverse-spec</a> backfills a spec from the code</li>
            <li>Type <code class="ic">/oc-ops</code> for the orchestrator's read on what's open</li>
            <li><a href="/skills/oc-code-auditor">oc-code-auditor</a> tells you the top-five concerns before your next commit</li>
          </ol>
        </article>

        <article class="path">
          <div class="path-head">
            <span class="path-num">03</span>
            <h3>Shipping a fix in flight</h3>
          </div>
          <p class="path-sub">Bug or feature already in progress</p>
          <ol class="path-steps">
            <li><a href="/skills/oc-bug-check">oc-bug-check</a> on the diff — type / lint / secrets / vulns</li>
            <li><a href="/skills/oc-code-auditor">oc-code-auditor</a> for an Auditor/Fixer/Verifier pass</li>
            <li><a href="/skills/oc-git-ops">oc-git-ops</a> opens the PR with shape-aware title + body</li>
            <li><a href="/skills/oc-deploy-ops">oc-deploy-ops</a> blocks prod until every audit gate is green</li>
          </ol>
        </article>
      </div>

      <p class="whatnext-cta">
        Not sure what fits? Try the
        <a href="/pipeline-builder">pipeline builder</a> — four
        questions, custom recommendations, a starter
        <code class="ic">CLAUDE.md</code>. Or browse
        <a href="/skills">every skill</a> and pick by hand.
      </p>
    </section>
  </main>

  <CaptureModal />

  <script>
    import { track } from "../lib/analytics";

    /**
     * Tiny copy-to-clipboard handler. Reads the literal command from
     * the button's `data-copy` attribute (preserves newlines exactly).
     * No JS bundle for the rest of the page — only this island runs.
     */
    document.querySelectorAll<HTMLButtonElement>("button.copy").forEach((btn) => {
      const original = btn.querySelector(".copy-label")?.textContent ?? "copy";
      btn.addEventListener("click", async () => {
        const text = btn.dataset.copy ?? "";
        track("install_copy_clicked", { flow: btn.dataset.flow ?? "unknown" });
        try {
          await navigator.clipboard.writeText(text);
          const lbl = btn.querySelector(".copy-label");
          if (lbl) {
            lbl.textContent = "copied ✓";
            setTimeout(() => (lbl.textContent = original), 1500);
          }
        } catch {
          /* clipboard blocked — leave the label alone */
        }
      });
    });
  </script>
</Base>

<style>
  .page {
    max-width: 720px;
    margin: 0 auto;
    padding: 3rem 1.5rem 6rem;
  }
  .page-head {
    display: flex;
    align-items: flex-end;
    justify-content: space-between;
    flex-wrap: wrap;
    gap: 1rem;
    margin-bottom: 1.5rem;
  }
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0;
  }
  .lede { color: var(--muted); margin: 0 0 2.5rem; max-width: 42rem; }

  .ic {
    font-family: var(--font-mono);
    font-size: 12px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    padding: 1px 5px;
    border-radius: var(--r-xs);
    color: var(--text);
  }

  .flow {
    display: grid;
    grid-template-columns: 60px 1fr;
    gap: 1rem;
    margin-bottom: 2.5rem;
  }
  .flow-num {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    color: var(--accent);
    padding-top: 0.4rem;
  }
  .flow-body h2 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    margin: 0 0 0.6rem;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
  }
  .flow-body p { color: var(--muted); margin: 0 0 0.85rem; }
  .flow-body .flow-sub { margin: 0.9rem 0 0.4rem; font-size: var(--fs-sm); }
  .flow-body .flow-sub strong { color: var(--text); }
  .flow-body .flow-sub code { font-family: var(--font-mono); }
  .flow-body .verify {
    margin-top: 0.9rem;
    padding: 0.75rem 0.95rem;
    border-left: 2px solid var(--accent);
    background: var(--surface);
    border-radius: var(--r-xs);
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .flow-body .verify strong { color: var(--text); }
  .flow-body a { color: var(--accent); }

  .code-row {
    display: grid;
    grid-template-columns: 1fr auto;
    gap: 0.4rem;
    align-items: start;
  }
  .codeblock {
    font-family: var(--font-mono);
    font-size: 12px;
    line-height: var(--lh-base);
    background: var(--obsidian);
    color: var(--linen);
    border: 0.5px solid var(--slag);
    border-radius: var(--r-md);
    padding: 0.85rem 1.1rem;
    overflow-x: auto;
    margin: 0;
