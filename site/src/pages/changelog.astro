---
/**
 * /changelog — Option C v2 layout: three full-width ARIA tabs, each with its
 * own colour identity, every section led by a rich card expanded on load.
 *
 *   Just Released → v1.8 open hero (accent) + v1.7 / v1.6 / v1.5 / v1.4.3
 *                   collapsed heroes (the "active" window) + compact release
 *                   cards (v1.4.2 ↓, older).
 *   Coming Next   → v1.9 distribution theme vote (relative bar-chart) — the
 *                   next slot; theme undecided, vote open.
 *   Planned       → v1.10/v1.11 grouped roadmap cards, then the request form.
 *
 * Voting is real: vote buttons carry data-vote-target=<id> and the client
 * script batches GET /api/votes then POSTs /api/votes/<id> per click (the
 * Worker dedups per-IP/day in KV). Votable ids:
 * OPC-170/173/174 (v1.9 distribution-theme options — these also drive the bar
 * chart), and OPC-18x (v1.10/v1.11 planned items). v1.8 shipped 2026-07-10, so
 * it has no vote buttons.
 *
 * Deep links (#v1-8/#v1-7/#v1-6/#v1-5 → Just Released; #v1-9 → Coming Next;
 * #v1-10/#v1-11 → Planned; #v1-4 → /coverage) are handled client-side:
 * the matching tab is activated, the target card expanded, and scrolled into
 * view.
 *
 * Accessibility: tablist with roving tabindex + arrow/Home/End keys; the
 * inactive panels are `hidden` (not a CSS slide — keeps the page Axe-clean);
 * each card is a button[aria-expanded] controlling an `inert` detail region.
 * The tab bar is deliberately NOT sticky — the global Header already is.
 */
import Base from "../layouts/Base.astro";
import RoadmapForm from "../components/RoadmapForm.astro";

// v1.7 "Seams & Signals" — shipped release. Three new skills take the catalog
// 24 → 27, lockstep-bumped to 1.7.0. Per the plan of record, oc-signal-forge
// lands first as 1.7; the oc-modularize-ops → oc-fleet-ops chain follows in
// 1.7.1. Source: docs/releases/1.7-plan.md.
const v17Skills = [
  {
    name: "oc-signal-forge",
    command: "/oc-signal",
    tag: "1.7",
    blurb:
      "Question → trustworthy metric. Designs the instrumentation, builds the harvester + transform, and adversarially proves the signal answers the question before wiring it to oc-dash-forge. The product-analytics backend none of the instrumentation skills owned.",
  },
  {
    name: "oc-modularize-ops",
    command: "/oc-modularize",
    tag: "1.7.1",
    blurb:
      'Decompose a live monolith with provably zero functionality/data loss — golden fixtures captured from real traffic as the equivalence oracle. Willing to say "don\'t." Hands the code-move + cutover to oc-migration-ops and deploy to oc-fleet-ops.',
  },
  {
    name: "oc-fleet-ops",
    command: "/oc-fleet",
    tag: "1.7.1",
    blurb:
      "Provision, deploy, and operate one-or-more containers across self-managed infra (k8s/Nomad/Compose, IaC, on-prem VMs, GCE). Terraform when it fits, not by reflex. Claims the bare-metal/VPS territory oc-deploy-ops routes away — its peer, not its rival.",
  },
];

