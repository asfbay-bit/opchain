---
/**
 * /changelog — Option C v3 layout: two ARIA tabs (Just Released · Coming
 * Next), each led by a rich hero card, with the most relevant card in each
 * section expanded on load.
 *
 *   Just Released → v1.4.2 hero (accent) + compact release cards (v1.4 ↓).
 *   Coming Next   → v1.5 hero (info) + the v1.6 / v1.7 roadmap, then the
 *                   feature-request form.
 *
 * Voting is real: vote buttons carry data-vote-target=<id> and the client
 * script batches GET /api/votes then POSTs /api/votes/<id> per click (the
 * Worker dedups per-IP/day in KV). The votable ids come from
 * roadmap-static.ts — OPC-150 (v1.5) and the per-feature OPC-16x / OPC-17x
 * items grouped by milestone below.
 *
 * Deep links (#v1-5 / #v1-6 / #v1-7 from the skill pages and external
 * links, #v1-4 → /coverage) are handled client-side: the matching tab is
 * activated, the target card expanded, and scrolled into view.
 *
 * Accessibility: tablist with roving tabindex + arrow/Home/End keys;
 * inactive panel is `hidden`; each card is a button[aria-expanded] that
 * controls its detail region (inert while collapsed so its links/votes
 * aren't reachable by keyboard).
 */
import Base from "../layouts/Base.astro";
import RoadmapForm from "../components/RoadmapForm.astro";
import { staticRoadmap } from "../data/roadmap-static";
import type { RoadmapItem } from "../data/roadmap-types";

// v1.5 is the single in-progress milestone (built, shipping next).
const v15 =
  staticRoadmap.items["in-progress"].find((i) => i.milestone === "v1.5") ?? null;

// Group the planned items by milestone, preserving source order.
const plannedByMilestone = new Map<string, RoadmapItem[]>();
for (const it of staticRoadmap.items.planned) {
  const key = it.milestone ?? "Later";
  const arr = plannedByMilestone.get(key) ?? [];
  arr.push(it);
  plannedByMilestone.set(key, arr);
}
const v16Items = plannedByMilestone.get("v1.6") ?? [];
const v17Items = plannedByMilestone.get("v1.7") ?? [];
---

<Base
  title="Changelog · opchain"
  description="Release notes for opchain — what shipped, when, and how to migrate. Plus what's shipping next and the live, votable roadmap."
  active="/changelog"
>
  <main class="page">
    <div class="page-head">
      <span class="eyebrow">changelog</span>
      <h1>Changelog.</h1>
      <p class="lede">
        What shipped, what's next, and what to do about it. Each skill's
        <code>version</code> field is the source of truth — this page rolls
        them up by release. Vote on what's coming to signal priority.
      </p>
    </div>

    <!-- ══ TAB BAR ══════════════════════════════════════════ -->
    <div class="tab-bar">
      <div class="tab-list" role="tablist" aria-label="Changelog sections" data-changelog-tabs>
        <button
          class="tab-btn"
          role="tab"
          id="tab-released"
          aria-controls="panel-released"
          aria-selected="true"
          tabindex="0"
        >
          Just Released <span class="tab-count">6 shipped</span>
        </button>
        <button
          class="tab-btn tab-btn--next"
          role="tab"
          id="tab-coming"
          aria-controls="panel-coming"
          aria-selected="false"
          tabindex="-1"
        >
          Coming Next <span class="tab-count">v1.5 → v1.7</span>
        </button>
      </div>
      <span class="tab-indicator" data-tab-indicator aria-hidden="true"></span>
    </div>

    <!-- ══ PANEL 0 — JUST RELEASED ═══════════════════════════ -->
    <section
      class="tab-panel"
      role="tabpanel"
      id="panel-released"
      aria-labelledby="tab-released"
      tabindex="0"
    >
      <div class="panel-head">
        <h2>What shipped</h2>
        <span class="panel-sub">Newest is open; click any release for full notes.</span>
      </div>

      <!-- v1.4.2 — newest, AUTO-OPEN; mirrors the v1.5 hero, accent-themed -->
      <article class="hero-card hero-card--released is-open" id="v1-4-2" data-card>
        <button
          class="hero-head"
          type="button"
          aria-expanded="true"
          aria-controls="v1-4-2-body"
          data-disclosure-toggle
        >
          <span class="hero-chevron" aria-hidden="true">▶</span>
          <span class="hero-badge">latest release</span>
          <span class="hero-ver">v1.4.2 · shipped Jun 05, 2026</span>
          <span class="hero-title">Complete bundles, honest checkpoints</span>
          <span class="hero-desc">
            An out-of-band emergency patch: one user-facing breakage and a
            long-overdue correctness pass, shipped ahead of v1.5. The
            &ldquo;download all&rdquo; bundle was shipping only each skill's
            <code>SKILL.md</code>, silently dropping the
            <code>references/</code>, <code>scripts/</code>, and
            <code>examples/</code> that make a skill actually run.
          </span>
        </button>
        <div class="card-body" id="v1-4-2-body" data-disclosure-body>
          <div class="card-body-inner hero-body-inner">
            <h3>What's new</h3>
            <div class="tile-grid">
              <div class="tile">
                <span class="tile-name">complete bundles</span>
                <p class="tile-desc">
                  &ldquo;Download all&rdquo; ships full skill trees again —
                  <code>opchain-skills.zip</code> now matches the per-skill
                  downloads on <a href="/skills">/skills</a>, references /
                  scripts / examples included.
                </p>
              </div>
              <div class="tile">
                <span class="tile-name">oc- canonical names</span>
                <p class="tile-desc">
                  Every skill gains an <code>oc-&lt;name&gt;</code> alias so
                  opchain skills are unambiguous next to same-named local
                  skills. Bare names still resolve.
                </p>
              </div>
              <div class="tile">
                <span class="tile-name">honest orchestrator</span>
                <p class="tile-desc">
                  Persistence docs rewritten to the git-tracked checkpoint it
                  actually uses; the phantom <code>checkpoint.sh</code> is
                  replaced by <code>scripts/checkpoint.mjs</code>.
                </p>
              </div>
              <div class="tile">
                <span class="tile-name">one checkpoint schema</span>
                <p class="tile-desc">
                  Validator, spec, and README agree on a single wire schema,
                  with timestamp-sanity and referential checks enforced.
                </p>
              </div>
              <div class="tile">
                <span class="tile-name">drift detection</span>
                <p class="tile-desc">
                  Automated drift detection so a stale checkpoint can no
                  longer tell future-you to redo work that already shipped.
                </p>
              </div>
            </div>

            <div class="callout">
              <h3>New CLI commands</h3>
              <ul class="callout-list">
                <li>
                  <strong>checkpoint:doctor</strong> — cross-checks checkpoints
                  against <code>git log</code> + live <code>/api/health</code>,
                  flags drift.
                </li>
                <li>
                  <strong>checkpoint:next</strong> — &ldquo;what should I do
                  next&rdquo; for the local project.
                </li>
                <li>
                  <strong>checkpoint:status --brief / --since</strong> — terse
                  resume view + a momentum digest.
                </li>
                <li>
                  <strong>checkpoint:init</strong> — deterministic cold-start
                  scaffold.
                </li>
              </ul>
            </div>

            <div class="compat-box">
              <strong>Back-compatible with v1.4.</strong> The <code>oc-</code>
              names are additive aliases. All 18 skills lockstep-bump to
              <code>1.4.2</code>.
            </div>
          </div>
        </div>
      </article>

      <div class="divider"><span class="divider-line"></span><span class="divider-label">earlier releases</span><span class="divider-line"></span></div>

      <!-- v1.4 — past; keeps id + /coverage deep-link -->
      <article class="rel-card" id="v1-4" data-card>
        <button class="rc-row" type="button" aria-expanded="false" aria-controls="v1-4-body" data-disclosure-toggle>
          <span class="rc-toggle" aria-hidden="true">▶</span>
          <span class="rc-meta">
            <span class="rc-head"><span class="ver-pill ver-pill--past">v1.4</span><span class="rc-title">Coverage as a plugin registry</span><span class="rc-date">May 12, 2026</span></span>
            <span class="rc-summary">32 packs across 13 languages, 9 frameworks, 4 mobile platforms, 6 deploy targets. One <code>pack.yml</code> per pack, validated on every build.</span>
          </span>
        </button>
        <div class="card-body" id="v1-4-body" data-disclosure-body inert>
          <div class="card-body-inner">
            <div class="tag-row"><span class="tag">pack registry</span><span class="tag">32 packs</span><span class="tag">5 skills bumped</span></div>
            <p>
              v1.4 turns <code>oc-stack-forge</code>'s coverage from hardcoded
              prose into a versioned pack registry — one <code>pack.yml</code>
              per language, framework, mobile platform, or deploy target,
              validated on every build. <a href="/coverage">/coverage</a> is
              the user-visible catalog; total coverage grows from 6 stacks in
              v1.3 to 32 packs.
            </p>
            <h3>What's new</h3>
            <ul>
              <li><strong>Pack registry architecture.</strong> <code>scripts/gen-stack-packs.mjs</code> validates every pack on every build.</li>
              <li><strong>Hybrid dispatch.</strong> <code>oc-deploy-ops</code> reads packs at runtime; <code>oc-api-dev</code> reads them at build time for typed scaffold metadata.</li>
              <li><strong>Modern web + enterprise + mobile bulk.</strong> elixir / bun / deno / java / csharp / kotlin / php / swift packs; phoenix / remix / sveltekit / solid / spring / dotnet / laravel frameworks; iOS / Android / Flutter / React-Native mobile packs.</li>
              <li><strong>Hosting adapters.</strong> railway / netlify / heroku / aws-amplify deploy-target packs.</li>
            </ul>
            <div class="compat-box"><strong>Back-compatible with v1.3.</strong> Five skills bump in lockstep to <code>1.4.0</code>.</div>
          </div>
        </div>
      </article>

      <!-- v1.3 -->
      <article class="rel-card" id="v1-3" data-card>
        <button class="rc-row" type="button" aria-expanded="false" aria-controls="v1-3-body" data-disclosure-toggle>
          <span class="rc-toggle" aria-hidden="true">▶</span>
          <span class="rc-meta">
            <span class="rc-head"><span class="ver-pill ver-pill--past">v1.3</span><span class="rc-title">Runtime PM, real platforms, automated releases</span><span class="rc-date">May 11, 2026</span></span>
            <span class="rc-summary">PM-MCP loop executable end-to-end. <code>oc-release-ops</code> ships as the 18th skill. Platform menu expands.</span>
          </span>
        </button>
        <div class="card-body" id="v1-3-body" data-disclosure-body inert>
          <div class="card-body-inner">
            <div class="tag-row"><span class="tag">oc-release-ops</span><span class="tag">18th skill</span><span class="tag">PM-MCP live</span></div>
            <p>v1.3 makes the v1.2 PM-MCP prose executable end-to-end and ships <code>oc-release-ops</code> — the 18th skill — to automate the scope → /changelog → bump → ship cadence opchain uses for itself.</p>
            <h3>What's new</h3>
            <ul>
              <li><strong>The PM-MCP loop is real.</strong> Concrete tool-name registry, retry/backoff, idempotency markers, deferred-action queue.</li>
              <li><strong><code>oc-release-ops</code> is the 18th skill.</strong> <code>/oc-release plan|draft|bump|announce|ship</code>: reads checkpoints to propose the next semver, drafts the changelog entry, bumps all skill versions atomically.</li>
              <li><strong>Platform menu grew.</strong> Django + Postgres + Render, Rails + Postgres + Heroku, Go + Fly.io, Rust + Axum + Shuttle.rs.</li>
            </ul>
            <div class="compat-box"><strong>Back-compatible with v1.2.</strong> All 18 skills lockstep at <code>1.3.0</code>.</div>
          </div>
        </div>
      </article>

      <!-- v1.2 -->
      <article class="rel-card" id="v1-2" data-card>
        <button class="rc-row" type="button" aria-expanded="false" aria-controls="v1-2-body" data-disclosure-toggle>
          <span class="rc-toggle" aria-hidden="true">▶</span>
          <span class="rc-meta">
            <span class="rc-head"><span class="ver-pill ver-pill--past">v1.2</span><span class="rc-title">PM-tool MCP integration</span><span class="rc-date">May 05, 2026</span></span>
            <span class="rc-summary">Linear, Jira, and GitHub Issues become first-class context for four skills.</span>
          </span>
        </button>
        <div class="card-body" id="v1-2-body" data-disclosure-body inert>
          <div class="card-body-inner">
            <div class="tag-row"><span class="tag">PM-MCP</span><span class="tag">Linear</span><span class="tag">Jira</span></div>
            <p>The ticket becomes the thread of execution. <code>oc-app-architect</code>, <code>oc-git-ops</code>, <code>oc-deploy-ops</code>, and <code>oc-monitoring-ops</code> all become PM-tool aware.</p>
            <div class="compat-box"><strong>Back-compatible with v1.1.</strong> The PM loop is enrichment, never a hard dependency.</div>
          </div>
        </div>
      </article>

      <!-- v1.1 -->
      <article class="rel-card" id="v1-1" data-card>
        <button class="rc-row" type="button" aria-expanded="false" aria-controls="v1-1-body" data-disclosure-toggle>
          <span class="rc-toggle" aria-hidden="true">▶</span>
          <span class="rc-meta">
            <span class="rc-head"><span class="ver-pill ver-pill--past">v1.1</span><span class="rc-title">Stable release</span><span class="rc-date">Apr 2026</span></span>
            <span class="rc-summary">Tri-agent harness, full pipeline, oc-checkpoint-protocol v1.0. Six in-action scenarios.</span>
          </span>
        </button>
        <div class="card-body" id="v1-1-body" data-disclosure-body inert>
          <div class="card-body-inner">
            <p>Tri-agent harness across <code>oc-app-architect</code>, <code>oc-code-auditor</code>, <code>oc-integrations-engineer</code>; full-pipeline flow from <code>/oc-discover</code> to <code>/oc-deploy</code>; oc-checkpoint-protocol v1.0 across every skill; static Astro site; first set of six in-action scenarios.</p>
          </div>
        </div>
      </article>

      <!-- v1.0 -->
      <article class="rel-card" id="v1-0" data-card>
        <button class="rc-row" type="button" aria-expanded="false" aria-controls="v1-0-body" data-disclosure-toggle>
          <span class="rc-toggle" aria-hidden="true">▶</span>
          <span class="rc-meta">
            <span class="rc-head"><span class="ver-pill ver-pill--past">v1.0</span><span class="rc-title">Initial release</span><span class="rc-date">Feb 2026</span></span>
            <span class="rc-summary">First public Markdown skill catalog for Claude Code. The foundation everything since has built on.</span>
          </span>
        </button>
        <div class="card-body" id="v1-0-body" data-disclosure-body inert>
          <div class="card-body-inner">
            <p>First public cut of the opchain skill catalog as a set of Markdown files installable into Claude Code. No site, no scenarios — just the skills.</p>
          </div>
        </div>
      </article>
    </section>

    <!-- ══ PANEL 1 — COMING NEXT ═════════════════════════════ -->
    <section
      class="tab-panel"
      role="tabpanel"
      id="panel-coming"
      aria-labelledby="tab-coming"
      tabindex="0"
      hidden
    >
      <div class="panel-head">
        <h2>What's coming</h2>
        <span class="panel-sub">v1.5 ships next; v1.6 / v1.7 are the roadmap. Vote to signal priority.</span>
      </div>

      <!-- v1.5 — next release, AUTO-OPEN, rich hero (info-themed) -->
      <article class="hero-card hero-card--next is-open" id="v1-5" data-card>
        <button
          class="hero-head"
          type="button"
          aria-expanded="true"
          aria-controls="v1-5-body"
          data-disclosure-toggle
        >
          <span class="hero-chevron" aria-hidden="true">▶</span>
          <span class="hero-badge">building now</span>
          <span class="hero-ver">v1.5.0 · ships next</span>
          <span class="hero-title">Build the AI app</span>
          <span class="hero-desc">
            v1.5 closes the biggest categorical gap in the catalog: nothing
            today owns <em>AI-feature</em> design. Four new AI-native skills
            ship wired through the existing pipeline — model routing, RAG,
            agent harnesses, and prompts as first-class version-controlled
            artifacts.
          </span>
        </button>
        <div class="card-body" id="v1-5-body" data-disclosure-body>
          <div class="card-body-inner hero-body-inner">
            <h3>Four new skills</h3>
            <div class="tile-grid">
              <div class="tile">
                <span class="tile-name">claude-api · /claude-api</span>
                <p class="tile-desc">Model routing (Opus/Sonnet/Haiku), prompt caching by default, streaming vs. batch, tool use, and migration playbooks for model-version bumps.</p>
              </div>
              <div class="tile">
                <span class="tile-name">rag-forge · /rag</span>
                <p class="tile-desc">Tri-agent. Vector-DB decision tree, embedding choice, chunking, hybrid search, and retrieval eval with golden sets and recall@k / NDCG.</p>
              </div>
              <div class="tile">
                <span class="tile-name">agent-forge · /agent</span>
                <p class="tile-desc">Tri-agent. Claude Agent SDK scaffold, subagent topology, tool-budget design, harness-loop shapes, and eval over golden trajectories.</p>
              </div>
              <div class="tile">
                <span class="tile-name">prompt-ops · /prompt</span>
                <p class="tile-desc">Prompts as artifacts: file-shaped versioning, eval datasets, regression detection. <code>/prompt regress</code> blocks on a PR drop.</p>
              </div>
            </div>

            <div class="callout">
              <h3>Cross-skill ripples</h3>
              <ul class="callout-list">
                <li><strong>oc-app-architect</strong> gains an &ldquo;AI app?&rdquo; branch in <code>/oc-discover</code> that routes to the four new skills.</li>
                <li><strong>oc-stack-forge</strong> adds vector-DB packs (pgvector, Turbopuffer, Pinecone, Supabase Vectors) to the pack registry.</li>
                <li><strong>oc-code-auditor</strong> learns prompt-injection and tool-use safety rules.</li>
              </ul>
            </div>

            <div class="compat-box">
              <strong>Back-compatible with v1.4.</strong> All 22 skills version-bump
              to <code>1.5.0</code>; the four new skills ship gated behind their
              <code>skills.registry.&lt;id&gt;.enabled</code> flags.
            </div>

            {v15 && (
              <div class="vote-row">
                <button
                  class="vote-btn"
                  type="button"
                  data-vote-target={v15.id}
                  aria-label={`Vote for ${v15.title}`}
                >
                  <span class="v-arrow" aria-hidden="true">▲</span>
                  <span class="v-count" data-vote-count>—</span>
                  <span class="v-label" data-vote-label>vote</span>
                </button>
                <span class="vote-note">Shipping next — vote to signal priority.</span>
              </div>
            )}
          </div>
        </div>
      </article>

      <div class="divider"><span class="divider-line"></span><span class="divider-label">on the roadmap</span><span class="divider-line"></span></div>

      <!-- v1.6 — first roadmap item, AUTO-OPEN -->
      <article class="plan-card is-open" id="v1-6" data-card>
        <button class="pc-row" type="button" aria-expanded="true" aria-controls="v1-6-body" data-disclosure-toggle>
          <span class="pc-toggle" aria-hidden="true">▶</span>
          <span class="pc-meta">
            <span class="pc-head"><span class="ver-pill ver-pill--next">v1.6</span><span class="pc-title">The instrumented pipeline</span><span class="pc-timing">est. Jul 2026</span></span>
            <span class="pc-summary">Cost attribution, opt-in telemetry, and the first oc-checkpoint-protocol bump since v1.2. Answers &ldquo;what did this feature cost?&rdquo;</span>
          </span>
        </button>
        <div class="card-body" id="v1-6-body" data-disclosure-body>
          <div class="card-body-inner">
            <div class="tag-row"><span class="tag tag--info">planned</span><span class="tag">est. Jul 2026</span><span class="tag">2 new skills</span></div>
            <p>v1.5 introduces four AI-native skills; the predictable next question is <em>what did they cost, and is my pipeline actually getting better?</em> v1.6 answers both — cost attribution and opt-in telemetry, plus the first <code>oc-checkpoint-protocol</code> bump since v1.2 (adds <code>cost</code>, <code>eval_scores</code>, <code>telemetry_handle</code>).</p>
            <h3>What's planned — vote on what matters most</h3>
            <ul class="vote-list">
              {v16Items.map((it) => (
                <li class="vote-item">
                  <div class="vote-item-meta">
                    <span class="vote-item-title">{it.title}</span>
                    <p class="vote-item-blurb">{it.blurb}</p>
                  </div>
                  <button
                    class="vote-btn"
                    type="button"
                    data-vote-target={it.id}
                    aria-label={`Vote for ${it.title}`}
                  >
                    <span class="v-arrow" aria-hidden="true">▲</span>
                    <span class="v-count" data-vote-count>—</span>
                    <span class="v-label" data-vote-label>vote</span>
                  </button>
                </li>
              ))}
            </ul>
            <div class="planned-box">Planned — scope may shift before release. All 24 skills lockstep-bump to <code>1.6.0</code>.</div>
          </div>
        </div>
      </article>

      <!-- v1.7 — collapsed by default -->
      <article class="plan-card" id="v1-7" data-card>
        <button class="pc-row" type="button" aria-expanded="false" aria-controls="v1-7-body" data-disclosure-toggle>
          <span class="pc-toggle" aria-hidden="true">▶</span>
          <span class="pc-meta">
            <span class="pc-head"><span class="ver-pill ver-pill--next">v1.7</span><span class="pc-title">Pick one distribution play</span><span class="pc-timing">lean: marketplace + templates</span></span>
            <span class="pc-summary">By v1.6, opchain has 24 skills and AI coverage. The biggest remaining gap is distribution — v1.7 promotes one growth play into a flagship theme.</span>
          </span>
        </button>
        <div class="card-body" id="v1-7-body" data-disclosure-body inert>
          <div class="card-body-inner">
            <div class="tag-row"><span class="tag tag--info">planned</span><span class="tag">est. Sep 2026</span></div>
            <p>By the time v1.6 ships, the biggest remaining gap isn't features — it's <strong>distribution</strong>. v1.7 deliberately promotes one growth play into a flagship theme instead of accreting more skills. The current lean is marketplace + templates.</p>
            <h3>The lean plan — vote on what matters most</h3>
            <ul class="vote-list">
              {v17Items.map((it) => (
                <li class="vote-item">
                  <div class="vote-item-meta">
                    <span class="vote-item-title">{it.title}</span>
                    <p class="vote-item-blurb">{it.blurb}</p>
                  </div>
                  <button
                    class="vote-btn"
                    type="button"
                    data-vote-target={it.id}
                    aria-label={`Vote for ${it.title}`}
                  >
                    <span class="v-arrow" aria-hidden="true">▲</span>
                    <span class="v-count" data-vote-count>—</span>
                    <span class="v-label" data-vote-label>vote</span>
                  </button>
                </li>
              ))}
            </ul>
            <p class="alt-note">
              Alternatives on the table: an <strong>agency play</strong>
              (<code>monorepo-ops</code>, <code>/for-agencies</code>) and
              <strong>pipeline depth</strong> (<code>discovery-ops</code>,
              <code>qa-ops</code>).
            </p>
            <div class="planned-box">Lean, not locked — the final v1.7 theme is chosen after the v1.5 / v1.6 retro.</div>
          </div>
        </div>
      </article>

      <div class="divider"><span class="divider-line"></span><span class="divider-label">backlog</span><span class="divider-line"></span></div>
      <p class="backlog-note">Backlog is deliberately open until v1.5 and v1.6 ship and the retros are done. Use the form below to add to it.</p>

      <RoadmapForm />
    </section>

    <p class="footer-note">
      Skill versions are stamped in <code>skills/&lt;name&gt;/SKILL.md</code>
      under <code>version:</code>; this page rolls them up by release.
    </p>
  </main>
</Base>

<script>
  (() => {
    // ===== Disclosure (cards) ==========================================
    const cardSel = ".rel-card, .plan-card, .hero-card";
    function setOpen(card: HTMLElement, open: boolean) {
      const btn = card.querySelector<HTMLButtonElement>("[data-disclosure-toggle]");
      const body = card.querySelector<HTMLElement>("[data-disclosure-body]");
      card.classList.toggle("is-open", open);
      if (btn) btn.setAttribute("aria-expanded", String(open));
      if (body) {
        if (open) body.removeAttribute("inert");
        else body.setAttribute("inert", "");
      }
    }
    document
      .querySelectorAll<HTMLButtonElement>("[data-disclosure-toggle]")
      .forEach((btn) => {
        btn.addEventListener("click", () => {
          const card = btn.closest<HTMLElement>(cardSel);
          if (card) setOpen(card, !card.classList.contains("is-open"));
        });
      });

    // ===== Tabs (ARIA tablist, roving tabindex) ========================
    const tablist = document.querySelector<HTMLElement>("[data-changelog-tabs]");
    const tabs = tablist
      ? Array.from(tablist.querySelectorAll<HTMLButtonElement>('[role="tab"]'))
      : [];
    const indicator = document.querySelector<HTMLElement>("[data-tab-indicator]");
    const panelOf = (tab: HTMLButtonElement) =>
      document.getElementById(tab.getAttribute("aria-controls") || "");

    function moveIndicator(tab: HTMLButtonElement) {
      if (!indicator) return;
      indicator.style.left = `${tab.offsetLeft}px`;
      indicator.style.width = `${tab.offsetWidth}px`;
      indicator.dataset.active = String(tabs.indexOf(tab));
    }
    function activateTab(tab: HTMLButtonElement, focus = false) {
      for (const t of tabs) {
        const selected = t === tab;
        t.setAttribute("aria-selected", String(selected));
        t.tabIndex = selected ? 0 : -1;
        const p = panelOf(t);
        if (p) p.hidden = !selected;
      }
      moveIndicator(tab);
      if (focus) tab.focus();
    }
    if (tablist) {
      tablist.addEventListener("click", (e) => {
        const tab = (e.target as HTMLElement).closest<HTMLButtonElement>('[role="tab"]');
        if (tab) activateTab(tab);
      });
      tablist.addEventListener("keydown", (e) => {
        const i = tabs.indexOf(document.activeElement as HTMLButtonElement);
        if (i < 0) return;
        let j = i;
        switch (e.key) {
          case "ArrowRight": j = (i + 1) % tabs.length; break;
          case "ArrowLeft": j = (i - 1 + tabs.length) % tabs.length; break;
          case "Home": j = 0; break;
          case "End": j = tabs.length - 1; break;
          default: return;
        }
        e.preventDefault();
        activateTab(tabs[j], true);
      });
      window.addEventListener("resize", () => {
        const sel = tabs.find((t) => t.getAttribute("aria-selected") === "true");
        if (sel) moveIndicator(sel);
      });
      const sel0 = tabs.find((t) => t.getAttribute("aria-selected") === "true") ?? tabs[0];
      if (sel0) moveIndicator(sel0);
    }

    // ===== Deep links (#v1-5 etc.) — open the right tab + card =========
    function tabForCard(card: HTMLElement): HTMLButtonElement | null {
      const panel = card.closest<HTMLElement>('[role="tabpanel"]');
      if (!panel) return null;
      return tabs.find((t) => t.getAttribute("aria-controls") === panel.id) ?? null;
    }
    function revealHash(hash: string) {
      if (!hash || hash.length < 2) return;
      let card: HTMLElement | null = null;
      try {
        card = document.querySelector<HTMLElement>(`${hash}[data-card]`);
      } catch {
        card = null;
      }
      if (!card) return;
      const tab = tabForCard(card);
      if (tab) activateTab(tab);
      setOpen(card, true);
      requestAnimationFrame(() =>
        card?.scrollIntoView({ behavior: "smooth", block: "start" }),
      );
    }
    document.addEventListener("click", (e) => {
      const a = (e.target as HTMLElement).closest<HTMLAnchorElement>("a");
      if (!a) return;
      const m = (a.getAttribute("href") || "").match(/#(v1-[0-9-]+)$/);
      if (!m) return;
      const url = new URL(a.href, location.href);
      if (url.pathname !== location.pathname && url.pathname !== "/changelog") return;
      const sel = `#${m[1]}`;
      let card: HTMLElement | null = null;
      try {
        card = document.querySelector<HTMLElement>(`${sel}[data-card]`);
      } catch {
        card = null;
      }
      if (!card) return;
      e.preventDefault();
      history.replaceState(null, "", sel);
      revealHash(sel);
    });
    window.addEventListener("hashchange", () => revealHash(location.hash));
    if (location.hash) revealHash(location.hash);

    // ===== Votes (batched GET + per-click POST; localStorage mirror) ===
    const voteButtons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-vote-target]"),
    );
    if (voteButtons.length) {
      const lsKey = (id: string) => `opchain-roadmap-voted:${id}`;
      const setCount = (btn: HTMLButtonElement, n: number) => {
        const el = btn.querySelector<HTMLElement>("[data-vote-count]");
        if (el) el.textContent = String(n);
      };
      const setVoted = (btn: HTMLButtonElement, voted: boolean) => {
        btn.classList.toggle("voted", voted);
        const l = btn.querySelector<HTMLElement>("[data-vote-label]");
        if (l) l.textContent = voted ? "voted" : "vote";
      };
      for (const btn of voteButtons) {
        const id = btn.dataset.voteTarget;
        if (id && localStorage.getItem(lsKey(id)) === "1") setVoted(btn, true);
      }
      const ids = voteButtons.map((b) => b.dataset.voteTarget ?? "").filter(Boolean);
      (async () => {
        try {
          const res = await fetch(`/api/votes?ids=${encodeURIComponent(ids.join(","))}`, {
            headers: { Accept: "application/json" },
          });
          if (res.ok) {
            const data = (await res.json()) as { counts: Record<string, number> };
            for (const btn of voteButtons) {
              setCount(btn, data.counts[btn.dataset.voteTarget ?? ""] ?? 0);
            }
          } else {
            for (const btn of voteButtons) setCount(btn, 0);
          }
        } catch {
          for (const btn of voteButtons) setCount(btn, 0);
        }
      })();
      for (const btn of voteButtons) {
        btn.addEventListener("click", async () => {
          const id = btn.dataset.voteTarget;
          if (!id) return;
          const countEl = btn.querySelector<HTMLElement>("[data-vote-count]");
          const previous = parseInt(countEl?.textContent || "0", 10) || 0;
          const optimistic = btn.classList.contains("voted") ? previous : previous + 1;
          setCount(btn, optimistic);
          setVoted(btn, true);
          btn.disabled = true;
          try {
            const res = await fetch(`/api/votes/${encodeURIComponent(id)}`, {
              method: "POST",
              headers: { "Content-Type": "application/json" },
              body: JSON.stringify({}),
            });
            if (res.ok) {
              const data = (await res.json()) as { ok: boolean; count: number };
              setCount(btn, data.count);
              localStorage.setItem(lsKey(id), "1");
              setVoted(btn, true);
            } else {
              setCount(btn, previous);
              setVoted(btn, localStorage.getItem(lsKey(id)) === "1");
            }
          } catch {
            setCount(btn, previous);
          } finally {
            btn.disabled = false;
          }
        });
      }
    }
  })();
</script>

