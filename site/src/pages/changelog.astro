// Planned release groups beyond v1.9. Votable to signal priority; fresh vote
// keys (OPC-18x), independent of any Linear identifier.
const futureReleaseGroups = [
  {
    version: "v1.10",
    id: "v1-10",
    title: "Install and operate anywhere",
    timing: "planned after v1.9",
