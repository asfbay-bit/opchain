---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Card from "../components/ui/Card.astro";

type Verdict = "good" | "partial" | "bad" | "info";

interface Cell {
  v: string;
  note?: string | null;
  /** Heatmap classification. Tints the cell background + prefixes a
   *  small status icon. opchain cells override the heat tint with the
   *  ember-hero treatment, so the verdict is still useful for accent
   *  parity but visually overridden. Omit for "no opinion" cells. */
  verdict?: Verdict;
}

interface Platform {
  name: string;
  /** Marks opchain — ember accent column header + cells */
  accent?: boolean;
  /** Always-on; not exposed as a chip and never removable */
  fixed?: boolean;
  /** Surfaces a "review" badge in the column header (e.g. for un-vetted content) */
  needsReview?: boolean;
  cells: Record<string, Cell>;
}

interface Feature {
  id: string;
  label: string;
}

const FEATURES: Feature[] = [
  { id: "prompts",     label: "Where the prompts live" },
  { id: "session",     label: "Session persistence" },
  { id: "pipeline",    label: "Pipeline awareness" },
  { id: "tri-agent",   label: "Tri-agent quality loops" },
  { id: "gates",       label: "Audit gates before deploy" },
  { id: "cost",        label: "Cost" },
  { id: "lockin",      label: "Vendor lock-in" },
  { id: "runs-on",     label: "Where it runs" },
  { id: "extend",      label: "Adding your own" },
  { id: "multi-proj",  label: "Multi-project status" },
];

const PLATFORMS: Record<string, Platform> = {
  opchain: {
    name: "opchain", accent: true, fixed: true,
    cells: {
      "prompts":    { v: "Markdown files in .claude/skills/", note: "MIT, in your repo, plain text — diffable, reviewable", verdict: "good" },
      "session":    { v: "JSON checkpoints in .checkpoints/", note: "Survive across chats; auto-resume next session", verdict: "good" },
      "pipeline":   { v: "Yes — orchestrator routes between 18 skills", note: "Knows what phase you're in and what's next", verdict: "good" },
      "tri-agent":  { v: "5 skills (app-architect, code-auditor, integrations-engineer, api-dev, ux-engineer)", note: "Planner → Generator → Evaluator built in", verdict: "good" },
      "gates":      { v: "Three (bug-check, code-auditor, security-auditor)", note: "deploy-ops blocks prod if any gate fails", verdict: "good" },
      "cost":       { v: "Free, MIT", note: "Pay only your Claude usage", verdict: "good" },
      "lockin":     { v: "None — every skill is one Markdown file", note: "Fork, edit, fork again", verdict: "good" },
      "runs-on":    { v: "Claude Code · Claude.ai · Claude Desktop", verdict: "good" },
      "extend":     { v: "Write a SKILL.md, drop it in .claude/skills/", note: "reverse-spec backfills one from existing code", verdict: "good" },
      "multi-proj": { v: "/ops command shows every project's last checkpoint", note: "Cross-repo dashboard built in", verdict: "good" },
    },
  },
  claude: {
    name: "Claude defaults", fixed: true,
    cells: {
      "prompts":    { v: "CLAUDE.md (single file)", note: "All-or-nothing", verdict: "partial" },
      "session":    { v: "Single CLAUDE.md context", note: "Re-read on every session", verdict: "partial" },
      "pipeline":   { v: "No", verdict: "bad" },
      "tri-agent":  { v: "No", verdict: "bad" },
      "gates":      { v: "No", verdict: "bad" },
      "cost":       { v: "Free", verdict: "good" },
      "lockin":     { v: "Claude-coupled", note: "But trivial to migrate", verdict: "partial" },
      "runs-on":    { v: "Anywhere Claude runs", verdict: "good" },
      "extend":     { v: "Edit CLAUDE.md", verdict: "good" },
      "multi-proj": { v: "No", verdict: "bad" },
    },
  },
  cursor: {
    name: "Cursor",
    cells: {
      "prompts":    { v: ".cursorrules / .mdc rules", note: "Per-project, editor-coupled", verdict: "partial" },
      "session":    { v: "Per-chat memory; no formal protocol", verdict: "partial" },
      "pipeline":   { v: "No — rules apply globally", verdict: "bad" },
      "tri-agent":  { v: "No", verdict: "bad" },
      "gates":      { v: "No", verdict: "bad" },
      "cost":       { v: "$20–40 / user / mo", verdict: "info" },
      "lockin":     { v: "IDE-coupled", note: "Rules only run inside Cursor", verdict: "bad" },
      "runs-on":    { v: "Cursor IDE", verdict: "partial" },
      "extend":     { v: "Write a .cursorrules file", verdict: "good" },
      "multi-proj": { v: "No", verdict: "bad" },
    },
  },
  copilot: {
    name: "GH Copilot",
    cells: {
      "prompts":    { v: ".github/copilot-instructions.md + hosted instructions", note: "Vendor-managed", verdict: "partial" },
      "session":    { v: "Per-IDE-session", verdict: "partial" },
      "pipeline":   { v: "No — chat is single-turn-ish", verdict: "bad" },
      "tri-agent":  { v: "No", verdict: "bad" },
      "gates":      { v: "No", verdict: "bad" },
      "cost":       { v: "$10–39 / user / mo", verdict: "info" },
      "lockin":     { v: "GitHub-coupled", note: "Runs against the Copilot service", verdict: "bad" },
      "runs-on":    { v: "VS Code · JetBrains · GitHub.com", verdict: "partial" },
      "extend":     { v: "Edit copilot-instructions.md", verdict: "good" },
      "multi-proj": { v: "No", verdict: "bad" },
    },
  },
  devin: {
    name: "Devin",
    cells: {
      "prompts":    { v: "Hosted, internal", note: "Black box", verdict: "bad" },
      "session":    { v: "Hosted task state", note: "Tied to a Devin task, not your repo", verdict: "good" },
      "pipeline":   { v: "Yes, but as one monolithic agent", verdict: "partial" },
      "tri-agent":  { v: "Implicit", note: "Not surfaced as a contract", verdict: "partial" },
      "gates":      { v: "Internal checks", note: "No external contract", verdict: "partial" },
      "cost":       { v: "$500 / mo seat (last published)", verdict: "info" },
      "lockin":     { v: "Service-coupled", note: "All work runs on Devin infra", verdict: "bad" },
      "runs-on":    { v: "Devin web UI", verdict: "bad" },
      "extend":     { v: "Limited", note: "Custom playbooks in Beta", verdict: "bad" },
      "multi-proj": { v: "Per-task dashboard", note: "Devin-hosted", verdict: "partial" },
    },
  },
  zed: {
    name: "Zed",
    cells: {
      "prompts":    { v: ".zed/settings.json + Agent Profiles", note: "Project + per-profile system prompts", verdict: "partial" },
      "session":    { v: "Persistent assistant panel per workspace; no cross-session protocol", verdict: "partial" },
      "pipeline":   { v: "No — single agent, no pipeline concept", verdict: "bad" },
      "tri-agent":  { v: "Agent profiles can chain", note: "Manual setup; not a contract", verdict: "partial" },
      "gates":      { v: "No", verdict: "bad" },
      "cost":       { v: "Editor free · Zed Pro $20/mo or BYOK", note: "AI usage gated; editor is fully free", verdict: "partial" },
      "lockin":     { v: "Editor-coupled", note: "Profiles only run inside Zed", verdict: "bad" },
      "runs-on":    { v: "Zed editor (Mac · Linux · Windows beta)", verdict: "partial" },
      "extend":     { v: "Add an Agent Profile or edit .zed/settings.json", verdict: "partial" },
      "multi-proj": { v: "No", verdict: "bad" },
    },
  },
  vscode: {
    name: "VS Code",
    cells: {
      "prompts":    { v: "Per-extension (Copilot / Continue / Cline)", note: "Whatever your AI extension wants", verdict: "partial" },
      "session":    { v: "Per extension; usually per-IDE-session", verdict: "partial" },
      "pipeline":   { v: "No — depends entirely on extension", verdict: "bad" },
      "tri-agent":  { v: "No", verdict: "bad" },
      "gates":      { v: "No", verdict: "bad" },
      "cost":       { v: "Editor free · extension pricing varies", note: "Copilot, Continue, Cline each priced separately", verdict: "partial" },
      "lockin":     { v: "Extension-coupled", note: "Tied to whichever AI extension you use", verdict: "partial" },
      "runs-on":    { v: "VS Code (Mac · Linux · Windows · Web)", verdict: "good" },
      "extend":     { v: "Configure your extension's prompt or rules file", verdict: "partial" },
      "multi-proj": { v: "No", verdict: "bad" },
    },
  },
  codex: {
    name: "OpenAI Codex",
    cells: {
      "prompts":    { v: "AGENTS.md in repo + ChatGPT custom instructions", note: "Per-repo; vendor model controls behaviour", verdict: "partial" },
      "session":    { v: "Per-task cloud session + ChatGPT memory", note: "No formal cross-task protocol", verdict: "partial" },
      "pipeline":   { v: "No — single autonomous reasoning loop", verdict: "bad" },
      "tri-agent":  { v: "No (single-agent)", verdict: "bad" },
      "gates":      { v: "No", verdict: "bad" },
      "cost":       { v: "Bundled with ChatGPT Plus/Pro ($20–200/mo)", note: "CLI free with API usage", verdict: "info" },
      "lockin":     { v: "OpenAI-coupled", note: "GPT-5/4 only; no model swap", verdict: "bad" },
      "runs-on":    { v: "chatgpt.com/codex · codex CLI · IDE extension", verdict: "partial" },
      "extend":     { v: "Edit AGENTS.md or ChatGPT instructions", verdict: "good" },
      "multi-proj": { v: "Per-project; no cross-repo dashboard", verdict: "partial" },
    },
  },
  antigravity: {
    name: "Google Antigravity", needsReview: true,
    cells: {
      "prompts":    { v: "Workspace instructions + Knowledge files", note: "Cross-session memory via Knowledge", verdict: "partial" },
      "session":    { v: "Knowledge persists; agent state per workspace", verdict: "partial" },
      "pipeline":   { v: "Multi-agent — Editor + Manager dispatch parallel agents", note: "Coordinated, but not a phase pipeline", verdict: "partial" },
      "tri-agent":  { v: "Yes — Manager dispatches and verifies via screenshot/recording", verdict: "good" },
      "gates":      { v: "Built-in verification (browser proof / screenshot)", verdict: "good" },
      "cost":       { v: "Free tier · paid tiers announced", verdict: "partial" },
      "lockin":     { v: "Google-coupled", note: "Gemini-first; Claude / GPT-OSS optional", verdict: "bad" },
      "runs-on":    { v: "Antigravity desktop app (Mac · Linux · Windows)", verdict: "partial" },
      "extend":     { v: "Add Knowledge files or workspace settings", verdict: "partial" },
      "multi-proj": { v: "Manager view shows every running workspace", verdict: "good" },
    },
  },
};

const FIXED_ORDER = ["opchain", "claude"];
const SELECTABLE = ["cursor", "copilot", "devin", "zed", "vscode", "codex", "antigravity"];
const MAX_EXTRAS = 4;

// Server-rendered default: shows a useful 4-platform comparison on
// first visit so a no-JS / pre-hydration reader still sees a populated
// table. The client script restores the user's last selection from
// localStorage on load if one exists.
const DEFAULT_EXTRAS = ["cursor", "copilot", "devin", "zed"];
const initialSelection = [...FIXED_ORDER, ...DEFAULT_EXTRAS];
---

<Base
  title="Compare · opchain"
  description="opchain vs. Cursor, Copilot, Devin, Zed, VS Code, OpenAI Codex, Google Antigravity, and stock Claude defaults — pick which to compare against, feature by feature."
  active="/"
>
  <main class="page">
    <div class="page-head">
      <Eyebrow>compare</Eyebrow>
      <h1>opchain vs. the others.</h1>
    </div>

    <p class="lede">
      Honest, opinionated comparison against seven popular AI-coding
      tools. opchain and stock Claude defaults are pinned on the left;
      pick up to four more to compare against — chips below the intro,
      one click toggles each column in or out.
    </p>

    <section class="quick">
      <Card variant="surface" glow={false}>
        <div class="quick-head">If you want…</div>
        <ul class="when-list">
          <li><strong>One prompt file your whole team edits</strong> → stock <code>CLAUDE.md</code> is fine</li>
          <li><strong>Editor autocomplete with style</strong> → Cursor or Copilot</li>
          <li><strong>A managed agent that ships PRs unattended</strong> → Devin or OpenAI Codex</li>
          <li><strong>A multi-agent dispatcher with browser-verified output</strong> → Google Antigravity</li>
          <li><strong>A pipeline of skills you own, free, in your repo</strong> → opchain</li>
        </ul>
      </Card>
    </section>

    <section class="picker-bar" aria-label="Comparison platform picker">
      <div class="picker-label">Compare opchain + Claude defaults vs:</div>
      <div class="chip-tray" id="chip-tray" role="group" aria-label="Toggleable platforms">
        {SELECTABLE.map((id) => {
          const p = PLATFORMS[id];
          const selected = DEFAULT_EXTRAS.includes(id);
          return (
            <button
              type="button"
              class="chip"
              data-chip={id}
              data-selected={selected ? "true" : "false"}
              aria-pressed={selected ? "true" : "false"}
            >
              <span class="chip-name">{p.name}</span>
              {p.needsReview && <span class="review-badge">review</span>}
            </button>
          );
        })}
        <span class="chip-counter" id="chip-counter">
          {DEFAULT_EXTRAS.length} of {MAX_EXTRAS} extra columns
        </span>
        <button type="button" class="chip-reset" id="chip-reset">reset</button>
      </div>
    </section>

    <section class="table-wrap">
      <table class="cmp" id="cmp-table">
        <thead>
          <tr id="cmp-head">
            <th></th>
            {initialSelection.map((id) => {
              const p = PLATFORMS[id];
              return (
                <th
                  class:list={[{ me: p.accent }]}
                  data-col={id}
                >
                  {p.name}
                  {p.needsReview && <span class="review-badge">review</span>}
                </th>
              );
            })}
          </tr>
        </thead>
        <tbody id="cmp-body">
          {FEATURES.map((feat) => (
            <tr data-feature={feat.id}>
              <th scope="row">{feat.label}</th>
              {initialSelection.map((id) => {
                const p = PLATFORMS[id];
                const cell = p.cells[feat.id] ?? { v: "—" };
                const heatClass = cell.verdict ? `heat-${cell.verdict}` : null;
                return (
                  <td class:list={[{ me: p.accent }, heatClass]} data-col={id}>
                    <span class="cell-v">
                      {cell.verdict && (
                        <span class={`verdict-icon ${cell.verdict}`} aria-hidden="true">
                          {cell.verdict === "good"    ? "✓" :
                           cell.verdict === "partial" ? "~" :
                           cell.verdict === "bad"     ? "×" :
                           cell.verdict === "info"    ? "$" : ""}
                        </span>
                      )}
                      {cell.v}
                    </span>
                    {cell.note && <span class="cell-note">{cell.note}</span>}
                  </td>
                );
              })}
            </tr>
          ))}
        </tbody>
      </table>
    </section>

    <section class="block">
      <h2>What opchain isn't</h2>
      <p>
        opchain isn't an IDE. It doesn't autocomplete as you type, and
        it won't open a PR against a remote repo for you while you sleep.
        It's a set of <a href="/skills">skills</a> that turn Claude (in
        any of its surfaces) into a pipeline you can lean on for the
        slow work — discovery, spec, audits, deploys, postmortems — and
        a <a href="/glossary#checkpoint-protocol">checkpoint protocol</a>
        that survives the gap between chats.
      </p>
      <p>
        If you use Cursor or Copilot for line-by-line code, opchain
        sits on top of them — it's the long-form thinking layer, not
        the keystroke layer.
      </p>
    </section>

    <section class="block">
      <h2>Switching from…</h2>
      <div class="switch-grid">
        <Card variant="surface" glow={false}>
          <div class="quick-head">From Cursor rules</div>
          <p>
            Keep Cursor for keystrokes. Add the opchain skill bundle to
            <code>.claude/skills/</code> and use it via Claude Code in a
            second terminal pane for the work Cursor isn't great at —
            spec interviews, security audits, multi-file refactors with
            an evaluator loop.
          </p>
        </Card>
        <Card variant="surface" glow={false}>
          <div class="quick-head">From a single CLAUDE.md</div>
          <p>
            Run <a href="/skills/reverse-spec"><code>reverse-spec</code></a>
            against your project — it'll backfill the spec opchain
            wants. Then unzip the bundle, commit it, and start invoking
            skills by name.
          </p>
        </Card>
        <Card variant="surface" glow={false}>
          <div class="quick-head">From Devin</div>
          <p>
            opchain is the local-first analog. Same pipeline (plan →
            build → audit → ship → monitor), no hosted agent — Claude
            does the work in your editor with full repo access.
          </p>
        </Card>
        <Card variant="surface" glow={false}>
          <div class="quick-head">From "nothing yet"</div>
          <p>
            Try the <a href="/pipeline-builder">pipeline builder</a> —
            4 questions, a recommended skill bundle, and an
            install snippet for your stack.
          </p>
        </Card>
      </div>
    </section>

    <section class="cta">
      <p>
        Want to test the claims above? <a href="/install">Install opchain</a>,
        run <code>/discover</code>, and watch the orchestrator route
        through five skills before lunch.
      </p>
    </section>

    <p class="footnote">
      Comparisons reflect publicly published features as of 2026-05.
      Spot a mistake? <button type="button" class="inline-link" data-feedback-launcher>tell us</button>.
    </p>
  </main>
</Base>

<!-- Inline data island used by the client picker script. JSON-Astro
     keeps the shape stable across server / client and avoids re-encoding
     the catalog into the script body. -->
<script
  type="application/json"
  id="cmp-data"
  set:html={JSON.stringify({ PLATFORMS, FEATURES, FIXED_ORDER, SELECTABLE, MAX_EXTRAS, DEFAULT_EXTRAS })}
/>

<script>
  /* ════════════════════════════════════════════════════════════════
   * /compare picker — chip-tray toggles, table reflow, persistence.
   *
   * State: an ordered array of selected "extra" platform ids (the
   * platforms after the two fixed ones). The user can have 0..4
   * extras. Persists to localStorage("opchain-compare-selection").
   * On invalid stored state (unknown ids, length > MAX_EXTRAS), fall
   * back to DEFAULT_EXTRAS — never break the page.
   * ════════════════════════════════════════════════════════════════ */
  type Verdict = "good" | "partial" | "bad" | "info";
  interface Cell { v: string; note?: string | null; verdict?: Verdict }
  interface Platform { name: string; accent?: boolean; fixed?: boolean; needsReview?: boolean; cells: Record<string, Cell> }
  const VERDICT_GLYPH: Record<Verdict, string> = { good: "✓", partial: "~", bad: "×", info: "$" };
  // Whitelist for runtime safety — verdicts come from server-rendered
  // JSON we control, but defending against malformed values keeps the
  // client render bulletproof.
  const VALID_VERDICTS = new Set<Verdict>(["good", "partial", "bad", "info"]);
  interface Feature { id: string; label: string }
  interface Catalog {
    PLATFORMS: Record<string, Platform>;
    FEATURES: Feature[];
    FIXED_ORDER: string[];
    SELECTABLE: string[];
    MAX_EXTRAS: number;
    DEFAULT_EXTRAS: string[];
  }

  const dataEl = document.getElementById("cmp-data");
  if (!dataEl) throw new Error("cmp-data island missing");
  const CATALOG = JSON.parse(dataEl.textContent || "{}") as Catalog;
  const { PLATFORMS, FEATURES, FIXED_ORDER, SELECTABLE, MAX_EXTRAS, DEFAULT_EXTRAS } = CATALOG;

  const STORAGE_KEY = "opchain-compare-selection";

  function loadExtras(): string[] {
    try {
      const raw = localStorage.getItem(STORAGE_KEY);
      if (!raw) return [...DEFAULT_EXTRAS];
      const parsed = JSON.parse(raw);
      if (!Array.isArray(parsed)) return [...DEFAULT_EXTRAS];
      // Validate every entry is a known selectable id; cap at the max.
      const valid = parsed.filter((id: unknown): id is string =>
        typeof id === "string" && SELECTABLE.includes(id),
      );
      return valid.slice(0, MAX_EXTRAS);
    } catch {
      return [...DEFAULT_EXTRAS];
    }
  }
  function saveExtras(extras: string[]) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(extras)); }
    catch { /* private mode / quota — keep the page working */ }
  }

  let extras = loadExtras();

  function escapeHtml(s: string) {
    return s.replace(/[&<>"]/g, (c) => ({ "&": "&amp;", "<": "&lt;", ">": "&gt;", '"': "&quot;" }[c]!));
  }

  function renderChips() {
    const counter = document.getElementById("chip-counter");
    const resetBtn = document.getElementById("chip-reset");
    document.querySelectorAll<HTMLButtonElement>("[data-chip]").forEach((chip) => {
      const id = chip.dataset.chip!;
      const on = extras.includes(id);
      chip.dataset.selected = on ? "true" : "false";
      chip.setAttribute("aria-pressed", on ? "true" : "false");
      // Disable un-selected chips at the cap so users can't exceed MAX_EXTRAS.
      chip.disabled = !on && extras.length >= MAX_EXTRAS;
      chip.title = chip.disabled
        ? `Max ${MAX_EXTRAS} extra columns — remove one first`
        : `Toggle ${PLATFORMS[id].name}`;
    });
    if (counter) counter.textContent = `${extras.length} of ${MAX_EXTRAS} extra columns`;
    if (resetBtn) (resetBtn as HTMLButtonElement).hidden = extras.length === 0;
  }

  function renderTable() {
    const cols = [...FIXED_ORDER, ...extras];

    const thead = document.getElementById("cmp-head");
    if (thead) {
      thead.innerHTML = "";
      thead.appendChild(document.createElement("th")); // corner
      cols.forEach((id) => {
        const p = PLATFORMS[id];
        const th = document.createElement("th");
        if (p.accent) th.className = "me";
        th.dataset.col = id;
        const review = p.needsReview ? '<span class="review-badge">review</span>' : "";
        th.innerHTML = escapeHtml(p.name) + (review ? " " + review : "");
        thead.appendChild(th);
      });
    }

    const tbody = document.getElementById("cmp-body");
    if (tbody) {
      tbody.innerHTML = "";
      FEATURES.forEach((feat) => {
        const tr = document.createElement("tr");
        tr.dataset.feature = feat.id;
        const rowHead = document.createElement("th");
        rowHead.scope = "row";
        rowHead.textContent = feat.label;
        tr.appendChild(rowHead);

        cols.forEach((id) => {
          const p = PLATFORMS[id];
          const cell = p.cells[feat.id] ?? { v: "—", note: null };
          const td = document.createElement("td");
          const classes: string[] = [];
          if (p.accent) classes.push("me");
          const verdict = cell.verdict && VALID_VERDICTS.has(cell.verdict) ? cell.verdict : undefined;
          if (verdict) classes.push(`heat-${verdict}`);
          if (classes.length) td.className = classes.join(" ");
          td.dataset.col = id;
          const iconHtml = verdict
            ? `<span class="verdict-icon ${verdict}" aria-hidden="true">${VERDICT_GLYPH[verdict]}</span>`
            : "";
          const noteHtml = cell.note
            ? `<span class="cell-note">${escapeHtml(cell.note)}</span>`
            : "";
          td.innerHTML = `<span class="cell-v">${iconHtml}${escapeHtml(cell.v)}</span>${noteHtml}`;
          tr.appendChild(td);
        });

        tbody.appendChild(tr);
      });
    }
  }

  function rerender() {
    renderChips();
    renderTable();
  }

  // Wire chip toggles once (chip nodes never get re-created — only
  // their data-selected attribute flips), and the reset button.
  document.querySelectorAll<HTMLButtonElement>("[data-chip]").forEach((chip) => {
    chip.addEventListener("click", () => {
      if (chip.disabled) return;
      const id = chip.dataset.chip!;
      if (extras.includes(id)) {
        extras = extras.filter((s) => s !== id);
      } else {
        if (extras.length >= MAX_EXTRAS) return;
        extras.push(id);
      }
      saveExtras(extras);
      rerender();
    });
  });
  document.getElementById("chip-reset")?.addEventListener("click", () => {
    extras = [];
    saveExtras(extras);
    rerender();
  });

  // Initial paint: if the server-rendered default matches our loaded
  // state we can skip the table rebuild; otherwise, rebuild from
  // stored state.
  const isDefault =
    extras.length === DEFAULT_EXTRAS.length &&
    extras.every((id, i) => id === DEFAULT_EXTRAS[i]);
  if (!isDefault) {
    rerender();
  } else {
    renderChips(); // still toggle the chip state in case page paint differs
  }
</script>

