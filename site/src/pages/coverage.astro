---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";

import packsCatalog from "../../../src/generated/packs-catalog.json";

/**
 * /coverage — a build-time-rendered catalog of every stack-forge pack.
 *
 * Source data is `src/generated/packs-catalog.json`, emitted by
 * `scripts/gen-packs-catalog.mjs` in prebuild from the pack.yml files
 * under `skills/stack-forge/packs/<id>/`. Grouped by kind:
 *   - languages — top-level toolchains with testRunner/buildCmd/lintCmd
 *   - frameworks — application frameworks layered on a language pack
 *   - mobile — checklist-driven mobile platforms
 *   - deploy-targets — hosting providers (no coverage flag)
 *
 * No client-side JS. No flag gating — the page is part of the v1.4
 * release surface and should always render.
 */

type PackData = {
  id: string;
  displayName: string;
  kind: "language" | "framework" | "deploy-target" | "mobile";
  status: "stable" | "beta" | "experimental" | "deprecated";
  since: string;
  language?: string;
  mobilePlatform?: "ios" | "android" | "flutter" | "react-native";
  testRunner?: string;
  buildCmd?: string;
  lintCmd?: string;
  defaultPlatform?: string;
  supportedPlatforms?: string[];
  frameworks?: string[];
};

const allPacks = packsCatalog as PackData[];

const languages     = allPacks.filter((p) => p.kind === "language");
const frameworks    = allPacks.filter((p) => p.kind === "framework");
const mobile        = allPacks.filter((p) => p.kind === "mobile");
const deployTargets = allPacks.filter((p) => p.kind === "deploy-target");

const STATUS_LABEL: Record<PackData["status"], string> = {
  stable: "stable",
  beta: "beta",
  experimental: "experimental",
  deprecated: "deprecated",
};

const REPO_TREE = "https://github.com/asfbay-bit/opchain/tree/main/skills/stack-forge/packs";
const sourceUrl = (id: string) => `${REPO_TREE}/${id}`;

const counts = {
  total: allPacks.length,
  language: languages.length,
  framework: frameworks.length,
  mobile: mobile.length,
  deployTarget: deployTargets.length,
};
---

<Base
  title="Coverage · opchain"
  description={`Every stack-forge pack opchain ships — ${counts.total} packs across ${counts.language} languages, ${counts.framework} frameworks, ${counts.mobile} mobile platforms, and ${counts.deployTarget} deploy targets.`}
  active="/"
>
  <main class="page coverage-page">
    <div class="page-head">
      <Eyebrow>coverage</Eyebrow>
      <h1>What opchain knows.</h1>
    </div>

    <p class="lede">
      Every <a href={REPO_TREE}><code>stack-forge</code> pack</a> opchain
      ships, grouped by what role it plays in the dispatch graph.
      <strong>Languages</strong> have a canonical test-runner / build /
      lint command. <strong>Frameworks</strong> attach to a language pack.
      <strong>Mobile</strong> packs dispatch through a release checklist
      instead of executable commands. <strong>Deploy-targets</strong> are
      the leaves of the dispatch graph &mdash; the hosting providers a
      language / framework / mobile pack can land on.
    </p>

    <nav class="cov-stats" aria-label="Jump to coverage section">
      <a class="cov-stat" href="#cov-h-languages"><span class="cov-num">{counts.total}</span><span class="cov-label">total packs</span></a>
      <a class="cov-stat" href="#cov-h-languages"><span class="cov-num">{counts.language}</span><span class="cov-label">languages</span></a>
      <a class="cov-stat" href="#cov-h-frameworks"><span class="cov-num">{counts.framework}</span><span class="cov-label">frameworks</span></a>
      <a class="cov-stat" href="#cov-h-mobile"><span class="cov-num">{counts.mobile}</span><span class="cov-label">mobile</span></a>
      <a class="cov-stat" href="#cov-h-deploy"><span class="cov-num">{counts.deployTarget}</span><span class="cov-label">deploy targets</span></a>
    </nav>

    <section class="cov-section" aria-labelledby="cov-h-languages">
      <h2 id="cov-h-languages">Languages</h2>
      <p class="cov-sub">
        Top-level toolchains. Each emits a <code>skills.coverage.&lt;id&gt;.enabled</code>
        flag and ships with a canonical test / build / lint command set.
      </p>
      <ul class="cov-grid">
        {languages.map((p) => (
          <li class={`cov-card cov-card--language status-${p.status}`}>
            <div class="cov-card-head">
              <a class="cov-name" href={sourceUrl(p.id)} rel="noopener">{p.displayName}</a>
              <span class={`cov-status status-${p.status}`}>{STATUS_LABEL[p.status]}</span>
            </div>
            <code class="cov-id">{p.id}</code>
            <dl class="cov-meta">
              <div><dt>test</dt><dd><code>{p.testRunner}</code></dd></div>
              {p.buildCmd && <div><dt>build</dt><dd><code>{p.buildCmd}</code></dd></div>}
              {p.lintCmd && <div><dt>lint</dt><dd><code>{p.lintCmd}</code></dd></div>}
              <div><dt>since</dt><dd>v{p.since}</dd></div>
            </dl>
            {p.frameworks && p.frameworks.length > 0 && (
              <p class="cov-frameworks">
                Frameworks: {p.frameworks.map((fw, i) => (
                  <>
                    {i > 0 && ", "}
                    <a href={`#pack-${fw}`}><code>{fw}</code></a>
                  </>
                ))}
              </p>
            )}
          </li>
        ))}
      </ul>
    </section>

    <section class="cov-section" aria-labelledby="cov-h-frameworks">
      <h2 id="cov-h-frameworks">Frameworks</h2>
      <p class="cov-sub">
        Application frameworks layered on a language pack. Inherit the
        language's test / build / lint command set; stack-forge picks them
        when the workload signal matches the framework profile.
      </p>
      <ul class="cov-grid">
        {frameworks.map((p) => (
          <li class={`cov-card cov-card--framework status-${p.status}`} id={`pack-${p.id}`}>
            <div class="cov-card-head">
              <a class="cov-name" href={sourceUrl(p.id)} rel="noopener">{p.displayName}</a>
              <span class={`cov-status status-${p.status}`}>{STATUS_LABEL[p.status]}</span>
            </div>
            <code class="cov-id">{p.id}</code>
            <dl class="cov-meta">
              <div><dt>language</dt><dd><code>{p.language}</code></dd></div>
              <div><dt>since</dt><dd>v{p.since}</dd></div>
            </dl>
          </li>
        ))}
      </ul>
    </section>

    <section class="cov-section" aria-labelledby="cov-h-mobile">
      <h2 id="cov-h-mobile">Mobile</h2>
      <p class="cov-sub">
        Mobile platforms. <code>stack-forge</code> dispatches these
        through the <code>dispatchMobile()</code> envelope &mdash; the
        ref doc is rendered as a release checklist (App Store review,
        Play Console rollout, EAS Submit) rather than executed as
        commands. There is no <code>mix test</code>-equivalent for an
        app-store submission.
      </p>
      <ul class="cov-grid">
        {mobile.map((p) => (
          <li class={`cov-card cov-card--mobile status-${p.status}`}>
            <div class="cov-card-head">
              <a class="cov-name" href={sourceUrl(p.id)} rel="noopener">{p.displayName}</a>
              <span class={`cov-status status-${p.status}`}>{STATUS_LABEL[p.status]}</span>
            </div>
            <code class="cov-id">{p.id}</code>
            <dl class="cov-meta">
              <div><dt>platform</dt><dd><code>{p.mobilePlatform}</code></dd></div>
              {p.defaultPlatform && <div><dt>default deploy</dt><dd><code>{p.defaultPlatform}</code></dd></div>}
              <div><dt>since</dt><dd>v{p.since}</dd></div>
            </dl>
          </li>
        ))}
      </ul>
    </section>

    <section class="cov-section" aria-labelledby="cov-h-deploy">
      <h2 id="cov-h-deploy">Deploy targets</h2>
      <p class="cov-sub">
        Hosting providers that language / framework / mobile packs can
        target. <strong>No coverage flag is emitted</strong> &mdash;
        deploy-targets are sub-selections under another offer, not
        top-level coverage units. <code>deploy-ops</code> uses these to
        pick the right provider section of its <code>SKILL.md</code>.
      </p>
      <ul class="cov-grid">
        {deployTargets.map((p) => (
          <li class={`cov-card cov-card--deploy status-${p.status}`}>
            <div class="cov-card-head">
              <a class="cov-name" href={sourceUrl(p.id)} rel="noopener">{p.displayName}</a>
              <span class={`cov-status status-${p.status}`}>{STATUS_LABEL[p.status]}</span>
            </div>
            <code class="cov-id">{p.id}</code>
            <dl class="cov-meta">
              <div><dt>since</dt><dd>v{p.since}</dd></div>
            </dl>
          </li>
        ))}
      </ul>
    </section>

    <section class="cov-section">
      <h2>How to use</h2>
      <p>
        Every pack ships with a reference doc in
        <a href={REPO_TREE} rel="noopener"><code>skills/stack-forge/packs/&lt;id&gt;/</code></a>
        covering when to pick it, the canonical tooling, default deploy
        targets, and gotchas. Click any pack name above to jump to the
        source on GitHub.
      </p>
      <p>
        Adding a pack is one <code>pack.yml</code> + one ref doc. See
        <a href={`${REPO_TREE}/CONTRIBUTING.md`} rel="noopener"><code>CONTRIBUTING.md</code></a>
        for the contract. The <code>scripts/gen-stack-packs.mjs</code>
        validator runs on every build, so accidental schema drift fails
        CI rather than silently breaking <code>stack-forge</code>'s
        recommendations.
      </p>
    </section>
  </main>
</Base>

<style>
  /* A — content container: matches compare.astro (1040px), centered with
     the standard page gutters. Base.astro wraps nothing, so each page
     owns this rule. */
  .page { max-width: 1040px; margin: 0 auto; padding: 3rem 1.5rem 6rem; }
  .page-head { margin-bottom: 1.25rem; }

  /* B — heading parity with compare/glossary */
  .page-head h1 {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0;
  }

  /* E — inline code uses the site mono face, not the browser default */
  .coverage-page code { font-family: var(--font-mono); }

  .coverage-page .lede {
    color: var(--muted);
    max-width: 70ch;
    margin: 0 0 2rem;
    line-height: var(--lh-base);
  }
  .coverage-page .lede a { color: var(--accent); }

  /* Stat boxes — the homepage `.stat` treatment, used here as jump links
     that smooth-scroll to the matching section. */
  .cov-stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(150px, 1fr));
    gap: 0.5rem;
    margin: 0 0 2rem;
  }
  .cov-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.8rem 0.9rem;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    color: var(--muted);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .cov-stat:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .cov-stat:focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }
  .cov-num {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    line-height: 1;
  }
  .cov-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--subtle);
  }
  @media (max-width: 560px) {
    .cov-stats { grid-template-columns: repeat(2, 1fr); }
  }

  /* Click-to-scroll: smooth jump + offset so the heading clears the
     sticky site header. Honors reduced-motion. */
  .cov-section h2 { scroll-margin-top: 90px; }
  :global(html) { scroll-behavior: smooth; }
  @media (prefers-reduced-motion: reduce) {
    :global(html) { scroll-behavior: auto; }
  }

  .cov-section { margin: 2rem 0; }
  .cov-section h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-lg);
    color: var(--text);
    margin: 0 0 0.25rem;
  }
  .cov-sub {
    color: var(--muted);
    max-width: 70ch;
    margin: 0 0 1rem;
    line-height: var(--lh-base);
  }

  /* "How to use" prose — excludes the card/section helper paragraphs */
  .cov-section p:not(.cov-sub):not(.cov-frameworks) {
    color: var(--muted);
    line-height: var(--lh-base);
    margin: 0 0 0.75rem;
    max-width: 70ch;
  }
  .cov-section p:not(.cov-sub):not(.cov-frameworks) a { color: var(--accent); }

  .cov-grid {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
    gap: 0.75rem;
  }
  /* C — real card surface (was var(--bg-elevated) which is undefined and
     fell back to the page background, so cards had no elevation). */
  .cov-card {
    border: 0.5px solid var(--border);
    border-left: 3px solid var(--accent);
    border-radius: var(--r-md);
    padding: 0.9rem;
    background: var(--surface);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }
  /* D — single ember palette; category distinguished by tint depth
     (language = strongest → deploy = faintest) instead of off-brand hues. */
  .cov-card--language  { border-left-color: var(--accent); }
  .cov-card--framework { border-left-color: color-mix(in srgb, var(--accent) 70%, var(--surface)); }
  .cov-card--mobile    { border-left-color: color-mix(in srgb, var(--accent) 45%, var(--surface)); }
  .cov-card--deploy    { border-left-color: color-mix(in srgb, var(--accent) 25%, var(--surface)); }

  .cov-card-head {
    display: flex;
    align-items: baseline;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .cov-name {
    color: var(--text);
    text-decoration: none;
    font-weight: 600;
  }
  .cov-name:hover { text-decoration: underline; }

  .cov-status {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    padding: 2px 8px;
    border-radius: 999px;
    text-transform: lowercase;
    color: var(--muted);
    background: var(--surface);
    border: 0.5px solid var(--border);
  }
  /* D — status colors mapped to palette tokens */
  .cov-status.status-stable {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .cov-status.status-beta,
  .cov-status.status-experimental {
    color: var(--warning);
    border-color: var(--warning);
    background: var(--warning-dim);
  }
  .cov-status.status-deprecated {
    color: var(--subtle);
    text-decoration: line-through;
  }

  .cov-id {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
  }

  .cov-meta {
    margin: 0;
    display: grid;
    grid-template-columns: max-content 1fr;
    gap: 0.25rem 0.75rem;
    font-size: var(--fs-sm);
  }
  .cov-meta > div { display: contents; }
  .cov-meta dt {
    color: var(--subtle);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
  }
  .cov-meta dd {
    margin: 0;
    color: var(--muted);
  }
  .cov-meta dd code { font-size: 0.85em; color: var(--text); }

  .cov-frameworks {
    margin: 0.25rem 0 0;
    font-size: var(--fs-sm);
    color: var(--muted);
  }
  .cov-frameworks a { color: var(--accent); text-decoration: none; }
  .cov-frameworks a:hover { text-decoration: underline; }
  .cov-frameworks code { color: var(--text); }

  /* Light-mode accent contrast — same treatment compare/glossary use */
  :global([data-theme="light"]) .cov-num,
  :global([data-theme="light"]) .cov-status.status-stable,
  :global([data-theme="light"]) .coverage-page .lede a,
  :global([data-theme="light"]) .cov-frameworks a,
  :global([data-theme="light"]) .cov-section p:not(.cov-sub):not(.cov-frameworks) a {
    color: var(--accent-hover);
  }
  :global([data-theme="light"]) .cov-status.status-stable { border-color: var(--accent-hover); }
</style>
