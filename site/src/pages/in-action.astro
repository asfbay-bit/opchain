---
import Base from "../layouts/Base.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Icon from "../components/Icon.astro";
import { walkthroughs } from "../data/walkthroughs";

/**
 * In Action — four scripted end-to-end sessions with opchain.
 *
 * UX:
 *   - Scenario picker pills select one of the four transcripts.
 *   - Enter or "play" reveals the next step.
 *   - Space, "skip", or End reveals everything.
 *   - Backspace / "restart" resets to step 0.
 *   - Numeric keys 1-4 jump between scenarios.
 */

// Inline the transcripts as a JSON island the client script can read
// without a round-trip. Static build, so this is free.
const catalog = JSON.stringify(
  walkthroughs.map((w) => ({
    id: w.id,
    title: w.title,
    summary: w.summary,
    skills: w.skills,
    runtime: w.runtime,
    steps: w.steps,
  })),
);
---

<Base
  title="In Action · opchain"
  description="Four fully-scripted end-to-end sessions showing how opchain skills chain, from concept to deployed app."
  active="/in-action"
>
  <main class="page">
    <header class="page-head">
      <Eyebrow>in action</Eyebrow>
      <h1>Proof, not pitches.</h1>
      <p class="lede">
        Four full opchain sessions, nothing redacted. A solo founder shipping
        v1 in a single chat. A rescue on a three-year-old codebase nobody
        remembers. A dashboard rebuild that halved the noise. Stripe
        subscriptions gated by a real audit and shipped in a week.
      </p>
      <p class="kbd-hint">
        <kbd>Enter</kbd> to live through each exchange ·
        <kbd>Space</kbd> to skip to the payoff ·
        <kbd>R</kbd> to restart ·
        <kbd>1</kbd>–<kbd>4</kbd> to jump between scenarios.
      </p>
    </header>

    <!-- ───────────── Scenario picker — collapsed strip ───────────── -->
    <section class="scenarios" id="scenario-picker" role="tablist" aria-label="Pick a scenario">
      {walkthroughs.map((w, i) => (
        <button
          type="button"
          class="scenario"
          role="tab"
          aria-pressed={i === 0 ? "true" : "false"}
          aria-selected={i === 0 ? "true" : "false"}
          {...({
            "data-scenario": w.id,
            "data-index": String(i),
          } as any)}
        >
          <span class="scenario-num">0{i + 1}</span>
          <span class="scenario-tagline">{w.tagline}</span>
        </button>
      ))}
    </section>

    <!-- ───────────── Detail panel — full width for the active scenario ───────────── -->
    <section class="detail" aria-live="polite">
      <div class="detail-head">
        <div>
          <h2 class="detail-title" id="detail-title">{walkthroughs[0].title}</h2>
          <p class="detail-summary" id="detail-summary">{walkthroughs[0].summary}</p>
        </div>
        <div class="detail-meta">
          <span class="detail-runtime" id="detail-runtime">{walkthroughs[0].runtime}</span>
          <div class="detail-skills" id="detail-skills">
            {walkthroughs[0].skills.map((s) => (<code class="chip">{s}</code>))}
          </div>
        </div>
      </div>

      <p class="detail-body" id="detail-body">{walkthroughs[0].description}</p>

      <div class="detail-io">
        <div class="io-col">
          <div class="io-head">Inputs</div>
          <ul class="io-list" id="detail-inputs">
            {walkthroughs[0].inputs.map((x) => <li>{x}</li>)}
          </ul>
        </div>
        <div class="io-col">
          <div class="io-head">Outputs <span class="io-hint">click to expand</span></div>
          <ul class="io-list artifacts" id="detail-outputs">
            {walkthroughs[0].outputs.map((a) => (
              <li class="artifact">
                <button
                  type="button"
                  class="artifact-head"
                  aria-expanded="false"
                  {...({ "data-artifact-id": a.id } as any)}
                >
                  <Icon name="arrow-right" size={10} class="artifact-chevron" />
                  <span class="artifact-label">{a.label}</span>
                  {a.kind && <span class="artifact-kind">{a.kind}</span>}
                </button>
                <div class="artifact-body markdown" hidden></div>
              </li>
            ))}
          </ul>
        </div>
      </div>
    </section>

    <!-- ───────────── Player ───────────── -->
    <section class="player" aria-label="Walkthrough player">
      <div class="player-head">
        <div class="player-title">
          <span class="player-eyebrow" id="player-eyebrow">scenario · 01</span>
          <h2 id="player-heading">{walkthroughs[0].title}</h2>
        </div>
        <div class="player-controls">
          <button type="button" id="btn-play" class="ctl ctl-primary" aria-label="Next step (Enter)">
            <Icon name="arrow-right" size={12} />
            <span id="btn-play-label">start</span>
          </button>
          <button type="button" id="btn-skip" class="ctl" aria-label="Skip to end (Space)">
            skip
          </button>
          <button type="button" id="btn-restart" class="ctl" aria-label="Restart (R)">
            restart
          </button>
        </div>
      </div>

      <div class="progress">
        <div class="progress-bar" id="progress-bar"></div>
        <span class="progress-label" id="progress-label" aria-live="polite">step 0 of 0</span>
      </div>

      <div id="transcript" class="transcript" aria-live="polite" aria-atomic="false">
        <!-- Populated by the client script. An initial prompt is shown below. -->
      </div>

      <div class="start-prompt" id="start-prompt">
        <Icon name="sparkles" />
        <p>
          <strong>Press <kbd>Enter</kbd></strong> (or click <em>start</em>) to
          begin. <kbd>Space</kbd> cuts to the end; <kbd>R</kbd> resets;
          <kbd>1</kbd>–<kbd>4</kbd> switches scenarios.
        </p>
      </div>
    </section>
  </main>

  <script is:inline id="walkthrough-data" type="application/json" set:html={catalog}></script>

  <script>
    import { renderSafeMarkdown } from "../lib/markdown";

    interface Beat {
      type: "beat";
      label: string;
      caption?: string;
      skills?: string[];
    }
    interface Exchange {
      type: "exchange";
      role: "user" | "claude";
      skill?: string;
      content: string;
      artifacts?: string[];
    }
    type Step = Beat | Exchange;
    interface Artifact {
      id: string;
      label: string;
      kind?: string;
      body: string;
    }
    interface Walkthrough {
      id: string;
      title: string;
      tagline: string;
      summary: string;
      description: string;
      inputs: string[];
      outputs: Artifact[];
      skills: string[];
      runtime: string;
      steps: Step[];
    }

    const dataEl = document.getElementById("walkthrough-data");
    if (!dataEl) throw new Error("walkthrough data missing");
    const catalog: Walkthrough[] = JSON.parse(dataEl.textContent || "[]");

    const picker       = document.getElementById("scenario-picker")!;
    const heading      = document.getElementById("player-heading")!;
    const eyebrow      = document.getElementById("player-eyebrow")!;
    const detailTitle  = document.getElementById("detail-title")!;
    const detailSum    = document.getElementById("detail-summary")!;
    const detailBody   = document.getElementById("detail-body")!;
    const detailRun    = document.getElementById("detail-runtime")!;
    const detailSkills = document.getElementById("detail-skills")!;
    const detailInputs = document.getElementById("detail-inputs")!;
    const detailOuts   = document.getElementById("detail-outputs")!;
    const transcript   = document.getElementById("transcript")!;
    const progressBar  = document.getElementById("progress-bar")!;
    const progressLbl  = document.getElementById("progress-label")!;
    const playBtn      = document.getElementById("btn-play")! as HTMLButtonElement;
    const playLbl      = document.getElementById("btn-play-label")!;
    const skipBtn      = document.getElementById("btn-skip")! as HTMLButtonElement;
    const restartBtn   = document.getElementById("btn-restart")! as HTMLButtonElement;
    const startPrompt  = document.getElementById("start-prompt")!;

    let currentIdx  = 0;       // which scenario
    let stepIdx     = 0;       // how many steps revealed

    function currentScenario(): Walkthrough {
      return catalog[currentIdx];
    }

    function setScenario(i: number) {
      if (i < 0 || i >= catalog.length) return;
      currentIdx = i;
      stepIdx = 0;
      transcript.innerHTML = "";
      const w = currentScenario();

      // Player head
      heading.textContent = w.title;
      eyebrow.textContent = `scenario · 0${i + 1}`;
      playLbl.textContent = "start";
      startPrompt.hidden = false;

      // Detail panel — title, summary, body, runtime, skills, I/O, artifacts.
      detailTitle.textContent = w.title;
      detailSum.textContent   = w.summary;
      detailBody.textContent  = w.description;
      detailRun.textContent   = w.runtime;
      detailSkills.innerHTML  = w.skills.map((s) => `<code class="chip">${escapeHTML(s)}</code>`).join("");
      detailInputs.innerHTML  = w.inputs.map((x) => `<li>${escapeHTML(x)}</li>`).join("");
      detailOuts.innerHTML    = w.outputs.map((a) => `
        <li class="artifact">
          <button type="button" class="artifact-head" aria-expanded="false" data-artifact-id="${escapeHTML(a.id)}">
            <svg class="artifact-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="artifact-label">${escapeHTML(a.label)}</span>
            ${a.kind ? `<span class="artifact-kind">${escapeHTML(a.kind)}</span>` : ""}
          </button>
          <div class="artifact-body markdown" hidden></div>
        </li>
      `).join("");
      wireArtifactToggles();

      updateProgress();

      // Toggle pressed state on the scenario cards.
      picker.querySelectorAll<HTMLElement>("[data-scenario]").forEach((el) => {
        const matched = el.dataset.scenario === w.id;
        el.setAttribute("aria-pressed", matched ? "true" : "false");
        el.setAttribute("aria-selected", matched ? "true" : "false");
      });
    }

    function wireArtifactToggles() {
      const w = currentScenario();
      const byId = new Map(w.outputs.map((a) => [a.id, a] as const));
      detailOuts.querySelectorAll<HTMLButtonElement>(".artifact-head").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.artifactId || "";
          const artifact = byId.get(id);
          if (!artifact) return;
          const body = btn.nextElementSibling as HTMLElement | null;
          if (!body) return;
          const open = btn.getAttribute("aria-expanded") === "true";
          if (open) {
            body.hidden = true;
            btn.setAttribute("aria-expanded", "false");
          } else {
            body.innerHTML = renderSafeMarkdown(artifact.body);
            body.hidden = false;
            btn.setAttribute("aria-expanded", "true");
          }
        });
      });
    }

    function updateProgress() {
      const total = currentScenario().steps.length;
      const pct = total === 0 ? 0 : Math.round((stepIdx / total) * 100);
      progressBar.style.width = `${pct}%`;
      progressLbl.textContent = `step ${stepIdx} of ${total}`;
      const atEnd = stepIdx >= total;
      playLbl.textContent = stepIdx === 0 ? "start" : atEnd ? "complete" : "next";
      playBtn.disabled = atEnd;
      skipBtn.disabled = atEnd;
      if (stepIdx > 0) startPrompt.hidden = true;
    }

    function escapeHTML(s: string): string {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    function renderStep(step: Step) {
      if (step.type === "beat") {
        const el = document.createElement("div");
        el.className = "beat";
        const skillsHtml = (step.skills ?? [])
          .map((s) => `<code class="chip">${escapeHTML(s)}</code>`)
          .join("");
        el.innerHTML = `
          <div class="beat-rule"></div>
          <div class="beat-body">
            <div class="beat-label">${escapeHTML(step.label)}</div>
            ${step.caption ? `<div class="beat-caption">${escapeHTML(step.caption)}</div>` : ""}
            ${skillsHtml ? `<div class="beat-skills">${skillsHtml}</div>` : ""}
          </div>
          <div class="beat-rule"></div>
        `;
        transcript.appendChild(el);
        return el;
      }

      const wrap = document.createElement("div");
      wrap.className = `msg msg--${step.role === "user" ? "user" : "assistant"}`;

      const label = document.createElement("div");
      label.className = "msg-label";
      label.textContent = step.role === "user"
        ? "you"
        : (step.skill ? `claude · ${step.skill}` : "claude");
      wrap.appendChild(label);

      const body = document.createElement("div");
      body.className = "msg-content markdown";
      if (step.role === "user") {
        body.textContent = step.content;
      } else {
        body.innerHTML = renderSafeMarkdown(step.content);
      }
      wrap.appendChild(body);

      // Artifact refs — render as clickable chips under the message body.
      // Click scrolls the page's detail panel into view and auto-expands
      // the matching artifact. Tight coupling is fine: both live on the
      // same page and share the active scenario.
      if (step.role === "claude" && step.artifacts && step.artifacts.length > 0) {
        const row = document.createElement("div");
        row.className = "msg-artifacts";
        const labels = new Map(
          currentScenario().outputs.map((a) => [a.id, { label: a.label, kind: a.kind }] as const),
        );
        step.artifacts.forEach((id) => {
          const meta = labels.get(id);
          if (!meta) return;
          const chip = document.createElement("button");
          chip.type = "button";
          chip.className = "msg-artifact";
          chip.dataset.artifactId = id;
          chip.innerHTML = `
            <svg width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
            <span>${escapeHTML(meta.label)}</span>
            ${meta.kind ? `<span class="msg-artifact-kind">${escapeHTML(meta.kind)}</span>` : ""}
          `;
          chip.addEventListener("click", () => focusArtifact(id));
          row.appendChild(chip);
        });
        wrap.appendChild(row);
      }

      transcript.appendChild(wrap);
      return wrap;
    }

    /** Scroll the transcript container only — never the whole page. */
    function scrollChat() {
      transcript.scrollTo({ top: transcript.scrollHeight, behavior: "smooth" });
    }

    /** Scroll the detail panel into view and auto-expand an artifact by id. */
    function focusArtifact(id: string) {
      const btn = detailOuts.querySelector<HTMLButtonElement>(
        `[data-artifact-id="${CSS.escape(id)}"]`,
      );
      if (!btn) return;
      const body = btn.nextElementSibling as HTMLElement | null;
      if (btn.getAttribute("aria-expanded") !== "true") {
        const artifact = currentScenario().outputs.find((a) => a.id === id);
        if (artifact && body) {
          body.innerHTML = renderSafeMarkdown(artifact.body);
          body.hidden = false;
          btn.setAttribute("aria-expanded", "true");
        }
      }
      btn.scrollIntoView({ behavior: "smooth", block: "center" });
    }

    function advance() {
      const w = currentScenario();
      if (stepIdx >= w.steps.length) return;
      renderStep(w.steps[stepIdx]);
      stepIdx++;
      updateProgress();
      scrollChat();
    }

    function skipToEnd() {
      const w = currentScenario();
      while (stepIdx < w.steps.length) {
        renderStep(w.steps[stepIdx]);
        stepIdx++;
      }
      updateProgress();
      scrollChat();
    }

    function restart() {
      stepIdx = 0;
      transcript.innerHTML = "";
      startPrompt.hidden = false;
      updateProgress();
    }

    // ── wire up ────────────────────────────────────────────────
    playBtn.addEventListener("click", advance);
    skipBtn.addEventListener("click", skipToEnd);
    restartBtn.addEventListener("click", restart);

    picker.querySelectorAll<HTMLButtonElement>("[data-scenario]").forEach((el, i) => {
      el.addEventListener("click", () => setScenario(i));
      // Native <button> Enter/Space → click. Stop the keydown from also
      // bubbling to the window player handler, which would otherwise
      // advance/skip the transcript on the same keystroke.
      el.addEventListener("keydown", (ev) => {
        if (ev.key === "Enter" || ev.key === " ") ev.stopPropagation();
      });
    });

    window.addEventListener("keydown", (ev) => {
      // Ignore shortcuts when the user is typing into a field.
      const target = ev.target as HTMLElement | null;
      if (target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable)) {
        return;
      }
      if (ev.key === "Enter") { ev.preventDefault(); advance(); return; }
      if (ev.key === " ")     { ev.preventDefault(); skipToEnd(); return; }
      if (ev.key.toLowerCase() === "r") { ev.preventDefault(); restart(); return; }
      const n = Number.parseInt(ev.key, 10);
      if (!Number.isNaN(n) && n >= 1 && n <= catalog.length) {
        ev.preventDefault();
        setScenario(n - 1);
      }
    });

    // First render.
    setScenario(0);
  </script>

  <style>
    .page {
      max-width: 960px;
      margin: 0 auto;
      padding: 3rem 1.5rem 6rem;
    }
    .page-head { margin-bottom: 2rem; }
    .page-head h1 {
      font-family: var(--font-display);
      font-size: var(--fs-2xl);
      font-weight: 600;
      letter-spacing: var(--ls-tight);
      color: var(--text);
      margin: 0.5rem 0 1rem;
    }
    .lede { color: var(--muted); max-width: 42rem; margin: 0 0 0.9rem; }
    .kbd-hint {
      margin: 0;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-wide);
      color: var(--subtle);
    }
    .kbd-hint kbd { margin: 0 0.15rem; }
    kbd {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-xs);
      padding: 1px 6px;
      color: var(--text);
    }

    /* ── Scenario picker — compact strip ─────────────────────── */
    .scenarios {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.45rem;
      margin-bottom: 1.5rem;
    }
    .scenario {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.8rem 1rem;
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-md);
      cursor: pointer;
      text-align: left;
      font: inherit;
      color: var(--text);
      transition:
        border-color var(--dur-fast) var(--ease-standard),
        background var(--dur-fast) var(--ease-standard),
        transform var(--dur-fast) var(--ease-standard);
    }
    .scenario:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
    }
    .scenario[aria-pressed="true"] {
      border-color: var(--accent);
      background: var(--accent-dim);
      box-shadow: var(--glow-md);
    }
    .scenario-num {
      flex: 0 0 auto;
      font-family: var(--font-mono);
      font-size: var(--fs-md);
      font-weight: 600;
      color: var(--accent);
      letter-spacing: var(--ls-tight);
      min-width: 1.75rem;
    }
    .scenario-tagline {
      flex: 1;
      font-family: var(--font-display);
      font-size: var(--fs-sm);
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.005em;
      line-height: 1.25;
    }
    .chip {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--text);
      background: var(--card);
      border: 0.5px solid var(--border);
      padding: 1px 6px;
      border-radius: var(--r-xs);
    }

    /* ── Detail panel — full width under the card strip ─────── */
    .detail {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.5rem 1.75rem;
      margin-bottom: 1.5rem;
      box-shadow: var(--glow-md);
    }
    .detail-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .detail-title {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
      margin: 0 0 0.35rem;
    }
    .detail-summary {
      margin: 0;
      font-size: var(--fs-sm);
      color: var(--muted);
      max-width: 52ch;
    }
    .detail-meta {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      align-items: flex-end;
    }
    .detail-runtime {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-wide);
      color: var(--subtle);
    }
    .detail-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
      justify-content: flex-end;
    }
    .detail-body {
      font-size: var(--fs-sm);
      line-height: var(--lh-base);
      color: var(--muted);
      margin: 0 0 1.25rem;
    }

    .detail-io {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 720px) {
      .detail-io { grid-template-columns: 1fr; }
    }
    .io-head {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--subtle);
      margin-bottom: 0.55rem;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }
    .io-hint {
      text-transform: none;
      letter-spacing: var(--ls-wide);
      font-size: 10px;
      color: var(--subtle);
      font-style: italic;
    }
    .io-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .io-list:not(.artifacts) li {
      font-size: var(--fs-sm);
      color: var(--muted);
      padding-left: 0.9rem;
      position: relative;
    }
    .io-list:not(.artifacts) li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--accent);
    }

    /* ── Artifacts (collapsible) ─────────────────────────────── */
    .artifacts { gap: 0.3rem; }
    .artifact {
      border: 0.5px solid var(--border);
      border-radius: var(--r-sm);
      background: var(--card);
      overflow: hidden;
    }
    .artifact-head {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      width: 100%;
      padding: 0.55rem 0.8rem;
      background: transparent;
      border: 0;
      cursor: pointer;
      text-align: left;
      font: inherit;
      color: var(--text);
      transition:
        background var(--dur-fast) var(--ease-standard),
        color var(--dur-fast) var(--ease-standard);
    }
    .artifact-head:hover {
      background: var(--accent-dim);
      color: var(--text);
    }
    .artifact-chevron {
      color: var(--accent);
      transition: transform var(--dur-fast) var(--ease-standard);
    }
    .artifact-head[aria-expanded="true"] .artifact-chevron {
      transform: rotate(90deg);
    }
    .artifact-label {
      flex: 1;
      font-size: var(--fs-sm);
      color: var(--text);
    }
    .artifact-kind {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--accent);
      background: var(--surface);
      border: 0.5px solid var(--border);
      padding: 1px 6px;
      border-radius: var(--r-xs);
      letter-spacing: var(--ls-wide);
    }
    .artifact-body {
      padding: 0.9rem 1.1rem;
      border-top: 0.5px solid var(--border);
      background: var(--ribbon);
      font-size: 12px;
      line-height: 1.55;
      color: var(--text);
      max-height: 28rem;
      overflow-y: auto;
    }
    .artifact-body[hidden] { display: none; }
    .artifact-body :global(h1),
    .artifact-body :global(h2),
    .artifact-body :global(h3) {
      font-family: var(--font-display);
      color: var(--text);
      margin: 0.6rem 0 0.35rem;
    }
    .artifact-body :global(h1) { font-size: var(--fs-md); }
    .artifact-body :global(h2) { font-size: var(--fs-sm); }
    .artifact-body :global(h3) { font-size: 12px; }
    .artifact-body :global(p)  { margin: 0 0 0.5rem; color: var(--muted); }
    .artifact-body :global(ul),
    .artifact-body :global(ol) { margin: 0.25rem 0 0.5rem 1.2rem; padding: 0; color: var(--muted); }
    .artifact-body :global(li) { margin: 0.1rem 0; }
    .artifact-body :global(code) {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--surface);
      border: 0.5px solid var(--border);
      padding: 0 4px;
      border-radius: var(--r-xs);
    }
    .artifact-body :global(pre) {
      background: var(--obsidian);
      color: var(--linen);
      border: 0.5px solid var(--slag);
      border-radius: var(--r-sm);
      padding: 0.75rem 0.95rem;
      overflow-x: auto;
      font-size: 11px;
      margin: 0.35rem 0 0.5rem;
    }
    .artifact-body :global(pre code) {
      background: transparent; border: 0; padding: 0;
    }
    .artifact-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin: 0.5rem 0;
    }
    .artifact-body :global(th),
    .artifact-body :global(td) {
      border: 0.5px solid var(--border);
      padding: 0.3rem 0.55rem;
      text-align: left;
    }
    .artifact-body :global(th) {
      background: var(--surface);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: var(--ls-wide);
      color: var(--muted);
    }
    .artifact-body :global(blockquote) {
      border-left: 2px solid var(--accent);
      padding: 0.2rem 0 0.2rem 0.8rem;
      margin: 0.4rem 0;
      color: var(--muted);
    }

    /* ── Player ──────────────────────────────────────────────── */
    .player {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.25rem;
      box-shadow: var(--glow-md);
    }
    .player-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .player-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--subtle);
    }
    .player-title h2 {
      font-family: var(--font-display);
      font-size: var(--fs-lg);
      font-weight: 600;
      color: var(--text);
      margin: 0.2rem 0 0;
      letter-spacing: -0.005em;
    }
    .player-controls {
      display: inline-flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .ctl {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: var(--ls-wide);
      padding: 0.55rem 0.95rem;
      border-radius: var(--r-sm);
      cursor: pointer;
      border: 0.5px solid var(--border);
      background: var(--card);
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition:
        color var(--dur-fast) var(--ease-standard),
        border-color var(--dur-fast) var(--ease-standard),
        background var(--dur-fast) var(--ease-standard);
    }
    .ctl:hover:not(:disabled) {
      color: var(--text);
      border-color: var(--muted);
    }
    .ctl-primary {
      background: var(--accent);
      color: var(--obsidian);
      border-color: transparent;
    }
    .ctl-primary:hover:not(:disabled) { background: var(--accent-hover); }
    .ctl:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ── Progress ────────────────────────────────────────────── */
    .progress {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 1rem;
    }
    .progress::before {
      content: "";
      grid-column: 1;
      grid-row: 1;
      height: 3px;
      background: var(--card);
      border-radius: var(--r-pill);
    }
    .progress-bar {
      grid-column: 1;
      grid-row: 1;
      height: 3px;
      width: 0;
      background: var(--accent);
      border-radius: var(--r-pill);
      transition: width var(--dur-base) var(--ease-standard);
    }
    .progress-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--subtle);
      letter-spacing: var(--ls-wide);
    }

    /* ── Transcript + messages ───────────────────────────────── */
    /* Fixed height so adding messages scrolls inside the chat, not the
       page. Page is stationary; the chat canvas keeps moving up on its
       own as exchanges stack. `height` (not max-height) so the container
       holds its size even when near-empty. `overscroll-behavior: contain`
       stops a scroll at the chat edge from bubbling to the page. */
    .transcript {
      height: 60vh;
      min-height: 20rem;
      overflow-y: auto;
      overscroll-behavior: contain;
      padding: 1rem 1.1rem;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
      background: var(--obsidian);
      border: 0.5px solid var(--slag);
      border-radius: var(--r-md);
    }
    @media (max-width: 720px) {
      .transcript { height: 70vh; }
    }

    .start-prompt {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 1rem;
      border: 0.5px dashed var(--slag);
      border-radius: var(--r-md);
      color: var(--sand);
      background: var(--forge);
      font-size: var(--fs-sm);
      margin-top: 0.5rem;
    }
    .start-prompt[hidden] { display: none; }
    .start-prompt kbd {
      background: var(--obsidian);
      border: 0.5px solid var(--slag);
      color: var(--linen);
    }

    .msg { max-width: 88%; }
    .msg--assistant { align-self: flex-start; }   /* Claude on the left */
    .msg--user      { align-self: flex-end;   }   /* user on the right  */
    .msg-label {
      font-family: var(--font-mono);
      font-size: 9px;
      font-weight: 500;
      letter-spacing: var(--ls-wider);
      text-transform: uppercase;
      color: var(--sand);
      margin-bottom: 0.3rem;
      opacity: 0.8;
    }
    .msg--user .msg-label { text-align: right; }
    .msg-content {
      padding: 0.8rem 1rem;
      border-radius: var(--r-md);
      font-size: var(--fs-sm);
      line-height: var(--lh-base);
      white-space: pre-wrap;
      word-wrap: break-word;
      border: 0.5px solid;
    }
    /* Claude (left): muted forge bubble with ember accent edge */
    .msg--assistant .msg-content {
      background: var(--forge);
      border-color: var(--slag);
      color: var(--linen);
      border-bottom-left-radius: var(--r-xs);
    }
    /* User (right): ember-accent bubble, clearly different from Claude's */
    .msg--user .msg-content {
      background: var(--accent);
      border-color: var(--accent-hover);
      color: var(--obsidian);
      border-bottom-right-radius: var(--r-xs);
      font-weight: 500;
    }

    /* Markdown prose — scoped to the assistant bubble (dark background). */
    .msg--assistant .msg-content :global(p) { margin: 0 0 0.55rem; color: var(--linen); }
    .msg--assistant .msg-content :global(p:last-child) { margin-bottom: 0; }
    .msg--assistant .msg-content :global(h1),
    .msg--assistant .msg-content :global(h2),
    .msg--assistant .msg-content :global(h3) {
      font-family: var(--font-display);
      color: var(--parchment);
      margin: 0.5rem 0 0.35rem;
    }
    .msg--assistant .msg-content :global(h2) { font-size: var(--fs-md); }
    .msg--assistant .msg-content :global(h3) { font-size: var(--fs-sm); }
    .msg--assistant .msg-content :global(ul),
    .msg--assistant .msg-content :global(ol) {
      margin: 0.25rem 0 0.55rem 1.1rem;
      padding: 0;
      color: var(--linen);
    }
    .msg--assistant .msg-content :global(li) { margin: 0.1rem 0; }
    .msg--assistant .msg-content :global(code) {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--obsidian);
      border: 0.5px solid var(--slag);
      color: var(--sand);
      padding: 1px 5px;
      border-radius: var(--r-xs);
    }
    .msg--assistant .msg-content :global(pre) {
      background: var(--char);
      color: var(--linen);
      border: 0.5px solid var(--obsidian);
      border-radius: var(--r-sm);
      padding: 0.75rem 0.95rem;
      overflow-x: auto;
      font-size: 11px;
      margin: 0.35rem 0 0.5rem;
    }
    .msg--assistant .msg-content :global(pre code) {
      background: transparent;
      border: 0;
      padding: 0;
      color: inherit;
      font-size: inherit;
    }
    .msg--assistant .msg-content :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin: 0.5rem 0;
    }
    .msg--assistant .msg-content :global(th),
    .msg--assistant .msg-content :global(td) {
      border: 0.5px solid var(--slag);
      padding: 0.3rem 0.55rem;
      text-align: left;
      color: var(--linen);
    }
    .msg--assistant .msg-content :global(th) {
      background: var(--char);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: var(--ls-wide);
      color: var(--sand);
    }
    .msg--assistant .msg-content :global(blockquote) {
      border-left: 2px solid var(--accent);
      padding: 0.25rem 0 0.25rem 0.85rem;
      margin: 0.5rem 0;
      color: var(--sand);
      font-style: italic;
    }
    .msg--assistant .msg-content :global(strong) { color: var(--parchment); }

    /* ── Inline artifact chips (under a Claude message) ───────── */
    .msg-artifacts {
      display: flex;
      flex-wrap: wrap;
      gap: 0.35rem;
      margin-top: 0.5rem;
    }
    .msg-artifact {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      background: var(--char);
      color: var(--parchment);
      border: 0.5px solid var(--slag);
      border-radius: var(--r-sm);
      padding: 0.35rem 0.6rem;
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: var(--ls-wide);
      cursor: pointer;
      transition:
        background var(--dur-fast) var(--ease-standard),
        color var(--dur-fast) var(--ease-standard),
        border-color var(--dur-fast) var(--ease-standard);
    }
    .msg-artifact:hover {
      background: var(--accent);
      color: var(--obsidian);
      border-color: var(--accent-hover);
    }
    .msg-artifact-kind {
      background: var(--obsidian);
      color: var(--sand);
      border: 0.5px solid var(--slag);
      padding: 1px 5px;
      border-radius: var(--r-xs);
      font-size: 9px;
    }
    .msg-artifact:hover .msg-artifact-kind {
      background: var(--obsidian);
      color: var(--accent);
    }

    /* ── Beat divider (inside the dark chat) ─────────────────── */
    .beat {
      display: grid;
      grid-template-columns: 1fr auto 1fr;
      align-items: center;
      gap: 0.85rem;
      margin: 0.5rem 0 0.25rem;
    }
    .beat-rule { height: 0; border-top: 0.5px solid var(--slag); }
    .beat-body {
      text-align: center;
      display: flex;
      flex-direction: column;
      gap: 0.2rem;
      align-items: center;
    }
    .beat-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--accent);
    }
    .beat-caption {
      font-size: var(--fs-xs);
      color: var(--sand);
    }
    .beat-skills {
      display: inline-flex;
      gap: 0.25rem;
      flex-wrap: wrap;
      justify-content: center;
      margin-top: 0.2rem;
    }
    .beat-skills .chip {
      background: var(--char);
      border-color: var(--slag);
      color: var(--sand);
    }

    @media (max-width: 720px) {
      .player-head { flex-direction: column; align-items: flex-start; }
    }
  </style>
</Base>
