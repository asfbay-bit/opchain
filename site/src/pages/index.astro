---
import Base from "../layouts/Base.astro";
import Logo from "../components/Logo.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Button from "../components/ui/Button.astro";
import Icon from "../components/Icon.astro";
import { walkthroughs } from "../data/walkthroughs";
import { defaultFor } from "../lib/flags/build-defaults";
import { getAllSkills } from "../lib/skills";

const demoEnabled = defaultFor("site.feature.demo-page") as boolean;
const allSkills = await getAllSkills();
const skillCount = allSkills.length;

// Featured-scenario rotation: the magazine cover that lives between
// the stats strip and the resources strip. Slot is keyed to wall-clock
// time so every visitor in the same 10-second window sees the same
// headline. Inline script below schedules the next swap on the slot
// boundary and updates the 12-dot indicator in lock-step.
const covers = walkthroughs.map((w, i) => ({
  num: String(i + 1).padStart(2, "0"),
  id: w.id,
  title: w.title,
  tagline: w.tagline,
}));
const initialCover = covers[0];
const coverCount = covers.length;
---

<Base
  title="opchain — skills that ship"
  description="opchain is a skillchain and checkpoint protocol designed to get you from concept to production to ops."
  active="/"
>
  <main class="intro">
    <Eyebrow>skill ecosystem</Eyebrow>

    <div class="intro-hero">
      <Logo size={88} />
      <h1 class="intro-mark">opchain</h1>
    </div>

    <p class="intro-claim">skills that ship.</p>

    <div class="intro-tagline">
      <span>a skillchain and checkpoint protocol designed to get you from concept to production to ops</span>
    </div>

    <div class="intro-body">
      <p>
        If you've ever tried to build something real with Claude and
        watched it lose the plot between chats — forgetting your spec,
        redesigning what it already designed, repeating questions it
        asked an hour ago — opchain is what you've been looking for.
      </p>
      <p>
        A set of Claude Code skills plus a checkpoint protocol. Each
        skill specializes in one piece of the puzzle (discovery, spec,
        design, build, audit, ship, monitor, migrate, scale). At the
        beginning of the next session, Claude reads them back to pick
        up right where you left off. A central orchestrator routes
        between them so you never have to think about which skill to
        call.
      </p>
      <p>
        Install them, trigger by name, keep going. No API keys. No SaaS.
        No vendor lock-in — every skill is a single Markdown file.
      </p>
    </div>

    <!-- Glowing matching release bar — current (ember) + next (slate).
         Both halves share one pill silhouette with a soft pulsing
         ember box-shadow. Links to /changelog for full notes. -->
    <a class="release-bar-glow" href="/changelog" aria-label="opchain releases">
      <span class="rb-half rb-current">
        <span class="rb-tag">v1.4 · shipped</span>
        <span class="rb-text">Codex MCP server · 32 packs · Apple · Android · Flutter</span>
      </span>
      <span class="rb-divider" aria-hidden="true"></span>
      <span class="rb-half rb-next">
        <span class="rb-tag rb-tag-next">v1.5 · next</span>
        <span class="rb-text rb-text-next">4 AI-native skills · RAG · agents · prompt-ops</span>
      </span>
      <span class="rb-arrow" aria-hidden="true">›</span>
    </a>

    <section class="stats" aria-label="opchain at a glance">
      <a class="stat" href="/skills">
        <span class="stat-num">{skillCount}</span>
        <span class="stat-label">skills shipped</span>
      </a>
      <a class="stat" href="/changelog">
        <span class="stat-num">v1.4</span>
        <span class="stat-label">latest release</span>
      </a>
      <a class="stat" href="/status">
        <span class="stat-num">live</span>
        <span class="stat-label">system status</span>
      </a>
      <a class="stat" href="https://github.com/asfbay-bit/opchain" rel="noopener">
        <span class="stat-num">MIT</span>
        <span class="stat-label">open source</span>
      </a>
    </section>

    <!-- Cinema banner — rotates every 10 s through the scenario
         catalog. Sits beneath the stats strip. -->
    <section class="stage" data-cover aria-label="Featured scenario">
      <div class="stage-mid">
        <div class="stage-issue">
          opchain · scenario <span data-cover-num>{initialCover.num}</span> of {String(coverCount).padStart(2, "0")}
        </div>
        <h2 class="stage-h" data-cover-title>{initialCover.title}</h2>
        <p class="stage-sub" data-cover-tagline>{initialCover.tagline}</p>
        <div class="stage-actions">
          {demoEnabled && (
            <a class="btn btn-primary" href="/demo#workbench">▶ open the workbench</a>
          )}
          <a class="btn btn-ghost" href="/install">install opchain</a>
        </div>

        <div class="dot-row" aria-label={`Scenario 1 of ${coverCount}`} data-cover-dots>
          {covers.map((c, i) => (
            <button
              class={`dot${i === 0 ? " active" : ""}`}
              type="button"
              data-i={i}
              aria-label={`Scenario ${c.num}: ${c.title}`}
              aria-current={i === 0 ? "true" : "false"}
            />
          ))}
          <span class="dot-counter">
            <span data-cover-num-counter>{initialCover.num}</span> / {String(coverCount).padStart(2, "0")}
          </span>
        </div>
      </div>
    </section>

    <script is:inline type="application/json" id="cover-data" set:html={JSON.stringify(covers)} />

    <!-- Resources strip — 4-up. The new "Skills" tile points to the
         raw skill source under /docs/<id>/SKILL.md, surfaced from
         skills/ via the build-time sync. -->
    <section class="resources-strip" aria-label="Resources">
      <Eyebrow>go deeper</Eyebrow>
      <h2 class="resources-heading">resources</h2>
      <p class="resources-sub">References and trust signals you'd otherwise have to scroll all the way to the footer to find.</p>
      <div class="res-grid">
        <a class="res-card" href="/skills">
          <span class="res-icon" aria-hidden="true">⛬</span>
          <h3>Skills</h3>
          <p>Read the source. Every skill is a single Markdown file you can audit, fork, and rewire.</p>
          <span class="read">read the files ›</span>
        </a>
        <a class="res-card" href="/glossary">
          <span class="res-icon" aria-hidden="true">📖</span>
          <h3>Glossary</h3>
          <p>Plain-English definitions for every opchain term — checkpoint, tri-agent, audit gate.</p>
          <span class="read">read ›</span>
        </a>
        <a class="res-card" href="/uses">
          <span class="res-icon" aria-hidden="true">◆</span>
          <h3>How it's built</h3>
          <p>opchain.dev is itself built with opchain. Every commit ran through the gates.</p>
          <span class="read">read ›</span>
        </a>
        <a class="res-card" href="/security">
          <span class="res-icon" aria-hidden="true">🔒</span>
          <h3>Security</h3>
          <p>Threat model, dependency posture, secret handling — what we actually do.</p>
          <span class="read">read ›</span>
        </a>
      </div>
    </section>

    <div class="intro-actions">
      <Button variant="primary" href="/install">
        <Icon name="download" />
        install opchain
      </Button>
      {demoEnabled && (
        <Button variant="outline" href="/demo">
          <Icon name="sparkles" />
          watch a demo
        </Button>
      )}
      <Button variant="ghost" href="/skills">
        browse skills
        <Icon name="arrow-right" />
      </Button>
    </div>
  </main>
</Base>

<style>
  .intro {
    /* Widened from 960 so body wraps on fewer lines and the cinema
       banner sits above the fold on a typical laptop viewport. */
    max-width: 1100px;
    margin: 0 auto;
    padding: 1.5rem 1.5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .intro-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.4rem;
    margin: 0.25rem 0 0.4rem;
  }

  .intro-mark {
    font-family: var(--font-display);
    font-weight: var(--wordmark-weight);
    /* Tighter than the original hero scale so the wordmark + logo
       stack leaves room for the banner above the fold. */
    font-size: clamp(2rem, 5.5vw, 3rem);
    letter-spacing: var(--ls-display);
    line-height: 1;
    color: var(--text);
    margin: 0;
  }

  .intro-claim {
    font-family: var(--font-display);
    font-weight: 700;   /* B-10: 700 = bold, so 20px qualifies as WCAG large text (3:1 threshold) */
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: 0.2px;
    color: var(--ember);
    margin: 0 0 0.7rem;
  }

  .intro-tagline {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-widest);
    color: var(--muted);
    max-width: 50rem;
    margin: 0 auto 1rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .intro-body {
    /* Wider wrap → fewer lines → shorter vertical stack so the
       cinema banner lands above the fold. */
    max-width: 52rem;
    margin: 0 auto;
    color: var(--muted);
    text-align: left;
  }
  .intro-body p { margin: 0 0 0.65rem; color: var(--muted); }
  .intro-body p:last-child { margin: 0; }

  .intro-actions {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1.5rem;
  }

  /* ── Glowing matching release bar (current + next).
        Replaces the single-release pill. Two halves share one chip
        silhouette; the next-release chip uses --info (slate) to read
        as pending rather than competing with the ember of current. ── */
  .release-bar-glow {
    display: inline-flex;
    align-items: center;
    gap: 0;
    align-self: center;
    margin: 1rem auto 0.5rem;
    padding: 4px 10px 4px 4px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    font-size: 12px;
    text-decoration: none;
    box-shadow:
      0 0 0 1px rgba(224, 92, 24, 0.18),
      0 0 24px -8px rgba(224, 92, 24, 0.4);
    animation: release-bar-pulse 3.4s ease-in-out infinite;
    transition:
      transform var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  @keyframes release-bar-pulse {
    0%, 100% {
      box-shadow:
        0 0 0 1px rgba(224, 92, 24, 0.18),
        0 0 18px -8px rgba(224, 92, 24, 0.35);
    }
    50% {
      box-shadow:
        0 0 0 1px rgba(224, 92, 24, 0.32),
        0 0 30px -6px rgba(224, 92, 24, 0.55);
    }
  }
  @media (prefers-reduced-motion: reduce) {
    .release-bar-glow { animation: none; }
  }
  .release-bar-glow:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .rb-half {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    padding: 0 8px;
  }
  .rb-tag {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 600;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    padding: 2px 7px;
    border-radius: 999px;
    /* Current release: filled ember background + obsidian text.
       9.5px bold text needs ≥4.5:1; the outlined variant we used in
       the preview was borderline. Filled-ember-on-obsidian = ~7:1.
       Visually this also makes "current" feel more present than the
       outlined "next" chip. */
    color: var(--obsidian);
    background: var(--accent);
    border: 0;
  }
  :global([data-theme="light"]) .rb-tag {
    /* In light mode --accent dips below AA-Normal on --obsidian. Match
       Button.astro's primary variant and use --ember. */
    background: var(--ember);
  }
  .rb-tag-next {
    color: var(--info);
    border: 0.5px solid var(--info);
    background: var(--info-dim);
  }
  .rb-text {
    font-family: var(--font-display);
    font-size: 11.5px;
    letter-spacing: var(--ls-wide);
    color: var(--text);
  }
  .rb-text-next { color: var(--muted); }
  .rb-divider {
    display: inline-block;
    width: 1px;
    height: 18px;
    background: var(--ribbon-edge);
    margin: 0 2px;
  }
  .rb-arrow {
    color: var(--subtle);
    font-size: 14px;
    line-height: 1;
    padding: 0 4px;
  }
  /* Light-mode contrast bump on the rb-text so the body text reads
     against the surface. */
  :global([data-theme="light"]) .release-bar-glow .rb-text { color: var(--obsidian); }

  /* ── Stat strip ── */
  .stats {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 0.5rem;
    width: 100%;
    max-width: 640px;
    margin: 1rem auto 0;
  }
  .stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.15rem;
    padding: 0.7rem 0.85rem;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    color: var(--muted);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .stat:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .stat-num {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
    line-height: 1;
  }
  .stat-label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--subtle);
  }

  /* ── Cinema banner ── */
  .stage {
    position: relative;
    align-self: stretch;
    max-width: none;
    margin: 1.5rem -1.5rem 0;
    padding: 1.25rem clamp(1.5rem, 4vw, 2.4rem) 1.1rem;
    overflow: hidden;
    text-align: left;
    min-height: 240px;
    display: flex;
    flex-direction: column;
    justify-content: center;
    background:
      radial-gradient(720px 320px at 75% 35%, var(--ember-glow), transparent 70%),
      radial-gradient(540px 260px at 12% 80%, var(--ember-dim), transparent 70%),
      linear-gradient(180deg, #14100a 0%, var(--bg) 100%);
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
  }
  .stage-mid { max-width: 940px; margin: 0 auto; width: 100%; }
  .stage-issue {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .stage-h {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.25rem, 2.6vw, 1.85rem);
    line-height: 1.15;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.4rem;
    max-width: 36ch;
    color: var(--text);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage-sub {
    font-size: var(--fs-base);
    color: var(--muted);
    max-width: 44rem;
    margin: 0 0 0.85rem;
    line-height: var(--lh-snug);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage[data-swapping] .stage-h,
  .stage[data-swapping] .stage-sub,
  .stage[data-swapping] .stage-issue { opacity: 0; }
  .stage-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .stage .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.55rem 1rem;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    border-radius: var(--r-xs);
    transition:
      transform var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .stage .btn-primary {
    background: var(--accent);
    color: var(--obsidian);
    border: 0;
    font-weight: 600;
  }
  :global([data-theme="light"]) .stage .btn-primary {
    background: var(--ember);
  }
  .stage .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--glow-md);
  }
  .stage .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 0.5px solid var(--border);
  }
  .stage .btn-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }

  /* 12-dot rotation indicator (active dot grows + ember-glows).
     Each button is a 24×24 click target to satisfy WCAG 2.5.8
     (target-size). The visible dot is rendered via ::before so the
     clickable area stays compliant without making the dots themselves
     larger. */
  .dot-row {
    display: flex;
    align-items: center;
    gap: 0;
    margin-top: 1rem;
    flex-wrap: wrap;
  }
  .dot-row .dot {
    position: relative;
    width: 24px;
    height: 24px;
    border-radius: 50%;
    background: transparent;
    border: 0;
    padding: 0;
    cursor: pointer;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .dot-row .dot::before {
    content: "";
    display: block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: rgba(232, 223, 208, 0.22);
    transition:
      width var(--dur-base) var(--ease-standard),
      height var(--dur-base) var(--ease-standard),
      background var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .dot-row .dot:hover::before { background: var(--muted); }
  /* Active dot: empty ring with a clockwise conic fill animated over
     10 s. The fill represents time-until-next-rotation. */
  .dot-row .dot.active::before {
    width: 14px;
    height: 14px;
    background: transparent;
    box-shadow:
      inset 0 0 0 1.5px var(--ember-dim),
      0 0 14px -3px var(--ember);
  }
  .dot-row .dot.active::after {
    content: "";
    position: absolute;
    width: 14px;
    height: 14px;
    border-radius: 50%;
    background: conic-gradient(from 0deg, var(--ember) var(--p, 0deg), transparent var(--p, 0deg));
    pointer-events: none;
    animation: dot-fill 10s linear infinite;
    animation-delay: calc(var(--fill-progress, 0) * -1ms);
  }
  @property --p {
    syntax: "<angle>";
    inherits: false;
    initial-value: 0deg;
  }
  @keyframes dot-fill {
    from { --p: 0deg; }
    to   { --p: 360deg; }
  }
  @media (prefers-reduced-motion: reduce) {
    .dot-row .dot.active::before {
      background: var(--ember);
      box-shadow:
        0 0 0 3px var(--ember-dim),
        0 0 14px -3px var(--ember);
    }
    .dot-row .dot.active::after { display: none; }
  }
  .dot-row .dot:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: -2px;
  }
  .dot-row .dot-counter {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--subtle);
    letter-spacing: var(--ls-wider);
    margin-left: 0.6rem;
  }

  /* ── Resources strip — 4-up; breaks to 2-up then 1-up. ── */
  .resources-strip {
    width: 100%;
    max-width: 960px;
    margin: 4rem auto 0;
    text-align: center;
  }
  .resources-heading {
    font-family: var(--font-display);
    font-size: var(--fs-2xl);
    font-weight: 600;
    letter-spacing: var(--ls-tight);
    margin: 0.5rem 0 0;
    color: var(--text);
  }
  .resources-sub {
    color: var(--muted);
    max-width: 48ch;
    margin: 0.5rem auto 1.5rem;
    font-size: var(--fs-sm);
  }
  .res-grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 0.75rem;
    text-align: left;
  }
  @media (max-width: 960px) {
    .res-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 540px) {
    .res-grid { grid-template-columns: 1fr; }
  }
  .res-card {
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.25rem;
    text-decoration: none;
    color: var(--text);
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard);
  }
  .res-card:hover {
    border-color: var(--accent);
    color: var(--text);
    transform: translateY(-1px);
    box-shadow: 0 0 0 1px var(--accent-dim);
  }
  .res-card .res-icon {
    width: 36px;
    height: 36px;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    background: var(--accent-dim);
    color: var(--accent);
    border-radius: 50%;
    font-family: var(--font-mono);
    font-size: 16px;
  }
  .res-card h3 {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    margin: 0;
    letter-spacing: 0.02em;
  }
  .res-card p {
    font-size: var(--fs-sm);
    color: var(--muted);
    margin: 0;
    line-height: var(--lh-snug);
  }
  .res-card .read {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: var(--ls-wide);
    color: var(--accent);
    margin-top: auto;
    text-transform: uppercase;
  }
</style>

<script is:inline>
  /* Cinema banner — 10-second slot rotation. Active dot in the
     indicator row tracks the active scenario in lock-step. */
  (() => {
    const stage = document.querySelector('[data-cover]');
    const dataNode = document.getElementById('cover-data');
    if (!stage || !dataNode) return;

    let covers;
    try { covers = JSON.parse(dataNode.textContent || '[]'); }
    catch { return; }
    if (!Array.isArray(covers) || covers.length === 0) return;

    const SLOT_MS = 10 * 1000;
    const numEl = stage.querySelector('[data-cover-num]');
    const titleEl = stage.querySelector('[data-cover-title]');
    const taglineEl = stage.querySelector('[data-cover-tagline]');
    const dotRow = stage.querySelector('[data-cover-dots]');
    const dots = dotRow ? Array.from(dotRow.querySelectorAll('.dot')) : [];
    const counterEl = stage.querySelector('[data-cover-num-counter]');

    function slotIndex() {
      return Math.floor(Date.now() / SLOT_MS) % covers.length;
    }
    function paint(c, i) {
      if (numEl) numEl.textContent = c.num;
      if (titleEl) titleEl.textContent = c.title;
      if (taglineEl) taglineEl.textContent = c.tagline;
      if (counterEl) counterEl.textContent = c.num;
      // Sync the conic fill animation to wall-clock slot progress —
      // toggling .active restarts the animation, so apply a negative
      // animation-delay equal to time elapsed in the current slot.
      const progressMs = Date.now() % SLOT_MS;
      dots.forEach((d, di) => {
        const active = di === i;
        d.classList.toggle('active', active);
        d.setAttribute('aria-current', active ? 'true' : 'false');
        if (active) {
          d.style.setProperty('--fill-progress', String(progressMs));
        } else {
          d.style.removeProperty('--fill-progress');
        }
      });
      if (dotRow) dotRow.setAttribute('aria-label', `Scenario ${i + 1} of ${covers.length}`);
    }
    function swap(animated) {
      const i = slotIndex();
      const c = covers[i];
      if (!animated) { paint(c, i); return; }
      stage.setAttribute('data-swapping', '');
      setTimeout(() => {
        paint(c, i);
        stage.removeAttribute('data-swapping');
      }, 200);
    }

    // Allow click-jumping to a specific scenario (debugging + power-user
    // affordance; the auto-rotation continues from there on the next
    // slot boundary).
    dots.forEach((d) => {
      d.addEventListener('click', () => {
        const i = parseInt(d.getAttribute('data-i') || '0', 10);
        paint(covers[i], i);
      });
    });

    swap(false);
    const msUntilNext = SLOT_MS - (Date.now() % SLOT_MS);
    setTimeout(() => {
      swap(true);
      setInterval(() => swap(true), SLOT_MS);
    }, msUntilNext);
  })();
</script>
