---
import Base from "../layouts/Base.astro";
import Logo from "../components/Logo.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Button from "../components/ui/Button.astro";
import Icon from "../components/Icon.astro";
import Card from "../components/ui/Card.astro";

const phases = [
  { step: "01", phase: "discover",  name: "Interview",     skill: "app-architect" },
  { step: "02", phase: "spec",      name: "Contract",      skill: "stack-forge + app-architect" },
  { step: "03", phase: "design",    name: "Style book",    skill: "ux-engineer + dash-forge" },
  { step: "04", phase: "build",     name: "Sprint loop",   skill: "app-architect" },
  { step: "05", phase: "audit",     name: "Quality gate",  skill: "code-auditor + security-auditor" },
  { step: "06", phase: "ship",      name: "Deploy",        skill: "git-ops + deploy-ops" },
  { step: "07", phase: "monitor",   name: "Observe",       skill: "monitoring-ops" },
  { step: "08", phase: "migrate",   name: "Engine swap",   skill: "migration-ops" },
];
---

<Base
  title="opchain — skills that ship"
  description="opchain is a set of Claude Code skills + a shared protocol that form an end-to-end software development pipeline: discover, spec, design, build, audit, ship, monitor, migrate, scale."
  active="/"
>
  <main class="intro">
    <Eyebrow>skill ecosystem</Eyebrow>

    <div class="intro-hero">
      <Logo size={128} />
      <h1 class="intro-mark">opchain</h1>
    </div>

    <div class="intro-tagline">
      <span>Claude Code skills + a shared checkpoint protocol</span>
      <span>skills that ship — concept to production to ops</span>
    </div>

    <div class="intro-body">
      <p>
        <strong>If you've ever tried to build something real with Claude
        and watched it lose the plot between chats</strong> — forgetting
        your spec, redesigning what it already designed, repeating
        questions it asked an hour ago — opchain is the missing layer.
      </p>
      <p>
        A set of Claude Code skills plus a shared checkpoint protocol.
        Each skill owns one phase (discover, spec, design, build, audit,
        ship, monitor, migrate, scale) and writes JSON checkpoints to
        <code>.checkpoints/</code>. Claude reads them back on the next
        session and picks up where you left off. Skills invoke each
        other automatically at phase boundaries — no manual handoffs,
        no copy-paste.
      </p>
      <p>
        Install them, trigger by name, keep going. No API keys. No SaaS.
        No vendor lock-in — every skill is a single Markdown file.
      </p>
    </div>

    <section class="phase-grid" aria-label="Pipeline phases">
      {phases.map((p) => (
        <Card variant="surface" glow={false}>
          <div class="phase-step">{p.step} · {p.phase}</div>
          <div class="phase-name">{p.name}</div>
          <div class="phase-skill">{p.skill}</div>
        </Card>
      ))}
    </section>

    <div class="intro-actions">
      <Button variant="primary" href="/install">
        <Icon name="download" />
        install opchain
      </Button>
      <Button variant="outline" href="/tryit">
        <Icon name="sparkles" />
        try it free
      </Button>
      <Button variant="ghost" href="/skills">
        browse skills
        <Icon name="arrow-right" />
      </Button>
    </div>
  </main>
</Base>

<style>
  .intro {
    max-width: 960px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  .intro-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.25rem;
    margin: 1.25rem 0 1.5rem;
  }

  .intro-mark {
    font-family: var(--font-display);
    font-weight: var(--wordmark-weight);
    font-size: var(--fs-hero);
    letter-spacing: var(--ls-display);
    line-height: 1;
    color: var(--text);
    margin: 0;
  }

  .intro-tagline {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-widest);
    color: var(--muted);
    max-width: 42rem;
    margin: 0 auto 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .intro-body {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--muted);
    text-align: left;
  }
  .intro-body p { margin: 0 0 1rem; color: var(--muted); }
  .intro-body p:last-child { margin: 0; }

  .phase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
    gap: 0.6rem;
    margin: 2.5rem 0;
    width: 100%;
    max-width: 720px;
    text-align: left;
  }

  .phase-step {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wider);
    color: var(--subtle);
    text-transform: uppercase;
    margin-bottom: 0.35rem;
  }
  .phase-name {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.02em;
    margin-bottom: 0.25rem;
  }
  .phase-skill {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--accent);
  }

  .intro-actions {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }
</style>
