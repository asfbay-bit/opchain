---
import Base from "../layouts/Base.astro";
import Logo from "../components/Logo.astro";
import Eyebrow from "../components/ui/Eyebrow.astro";
import Button from "../components/ui/Button.astro";
import Icon from "../components/Icon.astro";
import { walkthroughs } from "../data/walkthroughs";
import { defaultFor } from "../lib/flags/build-defaults";

const demoEnabled = defaultFor("site.feature.demo-page") as boolean;

type Role =
  | "workflow"
  | "tri-agent"
  | "audit-gate"
  | "specialist"
  | "advisor"
  | "orchestrator"
  | "success";

interface SkillPill {
  id: string;
  role: Role;
}

interface Phase {
  step: string;
  phase: string;
  name: string;
  skills: SkillPill[];
  blurb: string;
}

const phases: Phase[] = [
  {
    step: "01", phase: "discover", name: "Interview",
    skills: [{ id: "app-architect", role: "workflow" }],
    blurb: "Interview — scope the idea, users, success criteria, and MVP boundaries.",
  },
  {
    step: "02", phase: "spec", name: "Contract",
    skills: [
      { id: "stack-forge",   role: "advisor" },
      { id: "app-architect", role: "workflow" },
      { id: "api-dev",       role: "tri-agent" },
    ],
    blurb: "Contract — typed spec, stack picks, integration shape, and the first-party API surface as an OpenAPI/GraphQL contract.",
  },
  {
    step: "03", phase: "design", name: "Style book",
    skills: [
      { id: "ux-engineer", role: "tri-agent" },
      { id: "dash-forge",  role: "specialist" },
    ],
    blurb: "Style book — design system, screens, components, working prototype.",
  },
  {
    step: "04", phase: "build", name: "Sprint loop",
    skills: [{ id: "app-architect", role: "workflow" }],
    blurb: "Sprint loop — Generator/Evaluator build cycle, ship features behind quality gates.",
  },
  {
    step: "05", phase: "audit", name: "Quality gate",
    skills: [
      { id: "code-auditor",     role: "audit-gate" },
      { id: "security-auditor", role: "audit-gate" },
    ],
    blurb: "Quality gate — Auditor/Fixer/Verifier loop plus security posture review before ship.",
  },
  {
    step: "06", phase: "ship", name: "Deploy",
    skills: [
      { id: "git-ops",    role: "specialist" },
      { id: "deploy-ops", role: "orchestrator" },
    ],
    blurb: "Deploy — branch, PR, audit gate, staging, production, rollback if needed.",
  },
  {
    step: "07", phase: "monitor", name: "Observe",
    skills: [{ id: "monitoring-ops", role: "specialist" }],
    blurb: "Observe — uptime, errors, alerts, SLOs, on-call, postmortems.",
  },
  {
    step: "08", phase: "migrate", name: "Engine swap",
    skills: [{ id: "migration-ops", role: "specialist" }],
    blurb: "Engine swap — live migrations: database, framework, auth, platform — with rollback.",
  },
];

// Featured-scenario rotation: the magazine cover relocated from /demo
// (chunk 2 of the workbench port). Slot is keyed to wall-clock time so
// every visitor in the same 2-minute window sees the same headline; the
// inline script below schedules the next swap on the slot boundary.
const covers = walkthroughs.map((w, i) => ({
  num: String(i + 1).padStart(2, "0"),
  id: w.id,
  title: w.title,
  tagline: w.tagline,
}));
const initialCover = covers[0];
---

<Base
  title="opchain — skills that ship"
  description="opchain is a skillchain and checkpoint protocol designed to get you from concept to production to ops."
  active="/"
>
  <main class="intro">
    <Eyebrow>skill ecosystem</Eyebrow>

    <div class="intro-hero">
      <Logo size={128} />
      <h1 class="intro-mark">opchain</h1>
    </div>

    <p class="intro-claim">skills that ship.</p>

    <div class="intro-tagline">
      <span>a skillchain and checkpoint protocol designed to get you from concept to production to ops</span>
    </div>

    <div class="intro-body">
      <p>
        If you've ever tried to build something real with Claude and
        watched it lose the plot between chats — forgetting your spec,
        redesigning what it already designed, repeating questions it
        asked an hour ago — opchain is what you've been looking for.
      </p>
      <p>
        A set of Claude Code skills plus a checkpoint protocol. Each
        skill specializes in one piece of the puzzle (discovery, spec,
        design, build, audit, ship, monitor, migrate, scale). At the
        beginning of the next session, Claude reads them back to pick
        up right where you left off. A central orchestrator routes
        between them so you never have to think about which skill to
        call.
      </p>
      <p>
        Install them, trigger by name, keep going. No API keys. No SaaS.
        No vendor lock-in — every skill is a single Markdown file.
      </p>
    </div>

    <a class="release-pill" href="/changelog" aria-label="opchain v1.3 release notes">
      <span class="release-pill-tag">v1.3</span>
      <span class="release-pill-text">
        Runtime PM-MCP · Django / Rails / Go / Rust · release-ops
      </span>
      <span class="release-pill-arrow" aria-hidden="true">›</span>
    </a>

    <!-- Featured-scenario magazine cover — rotates every 10 s through
         every walkthrough in the catalog. "Open the workbench"
         deep-links into /demo so the click lands directly on the IDE
         workbench. -->
    <section class="stage" data-cover>
      <div class="stage-mid">
        <div class="stage-issue">
          opchain · scenario <span data-cover-num>{initialCover.num}</span>
        </div>
        <h2 class="stage-h" data-cover-title>{initialCover.title}</h2>
        <p class="stage-sub" data-cover-tagline>{initialCover.tagline}</p>
        <div class="stage-actions">
          {demoEnabled && (
            <a class="btn btn-primary" href="/demo#workbench">▶ open the workbench</a>
          )}
          <a class="btn btn-ghost" href="/install">install opchain</a>
        </div>
      </div>
    </section>

    <script is:inline type="application/json" id="cover-data" set:html={JSON.stringify(covers)} />

    <section class="phase-grid" aria-label="Pipeline phases">
      {phases.map((p) => (
        <article class="phase-card" tabindex="0" aria-label={`${p.name} — ${p.blurb}`}>
          <div class="phase-step">{p.step} · {p.phase}</div>
          <div class="phase-name">{p.name}</div>
          <div class="phase-pills">
            {p.skills.map((s) => (
              <span class="phase-pill" data-role={s.role}>{s.id}</span>
            ))}
          </div>
          <div class="phase-blurb">{p.blurb}</div>
        </article>
      ))}
    </section>

    <div class="intro-actions">
      <Button variant="primary" href="/install">
        <Icon name="download" />
        install opchain
      </Button>
      {demoEnabled && (
        <Button variant="outline" href="/demo">
          <Icon name="sparkles" />
          watch a demo
        </Button>
      )}
      <Button variant="ghost" href="/skills">
        browse skills
        <Icon name="arrow-right" />
      </Button>
    </div>
  </main>
</Base>

<style>
  .intro {
    max-width: 960px;
    margin: 0 auto;
    padding: 4rem 1.5rem 6rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
  }

  /* Tightened top stack: eyebrow ↔ hero ↔ wordmark ↔ claim. */
  .intro-hero {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;            /* Logo ↔ wordmark — was 1.25rem */
    margin: 0.4rem 0 0.5rem; /* eyebrow ↔ hero / hero ↔ claim — was 1.25rem 0 1.5rem */
  }

  .intro-mark {
    font-family: var(--font-display);
    font-weight: var(--wordmark-weight);
    font-size: var(--fs-hero);
    letter-spacing: var(--ls-display);
    line-height: 1;
    color: var(--text);
    margin: 0;
  }

  /* "skills that ship." — ember claim line below the wordmark. */
  .intro-claim {
    font-family: var(--font-display);
    font-weight: 700;   /* B-10: 700 = bold, so 20px qualifies as WCAG large text (3:1 threshold) */
    font-size: 20px;
    line-height: 1.3;
    letter-spacing: 0.2px;
    color: var(--ember);
    margin: 0 0 1rem;
  }

  .intro-tagline {
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-widest);
    color: var(--muted);
    max-width: 42rem;
    margin: 0 auto 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }

  .intro-body {
    max-width: 42rem;
    margin: 0 auto;
    color: var(--muted);
    text-align: left;
  }
  .intro-body p { margin: 0 0 1rem; color: var(--muted); }
  .intro-body p:last-child { margin: 0; }

  .phase-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
    gap: 0.6rem;
    margin: 2.5rem 0;
    width: 100%;
    max-width: 760px;
    text-align: left;
  }

  /* Card surface — replaces the previous <Card variant="surface"> so we can
     style hover/focus locally for the blurb reveal. */
  .phase-card {
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 0.85rem 0.95rem;
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
    cursor: default;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .phase-card:hover,
  .phase-card:focus-visible {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent-dim);
    outline: none;
  }

  .phase-step {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wider);
    color: var(--subtle);
    text-transform: uppercase;
  }
  .phase-name {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.02em;
  }

  /* Skill pills — square edges, role-colored fill. One pill per skill;
     multi-skill phases get multiple pills side by side. */
  .phase-pills {
    display: flex;
    flex-wrap: wrap;
    gap: 0.3rem;
    margin-top: 0.15rem;
  }
  .phase-pill {
    display: inline-flex;
    align-items: center;
    padding: 2px 7px;
    border-radius: 0;            /* square per spec */
    font-family: var(--font-mono);
    font-size: 10px;
    font-weight: 500;
    letter-spacing: 0.02em;
    line-height: 1.5;
    /* Outline + text in the role color, role color at 15% as fill.
       Each [data-role] override below sets --pill-color; the box
       picks up border, text, and fill from that single value. */
    --pill-color: var(--subtle);
    color: var(--pill-color);
    border: 0.5px solid var(--pill-color);
    background: color-mix(in srgb, var(--pill-color) 15%, transparent);
    white-space: nowrap;
  }
  /* Role colors — :root tokens map skill type → pill color.
     Border + text use the token directly; background is the same
     token at 15% via color-mix. */
  .phase-pill[data-role="workflow"]     { --pill-color: var(--workflow); }
  .phase-pill[data-role="tri-agent"]    { --pill-color: var(--tri-agent); }
  .phase-pill[data-role="audit-gate"]   { --pill-color: var(--audit-gate); }
  .phase-pill[data-role="specialist"]   { --pill-color: var(--specialist); }
  .phase-pill[data-role="advisor"]      { --pill-color: var(--advisor); }
  .phase-pill[data-role="orchestrator"] { --pill-color: var(--orchestrator); }
  .phase-pill[data-role="success"]      { --pill-color: var(--success); }

  /* Blurb — hidden at rest, fades in on hover/focus of the card. */
  .phase-blurb {
    font-family: var(--font-mono);
    font-size: 11px;
    line-height: 1.45;
    color: var(--muted);
    max-height: 0;
    opacity: 0;
    overflow: hidden;
    transition:
      max-height var(--dur-base) var(--ease-standard),
      opacity var(--dur-base) var(--ease-standard),
      margin-top var(--dur-base) var(--ease-standard);
  }
  .phase-card:hover .phase-blurb,
  .phase-card:focus-visible .phase-blurb,
  .phase-card:focus-within .phase-blurb {
    max-height: 6rem;
    opacity: 1;
    margin-top: 0.35rem;
  }
  /* Touch / no-hover devices — always show the blurb. */
  @media (hover: none) {
    .phase-blurb {
      max-height: none;
      opacity: 1;
      margin-top: 0.35rem;
    }
  }

  .intro-actions {
    display: flex;
    gap: 0.6rem;
    justify-content: center;
    flex-wrap: wrap;
    margin-top: 1rem;
  }

  /* ── Release pill (current-release marketing affordance). Sits above the
        magazine cover; links to /changelog. Subtle ember accent so
        it reads as a release callout, not a primary CTA. ── */
  .release-pill {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    align-self: center;
    margin: 1.75rem auto 0;
    padding: 0.4rem 0.9rem 0.4rem 0.5rem;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: 999px;
    color: var(--muted);
    font-size: var(--fs-sm);
    text-decoration: none;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .release-pill:hover {
    color: var(--text);
    border-color: var(--accent);
    transform: translateY(-1px);
  }
  .release-pill-tag {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(0, 0, 0, 0);
    border: 0.5px solid var(--accent);
    padding: 2px 8px;
    border-radius: 999px;
  }
  .release-pill-text {
    font-family: var(--font-sans);
    letter-spacing: var(--ls-wide);
  }
  .release-pill-arrow {
    color: var(--subtle);
    font-size: 16px;
    line-height: 1;
    transition: color var(--dur-fast) var(--ease-standard);
  }
  .release-pill:hover .release-pill-arrow { color: var(--accent); }

  /* ── Magazine cover (relocated from /demo, chunk 2). Sits between
        the intro body and the phase grid, full-bleed within the .intro
        column. Rotates every 2 minutes via the inline script below. ── */
  .stage {
    position: relative;
    align-self: stretch;
    max-width: none;
    margin: 2.5rem -1.5rem 2.5rem;
    padding: clamp(1.1rem, 2.5vw, 1.8rem) clamp(1rem, 4vw, 2.4rem);
    overflow: hidden;
    text-align: left;
    background:
      radial-gradient(640px 320px at 75% 30%, var(--ember-glow), transparent 70%),
      radial-gradient(420px 240px at 15% 80%, var(--ember-dim), transparent 70%),
      var(--bg);
    border-top: 0.5px solid var(--border);
    border-bottom: 0.5px solid var(--border);
  }
  .stage-mid { max-width: 940px; margin: 0 auto; width: 100%; }
  .stage-issue {
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }
  .stage-h {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.15rem, 2.2vw, 1.7rem);
    line-height: 1.15;
    letter-spacing: var(--ls-tight);
    margin: 0 0 0.4rem;
    max-width: 36ch;
    color: var(--text);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage-sub {
    font-size: var(--fs-base);
    color: var(--muted);
    max-width: 44rem;
    margin: 0 0 0.85rem;
    line-height: var(--lh-snug);
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .stage[data-swapping] .stage-h,
  .stage[data-swapping] .stage-sub,
  .stage[data-swapping] .stage-issue { opacity: 0; }
  .stage-actions {
    display: flex;
    gap: 0.5rem;
    align-items: center;
    flex-wrap: wrap;
  }
  .stage .btn {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    padding: 0.6rem 1.1rem;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    cursor: pointer;
    text-decoration: none;
    border-radius: var(--r-xs);
    transition:
      transform var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .stage .btn-primary {
    background: var(--accent);
    color: var(--obsidian);
    border: 0;
    font-weight: 600;
  }
  /* Light-theme contrast bump — mirrors Button.astro's primary
     variant. var(--accent) (#d95010) on --obsidian only hits 4.46:1
     in light mode, just below AA-Normal; var(--ember) (#e05c18) is
     the brand-constant ember and clears AA. */
  :global([data-theme="light"]) .stage .btn-primary {
    background: var(--ember);
  }
  .stage .btn-primary:hover {
    background: var(--accent-hover);
    transform: translateY(-1px);
    box-shadow: var(--glow-md);
  }
  .stage .btn-ghost {
    background: transparent;
    color: var(--text);
    border: 0.5px solid var(--border);
  }
  .stage .btn-ghost:hover {
    color: var(--accent);
    border-color: var(--accent);
  }
</style>

<script is:inline>
  /* Magazine cover — 10-second slot rotation (6 covers × 10 s = 60 s cycle). */
  (() => {
    const stage = document.querySelector('[data-cover]');
    const dataNode = document.getElementById('cover-data');
    if (!stage || !dataNode) return;

    let covers;
    try { covers = JSON.parse(dataNode.textContent || '[]'); }
    catch { return; }
    if (!Array.isArray(covers) || covers.length === 0) return;

    const SLOT_MS = 10 * 1000;
    const numEl = stage.querySelector('[data-cover-num]');
    const titleEl = stage.querySelector('[data-cover-title]');
    const taglineEl = stage.querySelector('[data-cover-tagline]');

    function slotIndex() {
      return Math.floor(Date.now() / SLOT_MS) % covers.length;
    }
    function paint(c) {
      if (numEl) numEl.textContent = c.num;
      if (titleEl) titleEl.textContent = c.title;
      if (taglineEl) taglineEl.textContent = c.tagline;
    }
    function swap(animated) {
      const c = covers[slotIndex()];
      if (!animated) { paint(c); return; }
      stage.setAttribute('data-swapping', '');
      setTimeout(() => {
        paint(c);
        stage.removeAttribute('data-swapping');
      }, 200);
    }

    swap(false);
    const msUntilNext = SLOT_MS - (Date.now() % SLOT_MS);
    setTimeout(() => {
      swap(true);
      setInterval(() => swap(true), SLOT_MS);
    }, msUntilNext);
  })();
</script>
