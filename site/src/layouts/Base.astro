---
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import FeedbackWidget from "../components/FeedbackWidget.astro";
import ConsentBanner from "../components/ConsentBanner.astro";
import { publicDefaults } from "../lib/flags/build-defaults";
import { defaultFor } from "../lib/flags/build-defaults";
import "../styles/global.css";

interface Props {
  title: string;
  description?: string;
  /** Route that matches the active nav link. */
  active?: string;
  /** Hide header/footer chrome (styleguide uses this for component framing). */
  bare?: boolean;
  /** Override the OpenGraph type (default: website). */
  ogType?: "website" | "article";
  /**
   * Override the OpenGraph image. Path relative to site root (e.g.
   * `/og/skills.png`) or a fully-qualified URL. If unset, the route →
   * asset map below picks one; if no entry matches, the global
   * `/og-image.png` is used as a fallback. See B-03 in
   * `roadmap/05-post-sprint-7-backlog.md`.
   */
  ogImage?: string;
  /**
   * Page-specific schema.org JSON-LD node(s), merged into the site-wide
   * `@graph` (Organization + WebSite). Pass a SoftwareApplication node on the
   * home page, a per-skill node on skill pages, etc. Lets AI crawlers and
   * search engines understand each page as structured data.
   */
  jsonLd?: Record<string, unknown> | Record<string, unknown>[];
}

const {
  title,
  description = "opchain — skills that ship. A set of interconnected skills for Claude Code, Claude.ai, Claude Desktop, and Codex / any MCP agent, forming a software development pipeline.",
  active = "/",
  bare = false,
  ogType = "website",
  ogImage: ogImageProp,
  jsonLd,
} = Astro.props;

// Route → OG image map. Per-page images lift social-share CTR over the
// single global asset. Drop new PNGs into `site/public/og/` and add the
// mapping here; pages without an explicit entry fall through to
// `/og-image.png` so nothing breaks for routes still on the global asset.
// Kept as a static map (rather than per-page props) so the source of
// truth is in one place — easier to audit which routes have a dedicated
// share card and which don't.
const ROUTE_OG_IMAGES: Record<string, string> = {
  "/":              "/og/home.png",
  "/skills":        "/og/skills.png",
  "/architecture":  "/og/architecture.png",
  "/install":       "/og/install.png",
  "/demo":          "/og/demo.png",
  "/privacy":       "/og/privacy.png",
  "/blog":          "/og/blog.png",
  // v1.5 AI-native skills — dedicated per-skill share cards (B-03).
  "/skills/oc-claude-api":  "/og/skills-oc-claude-api.png",
  "/skills/oc-rag-forge":   "/og/skills-oc-rag-forge.png",
  "/skills/oc-agent-forge": "/og/skills-oc-agent-forge.png",
  "/skills/oc-prompt-ops":  "/og/skills-oc-prompt-ops.png",
};

const canonical = new URL(Astro.url.pathname, Astro.site).toString();

// Public-flag snapshot stamped into HTML so the client has a deterministic
// initial value without a network round-trip. Post-consent, ConsentBanner
// loads PostHog; site/src/lib/flags/client.ts then layers PostHog overrides
// on top of these build-time defaults.
const flagSnapshot = JSON.stringify(publicDefaults());

// Build-time gates for site chrome. Defaults match prior behaviour (all
// true / true) so day-one rollout is invisible. Flipping a flag in the
// registry (or via a PostHog runtime override at the next build) opts
// the chrome out without touching this file.
const showFeedbackWidget = defaultFor("site.feature.feedback-widget") as boolean;
const consentBannerRequired = defaultFor("site.consent.banner-required") as boolean;
const cloudflareBeaconAllowed = defaultFor("platform.observability.cloudflare-beacon") as boolean;

// Resolution order: explicit prop → route map → global fallback. Each
// route page can pass `ogImage="/og/custom.png"` to override the static
// map (e.g. skill detail pages picking per-skill cards down the road).
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";
const skillDetailMatch = pathname.match(/^\/skills\/[^/]+$/);
const ogImagePath =
  ogImageProp ??
  ROUTE_OG_IMAGES[pathname] ??
  // Skill detail pages share the /skills card until each skill earns its own.
  (skillDetailMatch ? "/og/skills.png" : "/og-image.png");
const ogImage = new URL(ogImagePath, Astro.site).toString();

// schema.org JSON-LD. A site-wide Organization + WebSite graph (so every page
// carries publisher identity), plus any page-specific node(s) passed via the
// `jsonLd` prop. Helps AI crawlers + search engines parse the site as
// structured data — the read/index half of agentic discovery, alongside the
// /.well-known/ai-catalog.json (ARD) manifest the Worker serves.
const orgId = new URL("/#org", Astro.site).toString();
const websiteId = new URL("/#website", Astro.site).toString();
const siteRootUrl = new URL("/", Astro.site).toString();
const jsonLdGraph = [
  {
    "@type": "Organization",
    "@id": orgId,
    name: "opchain",
    url: siteRootUrl,
    logo: new URL("/favicon.svg", Astro.site).toString(),
  },
  {
    "@type": "WebSite",
    "@id": websiteId,
    name: "opchain",
    url: siteRootUrl,
    publisher: { "@id": orgId },
  },
  ...(Array.isArray(jsonLd) ? jsonLd : jsonLd ? [jsonLd] : []),
];
// Escape `<` so a description containing `</script>` can't break out of the
// JSON-LD block (set:html does not escape).
const jsonLdString = JSON.stringify({
  "@context": "https://schema.org",
  "@graph": jsonLdGraph,
}).replace(/</g, "\\u003c");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <!-- Agentic Resource Discovery (ARD): point agents/registries at the
         ai-catalog manifest the Worker serves (it lists the hosted MCP
         server). The /.well-known/ai-catalog.json well-known path is the
         other discovery hook. (A robots.txt `Agentmap:` directive is the
         third ARD method but Lighthouse's robots-txt SEO audit rejects
         non-standard directives, so we rely on the well-known path + this
         link tag.) -->
    <link rel="ai-catalog" href="/.well-known/ai-catalog.json" />
    <!-- schema.org structured data (Organization + WebSite + page node). -->
    <script type="application/ld+json" is:inline set:html={jsonLdString}></script>
    <!-- Build-time public-flag snapshot. Read by site/src/lib/flags/client.ts
         to seed initial values; overridden at runtime once PostHog loads
         post-consent. Server-only flags are never emitted here. -->
    <meta name="opchain-flags" content={flagSnapshot} />
    <script is:inline>
      // FOUC-preventing theme init — runs before CSS applies.
      // Default is dark (CSS default with no [data-theme] attribute).
      // The OS `prefers-color-scheme` media query is intentionally NOT
      // honored: opchain ships dark-first and a visitor on a light-mode
      // OS still sees the brand palette they came for. Once the user
      // clicks the ThemeToggle, the explicit choice is persisted to
      // localStorage and re-applied on every subsequent visit.
      (function () {
        try {
          var saved = localStorage.getItem("opchain-theme");
          if (saved === "light" || saved === "dark") {
            document.documentElement.setAttribute("data-theme", saved);
          }
        } catch (e) { /* best effort */ }
      })();
    </script>

    <!-- OpenGraph -->
    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content="opchain" />
    <meta property="og:image" content={ogImage} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Outfit:wght@200;300;400;500;600;700&family=JetBrains+Mono:wght@400;500;700&display=swap"
      rel="stylesheet"
    />

    <!-- Cloudflare Web Analytics — cookieless pageview beacon. Loaded on
         every page (no consent gate) because it collects no PII and sets
         no cookies. Token is set via `PUBLIC_CF_BEACON_TOKEN` at build. -->
    {cloudflareBeaconAllowed && import.meta.env.PUBLIC_CF_BEACON_TOKEN && (
      <script
        is:inline
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${import.meta.env.PUBLIC_CF_BEACON_TOKEN}"}`}
      />
    )}
  </head>
  <body>
    {!bare && <Header active={active} />}
    <slot />
    {!bare && <Footer />}
    {!bare && showFeedbackWidget && <FeedbackWidget />}
    {!bare && consentBannerRequired && <ConsentBanner />}
  </body>
</html>
