---
import Icon from "./Icon.astro";
import { walkthroughs } from "../data/walkthroughs";
import { getSkillRole, type Role } from "../lib/skills";

/**
 * Replays — six scripted end-to-end sessions with opchain.
 *
 * Used inside the Demo page's Replays tabpanel. The keyboard handler
 * (Enter / Space / R / 1–6) is gated so it only responds when this
 * component's hosting tabpanel is visible.
 */

// Role lookup for every skill referenced in any walkthrough — passed to the
// client script as a JSON island so runtime re-renders can color new pills
// without a second round-trip to lib/skills.
const allSkillIds = Array.from(
  new Set(
    walkthroughs.flatMap((w) => [
      ...w.skills,
      ...w.steps
        .map((s) => (s.type === "exchange" ? s.skill : s.type === "beat" ? (s.skills ?? []) : []))
        .flat()
        .filter((s): s is string => typeof s === "string"),
    ]),
  ),
);
const skillRoles: Record<string, Role> = Object.fromEntries(
  allSkillIds.map((id) => [id, getSkillRole(id)]),
);
const skillRolesJson = JSON.stringify(skillRoles);

const catalog = JSON.stringify(
  walkthroughs.map((w) => ({
    id: w.id,
    title: w.title,
    tagline: w.tagline,
    summary: w.summary,
    description: w.description,
    inputs: w.inputs,
    outputs: w.outputs,
    skills: w.skills,
    runtime: w.runtime,
    steps: w.steps,
  })),
);
---

<div class="replays" id="replays-root">
  <p class="kbd-hint">
    <kbd>Enter</kbd> next ·
    <kbd>Space</kbd> skip ·
    <kbd>R</kbd> restart ·
    <kbd>1</kbd>–<kbd>6</kbd> jump
  </p>

    <!-- ───────────── Scenario picker — collapsed strip ───────────── -->
    <section class="scenarios" id="scenario-picker" role="tablist" aria-label="Pick a scenario">
      {walkthroughs.map((w, i) => (
        <button
          type="button"
          class="scenario"
          role="tab"
          aria-pressed={i === 0 ? "true" : "false"}
          aria-selected={i === 0 ? "true" : "false"}
          {...({
            "data-scenario": w.id,
            "data-index": String(i),
          } as any)}
        >
          <span class="scenario-num">0{i + 1}</span>
          <span class="scenario-tagline">{w.tagline}</span>
        </button>
      ))}
    </section>

    <!-- ───────────── Detail panel — full width for the active scenario ───────────── -->
    <section class="detail" id="detail-card" aria-live="polite">
      <div class="detail-head">
        <div>
          <h2 class="detail-title" id="detail-title">{walkthroughs[0].title}</h2>
          <p class="detail-summary" id="detail-summary">{walkthroughs[0].summary}</p>
        </div>
        <div class="detail-meta">
          <span class="detail-runtime" id="detail-runtime">{walkthroughs[0].runtime}</span>
          <div class="detail-skills" id="detail-skills">
            {walkthroughs[0].skills.map((s) => (
              <span class="role-pill" data-role={getSkillRole(s)}>{s}</span>
            ))}
          </div>
          <button
            type="button"
            class="detail-toggle"
            id="detail-toggle"
            aria-expanded="true"
            aria-controls="detail-body-wrap"
            aria-label="Collapse details"
          >
            <Icon name="arrow-right" size={12} class="detail-toggle-chev" />
          </button>
        </div>
      </div>

      <div class="detail-body-wrap" id="detail-body-wrap">
        <p class="detail-body" id="detail-body">{walkthroughs[0].description}</p>

        <div class="detail-io">
          <div class="io-col">
            <div class="io-head">Inputs</div>
            <ul class="io-list" id="detail-inputs">
              {walkthroughs[0].inputs.map((x) => <li>{x}</li>)}
            </ul>
          </div>
          <div class="io-col">
            <div class="io-head">Outputs <span class="io-hint">click to expand</span></div>
            <ul class="io-list artifacts" id="detail-outputs">
              {walkthroughs[0].outputs.map((a) => (
                <li class="artifact">
                  <button
                    type="button"
                    class="artifact-head"
                    aria-expanded="false"
                    {...({ "data-artifact-id": a.id } as any)}
                  >
                    <Icon name="arrow-right" size={10} class="artifact-chevron" />
                    <span class="artifact-label">{a.label}</span>
                    {a.kind && <span class="artifact-kind">{a.kind}</span>}
                  </button>
                  <div class="artifact-body markdown" hidden></div>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>

    <!-- ───────────── Player ───────────── -->
    <section class="player" aria-label="Walkthrough player">
      <div class="player-head">
        <div class="player-title">
          <span class="player-eyebrow" id="player-eyebrow">scenario · 01</span>
          <h2 id="player-heading">{walkthroughs[0].title}</h2>
        </div>
        <div class="player-controls">
          <button type="button" id="btn-play" class="ctl ctl-primary" aria-label="Next step (Enter)">
            <Icon name="arrow-right" size={12} />
            <span id="btn-play-label">start</span>
          </button>
          <button type="button" id="btn-skip" class="ctl" aria-label="Skip to end (Space)">
            skip
          </button>
          <button type="button" id="btn-restart" class="ctl" aria-label="Restart (R)">
            restart
          </button>
        </div>
      </div>

      <div class="progress">
        <div class="progress-bar" id="progress-bar"></div>
        <span class="progress-label" id="progress-label" aria-live="polite">step 0 of 0</span>
      </div>

      <div class="terminal" id="transcript-wrap">
        <div class="cc-statusline">
          <span class="cc-cwd" id="cc-cwd">~/sessions/concept-to-shipped</span>
          <span class="cc-mode">claude-opus-4-7  ·  auto-accept</span>
        </div>
        <div id="transcript" class="cc-stream" aria-live="polite" aria-atomic="false">
          <!-- Populated by the client script. An initial prompt is shown below. -->
        </div>
      </div>

      <div class="start-prompt" id="start-prompt">
        <Icon name="sparkles" />
        <p><strong>Press <kbd>Enter</kbd></strong> or click <em>start</em>.</p>
      </div>
    </section>
</div>

<script is:inline id="walkthrough-data" type="application/json" set:html={catalog}></script>
<script is:inline id="skill-roles-data" type="application/json" set:html={skillRolesJson}></script>

  <script>
    import { renderSafeMarkdown } from "../lib/markdown";

    interface Beat {
      type: "beat";
      label: string;
      caption?: string;
      skills?: string[];
    }
    interface Exchange {
      type: "exchange";
      role: "user" | "claude";
      skill?: string;
      content: string;
      artifacts?: string[];
    }
    type Step = Beat | Exchange;
    interface Artifact {
      id: string;
      label: string;
      kind?: string;
      body: string;
    }
    interface Walkthrough {
      id: string;
      title: string;
      tagline: string;
      summary: string;
      description: string;
      inputs: string[];
      outputs: Artifact[];
      skills: string[];
      runtime: string;
      steps: Step[];
    }

    const dataEl = document.getElementById("walkthrough-data");
    if (!dataEl) throw new Error("walkthrough data missing");
    const catalog: Walkthrough[] = JSON.parse(dataEl.textContent || "[]");

    // Skill → role map. Pre-rendered server-side from lib/skills.getSkillRole
    // so runtime DOM updates can color new pills without re-fetching.
    const rolesEl = document.getElementById("skill-roles-data");
    const skillRoles: Record<string, string> = rolesEl
      ? JSON.parse(rolesEl.textContent || "{}")
      : {};
    function roleFor(skill: string | undefined): string {
      return (skill && skillRoles[skill]) || "specialist";
    }

    const picker       = document.getElementById("scenario-picker")!;
    const heading      = document.getElementById("player-heading")!;
    const eyebrow      = document.getElementById("player-eyebrow")!;
    const detailTitle  = document.getElementById("detail-title")!;
    const detailSum    = document.getElementById("detail-summary")!;
    const detailBody   = document.getElementById("detail-body")!;
    const detailRun    = document.getElementById("detail-runtime")!;
    const detailSkills = document.getElementById("detail-skills")!;
    const detailInputs = document.getElementById("detail-inputs")!;
    const detailOuts   = document.getElementById("detail-outputs")!;
    const transcript   = document.getElementById("transcript")!;
    const cwd          = document.getElementById("cc-cwd")!;
    const progressBar  = document.getElementById("progress-bar")!;
    const progressLbl  = document.getElementById("progress-label")!;
    const playBtn      = document.getElementById("btn-play")! as HTMLButtonElement;
    const playLbl      = document.getElementById("btn-play-label")!;
    const skipBtn      = document.getElementById("btn-skip")! as HTMLButtonElement;
    const restartBtn   = document.getElementById("btn-restart")! as HTMLButtonElement;
    const startPrompt  = document.getElementById("start-prompt")!;
    const detailCard   = document.getElementById("detail-card")!;
    const detailToggle = document.getElementById("detail-toggle")! as HTMLButtonElement;

    let currentIdx  = 0;       // which scenario
    let stepIdx     = 0;       // how many steps revealed

    function setDetailCollapsed(collapsed: boolean) {
      detailCard.classList.toggle("is-collapsed", collapsed);
      detailToggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
      detailToggle.setAttribute(
        "aria-label",
        collapsed ? "Expand details" : "Collapse details",
      );
    }

    function currentScenario(): Walkthrough {
      return catalog[currentIdx];
    }

    function setScenario(i: number) {
      if (i < 0 || i >= catalog.length) return;
      currentIdx = i;
      stepIdx = 0;
      transcript.innerHTML = "";
      // New scenario picked → re-expand the detail card so the user sees
      // its inputs / outputs before starting the new replay.
      setDetailCollapsed(false);
      const w = currentScenario();

      // Player head
      heading.textContent = w.title;
      eyebrow.textContent = `scenario · 0${i + 1}`;
      playLbl.textContent = "start";
      startPrompt.hidden = false;
      cwd.textContent = `~/sessions/${w.id}`;

      // Detail panel — title, summary, body, runtime, skills, I/O, artifacts.
      detailTitle.textContent = w.title;
      detailSum.textContent   = w.summary;
      detailBody.textContent  = w.description;
      detailRun.textContent   = w.runtime;
      detailSkills.innerHTML  = w.skills.map((s) => `<span class="role-pill" data-role="${escapeHTML(roleFor(s))}">${escapeHTML(s)}</span>`).join("");
      detailInputs.innerHTML  = w.inputs.map((x) => `<li>${escapeHTML(x)}</li>`).join("");
      detailOuts.innerHTML    = w.outputs.map((a) => `
        <li class="artifact">
          <button type="button" class="artifact-head" aria-expanded="false" data-artifact-id="${escapeHTML(a.id)}">
            <svg class="artifact-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="artifact-label">${escapeHTML(a.label)}</span>
            ${a.kind ? `<span class="artifact-kind">${escapeHTML(a.kind)}</span>` : ""}
          </button>
          <div class="artifact-body markdown" hidden></div>
        </li>
      `).join("");
      wireArtifactToggles();

      updateProgress();

      // Toggle pressed state on the scenario cards.
      picker.querySelectorAll<HTMLElement>("[data-scenario]").forEach((el) => {
        const matched = el.dataset.scenario === w.id;
        el.setAttribute("aria-pressed", matched ? "true" : "false");
        el.setAttribute("aria-selected", matched ? "true" : "false");
      });
    }

    function wireArtifactToggles() {
      const w = currentScenario();
      const byId = new Map(w.outputs.map((a) => [a.id, a] as const));
      detailOuts.querySelectorAll<HTMLButtonElement>(".artifact-head").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.artifactId || "";
          const artifact = byId.get(id);
          if (!artifact) return;
          const body = btn.nextElementSibling as HTMLElement | null;
          if (!body) return;
          const open = btn.getAttribute("aria-expanded") === "true";
          if (open) {
            body.hidden = true;
            btn.setAttribute("aria-expanded", "false");
          } else {
            body.innerHTML = renderSafeMarkdown(artifact.body);
            body.hidden = false;
            btn.setAttribute("aria-expanded", "true");
          }
        });
      });
    }

    function updateProgress() {
      const total = currentScenario().steps.length;
      const pct = total === 0 ? 0 : Math.round((stepIdx / total) * 100);
      progressBar.style.width = `${pct}%`;
      progressLbl.textContent = `step ${stepIdx} of ${total}`;
      const atEnd = stepIdx >= total;
      playLbl.textContent = stepIdx === 0 ? "start" : atEnd ? "complete" : "next";
      playBtn.disabled = atEnd;
      skipBtn.disabled = atEnd;
      if (stepIdx > 0) startPrompt.hidden = true;
    }

    function escapeHTML(s: string): string {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    function renderStep(step: Step) {
      if (step.type === "beat") {
        const el = document.createElement("div");
        el.className = "cc-divider";
        const skillsHtml = (step.skills ?? [])
          .map((s) => `<code class="cc-chip">${escapeHTML(s)}</code>`)
          .join("");
        const labelText = step.caption
          ? `${step.label} — ${step.caption}`
          : step.label;
        el.innerHTML = `
          <span class="cc-divider-rule"></span>
          <span class="cc-divider-label">${escapeHTML(labelText)}</span>
          ${skillsHtml ? `<span class="cc-divider-skills">${skillsHtml}</span>` : ""}
          <span class="cc-divider-rule"></span>
        `;
        transcript.appendChild(el);
        return el;
      }

      // User input — bordered terminal box with > prefix. If the message
      // contains " — " or " - " we two-tone-split: the part before becomes
      // the bold path-a header; the part after becomes the path-b question.
      if (step.role === "user") {
        const wrap = document.createElement("div");
        wrap.className = "cc-user";
        const splitMatch = step.content.match(/^(.+?)\s+[—-]\s+(.+)$/s);
        if (splitMatch) {
          const [, header, question] = splitMatch;
          wrap.classList.add("cc-user--two-tone");
          wrap.innerHTML = `
            <span class="cc-user-mark" aria-hidden="true">&gt;</span>
            <span class="cc-user-text">
              <strong class="cc-user-header"></strong>
              <span class="cc-user-sep" aria-hidden="true"> — </span>
              <span class="cc-user-question"></span>
            </span>
          `;
          (wrap.querySelector(".cc-user-header") as HTMLElement).textContent = header;
          (wrap.querySelector(".cc-user-question") as HTMLElement).textContent = question;
        } else {
          wrap.innerHTML = `
            <span class="cc-user-mark" aria-hidden="true">&gt;</span>
            <span class="cc-user-text"></span>
          `;
          (wrap.querySelector(".cc-user-text") as HTMLElement).textContent = step.content;
        }
        transcript.appendChild(wrap);
        return wrap;
      }

      // Assistant turn — `● claude · skill` head, body, optional ⎿ footer.
      // The head row is colored by the skill's role token (--turn-color).
      const wrap = document.createElement("div");
      wrap.className = "cc-assistant";
      wrap.dataset.role = roleFor(step.skill);

      const head = document.createElement("div");
      head.className = "cc-assistant-head";
      const skillBit = step.skill
        ? `<span class="cc-sep">·</span><span class="cc-skill">${escapeHTML(step.skill)}</span>`
        : "";
      head.innerHTML = `
        <span class="cc-bullet" aria-hidden="true">●</span>
        <span class="cc-name">claude</span>
        ${skillBit}
      `;
      wrap.appendChild(head);

      const body = document.createElement("div");
      body.className = "cc-assistant-body markdown";
      body.innerHTML = renderSafeMarkdown(step.content);
      wrap.appendChild(body);

      // Tool calls (artifacts produced by this turn). Each artifact renders
      // as `● Write(filename)` with an indented ⎿ result line; clicking the
      // result expands the full body inline below.
      if (step.artifacts && step.artifacts.length > 0) {
        const byId = new Map(
          currentScenario().outputs.map((a) => [a.id, a] as const),
        );
        const refs = step.artifacts
          .map((id) => byId.get(id))
          .filter((a): a is Artifact => !!a);

        for (const a of refs) {
          const tool = document.createElement("div");
          tool.className = "cc-tool";
          const arg = a.kind || a.label;
          tool.innerHTML = `
            <div class="cc-tool-head">
              <span class="cc-bullet cc-bullet--tool" aria-hidden="true">●</span>
              <span class="cc-tool-name">Write</span><span class="cc-tool-paren" aria-hidden="true">(</span><span class="cc-tool-arg"></span><span class="cc-tool-paren" aria-hidden="true">)</span>
            </div>
            <button type="button" class="cc-tool-result" aria-expanded="false">
              <span class="cc-tool-elbow" aria-hidden="true">⎿</span>
              <span class="cc-tool-result-text">  </span>
              <span class="cc-tool-hint">click to expand</span>
            </button>
            <div class="cc-tool-body markdown" hidden></div>
          `;
          (tool.querySelector(".cc-tool-arg") as HTMLElement).textContent = arg;
          (tool.querySelector(".cc-tool-result-text") as HTMLElement).textContent = a.label;
          const btn = tool.querySelector(".cc-tool-result") as HTMLButtonElement;
          const hint = tool.querySelector(".cc-tool-hint") as HTMLElement;
          const toolBody = tool.querySelector(".cc-tool-body") as HTMLElement;
          btn.addEventListener("click", () => {
            const open = btn.getAttribute("aria-expanded") === "true";
            if (open) {
              toolBody.hidden = true;
              btn.setAttribute("aria-expanded", "false");
              hint.textContent = "click to expand";
              return;
            }
            toolBody.innerHTML = renderSafeMarkdown(a.body);
            toolBody.hidden = false;
            btn.setAttribute("aria-expanded", "true");
            hint.textContent = "click to collapse";
            requestAnimationFrame(() => {
              const tRect = transcript.getBoundingClientRect();
              const gRect = tool.getBoundingClientRect();
              const target =
                transcript.scrollTop + (gRect.top - tRect.top) - 12;
              transcript.scrollTo({
                top: Math.max(0, target),
                behavior: "smooth",
              });
            });
          });
          wrap.appendChild(tool);
        }
      }

      transcript.appendChild(wrap);
      return wrap;
    }

    /** Scroll the transcript container only — never the whole page. */
    function scrollChat() {
      transcript.scrollTo({ top: transcript.scrollHeight, behavior: "smooth" });
    }

    function advance() {
      const w = currentScenario();
      if (stepIdx >= w.steps.length) return;
      renderStep(w.steps[stepIdx]);
      stepIdx++;
      // First step starts the chat — collapse the detail card to make room.
      if (stepIdx === 1) setDetailCollapsed(true);
      updateProgress();
      scrollChat();
    }

    function skipToEnd() {
      const w = currentScenario();
      while (stepIdx < w.steps.length) {
        renderStep(w.steps[stepIdx]);
        stepIdx++;
      }
      // Skipping also counts as starting the chat.
      setDetailCollapsed(true);
      updateProgress();
      scrollChat();
    }

    function restart() {
      stepIdx = 0;
      transcript.innerHTML = "";
      startPrompt.hidden = false;
      setDetailCollapsed(false);
      updateProgress();
    }

    // ── wire up ────────────────────────────────────────────────
    playBtn.addEventListener("click", advance);
    skipBtn.addEventListener("click", skipToEnd);
    restartBtn.addEventListener("click", restart);
    detailToggle.addEventListener("click", () => {
      setDetailCollapsed(!detailCard.classList.contains("is-collapsed"));
    });

    picker.querySelectorAll<HTMLButtonElement>("[data-scenario]").forEach((el, i) => {
      el.addEventListener("click", () => setScenario(i));
      // Native <button> Enter/Space → click. Stop the keydown from also
      // bubbling to the window player handler, which would otherwise
      // advance/skip the transcript on the same keystroke.
      el.addEventListener("keydown", (ev) => {
        if (ev.key === "Enter" || ev.key === " ") ev.stopPropagation();
      });
    });

    // When this component is mounted inside a tabpanel that's currently
    // hidden, swallow the global shortcuts — otherwise pressing Enter on
    // the Live tab would advance the (invisible) Replays transcript.
    const replaysRoot = document.getElementById("replays-root");
    function replaysVisible(): boolean {
      const panel = replaysRoot?.closest("[role=tabpanel]") as HTMLElement | null;
      return !panel || !panel.hidden;
    }

    window.addEventListener("keydown", (ev) => {
      if (!replaysVisible()) return;
      // Ignore shortcuts when the user is typing into a field.
      const target = ev.target as HTMLElement | null;
      if (target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable)) {
        return;
      }
      if (ev.key === "Enter") { ev.preventDefault(); advance(); return; }
      if (ev.key === " ")     { ev.preventDefault(); skipToEnd(); return; }
      if (ev.key.toLowerCase() === "r") { ev.preventDefault(); restart(); return; }
      const n = Number.parseInt(ev.key, 10);
      if (!Number.isNaN(n) && n >= 1 && n <= catalog.length) {
        ev.preventDefault();
        setScenario(n - 1);
      }
    });

    // First render.
    setScenario(0);
  </script>

  <style>
    .replays { display: block; }
    .kbd-hint {
      margin: 0 0 1.25rem;
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-wide);
      color: var(--subtle);
    }
    .kbd-hint kbd { margin: 0 0.15rem; }
    kbd {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-xs);
      padding: 1px 6px;
      color: var(--text);
    }

    /* ── Scenario picker — compact strip ─────────────────────── */
    .scenarios {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(180px, 1fr));
      gap: 0.45rem;
      margin-bottom: 1.5rem;
    }
    .scenario {
      display: flex;
      align-items: center;
      gap: 0.7rem;
      padding: 0.8rem 1rem;
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-md);
      cursor: pointer;
      text-align: left;
      font: inherit;
      color: var(--text);
      transition:
        border-color var(--dur-fast) var(--ease-standard),
        background var(--dur-fast) var(--ease-standard),
        transform var(--dur-fast) var(--ease-standard);
    }
    .scenario:hover {
      border-color: var(--accent);
      transform: translateY(-1px);
    }
    .scenario[aria-pressed="true"] {
      border-color: var(--accent);
      background: var(--accent-dim);
      box-shadow: var(--glow-md);
    }
    .scenario-num {
      flex: 0 0 auto;
      font-family: var(--font-mono);
      font-size: var(--fs-md);
      font-weight: 600;
      color: var(--accent);
      letter-spacing: var(--ls-tight);
      min-width: 1.75rem;
    }
    .scenario-tagline {
      flex: 1;
      font-family: var(--font-display);
      font-size: var(--fs-sm);
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.005em;
      line-height: 1.25;
    }
    .chip {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--text);
      background: var(--card);
      border: 0.5px solid var(--border);
      padding: 1px 6px;
      border-radius: var(--r-xs);
    }

    /* ── Detail panel — full width under the card strip ─────── */
    .detail {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.5rem 1.75rem;
      margin-bottom: 1.5rem;
      box-shadow: var(--glow-md);
    }
    .detail-head {
      display: flex;
      justify-content: space-between;
      align-items: flex-start;
      flex-wrap: wrap;
      gap: 1rem;
      margin-bottom: 1rem;
    }
    .detail-title {
      font-family: var(--font-display);
      font-size: var(--fs-xl);
      font-weight: 600;
      color: var(--text);
      letter-spacing: -0.01em;
      margin: 0 0 0.35rem;
    }
    .detail-summary {
      margin: 0;
      font-size: var(--fs-sm);
      color: var(--muted);
      max-width: 52ch;
    }
    .detail-meta {
      display: flex;
      flex-direction: column;
      gap: 0.4rem;
      align-items: flex-end;
    }
    .detail-runtime {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-wide);
      color: var(--subtle);
    }
    .detail-skills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.25rem;
      justify-content: flex-end;
    }
    .detail-body {
      font-size: var(--fs-sm);
      line-height: var(--lh-base);
      color: var(--muted);
      margin: 0 0 1.25rem;
    }

    .detail-io {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 1.5rem;
    }
    @media (max-width: 720px) {
      .detail-io { grid-template-columns: 1fr; }
    }
    .io-head {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--subtle);
      margin-bottom: 0.55rem;
      display: flex;
      align-items: baseline;
      gap: 0.5rem;
    }
    .io-hint {
      text-transform: none;
      letter-spacing: var(--ls-wide);
      font-size: 10px;
      color: var(--subtle);
      font-style: italic;
    }
    .io-list {
      list-style: none;
      padding: 0;
      margin: 0;
      display: flex;
      flex-direction: column;
      gap: 0.35rem;
    }
    .io-list:not(.artifacts) li {
      font-size: var(--fs-sm);
      color: var(--muted);
      padding-left: 0.9rem;
      position: relative;
    }
    .io-list:not(.artifacts) li::before {
      content: "•";
      position: absolute;
      left: 0;
      color: var(--accent);
    }

    /* ── Artifacts (collapsible) ─────────────────────────────── */
    .artifacts { gap: 0.3rem; }
    .artifact {
      border: 0.5px solid var(--border);
      border-radius: var(--r-sm);
      background: var(--card);
      overflow: hidden;
    }
    .artifact-head {
      display: flex;
      align-items: center;
      gap: 0.55rem;
      width: 100%;
      padding: 0.55rem 0.8rem;
      background: transparent;
      border: 0;
      cursor: pointer;
      text-align: left;
      font: inherit;
      color: var(--text);
      transition:
        background var(--dur-fast) var(--ease-standard),
        color var(--dur-fast) var(--ease-standard);
    }
    .artifact-head:hover {
      background: var(--accent-dim);
      color: var(--text);
    }
    .artifact-chevron {
      color: var(--accent);
      transition: transform var(--dur-fast) var(--ease-standard);
    }
    .artifact-head[aria-expanded="true"] .artifact-chevron {
      transform: rotate(90deg);
    }
    .artifact-label {
      flex: 1;
      font-size: var(--fs-sm);
      color: var(--text);
    }
    .artifact-kind {
      font-family: var(--font-mono);
      font-size: 10px;
      color: var(--accent);
      background: var(--surface);
      border: 0.5px solid var(--border);
      padding: 1px 6px;
      border-radius: var(--r-xs);
      letter-spacing: var(--ls-wide);
    }
    .artifact-body {
      padding: 0.9rem 1.1rem;
      border-top: 0.5px solid var(--border);
      background: var(--ribbon);
      font-size: 12px;
      line-height: 1.55;
      color: var(--text);
      max-height: 28rem;
      overflow-y: auto;
    }
    .artifact-body[hidden] { display: none; }
    .artifact-body :global(h1),
    .artifact-body :global(h2),
    .artifact-body :global(h3) {
      font-family: var(--font-display);
      color: var(--text);
      margin: 0.6rem 0 0.35rem;
    }
    .artifact-body :global(h1) { font-size: var(--fs-md); }
    .artifact-body :global(h2) { font-size: var(--fs-sm); }
    .artifact-body :global(h3) { font-size: 12px; }
    .artifact-body :global(p)  { margin: 0 0 0.5rem; color: var(--muted); }
    .artifact-body :global(ul),
    .artifact-body :global(ol) { margin: 0.25rem 0 0.5rem 1.2rem; padding: 0; color: var(--muted); }
    .artifact-body :global(li) { margin: 0.1rem 0; }
    .artifact-body :global(code) {
      font-family: var(--font-mono);
      font-size: 11px;
      background: var(--surface);
      border: 0.5px solid var(--border);
      padding: 0 4px;
      border-radius: var(--r-xs);
    }
    .artifact-body :global(pre) {
      background: var(--obsidian);
      color: var(--linen);
      border: 0.5px solid var(--slag);
      border-radius: var(--r-sm);
      padding: 0.75rem 0.95rem;
      overflow-x: auto;
      font-size: 11px;
      margin: 0.35rem 0 0.5rem;
    }
    .artifact-body :global(pre code) {
      background: transparent; border: 0; padding: 0;
    }
    .artifact-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin: 0.5rem 0;
    }
    .artifact-body :global(th),
    .artifact-body :global(td) {
      border: 0.5px solid var(--border);
      padding: 0.3rem 0.55rem;
      text-align: left;
    }
    .artifact-body :global(th) {
      background: var(--surface);
      font-family: var(--font-mono);
      font-size: 10px;
      letter-spacing: var(--ls-wide);
      color: var(--muted);
    }
    .artifact-body :global(blockquote) {
      border-left: 2px solid var(--accent);
      padding: 0.2rem 0 0.2rem 0.8rem;
      margin: 0.4rem 0;
      color: var(--muted);
    }

    /* ── Player ──────────────────────────────────────────────── */
    .player {
      background: var(--surface);
      border: 0.5px solid var(--border);
      border-radius: var(--r-lg);
      padding: 1.25rem;
      box-shadow: var(--glow-md);
    }
    .player-head {
      display: flex;
      align-items: flex-end;
      justify-content: space-between;
      flex-wrap: wrap;
      gap: 0.75rem;
      margin-bottom: 1rem;
    }
    .player-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--subtle);
    }
    .player-title h2 {
      font-family: var(--font-display);
      font-size: var(--fs-lg);
      font-weight: 600;
      color: var(--text);
      margin: 0.2rem 0 0;
      letter-spacing: -0.005em;
    }
    .player-controls {
      display: inline-flex;
      gap: 0.4rem;
      flex-wrap: wrap;
    }
    .ctl {
      font-family: var(--font-mono);
      font-size: 11px;
      font-weight: 500;
      letter-spacing: var(--ls-wide);
      padding: 0.55rem 0.95rem;
      border-radius: var(--r-sm);
      cursor: pointer;
      border: 0.5px solid var(--border);
      background: var(--card);
      color: var(--muted);
      display: inline-flex;
      align-items: center;
      gap: 0.35rem;
      transition:
        color var(--dur-fast) var(--ease-standard),
        border-color var(--dur-fast) var(--ease-standard),
        background var(--dur-fast) var(--ease-standard);
    }
    .ctl:hover:not(:disabled) {
      color: var(--text);
      border-color: var(--muted);
    }
    .ctl-primary {
      background: var(--accent);
      color: var(--obsidian);
      border-color: transparent;
    }
    .ctl-primary:hover:not(:disabled) { background: var(--accent-hover); }
    .ctl:disabled { opacity: 0.45; cursor: not-allowed; }

    /* ── Progress ────────────────────────────────────────────── */
    .progress {
      display: grid;
      grid-template-columns: 1fr auto;
      gap: 0.75rem;
      align-items: center;
      margin-bottom: 1rem;
    }
    .progress::before {
      content: "";
      grid-column: 1;
      grid-row: 1;
      height: 3px;
      background: var(--card);
      border-radius: var(--r-pill);
    }
    .progress-bar {
      grid-column: 1;
      grid-row: 1;
      height: 3px;
      width: 0;
      background: var(--accent);
      border-radius: var(--r-pill);
      transition: width var(--dur-base) var(--ease-standard);
    }
    .progress-label {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      color: var(--subtle);
      letter-spacing: var(--ls-wide);
    }

    /* ─────────────────────────────────────────────────────────
       Terminal — Claude Code-styled chat surface.

       Replaces the prior chat-bubble metaphor with a single dark
       terminal frame: monospace prose flow, > user input box,
       ● claude · skill assistant turns, ● Write(file) tool calls
       with ⎿ result lines, and ── beat ── dividers. Tokens scoped
       to .terminal so they don't leak.
    ───────────────────────────────────────────────────────── */
    .terminal {
      --cc-bg:      #181818;
      --cc-fg:      #e8e8e8;
      --cc-dim:     #8a8a8a;
      --cc-subtle:  #5a5a5a;
      --cc-cyan:    #62afff;
      --cc-orange:  #d99155;
      --cc-purple:  #b294ff;
      --cc-green:   #9ece6a;
      --cc-red:     #f7768e;
      --cc-border:  #2a2a2a;
      --cc-hover:   #222222;

      font-family: 'JetBrains Mono', 'SF Mono', Menlo, ui-monospace, monospace;
      background: var(--cc-bg);
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-md);
      overflow: hidden;
      display: flex;
      flex-direction: column;
      height: 60vh;
      min-height: 22rem;
    }
    @media (max-width: 720px) {
      .terminal { height: 70vh; }
    }

    /* Status line — working dir left, model + mode right. */
    .cc-statusline {
      display: flex;
      align-items: center;
      justify-content: space-between;
      padding: 0.5rem 0.9rem;
      background: #0f0f0f;
      border-bottom: 0.5px solid var(--cc-border);
      font-size: 11px;
      color: var(--cc-dim);
      letter-spacing: 0.01em;
    }
    .cc-cwd { color: var(--cc-cyan); }
    .cc-mode { color: var(--cc-dim); white-space: nowrap; }

    /* Scrollable transcript inside the terminal. */
    .cc-stream {
      flex: 1;
      overflow-y: auto;
      overscroll-behavior: contain;
      padding: 0.85rem 1rem 1.25rem;
      display: flex;
      flex-direction: column;
      gap: 1rem;
      color: var(--cc-fg);
      font-size: 13px;
      line-height: 1.6;
    }
    .cc-stream::-webkit-scrollbar { width: 8px; }
    .cc-stream::-webkit-scrollbar-track { background: transparent; }
    .cc-stream::-webkit-scrollbar-thumb {
      background: var(--cc-border);
      border-radius: 4px;
    }

    /* ── User input box ───────────────────────────────────── */
    .cc-user {
      display: flex;
      align-items: flex-start;
      gap: 0.55rem;
      padding: 0.6rem 0.85rem;
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      background: #1d1d1d;
    }
    .cc-user-mark {
      color: var(--cc-orange);
      font-weight: 600;
      flex: 0 0 auto;
      user-select: none;
    }
    .cc-user-text {
      color: var(--cc-fg);
      white-space: pre-wrap;
      word-break: break-word;
      flex: 1 1 auto;
    }

    /* ── Assistant turn — `● claude · <skill>` head + body ── */
    .cc-assistant {
      display: flex;
      flex-direction: column;
      gap: 0.3rem;
    }
    .cc-assistant-head {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 13px;
      line-height: 1;
    }
    .cc-bullet {
      color: var(--cc-cyan);
      font-size: 14px;
      line-height: 1;
      flex: 0 0 auto;
    }
    .cc-bullet--tool { color: var(--cc-cyan); }
    .cc-name { color: var(--cc-fg); font-weight: 600; }
    .cc-sep { color: var(--cc-subtle); }
    .cc-skill { color: var(--cc-purple); }

    .cc-assistant-body {
      padding-left: 1.25rem;        /* aligns body under the bullet */
      color: var(--cc-fg);
      font-size: 13px;
      line-height: 1.6;
    }

    /* Markdown inside the assistant body. Tight, mono prose. */
    .cc-assistant-body :global(p) { margin: 0 0 0.55rem; }
    .cc-assistant-body :global(p:last-child) { margin-bottom: 0; }
    .cc-assistant-body :global(strong) { color: #ffffff; font-weight: 600; }
    .cc-assistant-body :global(em) { color: var(--cc-fg); font-style: italic; }
    .cc-assistant-body :global(h1),
    .cc-assistant-body :global(h2),
    .cc-assistant-body :global(h3) {
      font-family: inherit;
      font-weight: 600;
      color: #ffffff;
      margin: 0.65rem 0 0.3rem;
    }
    .cc-assistant-body :global(h1) { font-size: 14px; }
    .cc-assistant-body :global(h2) { font-size: 13px; }
    .cc-assistant-body :global(h3) { font-size: 12px; color: var(--cc-fg); }
    .cc-assistant-body :global(ul),
    .cc-assistant-body :global(ol) {
      margin: 0.25rem 0 0.55rem 1.25rem;
      padding: 0;
    }
    .cc-assistant-body :global(li) { margin: 0.1rem 0; }
    .cc-assistant-body :global(code) {
      font-family: inherit;
      font-size: 12px;
      background: rgba(98, 175, 255, 0.08);
      color: var(--cc-cyan);
      padding: 0 4px;
      border-radius: var(--r-xs);
    }
    .cc-assistant-body :global(pre) {
      background: #0f0f0f;
      color: var(--cc-fg);
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      padding: 0.65rem 0.85rem;
      overflow-x: auto;
      font-size: 12px;
      margin: 0.4rem 0 0.55rem;
    }
    .cc-assistant-body :global(pre code) {
      background: transparent;
      color: inherit;
      padding: 0;
      font-size: inherit;
    }
    .cc-assistant-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      margin: 0.55rem 0;
    }
    .cc-assistant-body :global(th),
    .cc-assistant-body :global(td) {
      border: 0.5px solid var(--cc-border);
      padding: 0.3rem 0.55rem;
      text-align: left;
      color: var(--cc-fg);
    }
    .cc-assistant-body :global(th) {
      background: #0f0f0f;
      color: var(--cc-dim);
      font-weight: 600;
      letter-spacing: 0.01em;
    }
    .cc-assistant-body :global(blockquote) {
      border-left: 2px solid var(--cc-cyan);
      padding: 0.2rem 0 0.2rem 0.8rem;
      margin: 0.5rem 0;
      color: var(--cc-dim);
    }

    /* ── Tool call — `● Write(file)` + `⎿ result · click` ─── */
    .cc-tool {
      margin-top: 0.5rem;
      padding-left: 1.25rem;        /* aligns under the assistant body */
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .cc-tool-head {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 13px;
      line-height: 1.4;
    }
    .cc-tool-name { color: var(--cc-cyan); font-weight: 600; }
    .cc-tool-paren { color: var(--cc-subtle); }
    .cc-tool-arg { color: var(--cc-fg); }

    .cc-tool-result {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.15rem 0.4rem 0.15rem 0;
      background: transparent;
      border: 0;
      color: var(--cc-dim);
      font: inherit;
      font-size: 12px;
      line-height: 1.4;
      cursor: pointer;
      text-align: left;
      margin-left: 0.4rem;
    }
    .cc-tool-result:hover { color: var(--cc-fg); }
    .cc-tool-result:hover .cc-tool-hint { color: var(--cc-cyan); }
    .cc-tool-result:focus-visible {
      outline: 1px solid var(--cc-cyan);
      outline-offset: 2px;
      border-radius: var(--r-xs);
      color: var(--cc-fg);
    }
    .cc-tool-elbow {
      color: var(--cc-subtle);
      font-size: 13px;
      line-height: 1;
      flex: 0 0 auto;
      transition: color var(--dur-fast) var(--ease-standard);
    }
    .cc-tool-result[aria-expanded="true"] .cc-tool-elbow { color: var(--cc-cyan); }
    .cc-tool-result-text { color: var(--cc-fg); }
    .cc-tool-hint {
      color: var(--cc-subtle);
      font-size: 11px;
      font-style: italic;
    }

    .cc-tool-body {
      margin: 0.35rem 0 0.25rem 1.4rem;
      padding: 0.7rem 0.9rem;
      background: #0f0f0f;
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      color: var(--cc-fg);
      font-size: 12px;
      line-height: 1.6;
      max-height: 24rem;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
    .cc-tool-body[hidden] { display: none; }
    .cc-tool-body :global(h1),
    .cc-tool-body :global(h2),
    .cc-tool-body :global(h3) {
      font-family: inherit;
      color: #ffffff;
      font-weight: 600;
      margin: 0.5rem 0 0.3rem;
    }
    .cc-tool-body :global(h1) { font-size: 13px; }
    .cc-tool-body :global(h2) { font-size: 12px; }
    .cc-tool-body :global(h3) { font-size: 12px; color: var(--cc-fg); }
    .cc-tool-body :global(p) { margin: 0 0 0.45rem; color: var(--cc-fg); }
    .cc-tool-body :global(ul),
    .cc-tool-body :global(ol) { margin: 0.2rem 0 0.45rem 1.2rem; padding: 0; color: var(--cc-fg); }
    .cc-tool-body :global(li) { margin: 0.1rem 0; }
    .cc-tool-body :global(strong) { color: #ffffff; font-weight: 600; }
    .cc-tool-body :global(code) {
      font-family: inherit;
      font-size: 11px;
      background: rgba(98, 175, 255, 0.08);
      color: var(--cc-cyan);
      padding: 0 4px;
      border-radius: var(--r-xs);
    }
    .cc-tool-body :global(pre) {
      background: #050505;
      color: var(--cc-fg);
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      padding: 0.6rem 0.8rem;
      overflow-x: auto;
      font-size: 11px;
      margin: 0.35rem 0 0.5rem;
    }
    .cc-tool-body :global(pre code) {
      background: transparent;
      color: inherit;
      padding: 0;
      font-size: inherit;
    }
    .cc-tool-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin: 0.4rem 0;
    }
    .cc-tool-body :global(th),
    .cc-tool-body :global(td) {
      border: 0.5px solid var(--cc-border);
      padding: 0.25rem 0.5rem;
      text-align: left;
      color: var(--cc-fg);
    }
    .cc-tool-body :global(th) {
      background: #050505;
      color: var(--cc-dim);
      font-weight: 600;
    }
    .cc-tool-body :global(blockquote) {
      border-left: 2px solid var(--cc-cyan);
      padding: 0.2rem 0 0.2rem 0.7rem;
      margin: 0.4rem 0;
      color: var(--cc-dim);
    }

    /* ── Beat divider — `── 02 · Scaffold + wire ──` ──────── */
    .cc-divider {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin: 0.5rem 0 0.25rem;
      padding: 0.25rem 0;
      font-size: 11px;
      color: var(--cc-dim);
    }
    .cc-divider-rule {
      flex: 1 1 auto;
      min-width: 1rem;
      height: 0;
      border-top: 0.5px solid var(--cc-border);
    }
    .cc-divider-rule:first-child { flex: 0 0 1.5rem; }
    .cc-divider-label {
      color: var(--cc-cyan);
      font-weight: 600;
      letter-spacing: 0.02em;
      white-space: nowrap;
      flex: 0 0 auto;
    }
    .cc-divider-skills {
      display: inline-flex;
      gap: 0.3rem;
      flex-wrap: wrap;
      justify-content: flex-end;
      flex: 0 0 auto;
    }
    .cc-chip {
      font-family: inherit;
      font-size: 10px;
      color: var(--cc-purple);
      background: rgba(178, 148, 255, 0.08);
      border: 0.5px solid var(--cc-border);
      padding: 1px 6px;
      border-radius: var(--r-xs);
      letter-spacing: 0.01em;
    }

    /* ── Start prompt — restyled to match the terminal ────── */
    .start-prompt {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 1rem;
      border: 0.5px dashed var(--cc-border, var(--slag));
      border-radius: var(--r-md);
      color: var(--cc-dim, var(--sand));
      background: var(--cc-bg, var(--forge));
      font-family: 'JetBrains Mono', 'SF Mono', Menlo, ui-monospace, monospace;
      font-size: 12px;
      margin-top: 0.6rem;
    }
    .start-prompt[hidden] { display: none; }
    .start-prompt kbd {
      background: #1d1d1d;
      border: 0.5px solid var(--cc-border, var(--slag));
      color: var(--cc-fg, var(--linen));
    }

    @media (max-width: 720px) {
      .player-head { flex-direction: column; align-items: flex-start; }
    }

    /* ── Role pills for detail card + chat divider ──────────────────
