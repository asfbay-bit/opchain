    }

    /* Markdown inside the assistant body. Tight, mono prose. */
    .cc-assistant-body :global(p) { margin: 0 0 0.55rem; }
    .cc-assistant-body :global(p:last-child) { margin-bottom: 0; }
    .cc-assistant-body :global(strong) { color: #ffffff; font-weight: 600; }
    .cc-assistant-body :global(em) { color: var(--cc-fg); font-style: italic; }
    .cc-assistant-body :global(h1),
    .cc-assistant-body :global(h2),
    .cc-assistant-body :global(h3) {
      font-family: inherit;
      font-weight: 600;
      color: #ffffff;
      margin: 0.65rem 0 0.3rem;
    }
    .cc-assistant-body :global(h1) { font-size: 14px; }
    .cc-assistant-body :global(h2) { font-size: 13px; }
    .cc-assistant-body :global(h3) { font-size: 12px; color: var(--cc-fg); }
    .cc-assistant-body :global(ul),
    .cc-assistant-body :global(ol) {
      margin: 0.25rem 0 0.55rem 1.25rem;
      padding: 0;
    }
    .cc-assistant-body :global(li) { margin: 0.1rem 0; }
    .cc-assistant-body :global(code) {
      font-family: inherit;
      font-size: 12px;
      background: rgba(98, 175, 255, 0.08);
      color: var(--cc-cyan);
      padding: 0 4px;
      border-radius: var(--r-xs);
    }
    .cc-assistant-body :global(pre) {
      background: #0f0f0f;
      color: var(--cc-fg);
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      padding: 0.65rem 0.85rem;
      overflow-x: auto;
      font-size: 12px;
      margin: 0.4rem 0 0.55rem;
    }
    .cc-assistant-body :global(pre code) {
      background: transparent;
      color: inherit;
      padding: 0;
      font-size: inherit;
    }
    .cc-assistant-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 12px;
      margin: 0.55rem 0;
    }
    .cc-assistant-body :global(th),
    .cc-assistant-body :global(td) {
      border: 0.5px solid var(--cc-border);
      padding: 0.3rem 0.55rem;
      text-align: left;
      color: var(--cc-fg);
    }
    .cc-assistant-body :global(th) {
      background: #0f0f0f;
      color: var(--cc-dim);
      font-weight: 600;
      letter-spacing: 0.01em;
    }
    .cc-assistant-body :global(blockquote) {
      border-left: 2px solid var(--cc-cyan);
      padding: 0.2rem 0 0.2rem 0.8rem;
      margin: 0.5rem 0;
      color: var(--cc-dim);
    }

    /* ── Tool call — `● Write(file)` + `⎿ result · click` ─── */
    .cc-tool {
      margin-top: 0.5rem;
      padding-left: 1.25rem;        /* aligns under the assistant body */
      display: flex;
      flex-direction: column;
      gap: 0.15rem;
    }
    .cc-tool-head {
      display: flex;
      align-items: center;
      gap: 0.4rem;
      font-size: 13px;
      line-height: 1.4;
    }
    .cc-tool-name { color: var(--cc-cyan); font-weight: 600; }
    .cc-tool-paren { color: var(--cc-subtle); }
    .cc-tool-arg { color: var(--cc-fg); }

    .cc-tool-result {
      display: flex;
      align-items: center;
      gap: 0.45rem;
      padding: 0.15rem 0.4rem 0.15rem 0;
      background: transparent;
      border: 0;
      color: var(--cc-dim);
      font: inherit;
      font-size: 12px;
      line-height: 1.4;
      cursor: pointer;
      text-align: left;
      margin-left: 0.4rem;
    }
    .cc-tool-result:hover { color: var(--cc-fg); }
    .cc-tool-result:hover .cc-tool-hint { color: var(--cc-cyan); }
    .cc-tool-result:focus-visible {
      outline: 1px solid var(--cc-cyan);
      outline-offset: 2px;
      border-radius: var(--r-xs);
      color: var(--cc-fg);
    }
    .cc-tool-elbow {
      color: var(--cc-subtle);
      font-size: 13px;
      line-height: 1;
      flex: 0 0 auto;
      transition: color var(--dur-fast) var(--ease-standard);
    }
    .cc-tool-result[aria-expanded="true"] .cc-tool-elbow { color: var(--cc-cyan); }
    .cc-tool-result-text { color: var(--cc-fg); }
    .cc-tool-hint {
      color: var(--cc-subtle);
      font-size: 11px;
      font-style: italic;
    }

    .cc-tool-body {
      margin: 0.35rem 0 0.25rem 1.4rem;
      padding: 0.7rem 0.9rem;
      background: #0f0f0f;
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      color: var(--cc-fg);
      font-size: 12px;
      line-height: 1.6;
      max-height: 24rem;
      overflow-y: auto;
      overscroll-behavior: contain;
    }
    .cc-tool-body[hidden] { display: none; }
    .cc-tool-body :global(h1),
    .cc-tool-body :global(h2),
    .cc-tool-body :global(h3) {
      font-family: inherit;
      color: #ffffff;
      font-weight: 600;
      margin: 0.5rem 0 0.3rem;
    }
    .cc-tool-body :global(h1) { font-size: 13px; }
    .cc-tool-body :global(h2) { font-size: 12px; }
    .cc-tool-body :global(h3) { font-size: 12px; color: var(--cc-fg); }
    .cc-tool-body :global(p) { margin: 0 0 0.45rem; color: var(--cc-fg); }
    .cc-tool-body :global(ul),
    .cc-tool-body :global(ol) { margin: 0.2rem 0 0.45rem 1.2rem; padding: 0; color: var(--cc-fg); }
    .cc-tool-body :global(li) { margin: 0.1rem 0; }
    .cc-tool-body :global(strong) { color: #ffffff; font-weight: 600; }
    .cc-tool-body :global(code) {
      font-family: inherit;
      font-size: 11px;
      background: rgba(98, 175, 255, 0.08);
      color: var(--cc-cyan);
      padding: 0 4px;
      border-radius: var(--r-xs);
    }
    .cc-tool-body :global(pre) {
      background: #050505;
      color: var(--cc-fg);
      border: 0.5px solid var(--cc-border);
      border-radius: var(--r-sm);
      padding: 0.6rem 0.8rem;
      overflow-x: auto;
      font-size: 11px;
      margin: 0.35rem 0 0.5rem;
    }
    .cc-tool-body :global(pre code) {
      background: transparent;
      color: inherit;
      padding: 0;
      font-size: inherit;
    }
    .cc-tool-body :global(table) {
      width: 100%;
      border-collapse: collapse;
      font-size: 11px;
      margin: 0.4rem 0;
    }
    .cc-tool-body :global(th),
    .cc-tool-body :global(td) {
      border: 0.5px solid var(--cc-border);
      padding: 0.25rem 0.5rem;
      text-align: left;
      color: var(--cc-fg);
    }
    .cc-tool-body :global(th) {
      background: #050505;
      color: var(--cc-dim);
      font-weight: 600;
    }
    .cc-tool-body :global(blockquote) {
      border-left: 2px solid var(--cc-cyan);
      padding: 0.2rem 0 0.2rem 0.7rem;
      margin: 0.4rem 0;
      color: var(--cc-dim);
    }

    /* ── Beat divider — `── 02 · Scaffold + wire ──` ──────── */
    .cc-divider {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      margin: 0.5rem 0 0.25rem;
      padding: 0.25rem 0;
      font-size: 11px;
      color: var(--cc-dim);
    }
    .cc-divider-rule {
      flex: 1 1 auto;
      min-width: 1rem;
      height: 0;
      border-top: 0.5px solid var(--cc-border);
    }
    .cc-divider-rule:first-child { flex: 0 0 1.5rem; }
    .cc-divider-label {
      color: var(--cc-cyan);
      font-weight: 600;
      letter-spacing: 0.02em;
      white-space: nowrap;
      flex: 0 0 auto;
    }
    .cc-divider-skills {
      display: inline-flex;
      gap: 0.3rem;
      flex-wrap: wrap;
      justify-content: flex-end;
      flex: 0 0 auto;
    }
    .cc-chip {
      font-family: inherit;
      font-size: 10px;
      color: var(--cc-purple);
      background: rgba(178, 148, 255, 0.08);
      border: 0.5px solid var(--cc-border);
      padding: 1px 6px;
      border-radius: var(--r-xs);
      letter-spacing: 0.01em;
    }

    /* ── Start prompt — restyled to match the terminal ────── */
    .start-prompt {
      display: flex;
      align-items: center;
      gap: 0.6rem;
      padding: 0.85rem 1rem;
      border: 0.5px dashed var(--cc-border, var(--slag));
      border-radius: var(--r-md);
      color: var(--cc-dim, var(--sand));
      background: var(--cc-bg, var(--forge));
      font-family: 'JetBrains Mono', 'SF Mono', Menlo, ui-monospace, monospace;
      font-size: 12px;
      margin-top: 0.6rem;
    }
    .start-prompt[hidden] { display: none; }
    .start-prompt kbd {
      background: #1d1d1d;
      border: 0.5px solid var(--cc-border, var(--slag));
      color: var(--cc-fg, var(--linen));
    }

    @media (max-width: 720px) {
      .player-head { flex-direction: column; align-items: flex-start; }
    }

    /* ── Role pills for detail card + chat divider ──────────────────
       Outline + 15% color-mix fill, same visual language as the
       homepage and skill library. */
    /* The detail-skills row is rebuilt via innerHTML on every scenario
       change, so the new pills don't carry Astro's cid attribute. Scope
       these rules with :global(.detail-skills …) so they match runtime-
       replaced pills too (and don't leak to homepage / skill-library
       role-pills, which live outside .detail-skills). */
    :global(.detail-skills .role-pill) {
      --pill-color: var(--specialist);
      display: inline-flex;
      align-items: center;
      padding: 1px 7px;
      border-radius: 0;
      font-family: var(--font-mono);
      font-size: 10px;
      font-weight: 500;
      letter-spacing: 0.02em;
      line-height: 1.5;
      color: var(--pill-color);
      border: 0.5px solid var(--pill-color);
      background: color-mix(in srgb, var(--pill-color) 15%, transparent);
      white-space: nowrap;
    }
    :global(.detail-skills .role-pill[data-role="workflow"])     { --pill-color: var(--workflow); }
    :global(.detail-skills .role-pill[data-role="tri-agent"])    { --pill-color: var(--tri-agent); }
    :global(.detail-skills .role-pill[data-role="audit-gate"])   { --pill-color: var(--audit-gate); }
    :global(.detail-skills .role-pill[data-role="specialist"])   { --pill-color: var(--specialist); }
    :global(.detail-skills .role-pill[data-role="advisor"])      { --pill-color: var(--advisor); }
    :global(.detail-skills .role-pill[data-role="orchestrator"]) { --pill-color: var(--orchestrator); }
    :global(.detail-skills .role-pill[data-role="success"])      { --pill-color: var(--success); }

    /* ── Chat content rules ─────────────────────────────────────────
       The chat is rendered by JS at runtime (createElement), so its
       elements never get Astro's `data-astro-cid-X` scoping attribute.
       Rules below use :global() and anchor on the SSR'd `.cc-stream`
       parent (which DOES have the cid) to win specificity vs. the
       existing `.cc-name { color: var(--cc-fg); }`-style rules above. */

    /* 1.6.1 Beat divider — solid ember row, obsidian text. A strong
       brand band marks each phase change in the transcript. */
    :global(.cc-stream .cc-divider),
    :global(.cc-stream .cc-divider-label),
    :global(.cc-stream .cc-divider-rule) {
      color: var(--obsidian);
    }
    :global(.cc-stream .cc-divider) {
      background: var(--ember);
      padding: 0.3rem 0.6rem;
      border-radius: var(--r-xs);
    }
    :global(.cc-stream .cc-divider-rule) {
      background: color-mix(in srgb, var(--obsidian) 35%, transparent);
    }
    :global(.cc-stream .cc-divider .cc-chip) {
      color: var(--obsidian);
      border-color: color-mix(in srgb, var(--obsidian) 60%, transparent);
      background: color-mix(in srgb, var(--obsidian) 18%, transparent);
    }

    /* 1.6.3 Claude assistant header — colored by skill role. The wrapper
       sets data-role; CSS maps it to a per-turn --turn-color, then the
       head row reads that variable. */
    :global(.cc-stream .cc-assistant) {
      --turn-color: var(--specialist);
    }
    :global(.cc-stream .cc-assistant[data-role="workflow"])     { --turn-color: var(--workflow); }
    :global(.cc-stream .cc-assistant[data-role="tri-agent"])    { --turn-color: var(--tri-agent); }
    :global(.cc-stream .cc-assistant[data-role="audit-gate"])   { --turn-color: var(--audit-gate); }
    :global(.cc-stream .cc-assistant[data-role="specialist"])   { --turn-color: var(--specialist); }
    :global(.cc-stream .cc-assistant[data-role="advisor"])      { --turn-color: var(--advisor); }
    :global(.cc-stream .cc-assistant[data-role="orchestrator"]) { --turn-color: var(--orchestrator); }
    :global(.cc-stream .cc-assistant[data-role="success"])      { --turn-color: var(--success); }
    :global(.cc-stream .cc-assistant .cc-assistant-head),
    :global(.cc-stream .cc-assistant-head .cc-name),
    :global(.cc-stream .cc-assistant-head .cc-skill),
    :global(.cc-stream .cc-assistant-head .cc-bullet),
    :global(.cc-stream .cc-assistant-head .cc-sep) {
      color: var(--turn-color);
    }
    /* Only the header line is colored on an assistant turn (body below
       stays default white), so the same-color highlight stays on the
       head row — full row width, matching the artifact treatment. */
    :global(.cc-stream .cc-assistant-head) {
      background: color-mix(in srgb, var(--turn-color) 8%, transparent);
      padding: 0.3rem 0.5rem;
      border-radius: var(--r-xs);
    }

    /* V3 — Transcript rhythm: only assistant turns and tool calls
       carry a box. User input collapses to a left-stripe + cream row
       so beats / claude turns / user input read as three different
       weights rather than three competing boxes. */
    :global(.cc-stream .cc-user) {
      background: transparent;
      border: 0;
      border-left: 2px solid color-mix(in srgb, var(--linen) 35%, transparent);
      border-radius: 0;
      padding: 0.45rem 0.5rem 0.45rem 0.75rem;
    }
    :global(.cc-stream .cc-user .cc-user-text) {
      color: var(--linen);
    }
    :global(.cc-stream .cc-user .cc-user-mark) {
      color: var(--linen);
      opacity: 0.75;
    }

    /* 1.6.5 + 1.7.1 Artifacts (Write tool calls). Warning-lime stripe with
       dotted top + bottom. Expanded body renders as a markdown-file viewer:
       obsidian background, scrollable, monospace, generous padding. */
    :global(.cc-stream .cc-tool) {
      --tool-color: var(--tri-agent);   /* amber-gold #F59E0B */
      margin: 0.6rem 0;
      padding: 0.55rem 0;
      border-top: 1px dotted var(--tool-color);
      border-bottom: 1px dotted var(--tool-color);
      background: color-mix(in srgb, var(--tool-color) 6%, transparent);
    }
    :global(.cc-stream .cc-tool .cc-bullet),
    :global(.cc-stream .cc-tool .cc-tool-name),
    :global(.cc-stream .cc-tool .cc-tool-paren),
    :global(.cc-stream .cc-tool .cc-tool-arg),
    :global(.cc-stream .cc-tool .cc-tool-elbow),
    :global(.cc-stream .cc-tool .cc-tool-result-text) {
      color: var(--tool-color);
    }
    :global(.cc-stream .cc-tool .cc-tool-hint) {
      color: color-mix(in srgb, var(--tool-color) 70%, var(--muted));
    }
    :global(.cc-stream .cc-tool-body) {
      margin-top: 0.5rem;
      padding: 0.85rem 1rem;
      background: var(--obsidian);
      border: 0.5px solid color-mix(in srgb, var(--tri-agent) 35%, var(--border));
      border-radius: var(--r-sm);
      max-height: 360px;
      overflow: auto;
      font-family: var(--font-mono);
      font-size: 12px;
      line-height: 1.55;
      color: var(--text);
    }
    :global(.cc-stream .cc-tool-body p),
    :global(.cc-stream .cc-tool-body li) { color: var(--text); }
    :global(.cc-stream .cc-tool-body strong) { color: var(--text); }

    /* ── 1.7 Detail card collapse ─────────────────────────────────── */
    /* Toggle styling now lives further down (see 5.3) — reposition.   */
    .detail-body-wrap {
      max-height: 2000px;
      overflow: hidden;
      transition:
        max-height var(--dur-slow) var(--ease-standard),
        opacity var(--dur-base) var(--ease-standard),
        margin-top var(--dur-base) var(--ease-standard);
    }
    .detail.is-collapsed .detail-body-wrap {
      max-height: 0;
      opacity: 0;
      margin-top: 0;
      pointer-events: none;
    }
    .detail.is-collapsed .detail-summary {
      display: none;
    }
    /* V7 — Honour prefers-reduced-motion on the long collapse + drawer
       transitions. The chat-tab-dot pulse already opted out further
       down. */
    @media (prefers-reduced-motion: reduce) {
      .detail-body-wrap { transition: none; }
      .output-drawer-scrim,
      .output-drawer-panel,
      .input-drawer-scrim,
      .input-drawer-panel { transition: none; }
      .progress-bar { transition: none; }
    }

    /* 5.3 — Detail toggle pinned to the top-right corner of the card,
       above the runtime line. Renders × when expanded, ▾ when collapsed. */
    .detail { position: relative; }
    .detail-toggle {
      position: absolute;
      top: 0.6rem;
      right: 0.6rem;
      width: 28px;
      height: 28px;
      padding: 0;
      background: transparent;
      border: 0.5px solid var(--border);
      border-radius: var(--r-xs);
      color: var(--muted);
      cursor: pointer;
      display: inline-grid;
      place-items: center;
      font-family: var(--font-mono);
      font-size: 16px;
      line-height: 1;
      z-index: 2;
      transition:
        color var(--dur-fast) var(--ease-standard),
        border-color var(--dur-fast) var(--ease-standard),
        background var(--dur-fast) var(--ease-standard);
    }
    .detail-toggle:hover {
      color: var(--accent);
      border-color: var(--accent);
      background: var(--accent-dim);
    }
    .detail-toggle:focus-visible {
      outline: 2px solid var(--accent);
      outline-offset: 2px;
    }
    .detail-toggle-x,
    .detail-toggle-chev {
      display: inline-block;
    }
    .detail-toggle-chev { display: none; }
    .detail.is-collapsed .detail-toggle-x { display: none; }
    .detail.is-collapsed .detail-toggle-chev { display: inline-block; }

    /* 5.3.1 — Title + summary + skill pills scale with viewport width. */
    .detail-title {
      font-size: clamp(1rem, 2.4vw, 1.35rem);
      line-height: 1.25;
    }
    .detail-summary { font-size: clamp(0.78rem, 1.6vw, 0.92rem); }
    .detail-skills { flex-wrap: wrap; max-width: 100%; }
    .detail-meta { flex-wrap: wrap; }

    /* 5.7 — Claude assistant turn rendered as a 1-column 2-row "table":
       outer dotted border in the role colour, plus a thin dotted divider
       between the head row (skill name) and the body. */
    /* 1.5 — Body uses overflow-x:auto instead of clipping at the parent.
       Long markdown / <pre> blocks scroll horizontally inside the body
       row instead of being silently cropped (the previous overflow:hidden
       cut content off as the chat grew). The head row keeps its
       background sitting flush with the dotted border via flex layout. */
    :global(.cc-stream .cc-assistant) {
      border: 1px dotted var(--turn-color);
      border-radius: var(--r-xs);
      padding: 0;
      margin: 0.55rem 0;
      display: flex;
      flex-direction: column;
    }
    :global(.cc-stream .cc-assistant .cc-assistant-head) {
      padding: 0.45rem 0.75rem;
      border-bottom: 1px dotted var(--turn-color);
      background: color-mix(in srgb, var(--turn-color) 8%, transparent);
      border-radius: var(--r-xs) var(--r-xs) 0 0;
    }
    :global(.cc-stream .cc-assistant .cc-assistant-body) {
      padding: 0.65rem 0.85rem;
      overflow-x: auto;
      max-width: 100%;
    }

    /* 5.4 — Output drawer, slides in from the right of the chat. */
    .output-drawer {
      position: fixed;
      inset: 0;
      z-index: 70;
      pointer-events: none;
    }
    .output-drawer[aria-hidden="false"] { pointer-events: auto; }
    .output-drawer-scrim {
      position: absolute;
      inset: 0;
      background: rgba(0, 0, 0, 0.45);
      border: 0;
      cursor: pointer;
      opacity: 0;
      transition: opacity var(--dur-base) var(--ease-standard);
    }
    .output-drawer.is-open .output-drawer-scrim { opacity: 1; }
    .output-drawer-panel {
      position: absolute;
      top: 0;
      right: 0;
      bottom: 0;
      width: min(560px, 92vw);
      background: var(--surface);
      border-left: 1px dotted var(--tri-agent);
      box-shadow: -8px 0 24px rgba(0, 0, 0, 0.35);
      display: flex;
      flex-direction: column;
      transform: translateX(100%);
      transition: transform var(--dur-base) var(--ease-standard);
    }
    .output-drawer.is-open .output-drawer-panel { transform: translateX(0); }
    /* Round-3 2.0 — header is a single horizontal row. eyebrow + title +
       kind sit side-by-side; the close button anchors the right. No
       leading line break above the title. */
    .output-drawer-head {
      display: flex;
      align-items: center;
      flex-wrap: wrap;
      gap: 0.55rem 0.75rem;
      padding: 0.85rem 1.1rem;
      border-top: 1px dotted var(--tri-agent);
      border-bottom: 1px dotted var(--tri-agent);
      background: color-mix(in srgb, var(--tri-agent) 10%, transparent);
    }
    .output-drawer-eyebrow {
      font-family: var(--font-mono);
      font-size: var(--fs-xs);
      letter-spacing: var(--ls-widest);
      text-transform: uppercase;
      color: var(--tri-agent);
      flex: 0 0 auto;
    }
    .output-drawer-title {
      margin: 0;
      flex: 1 1 auto;
      font-family: var(--font-display);
      font-size: var(--fs-md);
      font-weight: 600;
      color: var(--text);
      line-height: 1.2;
    }
    .output-drawer-kind {
      flex: 0 0 auto;
      font-family: var(--font-mono);
      font-size: 11px;
      color: var(--muted);
      padding: 1px 6px;
      border: 0.5px solid color-mix(in srgb, var(--tri-agent) 35%, var(--border));
      border-radius: var(--r-xs);
      background: color-mix(in srgb, var(--tri-agent) 6%, transparent);
    }
    .output-drawer-close {
      appearance: none;
