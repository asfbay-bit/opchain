---
import Icon from "./Icon.astro";
import { walkthroughs } from "../data/walkthroughs";
import { getSkillRole, type Role } from "../lib/skills";

/**
 * Replays — six scripted end-to-end sessions with opchain.
 *
 * Used inside the Demo page's Replays tabpanel. The keyboard handler
 * (Enter / Space / R / 1–6) is gated so it only responds when this
 * component's hosting tabpanel is visible.
 */

// Role lookup for every skill referenced in any walkthrough — passed to the
// client script as a JSON island so runtime re-renders can color new pills
// without a second round-trip to lib/skills.
const allSkillIds = Array.from(
  new Set(
    walkthroughs.flatMap((w) => [
      ...w.skills,
      ...w.steps
        .map((s) => (s.type === "exchange" ? s.skill : s.type === "beat" ? (s.skills ?? []) : []))
        .flat()
        .filter((s): s is string => typeof s === "string"),
    ]),
  ),
);
const skillRoles: Record<string, Role> = Object.fromEntries(
  allSkillIds.map((id) => [id, getSkillRole(id)]),
);
const skillRolesJson = JSON.stringify(skillRoles);

const catalog = JSON.stringify(
  walkthroughs.map((w) => ({
    id: w.id,
    title: w.title,
    tagline: w.tagline,
    summary: w.summary,
    description: w.description,
    inputs: w.inputs,
    outputs: w.outputs,
    skills: w.skills,
    runtime: w.runtime,
    steps: w.steps,
  })),
);
---

<div class="replays" id="replays-root">
  <p class="kbd-hint">
    <kbd>Enter</kbd> next ·
    <kbd>Space</kbd> skip ·
    <kbd>R</kbd> restart ·
    <kbd>1</kbd>–<kbd>6</kbd> jump
  </p>

    <!-- ───────────── Scenario picker — collapsed strip ─────────────
         <div role="tablist"> rather than <section role="tablist">: <section>
         carries an implicit "region" role when given an aria-label, and an
         explicit "tablist" override on top of that fails axe's
         aria-allowed-role audit. Tabs also use aria-selected only — not
         aria-pressed (which is for role="button"). -->
    <div class="scenarios" id="scenario-picker" role="tablist" aria-label="Pick a scenario">
      {walkthroughs.map((w, i) => (
        <button
          type="button"
          class="scenario"
          role="tab"
          aria-selected={i === 0 ? "true" : "false"}
          {...({
            "data-scenario": w.id,
            "data-index": String(i),
          } as any)}
        >
          <span class="scenario-num">{String(i + 1).padStart(2, "0")}</span>
          <span class="scenario-tagline">{w.tagline}</span>
        </button>
      ))}
    </div>

    <!-- 1.4 — Tab bar. Splits the panel into Scenario / Chat tabs so
         the chat is never blocked by the scenario detail. Default tab
         is Scenario at rest; advance() auto-switches to Chat on the
         first user input; restart() sends focus back to Scenario. -->
    <div class="replays-tabs" role="tablist" aria-label="Replays panel">
      <button
        type="button"
        role="tab"
        id="rtab-detail"
        class="replays-tab is-active"
        data-rtab="detail"
        aria-selected="true"
        aria-controls="rpanel-detail"
      >
        scenario
      </button>
      <button
        type="button"
        role="tab"
        id="rtab-chat"
        class="replays-tab"
        data-rtab="chat"
        aria-selected="false"
        aria-controls="rpanel-chat"
      >
        chat
        <span class="replays-tab-dot" id="rtab-chat-dot" aria-hidden="true"></span>
      </button>
      <span class="replays-tab-hint" aria-hidden="true">↳ click to switch</span>
    </div>

    <!-- ───────────── Detail tabpanel — scenario card ───────────── -->
    <section
      class="replays-panel"
      id="rpanel-detail"
      role="tabpanel"
      aria-labelledby="rtab-detail"
      data-rtab="detail"
    >
    <section class="detail" id="detail-card" aria-live="polite">
      <!-- 5.3 — Toggle pinned to the top-right of the card, above the
           runtime / "= X exchanges" line. Renders an X when expanded
           and a down chevron when collapsed (CSS uses :is-collapsed). -->
      <button
        type="button"
        class="detail-toggle"
        id="detail-toggle"
        aria-expanded="true"
        aria-controls="detail-body-wrap"
        aria-label="Collapse details"
      >
        <span class="detail-toggle-x" aria-hidden="true">×</span>
        <span class="detail-toggle-chev" aria-hidden="true">▾</span>
      </button>

      <div class="detail-head">
        <div class="detail-title-block">
          <h2 class="detail-title" id="detail-title">{walkthroughs[0].title}</h2>
          <p class="detail-summary" id="detail-summary">{walkthroughs[0].summary}</p>
        </div>
        <div class="detail-meta">
          <span class="detail-runtime" id="detail-runtime">{walkthroughs[0].runtime}</span>
          <div class="detail-skills" id="detail-skills">
            {walkthroughs[0].skills.map((s) => (
              <span class="role-pill" data-role={getSkillRole(s)}>{s}</span>
            ))}
          </div>
        </div>
      </div>

      <div class="detail-body-wrap" id="detail-body-wrap">
        <p class="detail-body" id="detail-body">{walkthroughs[0].description}</p>

        <div class="detail-io">
          <div class="io-col">
            <div class="io-head">Inputs <span class="io-hint">click to open</span></div>
            <ul class="io-list artifacts" id="detail-inputs">
              {walkthroughs[0].inputs.map((x, i) => (
                <li class="artifact">
                  <button
                    type="button"
                    class="input-head"
                    {...({ "data-input-idx": String(i) } as any)}
                  >
                    <Icon name="arrow-right" size={10} class="artifact-chevron" />
                    <span class="artifact-label">{x}</span>
                  </button>
                </li>
              ))}
            </ul>
          </div>
          <div class="io-col">
            <div class="io-head">Outputs <span class="io-hint">click to open</span></div>
            <ul class="io-list artifacts" id="detail-outputs">
              {walkthroughs[0].outputs.map((a) => (
                <li class="artifact">
                  <button
                    type="button"
                    class="artifact-head"
                    {...({ "data-artifact-id": a.id } as any)}
                  >
                    <Icon name="arrow-right" size={10} class="artifact-chevron" />
                    <span class="artifact-label">{a.label}</span>
                    {a.kind && <span class="artifact-kind">{a.kind}</span>}
                  </button>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </section>
    </section><!-- /rpanel-detail -->

    <!-- ───────────── Chat tabpanel — player + terminal ───────────── -->
    <section
      class="replays-panel"
      id="rpanel-chat"
      role="tabpanel"
      aria-labelledby="rtab-chat"
      data-rtab="chat"
      hidden
    >
    <!-- ───────────── Player ───────────── -->
    <section class="player" aria-label="Walkthrough player">
      <div class="player-head">
        <div class="player-title">
          <span class="player-eyebrow" id="player-eyebrow">scenario · 01</span>
          <h2 id="player-heading">{walkthroughs[0].title}</h2>
        </div>
        <div class="player-controls">
          <button type="button" id="btn-play" class="ctl ctl-primary" aria-label="Next step (Enter)">
            <Icon name="arrow-right" size={12} />
            <span id="btn-play-label">start</span>
          </button>
          <button type="button" id="btn-skip" class="ctl" aria-label="Skip to end (Space)">
            skip
          </button>
          <button type="button" id="btn-restart" class="ctl" aria-label="Restart (R)">
            restart
          </button>
        </div>
      </div>

      <div class="progress">
        <div class="progress-bar" id="progress-bar"></div>
        <span class="progress-label" id="progress-label" aria-live="polite">step 0 of 0</span>
      </div>

      <div class="terminal" id="transcript-wrap">
        <div class="cc-statusline">
          <span class="cc-cwd" id="cc-cwd">~/sessions/concept-to-shipped</span>
          <span class="cc-mode">claude-opus-4-7  ·  auto-accept</span>
        </div>
        <div id="transcript" class="cc-stream" aria-live="polite" aria-atomic="false">
          <!-- Populated by the client script. An initial prompt is shown below. -->
        </div>
      </div>

      <div class="start-prompt" id="start-prompt">
        <Icon name="sparkles" />
        <p><strong>Press <kbd>Enter</kbd></strong> or click <em>start</em>.</p>
      </div>
    </section>
    </section><!-- /rpanel-chat -->

    <!-- 5.4 — Output drawer. Slides in from the right when the user
         clicks an output in the detail card. Renders the artifact body
         as fully-formatted markdown, framed in an amber stripe with
         dotted top + bottom borders.
         Round-3 2.0 — drawer header tightened so eyebrow, title, and
         kind sit on a single visual row (no awkward stack).
         Round-3 3.0 — sister .input-drawer below mirrors this from
         the LEFT edge so inputs get the same drawer affordance. -->
    <aside class="output-drawer" id="output-drawer" aria-hidden="true">
      <button
        type="button"
        class="output-drawer-scrim"
        id="output-drawer-scrim"
        aria-label="Close output"
        tabindex="-1"
      ></button>
      <div class="output-drawer-panel" role="dialog" aria-labelledby="output-drawer-title">
        <header class="output-drawer-head">
          <span class="output-drawer-eyebrow">output</span>
          <h3 class="output-drawer-title" id="output-drawer-title">—</h3>
          <span class="output-drawer-kind" id="output-drawer-kind"></span>
          <button type="button" class="output-drawer-close" id="output-drawer-close" aria-label="Close">×</button>
        </header>
        <div class="output-drawer-body markdown" id="output-drawer-body"></div>
      </div>
    </aside>

    <!-- Round-3 3.0 — Input drawer. Mirrors output-drawer but slides
         in from the LEFT. Inputs are short by nature; the body just
         renders the input string in a roomy reading frame. -->
    <aside class="input-drawer" id="input-drawer" aria-hidden="true">
      <button
        type="button"
        class="input-drawer-scrim"
        id="input-drawer-scrim"
        aria-label="Close input"
        tabindex="-1"
      ></button>
      <div class="input-drawer-panel" role="dialog" aria-labelledby="input-drawer-title">
        <header class="input-drawer-head">
          <button type="button" class="input-drawer-close" id="input-drawer-close" aria-label="Close">×</button>
          <span class="input-drawer-eyebrow">input</span>
          <h3 class="input-drawer-title" id="input-drawer-title">—</h3>
        </header>
        <div class="input-drawer-body" id="input-drawer-body"></div>
      </div>
    </aside>
</div>

<script is:inline id="walkthrough-data" type="application/json" set:html={catalog}></script>
<script is:inline id="skill-roles-data" type="application/json" set:html={skillRolesJson}></script>

  <script>
    import { renderSafeMarkdown } from "../lib/markdown";

    interface Beat {
      type: "beat";
      label: string;
      caption?: string;
      skills?: string[];
    }
    interface Exchange {
      type: "exchange";
      role: "user" | "claude";
      skill?: string;
      content: string;
      artifacts?: string[];
    }
    type Step = Beat | Exchange;
    interface Artifact {
      id: string;
      label: string;
      kind?: string;
      body: string;
    }
    interface Walkthrough {
      id: string;
      title: string;
      tagline: string;
      summary: string;
      description: string;
      inputs: string[];
      outputs: Artifact[];
      skills: string[];
      runtime: string;
      steps: Step[];
    }

    const dataEl = document.getElementById("walkthrough-data");
    if (!dataEl) throw new Error("walkthrough data missing");
    const catalog: Walkthrough[] = JSON.parse(dataEl.textContent || "[]");

    // Skill → role map. Pre-rendered server-side from lib/skills.getSkillRole
    // so runtime DOM updates can color new pills without re-fetching.
    const rolesEl = document.getElementById("skill-roles-data");
    const skillRoles: Record<string, string> = rolesEl
      ? JSON.parse(rolesEl.textContent || "{}")
      : {};
    function roleFor(skill: string | undefined): string {
      return (skill && skillRoles[skill]) || "specialist";
    }

    const picker       = document.getElementById("scenario-picker")!;
    const heading      = document.getElementById("player-heading")!;
    const eyebrow      = document.getElementById("player-eyebrow")!;
    const detailTitle  = document.getElementById("detail-title")!;
    const detailSum    = document.getElementById("detail-summary")!;
    const detailBody   = document.getElementById("detail-body")!;
    const detailRun    = document.getElementById("detail-runtime")!;
    const detailSkills = document.getElementById("detail-skills")!;
    const detailInputs = document.getElementById("detail-inputs")!;
    const detailOuts   = document.getElementById("detail-outputs")!;
    const transcript   = document.getElementById("transcript")!;
    const cwd          = document.getElementById("cc-cwd")!;
    const progressBar  = document.getElementById("progress-bar")!;
    const progressLbl  = document.getElementById("progress-label")!;
    const playBtn      = document.getElementById("btn-play")! as HTMLButtonElement;
    const playLbl      = document.getElementById("btn-play-label")!;
    const skipBtn      = document.getElementById("btn-skip")! as HTMLButtonElement;
    const restartBtn   = document.getElementById("btn-restart")! as HTMLButtonElement;
    const startPrompt  = document.getElementById("start-prompt")!;
    const detailCard   = document.getElementById("detail-card")!;
    const detailToggle = document.getElementById("detail-toggle")! as HTMLButtonElement;

    let currentIdx  = 0;       // which scenario
    let stepIdx     = 0;       // how many steps revealed

    function setDetailCollapsed(collapsed: boolean) {
      detailCard.classList.toggle("is-collapsed", collapsed);
      detailToggle.setAttribute("aria-expanded", collapsed ? "false" : "true");
      detailToggle.setAttribute(
        "aria-label",
        collapsed ? "Expand details" : "Collapse details",
      );
    }

    function currentScenario(): Walkthrough {
      return catalog[currentIdx];
    }

    function setScenario(i: number) {
      if (i < 0 || i >= catalog.length) return;
      currentIdx = i;
      stepIdx = 0;
      transcript.innerHTML = "";
      // New scenario picked → re-expand the detail card so the user sees
      // its inputs / outputs before starting the new replay.
      setDetailCollapsed(false);
      const w = currentScenario();

      // Player head
      heading.textContent = w.title;
      eyebrow.textContent = `scenario · ${String(i + 1).padStart(2, "0")}`;
      playLbl.textContent = "start";
      startPrompt.hidden = false;
      cwd.textContent = `~/sessions/${w.id}`;

      // Detail panel — title, summary, body, runtime, skills, I/O, artifacts.
      detailTitle.textContent = w.title;
      detailSum.textContent   = w.summary;
      detailBody.textContent  = w.description;
      detailRun.textContent   = w.runtime;
      detailSkills.innerHTML  = w.skills.map((s) => `<span class="role-pill" data-role="${escapeHTML(roleFor(s))}">${escapeHTML(s)}</span>`).join("");
      // Round-3 3.0 — inputs render as clickable buttons (mirrors outputs).
      detailInputs.innerHTML  = w.inputs.map((x, i) => `
        <li class="artifact">
          <button type="button" class="input-head" data-input-idx="${i}">
            <svg class="artifact-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="artifact-label">${escapeHTML(x)}</span>
          </button>
        </li>
      `).join("");
      detailOuts.innerHTML    = w.outputs.map((a) => `
        <li class="artifact">
          <button type="button" class="artifact-head" data-artifact-id="${escapeHTML(a.id)}">
            <svg class="artifact-chevron" width="10" height="10" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
            <span class="artifact-label">${escapeHTML(a.label)}</span>
            ${a.kind ? `<span class="artifact-kind">${escapeHTML(a.kind)}</span>` : ""}
          </button>
        </li>
      `).join("");
      wireArtifactToggles();

      updateProgress();

      // Toggle pressed state + roving tabindex on the scenario chips
      // so only the active chip is in the keyboard tab order (I6).
      picker.querySelectorAll<HTMLElement>("[data-scenario]").forEach((el) => {
        const matched = el.dataset.scenario === w.id;
        el.setAttribute("aria-selected", matched ? "true" : "false");
        el.setAttribute("tabindex", matched ? "0" : "-1");
      });
    }

    // 5.4.1 — Clicking an output in the detail card opens the side
    // drawer with the rendered markdown. Replaces the inline expand
    // behaviour. Each scenario rebuilds the list, so we re-wire on
    // every setScenario() call.
    function wireArtifactToggles() {
      const w = currentScenario();
      const byId = new Map(w.outputs.map((a) => [a.id, a] as const));
      detailOuts.querySelectorAll<HTMLButtonElement>(".artifact-head").forEach((btn) => {
        btn.addEventListener("click", () => {
          const id = btn.dataset.artifactId || "";
          const artifact = byId.get(id);
          if (!artifact) return;
          openOutputDrawer(artifact, btn);
        });
      });

      // Round-3 3.0 — Inputs open the LEFT drawer.
      detailInputs.querySelectorAll<HTMLButtonElement>(".input-head").forEach((btn) => {
        btn.addEventListener("click", () => {
          const idx = Number(btn.dataset.inputIdx ?? "-1");
          const text = w.inputs[idx];
          if (typeof text !== "string") return;
          openInputDrawer(text, btn);
        });
      });
    }

    // ── Drawer wiring (output + input) ───────────────────────────
    // I1–I4 — Both drawers are modal dialogs. Shared open/close logic
    // gives each: focus trap (Tab + Shift+Tab cycle within the drawer),
    // focus restore to the trigger that opened it, scoped Escape
    // handler (attached on open, removed on close), and synchronous
    // aria-hidden + .is-open class so AT and visual states stay in
    // sync. aria-modal lives on the role="dialog" panel, not the
    // outer container.
    const drawer       = document.getElementById("output-drawer")!;
    const drawerScrim  = document.getElementById("output-drawer-scrim")!;
    const drawerClose  = document.getElementById("output-drawer-close")!;
    const drawerTitle  = document.getElementById("output-drawer-title")!;
    const drawerKind   = document.getElementById("output-drawer-kind")!;
    const drawerBody   = document.getElementById("output-drawer-body")!;
    const drawerPanel  = drawer.querySelector<HTMLElement>(".output-drawer-panel");

    const inputDrawer       = document.getElementById("input-drawer")!;
    const inputDrawerScrim  = document.getElementById("input-drawer-scrim")!;
    const inputDrawerClose  = document.getElementById("input-drawer-close")!;
    const inputDrawerTitle  = document.getElementById("input-drawer-title")!;
    const inputDrawerBody   = document.getElementById("input-drawer-body")!;
    const inputDrawerPanel  = inputDrawer.querySelector<HTMLElement>(".input-drawer-panel");

    type DrawerHandle = {
      root: HTMLElement;
      panel: HTMLElement | null;
      close: HTMLElement;
      keydown: ((ev: KeyboardEvent) => void) | null;
      lastTrigger: HTMLElement | null;
    };

    const outputHandle: DrawerHandle = {
      root: drawer, panel: drawerPanel, close: drawerClose,
      keydown: null, lastTrigger: null,
    };
    const inputHandle: DrawerHandle = {
      root: inputDrawer, panel: inputDrawerPanel, close: inputDrawerClose,
      keydown: null, lastTrigger: null,
    };

    function getDrawerFocusables(root: HTMLElement): HTMLElement[] {
      const sel = 'button:not([disabled]), [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
      return Array.from(root.querySelectorAll<HTMLElement>(sel));
    }

    function makeDrawerKeydown(h: DrawerHandle, close: () => void) {
      return (ev: KeyboardEvent) => {
        if (ev.key === "Escape") {
          ev.preventDefault();
          close();
          return;
        }
        if (ev.key !== "Tab") return;
        const focusables = getDrawerFocusables(h.root);
        if (focusables.length === 0) return;
        const first = focusables[0];
        const last = focusables[focusables.length - 1];
        const active = document.activeElement as HTMLElement | null;
        if (ev.shiftKey && active === first) {
          ev.preventDefault();
          last.focus();
        } else if (!ev.shiftKey && active === last) {
          ev.preventDefault();
          first.focus();
        }
      };
    }

    function openDrawer(h: DrawerHandle, trigger: HTMLElement | null, close: () => void) {
      h.lastTrigger = trigger;
      h.root.classList.add("is-open");
      h.root.setAttribute("aria-hidden", "false");
      h.panel?.setAttribute("aria-modal", "true");
      h.keydown = makeDrawerKeydown(h, close);
      document.addEventListener("keydown", h.keydown);
      h.close.focus();
    }
    function closeDrawer(h: DrawerHandle) {
      h.root.classList.remove("is-open");
      h.root.setAttribute("aria-hidden", "true");
      h.panel?.removeAttribute("aria-modal");
      if (h.keydown) {
        document.removeEventListener("keydown", h.keydown);
        h.keydown = null;
      }
      h.lastTrigger?.focus();
      h.lastTrigger = null;
    }

    function openOutputDrawer(artifact: Artifact, trigger: HTMLElement | null) {
      drawerTitle.textContent = artifact.label;
      drawerKind.textContent = artifact.kind || "";
      drawerBody.innerHTML = renderSafeMarkdown(artifact.body);
      openDrawer(outputHandle, trigger, closeOutputDrawer);
    }
    function closeOutputDrawer() { closeDrawer(outputHandle); }
    drawerScrim.addEventListener("click", closeOutputDrawer);
    drawerClose.addEventListener("click", closeOutputDrawer);

    function openInputDrawer(text: string, trigger: HTMLElement | null) {
      inputDrawerTitle.textContent = "What the user said";
      inputDrawerBody.textContent = text;
      openDrawer(inputHandle, trigger, closeInputDrawer);
    }
    function closeInputDrawer() { closeDrawer(inputHandle); }
    inputDrawerScrim.addEventListener("click", closeInputDrawer);
    inputDrawerClose.addEventListener("click", closeInputDrawer);

    function updateProgress() {
      const total = currentScenario().steps.length;
      const pct = total === 0 ? 0 : Math.round((stepIdx / total) * 100);
      progressBar.style.width = `${pct}%`;
      progressLbl.textContent = `step ${stepIdx} of ${total}`;
      const atEnd = stepIdx >= total;
      playLbl.textContent = stepIdx === 0 ? "start" : atEnd ? "complete" : "next";
      playBtn.disabled = atEnd;
      skipBtn.disabled = atEnd;
      if (stepIdx > 0) startPrompt.hidden = true;
    }

    function escapeHTML(s: string): string {
      return s.replace(/&/g, "&amp;").replace(/</g, "&lt;").replace(/>/g, "&gt;");
    }

    function renderStep(step: Step) {
      if (step.type === "beat") {
        const el = document.createElement("div");
        el.className = "cc-divider";
        const skillsHtml = (step.skills ?? [])
          .map((s) => `<code class="cc-chip">${escapeHTML(s)}</code>`)
          .join("");
        const labelText = step.caption
          ? `${step.label} — ${step.caption}`
          : step.label;
        el.innerHTML = `
          <span class="cc-divider-rule"></span>
          <span class="cc-divider-label">${escapeHTML(labelText)}</span>
          ${skillsHtml ? `<span class="cc-divider-skills">${skillsHtml}</span>` : ""}
          <span class="cc-divider-rule"></span>
        `;
        transcript.appendChild(el);
        return el;
      }

      // User input — bordered terminal box with > prefix. Single-tone
      // (5.5: blue path-a / path-b two-tone removed); the cream highlight
      // on the row comes from .cc-user CSS (5.6).
      if (step.role === "user") {
        const wrap = document.createElement("div");
        wrap.className = "cc-user";
        wrap.innerHTML = `
          <span class="cc-user-mark" aria-hidden="true">&gt;</span>
          <span class="cc-user-text"></span>
        `;
        (wrap.querySelector(".cc-user-text") as HTMLElement).textContent = step.content;
        transcript.appendChild(wrap);
        return wrap;
      }

      // Assistant turn — `● claude · skill` head, body, optional ⎿ footer.
      // The head row is colored by the skill's role token (--turn-color).
      const wrap = document.createElement("div");
      wrap.className = "cc-assistant";
      wrap.dataset.role = roleFor(step.skill);

      const head = document.createElement("div");
      head.className = "cc-assistant-head";
      const skillBit = step.skill
        ? `<span class="cc-sep">·</span><span class="cc-skill">${escapeHTML(step.skill)}</span>`
        : "";
      head.innerHTML = `
        <span class="cc-bullet" aria-hidden="true">●</span>
        <span class="cc-name">claude</span>
        ${skillBit}
      `;
      wrap.appendChild(head);

      const body = document.createElement("div");
      body.className = "cc-assistant-body markdown";
      body.innerHTML = renderSafeMarkdown(step.content);
      wrap.appendChild(body);

      // Tool calls (artifacts produced by this turn). Each artifact renders
      // as `● Write(filename)` with an indented ⎿ result line; clicking the
      // result expands the full body inline below.
      if (step.artifacts && step.artifacts.length > 0) {
        const byId = new Map(
          currentScenario().outputs.map((a) => [a.id, a] as const),
        );
        const refs = step.artifacts
          .map((id) => byId.get(id))
          .filter((a): a is Artifact => !!a);

        for (const a of refs) {
          const tool = document.createElement("div");
          tool.className = "cc-tool";
          const arg = a.kind || a.label;
          tool.innerHTML = `
            <div class="cc-tool-head">
              <span class="cc-bullet cc-bullet--tool" aria-hidden="true">●</span>
              <span class="cc-tool-name">Write</span><span class="cc-tool-paren" aria-hidden="true">(</span><span class="cc-tool-arg"></span><span class="cc-tool-paren" aria-hidden="true">)</span>
            </div>
            <button type="button" class="cc-tool-result" aria-expanded="false">
              <span class="cc-tool-elbow" aria-hidden="true">⎿</span>
              <span class="cc-tool-result-text">  </span>
              <span class="cc-tool-hint">click to expand</span>
            </button>
            <div class="cc-tool-body markdown" hidden></div>
          `;
          (tool.querySelector(".cc-tool-arg") as HTMLElement).textContent = arg;
          (tool.querySelector(".cc-tool-result-text") as HTMLElement).textContent = a.label;
          const btn = tool.querySelector(".cc-tool-result") as HTMLButtonElement;
          const hint = tool.querySelector(".cc-tool-hint") as HTMLElement;
          const toolBody = tool.querySelector(".cc-tool-body") as HTMLElement;
          btn.addEventListener("click", () => {
            const open = btn.getAttribute("aria-expanded") === "true";
            if (open) {
              toolBody.hidden = true;
              btn.setAttribute("aria-expanded", "false");
              hint.textContent = "click to expand";
              return;
            }
            toolBody.innerHTML = renderSafeMarkdown(a.body);
            toolBody.hidden = false;
            btn.setAttribute("aria-expanded", "true");
            hint.textContent = "click to collapse";
            requestAnimationFrame(() => {
              const tRect = transcript.getBoundingClientRect();
              const gRect = tool.getBoundingClientRect();
              const target =
                transcript.scrollTop + (gRect.top - tRect.top) - 12;
              transcript.scrollTo({
                top: Math.max(0, target),
                behavior: "smooth",
              });
            });
          });
          wrap.appendChild(tool);
        }
      }

      transcript.appendChild(wrap);
      return wrap;
    }

    /** Scroll the transcript container only — never the whole page. */
    function scrollChat() {
      transcript.scrollTo({ top: transcript.scrollHeight, behavior: "smooth" });
    }

    function advance() {
      const w = currentScenario();
      if (stepIdx >= w.steps.length) return;
      renderStep(w.steps[stepIdx]);
      stepIdx++;
      // First step starts the chat — collapse the detail card to make
      // room AND auto-switch to the Chat tab so the user sees the
      // transcript immediately.
      if (stepIdx === 1) {
        setDetailCollapsed(true);
        switchTab("chat");
      } else {
        // Subsequent advances: if the user has switched back to Scenario
        // since starting the chat, flash a small dot on the Chat tab so
        // they know there's new content.
        flashChatDot();
      }
      updateProgress();
      scrollChat();
    }

    function skipToEnd() {
      const w = currentScenario();
      while (stepIdx < w.steps.length) {
        renderStep(w.steps[stepIdx]);
        stepIdx++;
      }
      // Skipping also counts as starting the chat.
      setDetailCollapsed(true);
      switchTab("chat");
      updateProgress();
      scrollChat();
    }

    function restart() {
      // I7 — Switch tab first so the slow detail-expand animation
      // happens on the now-visible panel rather than under the chat
      // panel. Then reset transcript + startPrompt + detail collapse
      // state in a single frame.
      switchTab("detail");
      stepIdx = 0;
      transcript.innerHTML = "";
      startPrompt.hidden = false;
      setDetailCollapsed(false);
      updateProgress();
    }

    // ── 1.4 — Tab switching (Scenario / Chat) ──────────────────
    const tabButtons   = document.querySelectorAll<HTMLButtonElement>(".replays-tab[data-rtab]");
    const tabPanels    = document.querySelectorAll<HTMLElement>(".replays-panel[data-rtab]");
    const chatTabDot   = document.getElementById("rtab-chat-dot");

    function switchTab(name: "detail" | "chat") {
      tabButtons.forEach((b) => {
        const matched = b.dataset.rtab === name;
        b.classList.toggle("is-active", matched);
        b.setAttribute("aria-selected", matched ? "true" : "false");
        // I6 — roving tabindex: only the active tab is in the tab order.
        b.setAttribute("tabindex", matched ? "0" : "-1");
      });
      tabPanels.forEach((p) => {
        p.hidden = p.dataset.rtab !== name;
      });
      if (name === "chat" && chatTabDot) chatTabDot.classList.remove("is-on");
    }
    function flashChatDot() {
      // Show a tiny pulse on the Chat tab if the user is on Scenario when
      // a new chat step lands. They can switch over at their own pace.
      const activeTab = document.querySelector<HTMLButtonElement>(".replays-tab.is-active");
      if (activeTab?.dataset.rtab === "detail" && chatTabDot) {
        chatTabDot.classList.add("is-on");
      }
    }

    tabButtons.forEach((b) => {
      b.addEventListener("click", () => {
        switchTab(b.dataset.rtab === "chat" ? "chat" : "detail");
      });
    });

    // I6 — ARIA tablist keyboard pattern for the Scenario / Chat bar.
    // Left/Right + Home/End cycle and auto-activate; Enter/Space
    // activate via the native button click. Roving tabindex (above)
    // keeps a single tabstop in the bar.
    function focusTab(name: "detail" | "chat") {
      const target = Array.from(tabButtons).find((b) => b.dataset.rtab === name);
      target?.focus();
    }
    tabButtons.forEach((b) => {
      b.addEventListener("keydown", (ev) => {
        const key = ev.key;
        if (key === "ArrowLeft" || key === "ArrowUp" || key === "Home") {
          ev.preventDefault();
          switchTab("detail");
          focusTab("detail");
        } else if (key === "ArrowRight" || key === "ArrowDown" || key === "End") {
          ev.preventDefault();
          switchTab("chat");
          focusTab("chat");
        } else if (key === "Enter" || key === " ") {
          ev.stopPropagation();
        }
      });
    });

    // ── wire up ────────────────────────────────────────────────
    playBtn.addEventListener("click", advance);
    skipBtn.addEventListener("click", skipToEnd);
    restartBtn.addEventListener("click", restart);
    detailToggle.addEventListener("click", () => {
      setDetailCollapsed(!detailCard.classList.contains("is-collapsed"));
    });

    // I6 — ARIA tablist keyboard pattern for the scenario chip strip.
    // Roving tabindex (set inside setScenario) keeps a single tabstop
    // in the picker; arrow keys + Home/End cycle and auto-activate
    // the focused chip.
    const scenarioChips = Array.from(
      picker.querySelectorAll<HTMLButtonElement>("[data-scenario]"),
    );
    function focusScenarioChip(i: number) {
      const target = scenarioChips[i];
      target?.focus();
    }
    scenarioChips.forEach((el, i) => {
      // Initial roving tabindex: 0 on the active chip, -1 on the rest.
      el.setAttribute("tabindex", i === 0 ? "0" : "-1");
      el.addEventListener("click", () => setScenario(i));
      el.addEventListener("keydown", (ev) => {
        const key = ev.key;
        if (key === "Enter" || key === " ") {
          ev.stopPropagation();
          return;
        }
        if (key === "ArrowLeft" || key === "ArrowUp") {
          ev.preventDefault();
          ev.stopPropagation();
          const next = (i - 1 + scenarioChips.length) % scenarioChips.length;
          setScenario(next);
          focusScenarioChip(next);
        } else if (key === "ArrowRight" || key === "ArrowDown") {
          ev.preventDefault();
          ev.stopPropagation();
          const next = (i + 1) % scenarioChips.length;
          setScenario(next);
          focusScenarioChip(next);
        } else if (key === "Home") {
          ev.preventDefault();
          ev.stopPropagation();
          setScenario(0);
          focusScenarioChip(0);
        } else if (key === "End") {
          ev.preventDefault();
          ev.stopPropagation();
          const last = scenarioChips.length - 1;
          setScenario(last);
          focusScenarioChip(last);
        }
      });
    });

    // When this component is mounted inside a tabpanel that's currently
    // hidden, swallow the global shortcuts — otherwise pressing Enter on
    // the Live tab would advance the (invisible) Replays transcript.
    const replaysRoot = document.getElementById("replays-root");
    function replaysVisible(): boolean {
      const panel = replaysRoot?.closest("[role=tabpanel]") as HTMLElement | null;
      return !panel || !panel.hidden;
    }

    window.addEventListener("keydown", (ev) => {
      if (!replaysVisible()) return;
      // Ignore shortcuts when the user is typing into a field.
      const target = ev.target as HTMLElement | null;
      if (target && (target.tagName === "INPUT" || target.tagName === "TEXTAREA" || target.isContentEditable)) {
        return;
      }
      if (ev.key === "Enter") { ev.preventDefault(); advance(); return; }
      if (ev.key === " ")     { ev.preventDefault(); skipToEnd(); return; }
      if (ev.key.toLowerCase() === "r") { ev.preventDefault(); restart(); return; }
      const n = Number.parseInt(ev.key, 10);
      if (!Number.isNaN(n) && n >= 1 && n <= catalog.length) {
        ev.preventDefault();
        setScenario(n - 1);
        // I5 — Send keyboard focus to the picked chip so AT users
        // hear the new scenario announced via the role="tab" +
        // aria-selected change.
        focusScenarioChip(n - 1);
      }
    });

    // First render.
    setScenario(0);
  </script>

