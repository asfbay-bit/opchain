---
/**
 * Three-node chain icon. Token-driven fills/strokes so the mark
 * auto-recolors when the theme flips.
 */
interface Props {
  size?: number;
  class?: string;
}
const { size = 28, class: className = "" } = Astro.props;
const viewBox = "0 0 32 32";
const width = size;
const height = size;
---

<svg
  width={width}
  height={height}
  viewBox={viewBox}
  class={className}
  aria-hidden="true"
>
  <line
    x1="3" y1="16" x2="29" y2="16"
    stroke="var(--logo-spine, #5a5040)" stroke-width="1"
  />
  <rect
    x="3" y="10" width="7" height="12" rx="1.5"
    fill="none" stroke="var(--logo-stroke, #e8dfd0)" stroke-width="1.2"
  />
  <rect
    x="12" y="10" width="7" height="12" rx="1.5"
    fill="none" stroke="var(--logo-stroke, #e8dfd0)" stroke-width="1.2"
  />
  <rect
    x="21" y="10" width="8" height="12" rx="1.5"
    fill="var(--logo-filled, #e05c18)"
  />
  <circle cx="6.5" cy="16" r="1.6" fill="var(--logo-stroke, #e8dfd0)" />
  <circle cx="15.5" cy="16" r="1.6" fill="var(--logo-stroke, #e8dfd0)" />
  <circle cx="25" cy="16" r="1.6" fill="var(--logo-dot-dark, #1c1710)" />
</svg>
