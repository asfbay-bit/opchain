  .cc-stream > * { padding-left: 0.9rem; padding-right: 0.9rem; }
  .cc-stream > .transcript-head { padding-left: 0.9rem; padding-right: 0.9rem; }

  .cc-beat {
    display: flex;
    align-items: center;
    gap: 0.7rem;
    margin: 1.2rem 0 0.6rem;
    color: var(--cc-dim);
    font-size: 11px;
    letter-spacing: 0.06em;
