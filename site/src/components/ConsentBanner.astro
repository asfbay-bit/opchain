---
/**
 * Consent banner + PostHog loader.
 *
 * Stored in `localStorage.opchain-consent` = "granted" | "declined".
 * Nothing loads until a decision is made (banner visible), so declining
 * the banner means no PostHog SDK, no cookies, no network calls.
 *
 * PostHog client key is exposed via `import.meta.env.PUBLIC_POSTHOG_KEY`
 * — if unset, the banner still renders (for consent hygiene) but accept
 * becomes a no-op. That matches how `.env.example` documents the var:
 * local dev and CI don't need it.
 *
 * The default host fallback points at the production managed reverse
 * proxy (`t.opchain.dev`). Staging deploys override it via
 * `PUBLIC_POSTHOG_HOST=https://t.staging.opchain.dev` baked into
 * `npm run deploy:staging`. Routing PostHog traffic through our own
 * domain dodges most ad blockers without changing what's collected.
 */
import { defaultFor } from "../lib/flags/build-defaults";

const publicKey = import.meta.env.PUBLIC_POSTHOG_KEY || "";
const posthogHost = import.meta.env.PUBLIC_POSTHOG_HOST || "https://t.opchain.dev";
// Build-time gate. The client-side `flags/client.ts` layer overrides this
// post-consent if PostHog flips the flag at runtime.
const posthogClientEnabled = defaultFor("platform.observability.posthog-client") as boolean;
---

<div id="consent-banner" class="consent-banner" role="dialog" aria-labelledby="consent-title" hidden>
  <div class="consent-inner">
    <div class="consent-text">
      <p class="title" id="consent-title">Cookies &amp; analytics</p>
      <p class="body">
        We use <a href="/privacy">privacy-friendly analytics</a> to understand
        which skills and pages help. No ads, no cross-site tracking.
      </p>
    </div>
    <div class="consent-actions">
      <button type="button" class="btn btn-ghost" id="consent-decline">decline</button>
      <button type="button" class="btn btn-primary" id="consent-accept">accept</button>
    </div>
  </div>
</div>

<script is:inline define:vars={{ publicKey, posthogHost, posthogClientEnabled }}>
  (function () {
    const KEY = "opchain-consent";
    const banner = document.getElementById("consent-banner");
    const accept = document.getElementById("consent-accept");
    const decline = document.getElementById("consent-decline");

    function loadPosthog() {
      if (!posthogClientEnabled) return;
      if (!publicKey) return;
      if (window.posthog) return;
      // Minimal inlined bootstrap — mirrors the official snippet. Once loaded,
      // posthog-js handles session IDs + auto-captures pageviews.
      // eslint-disable-next-line no-unused-expressions
      !function(t,e){var o,n,p,r;e.__SV||(window.posthog=e,e._i=[],e.init=function(i,s,a){function g(t,e){var o=e.split(".");2==o.length&&(t=t[o[0]],e=o[1]),t[e]=function(){t.push([e].concat(Array.prototype.slice.call(arguments,0)))}}(p=t.createElement("script")).type="text/javascript",p.async=!0,p.src=s.api_host.replace(".i.posthog.com","-assets.i.posthog.com")+"/static/array.js",(r=t.getElementsByTagName("script")[0]).parentNode.insertBefore(p,r);var u=e;for(void 0!==a?u=e[a]=[]:a="posthog",u.people=u.people||[],u.toString=function(t){var e="posthog";return"posthog"!==a&&(e+="."+a),t||(e+=" (stub)"),e},u.people.toString=function(){return u.toString(1)+".people (stub)"},o="init capture register register_once register_for_session unregister unregister_for_session getFeatureFlag getFeatureFlagPayload isFeatureEnabled reloadFeatureFlags updateEarlyAccessFeatureEnrollment getEarlyAccessFeatures on onFeatureFlags onSessionId getSurveys getActiveMatchingSurveys renderSurvey canRenderSurvey identify setPersonProperties group resetGroups setPersonPropertiesForFlags resetPersonPropertiesForFlags setGroupPropertiesForFlags resetGroupPropertiesForFlags reset get_distinct_id getGroups get_session_id get_session_replay_url alias set_config startSessionRecording stopSessionRecording sessionRecordingStarted captureException loadToolbar get_property getSessionProperty createPersonProfile opt_in_capturing opt_out_capturing has_opted_in_capturing has_opted_out_capturing clear_opt_in_out_capturing debug getPageViewId captureTraceFeedback captureTraceMetric".split(" "),n=0;n<o.length;n++)g(u,o[n]);e._i.push([i,s,a])},e.__SV=1)}(document,window.posthog||[]);
      window.posthog.init(publicKey, {
        api_host: posthogHost,
        // Provided per the snippet wired by the proxy setup. `defaults`
        // pins SDK behavior to a known release, `person_profiles:
        // 'identified_only'` skips creating profiles for anon visitors.
        defaults: "2026-01-30",
        person_profiles: "identified_only",
        persistence: "localStorage",
        autocapture: true,
        capture_pageview: true,
        disable_session_recording: true,
      });
    }

    function hideBanner() { if (banner) banner.hidden = true; }
    function showBanner() { if (banner) banner.hidden = false; }

    let saved = null;
    try { saved = localStorage.getItem(KEY); } catch { /* localStorage blocked */ }

    if (saved === "granted") {
      loadPosthog();
      hideBanner();
    } else if (saved === "declined") {
      hideBanner();
    } else {
      showBanner();
    }

    accept?.addEventListener("click", () => {
      try { localStorage.setItem(KEY, "granted"); } catch { /* ignore */ }
      loadPosthog();
      hideBanner();
    });
    decline?.addEventListener("click", () => {
      try { localStorage.setItem(KEY, "declined"); } catch { /* ignore */ }
      hideBanner();
    });
  })();
</script>

<style>
  .consent-banner {
    position: fixed;
    left: 1rem;
    right: 1rem;
    bottom: 1rem;
    z-index: 60;
    background: var(--surface);
    color: var(--text);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    box-shadow: var(--shadow-lg);
    padding: 1rem 1.1rem;
  }
  .consent-banner[hidden] { display: none; }
  /* When the MobileWorkbench's fixed bottom tab bar is mounted on the
     page (i.e. /demo at ≤767px), shift this banner above the tabs so
     it doesn't cover them or intercept tab clicks. .mw-tab min-height
     is 52px + 1px border = 53px, plus the device safe-area inset, plus
     the existing 1rem gap. */
  body:has(.mw-tabbar) .consent-banner {
    bottom: calc(53px + env(safe-area-inset-bottom) + 1rem);
  }
  .consent-inner {
    max-width: 960px;
    margin: 0 auto;
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    justify-content: space-between;
    gap: 0.9rem;
  }
  .consent-text { flex: 1 1 18rem; }
  .consent-text .title {
    margin: 0 0 0.2rem;
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    color: var(--text);
  }
  .consent-text .body {
    margin: 0;
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: var(--lh-base);
  }
  .consent-text a { color: var(--accent); }
  /* B-10: --accent link text on light --surface = 3.05:1 ✗. --accent-hover = 4.55:1 ✓. */
  :global([data-theme="light"]) .consent-text a { color: var(--accent-hover); }

  .consent-actions {
    display: flex;
    gap: 0.5rem;
    flex-wrap: wrap;
  }
  .btn {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--ls-wide);
    padding: 0.55rem 1.1rem;
    border-radius: var(--r-sm);
    cursor: pointer;
    border: 0.5px solid transparent;
    transition:
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .btn-primary {
    background: var(--accent);
    color: var(--obsidian);
    border: none;
  }
  .btn-primary:hover { background: var(--accent-hover); }
  /* B-10: light --accent bg + --obsidian text = 4.33:1 ✗. --ember = 4.84:1 ✓. */
  :global([data-theme="light"]) .btn-primary { background: var(--ember); }
  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border-color: var(--border);
  }
  .btn-ghost:hover {
    color: var(--text);
    border-color: var(--muted);
  }
</style>
