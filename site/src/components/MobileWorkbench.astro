---
import { walkthroughs } from "../data/walkthroughs";
import { getSkillRole } from "../lib/skills";
import { renderSafeMarkdown } from "../lib/markdown";

interface Props {
  /** When true, render the Find (search + filter) overlay + topbar trigger. */
  search?: boolean;
}
const { search = false } = Astro.props;

/**
 * Mobile workbench — Direction A: Bottom-Tab IDE.
 *
 * The desktop workbench's four panels (sidebar · editor summary · editor
 * transcript · inspector) become four bottom-tab views (Scenarios ·
 * Stream · I/O · Inspector). Touch-friendly: every tap target is ≥44px,
 * the topbar shows the active scenario name, and selecting a scenario
 * from the Scenarios tab auto-switches to Stream.
 *
 * The shared <dialog> lightbox in demo.astro picks up clicks on
 * `.output-row[data-output-scenario][data-output-id]` via document-level
 * event delegation — this component just needs to emit the same buttons
 * with the same data attributes that DesktopWorkbench does. No mobile-
 * specific modal logic needed.
 *
 * All class names are prefixed `mw-` and all interactive selectors are
 * scoped under `[data-mobile-workbench]` so the desktop component's JS
 * never reaches into this subtree (and vice versa).
 */

const transcripts = walkthroughs.map((w) => ({
  id: w.id,
  title: w.title,
  tagline: w.tagline,
  summary: w.summary,
  runtime: w.runtime,
  inputs: w.inputs,
  outputs: w.outputs,
  skills: w.skills.map((id) => ({ id, role: getSkillRole(id) })),
  stepCount: w.steps.length,
  beatCount: w.steps.filter((s) => s.type === "beat").length,
  steps: w.steps.map((step) => {
    if (step.type === "beat") {
      return {
        kind: "beat" as const,
        label: step.label,
        caption: step.caption ?? "",
        skills: (step.skills ?? []).map((id) => ({ id, role: getSkillRole(id) })),
      };
    }
    if (step.role === "user") {
      return { kind: "user" as const, content: step.content };
    }
    return {
      kind: "claude" as const,
      skill: step.skill ?? "",
      skillRole: step.skill ? getSkillRole(step.skill) : null,
      html: renderSafeMarkdown(step.content),
      artifacts: (step.artifacts ?? []).map((aid) => {
        const a = w.outputs.find((o) => o.id === aid);
        return { id: aid, label: a?.label ?? aid, kind: a?.kind ?? "" };
      }),
    };
  }),
}));
---

<section class="mw" data-mobile-workbench aria-label="Mobile workbench">
  <header class="mw-topbar">
    <span class="mw-brand">opchain</span>
    <span class="mw-scn-label" data-mw-active-label>scenarios</span>
    {search && (
      <button class="mw-find-btn" type="button" data-ocs-open aria-label="Search and filter scenarios">
        <span aria-hidden="true">⌕</span>
      </button>
    )}
  </header>

  <div class="mw-panels">
    <!-- Scenarios tab — the picker -->
    <section class="mw-panel is-active" data-mw-panel="scenarios" aria-label="Scenarios">
      <h2 class="mw-section-eyebrow">Scenarios · {transcripts.length}</h2>
      <div class="mw-scn-list">
        {transcripts.map((w, i) => (
          <button
            type="button"
            class="mw-scn-card"
            data-mw-scenario={w.id}
            aria-pressed="false"
          >
            <div class="mw-scn-num">{String(i + 1).padStart(2, "0")} · {w.runtime}</div>
            <div class="mw-scn-title">{w.title}</div>
            <div class="mw-scn-tagline">{w.tagline}</div>
            <div class="mw-scn-summary">{w.summary}</div>
            <div class="mw-scn-meta">
              {w.skills.slice(0, 4).map((sk) => (
                <span class:list={["mw-skill-pill", `mw-role-${sk.role}`]}>{sk.id}</span>
              ))}
              {w.skills.length > 4 && (
                <span class="mw-skill-more">+{w.skills.length - 4}</span>
              )}
            </div>
          </button>
        ))}
      </div>
    </section>

    <!-- Stream tab — transcript -->
    <section class="mw-panel" data-mw-panel="stream" aria-label="Transcript stream">
      <div class="mw-empty" data-mw-empty>
        <div class="mw-empty-eyebrow">no scenario picked</div>
        <p class="mw-empty-h">Pick a scenario.</p>
        <p class="mw-empty-sub">
          Tap any card on the <strong>Scenarios</strong> tab to load its
          transcript here.
        </p>
      </div>

      {transcripts.map((w) => (
        <article
          class="mw-stream"
          data-mw-stream={w.id}
          aria-label={`${w.title} transcript`}
          hidden
        >
          <header class="mw-stream-head">
            <div class="mw-stream-eyebrow">{w.tagline}</div>
            <h3 class="mw-stream-title">{w.title}</h3>
            <div class="mw-stream-meta">{w.stepCount} steps · {w.beatCount} stages · {w.runtime}</div>
          </header>

          <div class="mw-cc-stream">
            {w.steps.map((step, si) => {
              if (step.kind === "beat") {
                return (
                  <div class="mw-beat" data-step-id={`s${si}`}>
                    <div class="mw-beat-label">{step.label}</div>
                    {step.caption && <div class="mw-beat-caption">{step.caption}</div>}
                    {step.skills.length > 0 && (
                      <div class="mw-beat-skills">
                        {step.skills.map((sk) => (
                          <span class:list={["mw-skill-pill", "mw-skill-pill--xs", `mw-role-${sk.role}`]}>{sk.id}</span>
                        ))}
                      </div>
                    )}
                  </div>
                );
              }
              if (step.kind === "user") {
                return (
                  <div class="mw-user" data-step-id={`s${si}`}>
                    <span class="mw-user-mark" aria-hidden="true">&gt;</span>
                    <span class="mw-user-text">{step.content}</span>
                  </div>
                );
              }
              return (
                <div class="mw-claude" data-step-id={`s${si}`}>
                  <div class="mw-claude-head">
                    <span class="mw-claude-bullet" aria-hidden="true">●</span>
                    <span class="mw-claude-name">claude</span>
                    {step.skill && (
                      <>
                        <span class="mw-claude-sep" aria-hidden="true">·</span>
                        <code class:list={[
                          "mw-claude-skill",
                          step.skillRole && `mw-role-${step.skillRole}`,
                        ]}>{step.skill}</code>
                      </>
                    )}
                  </div>
                  <div class="mw-claude-body" set:html={step.html} />
                  {step.artifacts.length > 0 && (
                    <div class="mw-artifacts" aria-label="Outputs from this exchange">
                      {step.artifacts.map((a) => (
                        <button
                          type="button"
                          class="output-row mw-artifact-chip"
                          data-output-scenario={w.id}
                          data-output-id={a.id}
                          aria-label={`Open ${a.label}`}
                        >
                          <span class="output-ico" aria-hidden="true">⊞</span>
                          <span class="output-label">{a.label}</span>
                          {a.kind && <span class="output-kind">{a.kind}</span>}
                        </button>
                      ))}
                    </div>
                  )}
                </div>
              );
            })}
          </div>
        </article>
      ))}
    </section>

    <!-- I/O tab — inputs + outputs -->
    <section class="mw-panel" data-mw-panel="io" aria-label="Inputs and outputs">
      <div class="mw-empty" data-mw-empty-io>
        <div class="mw-empty-eyebrow">no scenario picked</div>
        <p class="mw-empty-h">Pick a scenario.</p>
        <p class="mw-empty-sub">Inputs and outputs land here.</p>
      </div>

      {transcripts.map((w) => (
        <div class="mw-io" data-mw-io={w.id} hidden>
          <h3 class="mw-section-eyebrow">Inputs · {w.inputs.length}</h3>
          <ul class="mw-input-list">
            {w.inputs.map((line) => (<li>{line}</li>))}
          </ul>

          <h3 class="mw-section-eyebrow">Outputs · {w.outputs.length}</h3>
          <ul class="mw-output-list">
            {w.outputs.map((o) => (
              <li>
                <button
                  type="button"
                  class="output-row mw-output-row"
                  data-output-scenario={w.id}
                  data-output-id={o.id}
                  aria-label={`Open ${o.label}`}
                >
                  <span class="output-ico" aria-hidden="true">⊞</span>
                  <span class="output-label">{o.label}</span>
                  {o.kind && <span class="output-kind">{o.kind}</span>}
                </button>
              </li>
            ))}
          </ul>
        </div>
      ))}
    </section>

    <!-- Inspector tab — scenario meta -->
    <section class="mw-panel" data-mw-panel="inspector" aria-label="Inspector">
      <div class="mw-empty" data-mw-empty-insp>
        <div class="mw-empty-eyebrow">no scenario picked</div>
        <p class="mw-empty-h">Pick a scenario.</p>
        <p class="mw-empty-sub">Skills, runtime, and a summary land here.</p>
      </div>

      {transcripts.map((w, i) => (
        <div class="mw-insp" data-mw-insp={w.id} hidden>
          <div class="mw-insp-card">
            <div class="mw-insp-eyebrow">scenario {String(i + 1).padStart(2, "0")}</div>
            <div class="mw-insp-title">{w.title}</div>
            <div class="mw-insp-tagline">{w.tagline}</div>
          </div>

          <div class="mw-insp-card">
            <div class="mw-insp-eyebrow">runtime</div>
            <div class="mw-insp-value">{w.runtime}</div>
          </div>

          <div class="mw-insp-card">
            <div class="mw-insp-eyebrow">skills · {w.skills.length}</div>
            <div class="mw-insp-skills">
              {w.skills.map((sk) => (
                <span class:list={["mw-skill-pill", `mw-role-${sk.role}`]}>{sk.id}</span>
              ))}
            </div>
          </div>

          <div class="mw-insp-card">
            <div class="mw-insp-eyebrow">summary</div>
            <p class="mw-insp-body">{w.summary}</p>
          </div>

          <div class="mw-insp-card">
            <div class="mw-insp-eyebrow">stages · {w.beatCount}</div>
            <ol class="mw-insp-beats">
              {w.steps.map((s) => s.kind === "beat" ? (
                <li>
                  <span class="mw-insp-beat-label">{s.label}</span>
                  {s.caption && <span class="mw-insp-beat-caption"> · {s.caption}</span>}
                </li>
              ) : null)}
            </ol>
          </div>
        </div>
      ))}
    </section>
  </div>

  <nav class="mw-tabbar" role="tablist" aria-label="Workbench tabs">
    <button class="mw-tab" role="tab" type="button" aria-selected="true" data-mw-tab="scenarios">
      <span class="mw-tab-ico" aria-hidden="true">▦</span>
      <span class="mw-tab-label">Scenarios</span>
    </button>
    <button class="mw-tab" role="tab" type="button" aria-selected="false" data-mw-tab="stream">
      <span class="mw-tab-ico" aria-hidden="true">⏵</span>
      <span class="mw-tab-label">Stream</span>
    </button>
    <button class="mw-tab" role="tab" type="button" aria-selected="false" data-mw-tab="io">
      <span class="mw-tab-ico" aria-hidden="true">⇄</span>
      <span class="mw-tab-label">I/O</span>
    </button>
    <button class="mw-tab" role="tab" type="button" aria-selected="false" data-mw-tab="inspector">
      <span class="mw-tab-ico" aria-hidden="true">●</span>
      <span class="mw-tab-label">Inspector</span>
    </button>
  </nav>

  {search && (
    <div class="mw-find" data-ocs-overlay hidden role="dialog" aria-modal="true" aria-label="Search and filter">
      <div class="mw-find-head">
        <div class="mw-find-row">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><circle cx="11" cy="11" r="7"/><path d="m21 21-4.3-4.3"/></svg>
          <input class="mw-find-input" type="text" data-ocs-input placeholder="Search transcripts…" aria-label="Search demo transcripts" autocomplete="off" spellcheck="false" />
          <button class="mw-find-done" type="button" data-ocs-overlay-close>Done</button>
        </div>
        <div class="ocs-count" data-ocs-count></div>
        <div class="ocs-pills" data-ocs-pills></div>
        <details class="mw-find-filters">
          <summary>Filters <span class="mw-find-scn" data-ocs-scn-count></span></summary>
          <div class="ocs-facets" data-ocs-facets></div>
          <button class="ocs-clearall" type="button" data-ocs-clear>clear all filters</button>
        </details>
      </div>
      <div class="ocs-results mw-find-results" data-ocs-results aria-label="Search results" aria-live="polite"></div>
    </div>
  )}
</section>

<style>
  /* ── Mobile workbench shell ──
     Natural-flow column: the page is the scroll context (not the shell),
     so the topbar can stick below the sticky site header and the bottom
     tabbar can pin to the viewport edge with safe-area inset. */
  .mw {
    display: flex;
    flex-direction: column;
    background: var(--bg);
    border-top: 0.5px solid var(--border);
    /* Bottom border lives on .mw-tabbar (fixed) so the workbench reads
       as a single visual frame anchored to the viewport edge. */
    /* Reserve space at the bottom of the column equal to the fixed
       tabbar's intrinsic height + the device's safe-area inset, so
       the last item in any panel can scroll into view above the bar. */
    padding-bottom: calc(53px + env(safe-area-inset-bottom));
  }

  /* Topbar — sticks below the sticky site header (top: 56px from
     .site-header-inner). z-index just under the site header (50) and
     just over the tabbar (40) so neither covers it during scroll. */
  .mw-topbar {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 10px 14px;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--border);
    min-height: 44px;
    position: sticky;
    top: 56px;
    z-index: 30;
  }
  .mw-brand {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: 13px;
    letter-spacing: var(--ls-display);
    color: var(--text);
  }
  .mw-scn-label {
    flex: 1;
    text-align: right;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    color: var(--accent);
    overflow: hidden;
    text-overflow: ellipsis;
    white-space: nowrap;
  }

  /* Panels — exactly one is .is-active at a time. Natural block flow:
     the page (not the panel) is the scroll context, so the section
     eyebrow flows below the sticky topbar and the bottom of the panel
     clears the fixed tabbar via .mw's padding-bottom. */
  .mw-panels {
    display: block;
  }
  .mw-panel {
    overscroll-behavior: contain;
    padding: 14px clamp(12px, 4vw, 18px) 24px;
    display: none;
  }
  .mw-panel.is-active { display: block; }

  /* Empty states */
  .mw-empty {
    padding: 32px 16px;
    text-align: center;
    color: var(--muted);
  }
  .mw-empty[hidden] { display: none; }
  .mw-empty-eyebrow {
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    margin-bottom: 8px;
  }
  :global([data-theme="light"]) .mw-empty-eyebrow { color: #993505; }
  .mw-empty-h {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 500;
    color: var(--text);
    margin: 0 0 6px;
  }
  .mw-empty-sub {
    font-size: var(--fs-sm);
    line-height: var(--lh-base);
    margin: 0;
    max-width: 22rem;
    margin-left: auto;
    margin-right: auto;
  }
  .mw-empty-sub strong { color: var(--accent); font-weight: 500; }

  /* Section eyebrow */
  .mw-section-eyebrow {
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    color: var(--subtle);
    font-weight: 500;
    margin: 0 0 10px;
  }
  .mw-section-eyebrow + .mw-section-eyebrow { margin-top: 18px; }

  /* Skill pill — namespaced for the mobile workbench */
  .mw-skill-pill {
    display: inline-block;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
    padding: 3px 7px;
    border-radius: var(--r-pill);
    border: 0.5px solid var(--border);
    background: rgba(255, 255, 255, 0.02);
    color: var(--muted);
  }
  .mw-skill-pill--xs { font-size: 9px; padding: 2px 6px; }
  .mw-skill-more {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--subtle);
    padding: 3px 0;
  }
  .mw-role-workflow     { color: var(--workflow);     border-color: var(--workflow); }
  .mw-role-tri-agent    { color: var(--tri-agent);    border-color: var(--tri-agent); }
  .mw-role-audit-gate   { color: var(--audit-gate);   border-color: var(--audit-gate); }
  .mw-role-specialist   { color: var(--specialist);   border-color: var(--specialist); }
  .mw-role-advisor      { color: var(--advisor);      border-color: var(--advisor); }
  .mw-role-orchestrator { color: var(--orchestrator); border-color: var(--orchestrator); }
  .mw-role-success      { color: var(--success);      border-color: var(--success); }

  /* ── Scenarios panel ── */
  .mw-scn-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .mw-scn-card {
    appearance: none;
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 14px 14px 12px;
    text-align: left;
    color: var(--text);
    font-family: inherit;
    width: 100%;
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .mw-scn-card:hover { border-color: var(--accent); }
  .mw-scn-card[aria-pressed="true"] {
    border-color: var(--accent);
    background: var(--ember-dim);
    box-shadow: var(--glow-md);
  }
  .mw-scn-card:focus-visible {
    outline: none;
    box-shadow: var(--focus-ring);
  }
  .mw-scn-num {
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    margin-bottom: 4px;
  }
  :global([data-theme="light"]) .mw-scn-num { color: #993505; }
  .mw-scn-title {
    font-family: var(--font-display);
    font-size: var(--fs-md);
    font-weight: 600;
    line-height: var(--lh-tight);
    color: var(--text);
    margin-bottom: 4px;
  }
  .mw-scn-tagline {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--muted);
    margin-bottom: 8px;
    letter-spacing: var(--ls-wide);
  }
  .mw-scn-summary {
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: var(--lh-snug);
    margin-bottom: 10px;
  }
  .mw-scn-meta {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
  }

  /* ── Stream panel ── */
  .mw-stream[hidden] { display: none; }
  .mw-stream-head {
    margin-bottom: 12px;
    padding-bottom: 10px;
    border-bottom: 0.5px solid var(--border);
  }
  .mw-stream-eyebrow {
    color: #f5894d;
    font-family: var(--font-mono);
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: var(--ls-widest);
    margin-bottom: 4px;
  }
  :global([data-theme="light"]) .mw-stream-eyebrow { color: #993505; }
  .mw-stream-title {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: var(--fs-lg);
    line-height: var(--lh-tight);
    margin: 0 0 6px;
    color: var(--text);
  }
  .mw-stream-meta {
    font-family: var(--font-mono);
    font-size: 10.5px;
    color: var(--subtle);
    text-transform: uppercase;
    letter-spacing: var(--ls-wide);
  }

  .mw-cc-stream {
    /* Same Claude-Code terminal palette as desktop, just sized for phones. */
    --mw-cc-bg:      #181818;
    --mw-cc-fg:      #e8e8e8;
    --mw-cc-dim:     #8a8a8a;
    --mw-cc-subtle:  #5a5a5a;
    --mw-cc-cyan:    #62afff;
    --mw-cc-orange:  #d99155;
    --mw-cc-border:  #2a2a2a;

    background: var(--mw-cc-bg);
    color: var(--mw-cc-fg);
    font-family: var(--font-mono);
    font-size: clamp(12px, 3.4vw, 13px);
    line-height: var(--lh-base);
    padding: 12px 12px 16px;
    border: 0.5px solid var(--mw-cc-border);
    border-radius: var(--r-md);
  }

  .mw-beat {
    margin: 14px 0 10px;
    padding-bottom: 8px;
    border-bottom: 0.5px dashed var(--mw-cc-border);
  }
  .mw-beat:first-child { margin-top: 0; }
  .mw-beat-label {
    color: var(--mw-cc-fg);
    font-size: 11px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .mw-beat-caption {
    color: var(--mw-cc-dim);
    font-size: 10.5px;
    margin-top: 2px;
    text-transform: uppercase;
    letter-spacing: 0.04em;
  }
  .mw-beat-skills {
    display: flex;
    flex-wrap: wrap;
    gap: 4px;
    margin-top: 6px;
  }

  .mw-user {
    display: flex;
    gap: 8px;
    margin: 10px 0;
    color: var(--mw-cc-fg);
  }
  .mw-user-mark { color: var(--mw-cc-cyan); flex: 0 0 auto; }
  .mw-user-text { white-space: pre-wrap; }

  .mw-claude { margin: 10px 0 14px; }
  .mw-claude-head {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
    margin-bottom: 6px;
    color: var(--mw-cc-dim);
    font-size: 11px;
  }
  .mw-claude-bullet { color: var(--mw-cc-orange); }
  .mw-claude-name   { color: var(--mw-cc-fg); font-weight: 600; }
  .mw-claude-sep    { color: var(--mw-cc-subtle); }
  .mw-claude-skill {
    font-family: var(--font-mono);
    font-size: 10.5px;
