  .mw-find-filters > summary::-webkit-details-marker { display: none; }
  .mw-find-scn { color: var(--subtle); text-transform: none; }
  .mw-find-results {
    flex: 1 1 auto;
    overflow-y: auto;
    padding: 6px 0 calc(24px + env(safe-area-inset-bottom));
    -webkit-overflow-scrolling: touch;
