</style>

<script is:inline>
  /* MobileWorkbench wiring — scoped to its own subtree via [data-mobile-workbench]. */
  (() => {
    const root = document.querySelector('[data-mobile-workbench]');
    if (!root) return;

    const tabs = root.querySelectorAll('[data-mw-tab]');
    const panels = root.querySelectorAll('[data-mw-panel]');
    const cards = root.querySelectorAll('[data-mw-scenario]');
    const streams = root.querySelectorAll('[data-mw-stream]');
    const ios = root.querySelectorAll('[data-mw-io]');
    const insps = root.querySelectorAll('[data-mw-insp]');
    const emptyStream = root.querySelector('[data-mw-empty]');
    const emptyIo = root.querySelector('[data-mw-empty-io]');
    const emptyInsp = root.querySelector('[data-mw-empty-insp]');
    const activeLabel = root.querySelector('[data-mw-active-label]');

    function show(name) {
      tabs.forEach((t) => t.setAttribute('aria-selected', t.dataset.mwTab === name));
      panels.forEach((p) => p.classList.toggle('is-active', p.dataset.mwPanel === name));
      const ap = root.querySelector(`[data-mw-panel="${name}"]`);
      if (ap) ap.scrollTop = 0;
    }

    function selectScenario(id) {
      cards.forEach((c) => c.setAttribute('aria-pressed', c.dataset.mwScenario === id ? 'true' : 'false'));
      streams.forEach((s) => {
        if (s.dataset.mwStream === id) s.removeAttribute('hidden');
        else                            s.setAttribute('hidden', '');
      });
      ios.forEach((s) => {
        if (s.dataset.mwIo === id) s.removeAttribute('hidden');
        else                       s.setAttribute('hidden', '');
      });
      insps.forEach((s) => {
        if (s.dataset.mwInsp === id) s.removeAttribute('hidden');
        else                         s.setAttribute('hidden', '');
      });
      if (emptyStream) emptyStream.setAttribute('hidden', '');
      if (emptyIo) emptyIo.setAttribute('hidden', '');
      if (emptyInsp) emptyInsp.setAttribute('hidden', '');

      const card = root.querySelector(`[data-mw-scenario="${CSS.escape(id)}"]`);
      const title = card && card.querySelector('.mw-scn-title');
      if (activeLabel && title) activeLabel.textContent = title.textContent || id;
    }

    tabs.forEach((t) => t.addEventListener('click', () => show(t.dataset.mwTab)));
    cards.forEach((c) => c.addEventListener('click', () => {
      selectScenario(c.dataset.mwScenario);
      show('stream');
    }));

    show('scenarios');

    /* Deep-link API for the search client (mobile): select a scenario, switch
       to the Stream tab, then scroll + flash a specific exchange. */
    function flashStep(el) {
      el.classList.remove('ocs-flash');
      void el.offsetWidth;
      el.classList.add('ocs-flash');
      const clear = () => el.classList.remove('ocs-flash');
      el.addEventListener('animationend', clear, { once: true });
      window.setTimeout(clear, 3600);
    }

    function openStep(scenarioId, stepId) {
      selectScenario(scenarioId);
      show('stream');
      const stream = root.querySelector(`[data-mw-stream="${CSS.escape(scenarioId)}"]`);
      if (!stream) return;
      const target = stream.querySelector(`[data-step-id="${CSS.escape(stepId)}"]`);
      if (target) {
        window.requestAnimationFrame(() => {
          target.scrollIntoView({ block: 'center', behavior: 'smooth' });
          flashStep(target);
        });
      }
    }

    window.__ocDemoMobile = { openStep };
  })();
</script>
