---
/**
 * Roadmap timeline — vertical stack (shipped → in-progress → planned →
 * backlog) rendered on /changelog. Item data is pulled from Linear at
 * build time by scripts/gen-roadmap.mjs and read here via the fs-backed
 * loader so a missing roadmap.json just yields an empty roadmap (and
 * the component renders nothing) instead of breaking the build.
 *
 * Vote counts are hydrated client-side from GET /api/votes?ids=…
 * after first paint. Clicking a vote button POSTs /api/votes/<id>;
 * the Worker dedups per-IP/day server-side. `localStorage` mirrors
 * the server's "already voted" verdict for instant UI feedback on
 * subsequent visits.
 */
import { loadRoadmap, type RoadmapBucket, type RoadmapItem } from "../data/roadmap-types";

const roadmap = loadRoadmap();

const BUCKETS: { key: RoadmapBucket; label: string; blurb: string }[] = [
  { key: "shipped",     label: "Shipped",     blurb: "What's already live in production." },
  { key: "in-progress", label: "In progress", blurb: "Open Linear issues actively being worked." },
  { key: "planned",     label: "Planned",     blurb: "Scoped into a future milestone — design or spec in flight." },
  { key: "backlog",     label: "Backlog",     blurb: "Top-voted asks not yet scoped. Triaged quarterly; high votes get promoted." },
];

function bucketDate(items: RoadmapItem[]): string | null {
  // Show the earliest target date in the bucket as a hint; null when
  // none of the items have a milestone targetDate.
  const dates = items.map((i) => i.targetDate).filter((d): d is string => !!d);
  if (!dates.length) return null;
  return dates.sort()[0];
}

const hasAny = BUCKETS.some((b) => roadmap.items[b.key].length > 0);
const fmtDate = (iso: string) =>
  new Date(iso).toLocaleDateString("en-US", { month: "short", year: "numeric" });
---

<section class="roadmap" aria-label="opchain roadmap">
  <header class="roadmap-head">
    <span class="roadmap-eyebrow">where we're going</span>
    <h2>Roadmap</h2>
    <p>
      Shipped, in flight, and what's queued. Items come from Linear in real
      time — anyone can request a feature with the form below; the team
      triages and promotes asks onto the public roadmap from there.
    </p>
  </header>

  {!hasAny && (
    <div class="roadmap-empty">
      <p>
        No roadmap items published yet. {roadmap.note ? <em>({roadmap.note})</em> : null}
        Use the form below to send the first one — it lands as a Linear
        ticket the team will triage on the next pass.
      </p>
    </div>
  )}

  {hasAny && (
    <div class="timeline">
      {BUCKETS.map(({ key, label, blurb }) => {
        const items = roadmap.items[key];
        if (!items.length) return null;
        const date = bucketDate(items);
        return (
          <article class="release-block" data-state={key}>
            <div class="release-head">
              <span class="release-version">{label}</span>
              <span class="release-state" data-state={key}>{key}</span>
              {date && <span class="release-date">est. {fmtDate(date)}</span>}
            </div>
            <p class="release-blurb">{blurb}</p>

            <div class="item-list">
              {items.map((it) => (
                <div class="item-card" data-issue-id={it.id}>
                  <div class="item-meta">
                    <div class="item-title-row">
                      <span class="item-title">{it.title}</span>
                      {it.milestone && <span class="item-tag">{it.milestone}</span>}
                      {it.labels.includes("community-submitted") && (
                        <span class="item-tag community">community</span>
                      )}
                    </div>
                    {it.blurb && <p class="item-blurb">{it.blurb}</p>}
                    <a class="item-linear" href={it.url} target="_blank" rel="noopener">{it.id} ↗</a>
                  </div>
                  {key === "shipped" ? (
                    <span class="vote-placeholder">shipped</span>
                  ) : (
                    <button
                      class="vote-btn"
                      type="button"
                      data-vote-target={it.id}
                      aria-label={`Vote for ${it.title}`}
                    >
                      <span class="arrow" aria-hidden="true">▲</span>
                      <span class="count" data-vote-count>—</span>
                      <span class="label" data-vote-label>vote</span>
                    </button>
                  )}
                </div>
              ))}
            </div>
          </article>
        );
      })}
    </div>
  )}
</section>

<script>
  // ── Hydrate vote counts + handle clicks ────────────────────────
  // Single batched GET on load to fill in all counts. Subsequent
  // clicks POST per-issue. localStorage mirrors the server's
  // "alreadyVoted" verdict so a refreshed page reflects the user's
  // state instantly (without a network round-trip).
  (async () => {
    const buttons = Array.from(
      document.querySelectorAll<HTMLButtonElement>("[data-vote-target]"),
    );
    if (!buttons.length) return;

    const ids = buttons.map((b) => b.dataset.voteTarget!).filter(Boolean);
    const setCount = (btn: HTMLButtonElement, n: number) => {
      const el = btn.querySelector<HTMLElement>("[data-vote-count]");
      if (el) el.textContent = String(n);
    };
    const setVoted = (btn: HTMLButtonElement, voted: boolean) => {
      btn.classList.toggle("voted", voted);
      const label = btn.querySelector<HTMLElement>("[data-vote-label]");
      if (label) label.textContent = voted ? "voted" : "vote";
    };
    const lsKey = (id: string) => `opchain-roadmap-voted:${id}`;

    // Initial state: read localStorage, paint "voted" mirror.
    for (const btn of buttons) {
      const id = btn.dataset.voteTarget!;
      if (localStorage.getItem(lsKey(id)) === "1") setVoted(btn, true);
    }

    // Batched count fetch.
    try {
      const res = await fetch(`/api/votes?ids=${encodeURIComponent(ids.join(","))}`, {
        headers: { Accept: "application/json" },
      });
      if (res.ok) {
        const data = (await res.json()) as { counts: Record<string, number> };
        for (const btn of buttons) {
          const id = btn.dataset.voteTarget!;
          setCount(btn, data.counts[id] ?? 0);
        }
      } else {
        for (const btn of buttons) setCount(btn, 0);
      }
    } catch {
      for (const btn of buttons) setCount(btn, 0);
    }

    // Click handler.
    for (const btn of buttons) {
      btn.addEventListener("click", async () => {
        const id = btn.dataset.voteTarget!;
        // Tiny optimistic bump — server may correct on response.
        const countEl = btn.querySelector<HTMLElement>("[data-vote-count]");
        const previous = parseInt(countEl?.textContent || "0", 10) || 0;
        const optimistic = btn.classList.contains("voted") ? previous : previous + 1;
        setCount(btn, optimistic);
        setVoted(btn, true);
        btn.disabled = true;

        try {
          const res = await fetch(`/api/votes/${encodeURIComponent(id)}`, {
            method: "POST",
            headers: { "Content-Type": "application/json" },
            body: JSON.stringify({}),
          });
          if (res.ok) {
            const data = (await res.json()) as {
              ok: boolean;
              count: number;
              alreadyVoted?: boolean;
            };
            setCount(btn, data.count);
            // Server is the source of truth — sync localStorage to it.
            localStorage.setItem(lsKey(id), "1");
            setVoted(btn, true);
          } else {
            // Revert on error.
            setCount(btn, previous);
            setVoted(btn, localStorage.getItem(lsKey(id)) === "1");
          }
        } catch {
          setCount(btn, previous);
        } finally {
          btn.disabled = false;
        }
      });
    }
  })();
</script>

<style>
  .roadmap {
    max-width: 960px;
    margin: 0 auto 4rem;
    padding: 1rem 1.5rem 0;
  }
  .roadmap-head { text-align: left; margin-bottom: 1.75rem; }
  .roadmap-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--subtle);
  }
  .roadmap-head h2 {
    font-family: var(--font-display);
    font-weight: 600;
    font-size: clamp(1.5rem, 3vw, 2rem);
    letter-spacing: var(--ls-tight);
    margin: 0.4rem 0 0.5rem;
    color: var(--text);
    line-height: 1.1;
  }
  .roadmap-head p {
    color: var(--muted);
    max-width: 60ch;
    font-size: var(--fs-sm);
    margin: 0;
    line-height: var(--lh-snug);
  }

  .roadmap-empty {
    padding: 1.5rem;
    background: var(--card);
    border: 0.5px dashed var(--border);
    border-radius: var(--r-md);
    color: var(--muted);
    font-size: var(--fs-sm);
  }
  .roadmap-empty em { color: var(--subtle); }

  .timeline {
    position: relative;
    padding-left: 2.5rem;
  }
  .timeline::before {
    content: "";
    position: absolute;
    left: 11px; top: 0; bottom: 0;
    width: 1px;
    background: linear-gradient(180deg,
      var(--accent) 0%,
      var(--accent) 8%,
      var(--info) 30%,
      var(--info) 55%,
      var(--subtle) 75%,
      transparent 100%);
  }
  .release-block {
    position: relative;
    margin-bottom: 2.5rem;
  }
  .release-block:last-child { margin-bottom: 0; }
  .release-block::before {
    content: "";
    position: absolute;
    left: -2.5rem;
    top: 4px;
    width: 24px; height: 24px;
    border-radius: 50%;
    border: 1px solid var(--release-dot-color, var(--subtle));
    background: var(--bg);
    box-shadow:
      0 0 0 4px var(--bg),
      0 0 0 5px var(--release-dot-color, var(--subtle));
    z-index: 1;
  }
  .release-block::after {
    content: "";
    position: absolute;
    left: -2.5rem;
    top: 4px;
    width: 24px; height: 24px;
    border-radius: 50%;
    background: var(--release-dot-fill, transparent);
    transform: scale(0.45);
    z-index: 2;
  }
  .release-block[data-state="shipped"]      { --release-dot-color: var(--accent); --release-dot-fill: var(--accent); }
  .release-block[data-state="in-progress"]  { --release-dot-color: var(--info); --release-dot-fill: var(--info); }
  .release-block[data-state="planned"]      { --release-dot-color: var(--info); --release-dot-fill: transparent; }
  .release-block[data-state="backlog"]      { --release-dot-color: var(--subtle); --release-dot-fill: transparent; }

  .release-head {
    display: flex; align-items: baseline; gap: 0.65rem;
    margin-bottom: 0.4rem;
    flex-wrap: wrap;
  }
  .release-version {
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    letter-spacing: var(--ls-tight);
    color: var(--text);
    line-height: 1;
  }
  .release-state {
    font-family: var(--font-mono);
    font-size: 9.5px;
    font-weight: 700;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    padding: 3px 8px;
    border-radius: var(--r-pill);
  }
  /* Filled-on-obsidian for shipped (clears AA at 9.5px bold);
     outlined for everything else. */
  .release-state[data-state="shipped"]      { color: var(--obsidian); background: var(--accent); border: 0; }
  :global([data-theme="light"]) .release-state[data-state="shipped"] { background: var(--ember); }
  .release-state[data-state="in-progress"]  { color: var(--info); border: 0.5px solid var(--info); background: var(--info-dim); }
  .release-state[data-state="planned"]      { color: var(--info); border: 0.5px solid var(--info); background: transparent; }
  .release-state[data-state="backlog"]      { color: var(--text); border: 0.5px solid var(--subtle); background: transparent; }
  .release-date {
    font-family: var(--font-mono);
    font-size: 11px;
    color: var(--subtle);
    letter-spacing: var(--ls-wide);
  }

  .release-blurb {
    color: var(--muted);
    font-size: var(--fs-sm);
    max-width: 60ch;
    margin: 0 0 1rem;
    line-height: var(--lh-snug);
  }

  .item-list { display: grid; gap: 0.55rem; }
  .item-card {
    background: var(--card);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 0.85rem 1rem;
    display: grid;
    grid-template-columns: 1fr auto;
    align-items: center;
    gap: 1rem;
    transition: border-color var(--dur-fast) var(--ease-standard);
  }
  .item-card:hover { border-color: var(--accent); }
  .item-meta { min-width: 0; }
  .item-title-row {
    display: flex; align-items: center; gap: 0.5rem;
    margin-bottom: 2px;
    flex-wrap: wrap;
  }
  .item-title {
    font-family: var(--font-display);
    font-size: var(--fs-base);
    font-weight: 600;
    color: var(--text);
    letter-spacing: 0.01em;
  }
  .item-tag {
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    padding: 2px 6px;
    border-radius: var(--r-xs);
    color: var(--muted);
    border: 0.5px solid var(--border);
  }
  .item-tag.community {
    color: var(--accent);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .item-blurb {
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: var(--lh-snug);
    margin: 0;
  }
  .item-linear {
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--advisor);
    text-decoration: none;
    letter-spacing: var(--ls-wide);
    margin-top: 4px;
    display: inline-block;
  }
  .item-linear:hover { color: var(--text); }

  .vote-btn {
    display: inline-flex; flex-direction: column; align-items: center;
    gap: 2px;
    min-width: 52px;
    min-height: 48px;
    padding: 8px 10px;
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    color: var(--text);
    font-family: var(--font-mono);
    cursor: pointer;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
  }
  .vote-btn:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
    transform: translateY(-1px);
  }
  .vote-btn:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .vote-btn[disabled] { opacity: 0.6; cursor: progress; }
  .vote-btn.voted {
    border-color: var(--accent);
    background: var(--accent-dim);
    color: var(--accent);
  }
  .vote-btn .arrow { font-size: 14px; line-height: 1; }
  .vote-btn .count { font-size: 13px; font-weight: 700; line-height: 1; color: var(--text); }
  .vote-btn.voted .count { color: var(--accent); }
  .vote-btn .label {
    font-size: 8.5px;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--subtle);
    line-height: 1;
  }
  .vote-btn.voted .label { color: var(--accent); }

  .vote-placeholder {
    min-width: 52px;
    text-align: center;
    font-family: var(--font-mono);
    font-size: 9px;
    color: var(--subtle);
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
  }
</style>
