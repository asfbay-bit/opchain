---
type Variant = "primary" | "outline" | "ghost";
type Size = "sm" | "md" | "lg";

interface Props {
  variant?: Variant;
  size?: Size;
  href?: string;
  type?: "button" | "submit" | "reset";
  disabled?: boolean;
  class?: string;
  /** aria-label, forwarded when present. */
  label?: string;
}

const {
  variant = "primary",
  size = "md",
  href,
  type = "button",
  disabled = false,
  class: className = "",
  label,
} = Astro.props;

const classes = ["btn", `btn-${variant}`, `btn-${size}`, className]
  .filter(Boolean)
  .join(" ");
---

{href ? (
  <a href={href} class={classes} aria-label={label} aria-disabled={disabled || undefined}>
    <slot />
  </a>
) : (
  <button type={type} class={classes} disabled={disabled} aria-label={label}>
    <slot />
  </button>
)}

<style>
  .btn {
    font-family: var(--font-mono);
    font-weight: 500;
    letter-spacing: var(--ls-wide);
    border-radius: var(--r-sm);
    cursor: pointer;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.4rem;
    transition:
      background var(--dur-fast) var(--ease-standard),
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
    white-space: nowrap;
  }
  .btn-sm { font-size: 10px; padding: 0.4rem 0.75rem; }
  .btn-md { font-size: 11px; padding: 0.55rem 1.1rem; }
  .btn-lg { font-size: 12px; padding: 0.7rem 1.4rem; }

  .btn-primary { background: var(--accent); color: var(--obsidian); border: none; }
  .btn-primary:hover:not([disabled]):not([aria-disabled="true"]) {
    background: var(--accent-hover);
    color: var(--obsidian);
  }
  /* B-10: light --accent (#d95010, L=0.206) only gives 4.33:1 with --obsidian.
     --ember (#e05c18, L=0.235) is the constant dark-mode value — gives 4.84:1 ✓.
     :global() needed so [data-theme="light"] targets <html>, not the component root. */
  :global([data-theme="light"]) .btn-primary { background: var(--ember); }

  .btn-outline {
    background: transparent;
    color: var(--accent);
    border: 0.5px solid var(--accent);
  }
  .btn-outline:hover:not([disabled]):not([aria-disabled="true"]) {
    background: var(--accent-dim);
  }
  /* B-10: --accent as text on light bg = 3.50:1 ✗. --accent-hover = 5.22:1 ✓. */
  :global([data-theme="light"]) .btn-outline { color: var(--accent-hover); border-color: var(--accent-hover); }

  .btn-ghost {
    background: transparent;
    color: var(--muted);
    border: 0.5px solid transparent;
  }
  .btn-ghost:hover:not([disabled]):not([aria-disabled="true"]) {
    color: var(--text);
    border-color: var(--border);
  }

  .btn[disabled] {
    opacity: 0.4;
    cursor: not-allowed;
  }
  .btn[aria-disabled="true"] {
    opacity: 0.4;
    cursor: not-allowed;
    pointer-events: none;
  }
</style>
