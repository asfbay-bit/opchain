---
/**
 * Feedback dialog. Mounted once in Base.astro; opened by any
 * [data-feedback-launcher] in the document (header button, inline
 * "send feedback" links, etc.). POSTs to /api/feedback.
 */
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
import Textarea from "./ui/Textarea.astro";
import Alert from "./ui/Alert.astro";
---

<dialog class="feedback-dialog" id="feedback-dialog" aria-labelledby="feedback-title">
  <form method="dialog" class="feedback-form" id="feedback-form" autocomplete="off">
    <header class="feedback-head">
      <h2 id="feedback-title">Send feedback</h2>
      <button type="button" class="close" id="feedback-close" aria-label="Close">×</button>
    </header>

    <label class="field">
      <span class="label">Type</span>
      <select name="type" required>
        <option value="bug">Bug</option>
        <option value="feature">Feature request</option>
        <option value="improvement">Improvement</option>
        <option value="general" selected>General</option>
      </select>
    </label>

    <label class="field">
      <span class="label">Subject</span>
      <Input name="title" required placeholder="Tell us what you're writing about…" />
    </label>

    <label class="field">
      <span class="label">Details</span>
      <Textarea name="description" rows={4} placeholder="Give us as much or as little detail as you'd like…" />
    </label>

    <label class="field">
      <span class="label">Email <span class="opt">(required if you'd like a response)</span></span>
      <Input type="email" name="email" placeholder="you@example.com" autocomplete="email" />
    </label>

    <div class="status" id="feedback-status" hidden>
      <Alert variant="info"><span id="feedback-status-msg"></span></Alert>
    </div>

    <footer class="feedback-foot">
      <Button type="submit" variant="primary" label="Submit">submit</Button>
    </footer>
  </form>
</dialog>

<script>
  // Bind to every [data-feedback-launcher] in the document so multiple
  // entry points (the floating pill in this component AND the mobile
  // feedback icon in Header.astro) open the same dialog.
  const launchers = document.querySelectorAll<HTMLButtonElement>("[data-feedback-launcher]");
  const dialog   = document.getElementById("feedback-dialog") as HTMLDialogElement | null;
  const form     = document.getElementById("feedback-form")  as HTMLFormElement | null;
  const closeBtn = document.getElementById("feedback-close") as HTMLButtonElement | null;
  const statusEl = document.getElementById("feedback-status") as HTMLElement | null;
  const statusMsg= document.getElementById("feedback-status-msg") as HTMLElement | null;

  if (launchers.length && dialog && form) {
    const open = () => {
      if (statusEl) statusEl.hidden = true;
      form.reset();
      // When the modal is opened from a /skills/<id> detail page, prefill
      // the Subject with [<id>] so the resulting Linear issue is grouped
      // with the right skill at a glance. The user can edit / delete it.
      const skillMatch = location.pathname.match(/^\/skills\/([^/]+)\/?$/);
      if (skillMatch) {
        const subjectInput = form.querySelector('input[name="title"]') as HTMLInputElement | null;
        if (subjectInput) subjectInput.value = `[${skillMatch[1]}] `;
      }
      if (typeof dialog.showModal === "function") dialog.showModal();
      else dialog.setAttribute("open", "");
    };
    launchers.forEach((btn) => btn.addEventListener("click", open));

    closeBtn?.addEventListener("click", () => dialog.close());

    form.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      const fd = new FormData(form);
      const payload: Record<string, unknown> = Object.fromEntries(fd.entries());
      // Strip empty optional fields so Zod's `.optional()` behaves.
      for (const k of ["description", "email"]) {
        if (payload[k] === "") delete payload[k];
      }
      if (statusMsg && statusEl) {
        statusMsg.textContent = "Sending…";
        statusEl.hidden = false;
      }
      try {
        const res = await fetch("/api/feedback", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify(payload),
        });
        const body = await res.json().catch(() => ({}));
        if (res.ok) {
          // Dry-run on staging returns a synthetic id; treat the same as
          // a real success so the staging UX matches prod.
          if (statusMsg) statusMsg.textContent = "Thanks — logged as " + (body.id || "an issue") + ".";
          setTimeout(() => dialog.close(), 1500);
        } else {
          // Soften server-side error codes into end-user copy. The raw
          // server `error` strings are developer-facing.
          let msg: string;
          switch (body.code) {
            case "not_configured":
            case "upstream_unreachable":
            case "upstream_error":
              msg = "Feedback isn't available right now — please try again later.";
              break;
            case "invalid_body":
            case "invalid_json":
              msg = body.error || "Please check the form and try again.";
              break;
            default:
              msg = body.error || `Failed (HTTP ${res.status}).`;
          }
          if (statusMsg) statusMsg.textContent = msg;
        }
      } catch {
        if (statusMsg) statusMsg.textContent = "Network error — please try again.";
      }
    });
  }
</script>

<style>
  .feedback-dialog {
    /* Lock to viewport center regardless of scroll position or surrounding
       layout. `<dialog>::showModal` centers by default in spec, but some
       browsers / page contexts (large pages, sticky headers) can drift —
       inset:0 + margin:auto pins it explicitly. */
    position: fixed;
    inset: 0;
    margin: auto;
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    background: var(--surface);
    color: var(--text);
    padding: 0;
    max-width: 32rem;
    width: calc(100% - 2rem);
    max-height: calc(100vh - 2rem);
    box-shadow: var(--shadow-xl);
  }
  .feedback-dialog::backdrop {
    background: rgba(0, 0, 0, 0.45);
  }

  .feedback-form {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    padding: 1.25rem;
  }
  .feedback-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 0.25rem;
  }
  .feedback-head h2 {
    font-family: var(--font-display);
    font-size: var(--fs-lg);
    font-weight: 600;
    margin: 0;
    color: var(--text);
  }
  .close {
    background: transparent;
    border: none;
    color: var(--muted);
    font-size: 20px;
    line-height: 1;
    cursor: pointer;
    padding: 0.1rem 0.4rem;
  }
  .close:hover { color: var(--text); }

  .field {
    display: flex;
    flex-direction: column;
    gap: 0.3rem;
  }
  .label {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--subtle);
  }
  .opt { text-transform: none; font-style: italic; }

  .field select {
    padding: 0.55rem 0.85rem;
    border-radius: var(--r-sm);
    border: 0.5px solid var(--border);
    background: var(--card);
    color: var(--text);
    font-family: var(--font-body);
    font-size: var(--fs-base);
  }
  .field select:focus {
    outline: none;
    border-color: var(--accent);
    box-shadow: 0 0 0 2px var(--accent-dim);
  }

  .feedback-foot {
    display: flex;
    justify-content: flex-end;
    margin-top: 0.25rem;
  }
</style>
