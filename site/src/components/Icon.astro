  "zap":           '<polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>',
  "puzzle":        '<path d="M19.44 7.85c-.05.32.06.65.29.88l1.57 1.57c.47.47.7 1.09.7 1.7 0 .62-.23 1.24-.7 1.71l-1.61 1.6c-.22.23-.53.34-.84.28-.47-.07-.8-.48-.97-.92a2.5 2.5 0 1 0-3.21 3.2c.45.17.85.5.92.97.06.31-.05.62-.27.84l-1.61 1.6c-.47.47-1.09.71-1.71.71-.61 0-1.23-.24-1.7-.7l-1.57-1.57a1.03 1.03 0 0 0-.88-.29c-.49.07-.84.5-1.02.97a2.5 2.5 0 1 1-3.23-3.24c.46-.18.89-.53.97-1.02a1.03 1.03 0 0 0-.29-.88L2.7 13.7A2.4 2.4 0 0 1 2 12c0-.62.24-1.23.7-1.7L4.23 8.77c.24-.24.58-.36.92-.3.51.07.88.52 1.07 1a2.5 2.5 0 1 0 3.26-3.25c-.48-.2-.93-.56-1.01-1.07a1.03 1.03 0 0 1 .3-.92L10.3 2.7c.47-.47 1.08-.7 1.7-.7.61 0 1.23.23 1.7.7l1.57 1.57c.23.23.56.34.88.29.49-.07.84-.5 1.02-.97a2.5 2.5 0 1 1 3.23 3.24c-.46.18-.89.52-.97 1.02Z"/>',
