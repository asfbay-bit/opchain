---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import SearchPalette from "./SearchPalette.astro";
import Icon from "./Icon.astro";
import { defaultFor } from "../lib/flags/build-defaults";

interface Props {
  /** Route of the current page (e.g. "/architecture"). Underlines the matching nav group. */
  active?: string;
}

const demoEnabled = defaultFor("site.feature.demo-page") as boolean;
const { active = "/" } = Astro.props;
const CURRENT_RELEASE = "v1.5";
const CURRENT_RELEASE_HREF = "/changelog#v1-5";

interface DropdownItem {
  href: string;
  label: string;
  blurb?: string;
  badge?: "new" | "tool" | string; // string = count chip e.g. "14"
}
interface NavGroup {
  id: "product" | "pipeline" | "resources";
  label: string;
  badge?: "new" | "tool";
  items: DropdownItem[];
}

// Pages that live under each group. Used to decide which group's
// label gets the active-section underline.
const groups: NavGroup[] = [
  {
    id: "product",
    label: "Product",
    items: [
      { href: "/architecture", label: "Architecture", blurb: "Skillchain & checkpoint protocol with diagrams." },
      { href: "/skills",       label: "Skills",       blurb: "Every skill, role-tagged, filterable." },
      { href: "/coverage",     label: "Coverage",     blurb: "Every supported language, framework, and deploy target." },
      { href: "/compare",      label: "Compare",      blurb: "opchain vs Codex, Devin, Cursor, Copilot, Zed, and Claude." },
      { href: "/for-agencies", label: "For agencies", blurb: "Run opchain as a per-client delivery pipeline." },
      { href: "/changelog",    label: "Changelog",    blurb: "Release history.", badge: "new" },
    ],
  },
  {
    id: "pipeline",
    label: "Pipeline",
    items: [
      { href: "/pipeline-builder", label: "Pipeline Builder", blurb: "Answer 4 questions, get a curated stack." },
      { href: "/ai-recipes", label: "AI Recipes", blurb: "Multi-skill walkthroughs for AI features." },
      ...(demoEnabled ? [{ href: "/demo", label: "Demo", blurb: "Walkthroughs of opchain end-to-end." }] : []),
      { href: "/showcase", label: "Showcase", blurb: "Projects shipped with opchain." },
      { href: "/status",   label: "Status",   blurb: "Live API health from /api/health." },
    ],
  },
  {
    id: "resources",
    label: "Resources",
    items: [
      { href: "/blog",     label: "Blog",            blurb: "Releases and engineering notes." },
      { href: "/glossary", label: "Glossary",        blurb: "Plain-English definitions for every opchain term." },
      { href: "/uses",     label: "How it's built",  blurb: "opchain.dev built with opchain — the recursion." },
      { href: "/security", label: "Security",        blurb: "Threat model, dependency posture, secrets." },
      { href: "/privacy",  label: "Privacy",         blurb: "PostHog scope, cookies, consent." },
    ],
  },
];

function isActiveGroup(g: NavGroup): boolean {
  if (active === "/") return false;
  return g.items.some((it) => active.startsWith(it.href));
}

const GROUP_ICONS: Record<NavGroup["id"], "puzzle" | "zap" | "book-open"> = {
  product: "puzzle",
  pipeline: "zap",
  resources: "book-open",
};
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="site-header-brand" href="/" aria-label="opchain home">
      <Logo size={28} />
      <span class="logo">opchain</span>
    </a>

    <nav class="nav" aria-label="Primary">
      {groups.map((g) => (
        <div class:list={["nav-group", { "is-active-section": isActiveGroup(g) }]} data-group={g.id}>
          <button
            class:list={["nav-link", { "is-active": isActiveGroup(g) }]}
            type="button"
            aria-haspopup="true"
            aria-expanded="false"
            aria-controls={`dropdown-${g.id}`}
          >
            {g.label}
            <span class="nav-badge tool" aria-hidden="true">
              <Icon name={GROUP_ICONS[g.id]} size={11} />
            </span>
            {g.badge === "new" && <span class="nav-badge new">NEW</span>}
            <span class="nav-caret" aria-hidden="true"></span>
          </button>
          <div class="dropdown" id={`dropdown-${g.id}`} role="menu" aria-label={g.label}>
            <div class="dropdown-section-head">{g.label.toLowerCase()}</div>
            {g.items.map((it) => (
              <a class="dropdown-item" href={it.href} role="menuitem">
                <span class="dropdown-label">
                  {it.label}
                  {it.badge === "new" && <span class="pillet new">NEW</span>}
                  {it.badge === "tool" && <span class="pillet tool">TOOL</span>}
                  {typeof it.badge === "string" && it.badge !== "new" && it.badge !== "tool" && (
                    <span class="pillet count">{it.badge}</span>
                  )}
                </span>
                {it.blurb && <span class="dropdown-blurb">{it.blurb}</span>}
              </a>
            ))}
          </div>
        </div>
      ))}
      <a
        class:list={["nav-install", { "is-active": active === "/install" }]}
        href="/install"
      >install</a>
    </nav>

    <div class="right-cluster">
      <!-- Search trigger (looks like an input; opens the global ⌘K palette).
           Real <input> with placeholder so it reads as search; not a pill. -->
      <label class="search-trigger" aria-label="Search opchain">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        <input
          type="text"
          placeholder="Search pages, skills, glossary…"
          data-palette-trigger
          autocomplete="off"
          spellcheck="false"
        />
        <kbd class="search-kbd">⌘K</kbd>
      </label>

      <a
        class="version-chip"
        href={CURRENT_RELEASE_HREF}
        title={`${CURRENT_RELEASE} · checking live Worker health`}
        aria-label={`${CURRENT_RELEASE} release; checking live Worker health`}
        data-version-chip
        data-state="loading"
        data-release-version={CURRENT_RELEASE}
      >
        <span class="vchip-tag">{CURRENT_RELEASE}</span>
        <span class="vchip-dot" aria-hidden="true"></span>
      </a>

      <!-- Feedback button — text label (was a chat-bubble icon).
           Preserves [data-feedback-launcher] so FeedbackWidget binds. -->
      <button
        type="button"
        class="util-feedback"
        data-feedback-launcher
        aria-label="Send feedback"
      >feedback</button>

      <ThemeToggle />
    </div>

    <button
      type="button"
      class="nav-burger"
      id="nav-burger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="nav-burger-line" aria-hidden="true"></span>
      <span class="nav-burger-line" aria-hidden="true"></span>
      <span class="nav-burger-line" aria-hidden="true"></span>
    </button>
  </div>

  <div
    class="nav-drawer"
    id="nav-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    hidden
  >
    <button
      type="button"
      class="nav-drawer-scrim"
      aria-label="Close navigation menu"
      tabindex="-1"
    ></button>
    <nav class="nav-drawer-panel" aria-label="Primary, mobile">
      <a class="nav-drawer-primary" href="/install">install opchain</a>
      <button class="nav-drawer-search" type="button" data-palette-trigger>
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <circle cx="11" cy="11" r="7"/>
          <path d="m21 21-4.3-4.3"/>
        </svg>
        search opchain
      </button>
      {groups.map((g) => (
        <>
          <h3 class="nav-drawer-group">{g.label}</h3>
          {g.items.map((it) => (
            <a
              href={it.href}
              class:list={["nav-drawer-link", { active: active.startsWith(it.href) }]}
            >{it.label}</a>
          ))}
        </>
      ))}
    </nav>
  </div>

  <!-- Global ⌘K palette — single instance per page. -->
  <SearchPalette />
</header>

<script>
  // ── Dropdown controller ────────────────────────────────────────
  // Hover opens, click toggles, Esc / outside-click closes. Only one
  // group open at a time.
  document.querySelectorAll<HTMLDivElement>(".nav-group").forEach((group) => {
    const trigger = group.querySelector<HTMLButtonElement>(".nav-link");
    if (!trigger) return;

    const setOpen = (open: boolean) => {
      group.classList.toggle("is-open", open);
      trigger.setAttribute("aria-expanded", open ? "true" : "false");
    };

    trigger.addEventListener("click", (e) => {
      e.preventDefault();
      const open = !group.classList.contains("is-open");
      // Close siblings before opening this one.
      document.querySelectorAll<HTMLDivElement>(".nav-group.is-open").forEach((g) => {
        if (g !== group) {
          g.classList.remove("is-open");
          g.querySelector(".nav-link")?.setAttribute("aria-expanded", "false");
        }
      });
      setOpen(open);
    });

    // Hover-to-open on pointer devices (no-op on touch — click handles it).
    group.addEventListener("pointerenter", (e) => {
      if (e.pointerType === "mouse") {
        document.querySelectorAll<HTMLDivElement>(".nav-group.is-open").forEach((g) => {
          if (g !== group) {
            g.classList.remove("is-open");
            g.querySelector(".nav-link")?.setAttribute("aria-expanded", "false");
          }
        });
        setOpen(true);
      }
    });
    group.addEventListener("pointerleave", (e) => {
      if (e.pointerType === "mouse") setOpen(false);
    });
  });

  // Click outside any group closes all dropdowns.
  document.addEventListener("click", (e) => {
    const target = e.target as Element | null;
    if (!target?.closest(".nav-group")) {
      document.querySelectorAll<HTMLDivElement>(".nav-group.is-open").forEach((g) => {
        g.classList.remove("is-open");
        g.querySelector(".nav-link")?.setAttribute("aria-expanded", "false");
      });
    }
  });
  // Esc closes everything.
  document.addEventListener("keydown", (e) => {
    if (e.key !== "Escape") return;
    document.querySelectorAll<HTMLDivElement>(".nav-group.is-open").forEach((g) => {
      g.classList.remove("is-open");
      g.querySelector<HTMLButtonElement>(".nav-link")?.setAttribute("aria-expanded", "false");
    });
  });

  // ── Live Worker health for the release chip dot ───────────────
  const versionChip = document.querySelector<HTMLAnchorElement>("[data-version-chip]");
  type HealthPayload = {
    ok?: boolean;
    status?: string;
  };

  function setVersionChip(state: "loading" | "ok" | "degraded" | "down", title: string) {
    if (!versionChip) return;
    versionChip.dataset.state = state;
    versionChip.title = title;
    versionChip.setAttribute("aria-label", title);
  }

  async function refreshVersionChip() {
    if (!versionChip) return;
    const releaseVersion = versionChip.dataset.releaseVersion || "current release";
    setVersionChip("loading", `${releaseVersion} · checking live Worker health`);

    try {
      const res = await fetch("/api/health", { cache: "no-store" });
      const contentType = res.headers.get("content-type") || "";
      let body: HealthPayload = {};
      if (contentType.includes("application/json")) {
        try { body = await res.json(); } catch { body = {}; }
      }

      const reportsHealthy = body.ok === true || body.status === "ok";
      if (res.ok && reportsHealthy) {
        setVersionChip("ok", `${releaseVersion} · /api/health ok`);
      } else if (res.ok) {
        setVersionChip("degraded", `${releaseVersion} · health payload did not report ok`);
      } else {
        setVersionChip("down", `${releaseVersion} · /api/health returned HTTP ${res.status}`);
      }
    } catch {
      const releaseVersion = versionChip.dataset.releaseVersion || "current release";
      setVersionChip("down", `${releaseVersion} · /api/health could not be reached`);
    }
  }

  refreshVersionChip();
  window.setInterval(() => {
    if (document.visibilityState === "visible") refreshVersionChip();
  }, 60_000);

  // ── Mobile drawer (unchanged from previous Header) ─────────────
  const burger = document.getElementById("nav-burger") as HTMLButtonElement | null;
  const drawer = document.getElementById("nav-drawer") as HTMLDivElement | null;
  if (burger && drawer) {
    const scrim = drawer.querySelector(".nav-drawer-scrim") as HTMLButtonElement | null;
    const links = drawer.querySelectorAll<HTMLAnchorElement>(".nav-drawer-link");
    const firstLink = links[0];
    const lastLink = links[links.length - 1];

    const open = () => {
      drawer.hidden = false;
      requestAnimationFrame(() => drawer.classList.add("is-open"));
      burger.setAttribute("aria-expanded", "true");
      document.documentElement.style.overflow = "hidden";
      firstLink?.focus();
    };
    const close = (returnFocus = true) => {
      drawer.classList.remove("is-open");
      burger.setAttribute("aria-expanded", "false");
      document.documentElement.style.overflow = "";
      window.setTimeout(() => { drawer.hidden = true; }, 180);
      if (returnFocus) burger.focus();
    };

    burger.addEventListener("click", () => { drawer.hidden ? open() : close(); });
    scrim?.addEventListener("click", () => close());
    links.forEach((a) => a.addEventListener("click", () => close(false)));
    drawer.querySelector(".nav-drawer-primary")?.addEventListener("click", () => close(false));
    drawer.querySelector(".nav-drawer-search")?.addEventListener("click", () => close(false));

    document.addEventListener("keydown", (e) => {
      if (drawer.hidden) return;
      if (e.key === "Escape") { e.preventDefault(); close(); }
      else if (e.key === "Tab") {
        if (e.shiftKey && document.activeElement === firstLink) {
          e.preventDefault();
          lastLink?.focus();
        } else if (!e.shiftKey && document.activeElement === lastLink) {
          e.preventDefault();
          firstLink?.focus();
        }
      }
    });

    const mq = window.matchMedia("(min-width: 980px)");
    mq.addEventListener("change", (e) => {
      if (e.matches && !drawer.hidden) close(false);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--ribbon-edge);
    box-shadow: var(--glow-ribbon);
    transition:
      background var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .site-header-inner {
    /* Widened from 960 to match the homepage container so the right
       cluster can breathe. */
    max-width: 1180px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    gap: 0.5rem;
  }
  .site-header-brand {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    color: var(--text);
    text-decoration: none;
    margin-right: auto;
  }
  .site-header-brand:hover { color: var(--text); }
  .logo {
    font-family: var(--font-display);
    font-weight: var(--wordmark-weight);
    font-size: 15px;
    letter-spacing: var(--wordmark-tracking);
    color: var(--text);
  }

  /* ── Nav (group dropdowns) ─────────────────────────────────── */
  .nav {
    display: flex;
    align-items: stretch;
  }
  .nav-group { position: relative; }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    color: var(--muted);
    padding: 0 1rem;
    height: 56px;
    display: inline-flex;
    align-items: center;
    gap: 0.45rem;
    text-decoration: none;
    background: transparent;
    border: 0;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .nav-link:hover,
  .nav-link.is-active,
  .nav-group.is-open .nav-link {
    color: var(--text);
  }
  .nav-link.is-active,
  .nav-group.is-open .nav-link {
    border-bottom-color: var(--accent);
  }
  /* B-10: in light mode, --accent on --ribbon dips below AA at 11px. */
  :global([data-theme="light"]) .nav-link.is-active { color: var(--text); }

  .nav-caret {
    display: inline-block;
    width: 6px;
    height: 6px;
    border-right: 1.5px solid currentColor;
    border-bottom: 1.5px solid currentColor;
    transform: translateY(-1px) rotate(45deg);
    opacity: 0.7;
    transition: transform var(--dur-fast) var(--ease-standard);
  }
  .nav-group.is-open .nav-caret { transform: translateY(1px) rotate(225deg); }

  .nav-badge {
    font-family: var(--font-mono);
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: var(--ls-wider);
    padding: 2px 5px;
    border-radius: var(--r-xs);
    line-height: 1;
    display: inline-flex;
    align-items: center;
    justify-content: center;
  }
  .nav-badge.new  { background: var(--accent); color: var(--obsidian); }
  .nav-badge.tool {
    background: rgba(20, 184, 166, 0.16);
    color: var(--specialist);
    border: 0.5px solid var(--specialist);
    padding: 2px 4px;
  }
  .nav-badge.tool :global(svg) { display: block; }

  .nav-install {
    margin-left: 0.4rem;
    padding: 0 0.95rem;
    height: 32px;
    align-self: center;
    background: var(--accent);
    color: var(--obsidian);
    border: 0;
    border-radius: var(--r-pill);
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 600;
    letter-spacing: var(--ls-wide);
    text-transform: uppercase;
    text-decoration: none;
    display: inline-flex;
    align-items: center;
    transition: background var(--dur-fast) var(--ease-standard);
  }
  .nav-install:hover { background: var(--accent-hover); color: var(--obsidian); }
  /* B-10 light-mode contrast: --accent on light bg only hits 4.46:1 on
     --obsidian; use --ember (#e05c18) instead, like Button.astro does. */
  :global([data-theme="light"]) .nav-install { background: var(--ember); }
  .nav-install.is-active { box-shadow: 0 0 0 2px var(--accent-dim); }

  /* ── Dropdown panels ───────────────────────────────────────── */
  .dropdown {
    position: absolute;
    top: 56px;
    left: 0;
    min-width: 320px;
    max-width: 460px;
    background: var(--ribbon);
    border: 0.5px solid var(--ribbon-edge);
    border-radius: var(--r-md);
    box-shadow: var(--shadow-lg);
    padding: 0.5rem;
    display: grid;
    grid-template-columns: 1fr;
    gap: 0.15rem;
    opacity: 0;
    transform: translateY(-4px);
    pointer-events: none;
    transition:
      opacity var(--dur-fast) var(--ease-standard),
      transform var(--dur-fast) var(--ease-standard);
    z-index: 100;
  }
  .nav-group.is-open .dropdown {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }
  .dropdown-section-head {
    padding: 0.4rem 0.75rem 0.6rem;
    font-family: var(--font-mono);
    font-size: 9px;
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--subtle);
  }
  .dropdown-item {
    display: flex;
    flex-direction: column;
    gap: 2px;
    padding: 0.55rem 0.75rem;
    border-radius: var(--r-sm);
    text-decoration: none;
    color: var(--text);
    transition: background var(--dur-fast) var(--ease-standard);
  }
  .dropdown-item:hover { background: var(--accent-dim); color: var(--text); }
  .dropdown-label {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-family: var(--font-display);
    font-size: var(--fs-sm);
    font-weight: 500;
  }
  .dropdown-blurb {
    font-family: var(--font-body);
    font-size: 11px;
    color: var(--subtle);
    line-height: 1.3;
  }
  .pillet {
    font-family: var(--font-mono);
    font-size: 8.5px;
    font-weight: 700;
    letter-spacing: var(--ls-wider);
    padding: 2px 5px;
    border-radius: var(--r-xs);
    line-height: 1;
  }
  .pillet.new   { background: var(--accent); color: var(--obsidian); }
  .pillet.tool  { background: rgba(20,184,166,0.16); color: var(--specialist); border: 0.5px solid var(--specialist); }
  .pillet.count { background: var(--accent-dim); color: var(--accent); border: 0.5px solid rgba(224,92,24,0.4); }

  /* ── Right cluster (search → version chip → feedback → theme) ── */
  .right-cluster {
    display: flex;
    align-items: center;
    gap: 0.4rem;
  }

  .search-trigger {
    display: flex;
    align-items: center;
    gap: 8px;
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    padding: 4px 10px;
    width: 220px;
    cursor: text;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard);
  }
  .search-trigger:focus-within {
    border-color: var(--accent);
    box-shadow: 0 0 0 1px var(--accent-dim);
  }
  .search-trigger svg {
    width: 12px;
    height: 12px;
    color: var(--subtle);
    flex-shrink: 0;
  }
  .search-trigger input {
    flex: 1;
    min-width: 0;
    background: transparent;
    border: 0;
    outline: 0;
    color: var(--text);
    font-family: var(--font-body);
    font-size: 12px;
    padding: 0;
  }
  .search-trigger input::placeholder { color: var(--subtle); }
  .search-kbd {
    font-family: var(--font-mono);
    font-size: 10px;
    line-height: 1;
    padding: 3px 5px;
    border: 0.5px solid var(--border);
    border-radius: var(--r-xs);
    background: var(--surface);
    color: var(--muted);
    flex-shrink: 0;
  }

  .version-chip {
    display: inline-flex;
    align-items: center;
    gap: 6px;
    padding: 4px 10px;
    font-family: var(--font-mono);
    font-size: 10px;
    color: var(--text);
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-sm);
    text-decoration: none;
    line-height: 1;
    min-width: 78px;
    justify-content: center;
    transition: border-color var(--dur-fast) var(--ease-standard);
  }
  .version-chip:hover { border-color: var(--accent); }
  .vchip-tag { color: var(--text); font-weight: 600; }
  .vchip-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: var(--muted);
    box-shadow: 0 0 0 0 transparent;
    transition:
      background var(--dur-fast) var(--ease-standard),
      box-shadow var(--dur-fast) var(--ease-standard);
  }
  .version-chip[data-state="loading"] .vchip-dot {
    background: var(--accent);
    box-shadow: 0 0 0 3px var(--accent-dim);
    animation: vchip-pulse 1.4s ease-in-out infinite;
