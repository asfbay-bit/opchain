---
import Logo from "./Logo.astro";
import ThemeToggle from "./ThemeToggle.astro";
import Icon from "./Icon.astro";

interface NavLink {
  href: string;
  label: string;
}

interface Props {
  /** Route of the current page (e.g. "/architecture"). Underlines the matching nav link. */
  active?: string;
  links?: NavLink[];
}

const defaultLinks: NavLink[] = [
  { href: "/",              label: "Home" },
  { href: "/architecture",  label: "Architecture" },
  { href: "/skills",        label: "Skill Library" },
  { href: "/demo",          label: "Demo" },
  { href: "/install",       label: "Install" },
];

const { active = "/", links = defaultLinks } = Astro.props;
---

<header class="site-header">
  <div class="site-header-inner">
    <a class="site-header-brand" href="/" aria-label="opchain home">
      <Logo size={28} />
      <span class="logo">opchain</span>
    </a>

    <nav class="nav-scroll" aria-label="Primary">
      <div class="nav">
        {links.map((link) => (
          <a
            href={link.href}
            class:list={["nav-link", { active: link.href === active }]}
          >
            {link.label}
          </a>
        ))}
      </div>
    </nav>

    <button
      type="button"
      class="nav-burger"
      id="nav-burger"
      aria-label="Open navigation menu"
      aria-expanded="false"
      aria-controls="nav-drawer"
    >
      <span class="nav-burger-line" aria-hidden="true"></span>
      <span class="nav-burger-line" aria-hidden="true"></span>
      <span class="nav-burger-line" aria-hidden="true"></span>
    </button>

    <button
      type="button"
      class="header-feedback"
      data-feedback-launcher
      aria-label="Send feedback"
    >
      <Icon name="message-square" size={14} />
    </button>

    <ThemeToggle />
  </div>

  <div
    class="nav-drawer"
    id="nav-drawer"
    role="dialog"
    aria-modal="true"
    aria-label="Navigation menu"
    hidden
  >
    <button
      type="button"
      class="nav-drawer-scrim"
      aria-label="Close navigation menu"
      tabindex="-1"
    ></button>
    <nav class="nav-drawer-panel" aria-label="Primary, mobile">
      {links.map((link) => (
        <a
          href={link.href}
          class:list={["nav-drawer-link", { active: link.href === active }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<script>
  // Mobile nav drawer: opens on hamburger click, closes on link click,
  // scrim click, Escape key, or viewport widening past the breakpoint.
  // Focus is trapped to the drawer panel while open.
  const burger = document.getElementById("nav-burger") as HTMLButtonElement | null;
  const drawer = document.getElementById("nav-drawer") as HTMLDivElement | null;
  if (burger && drawer) {
    const scrim = drawer.querySelector(".nav-drawer-scrim") as HTMLButtonElement | null;
    const links = drawer.querySelectorAll<HTMLAnchorElement>(".nav-drawer-link");
    const firstLink = links[0];
    const lastLink = links[links.length - 1];

    const open = () => {
      drawer.hidden = false;
      requestAnimationFrame(() => drawer.classList.add("is-open"));
      burger.setAttribute("aria-expanded", "true");
      document.documentElement.style.overflow = "hidden";
      firstLink?.focus();
    };
    const close = (returnFocus = true) => {
      drawer.classList.remove("is-open");
      burger.setAttribute("aria-expanded", "false");
      document.documentElement.style.overflow = "";
      // Wait for the slide transition before hiding from a11y tree.
      window.setTimeout(() => { drawer.hidden = true; }, 180);
      if (returnFocus) burger.focus();
    };

    burger.addEventListener("click", () => {
      drawer.hidden ? open() : close();
    });
    scrim?.addEventListener("click", () => close());
    links.forEach((a) => a.addEventListener("click", () => close(false)));

    document.addEventListener("keydown", (e) => {
      if (drawer.hidden) return;
      if (e.key === "Escape") {
        e.preventDefault();
        close();
      } else if (e.key === "Tab") {
        // Trap focus within the drawer.
        if (e.shiftKey && document.activeElement === firstLink) {
          e.preventDefault();
          lastLink?.focus();
        } else if (!e.shiftKey && document.activeElement === lastLink) {
          e.preventDefault();
          firstLink?.focus();
        }
      }
    });

    // If the user resizes past the breakpoint while the drawer is open,
    // close it — the inline nav takes over.
    const mq = window.matchMedia("(min-width: 720px)");
    mq.addEventListener("change", (e) => {
      if (e.matches && !drawer.hidden) close(false);
    });
  }
</script>

<style>
  .site-header {
    position: sticky;
    top: 0;
    z-index: 50;
    background: var(--ribbon);
    border-bottom: 0.5px solid var(--ribbon-edge);
    box-shadow: var(--glow-ribbon);
    transition:
      background var(--dur-base) var(--ease-standard),
      border-color var(--dur-base) var(--ease-standard),
      box-shadow var(--dur-base) var(--ease-standard);
  }
  .site-header-inner {
    max-width: 960px;
    margin: 0 auto;
    padding: 0 1.5rem;
    height: 56px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
  }
  .site-header-brand {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    color: var(--text);
    text-decoration: none;
  }
  .site-header-brand:hover { color: var(--text); }
  .logo {
    font-family: var(--font-display);
    font-weight: var(--wordmark-weight);
    font-size: 15px;
    letter-spacing: var(--wordmark-tracking);
    color: var(--text);
  }
  .nav-scroll {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    flex: 1;
    min-width: 0;
  }
  .nav-scroll::-webkit-scrollbar { display: none; }
  .nav {
    display: flex;
    gap: 0;
    white-space: nowrap;
    justify-content: flex-end;
  }
  .nav-link {
    font-family: var(--font-mono);
    font-size: 11px;
    font-weight: 500;
    letter-spacing: var(--ls-wide);
    color: var(--muted);
    padding: 0 1rem;
    height: 56px;
    display: inline-flex;
    align-items: center;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .nav-link:hover { color: var(--text); }
  .nav-link.active {
    color: var(--accent);
    border-bottom-color: var(--accent);
  }
  /* B-10: --accent on light --ribbon fails AA normal at 11px. Use --text for the
     active label; the ember border-bottom is sufficient as the selection indicator.
     :global() escapes [data-theme="light"] from Astro's CID scoping so it can
     correctly target the <html> ancestor. */
  :global([data-theme="light"]) .nav-link.active { color: var(--text); }
  /* B-10: same fix for mobile drawer active link (--accent on --ribbon = 3.03:1 ✗). */
  :global([data-theme="light"]) .nav-drawer-link.active { color: var(--text); }

  /* ── Hamburger (hidden ≥720px, shown below) ──────────────── */
  .nav-burger {
    display: none;
    background: transparent;
    border: 0.5px solid var(--border);
    border-radius: var(--r-sm);
    width: 36px;
    height: 32px;
    padding: 0;
    cursor: pointer;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    gap: 4px;
    transition:
      border-color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard);
  }
  .nav-burger:hover {
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .nav-burger:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }
  .nav-burger-line {
    display: block;
    width: 16px;
    height: 1.5px;
    background: var(--text);
    border-radius: 1px;
    transition: transform var(--dur-fast) var(--ease-standard);
  }
  .nav-burger[aria-expanded="true"] .nav-burger-line:nth-child(1) {
    transform: translateY(5.5px) rotate(45deg);
  }
  .nav-burger[aria-expanded="true"] .nav-burger-line:nth-child(2) {
    opacity: 0;
  }
  .nav-burger[aria-expanded="true"] .nav-burger-line:nth-child(3) {
    transform: translateY(-5.5px) rotate(-45deg);
  }

  /* ── Drawer ──────────────────────────────────────────────── */
  .nav-drawer {
    position: fixed;
    inset: 0;
    z-index: 60;
    display: flex;
    justify-content: flex-end;
  }
  .nav-drawer[hidden] { display: none; }
  .nav-drawer-scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.45);
    border: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .nav-drawer.is-open .nav-drawer-scrim { opacity: 1; }
  .nav-drawer-panel {
    position: relative;
    width: min(280px, 80vw);
    background: var(--ribbon);
    border-left: 0.5px solid var(--ribbon-edge);
    box-shadow: -8px 0 24px rgba(0, 0, 0, 0.35);
    display: flex;
    flex-direction: column;
    padding: 4.5rem 0.75rem 1.5rem;   /* clear the sticky header */
    transform: translateX(100%);
    transition: transform var(--dur-base) var(--ease-standard);
  }
  .nav-drawer.is-open .nav-drawer-panel { transform: translateX(0); }
  .nav-drawer-link {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    letter-spacing: var(--ls-wide);
    color: var(--muted);
    padding: 0.75rem 1rem;
    text-decoration: none;
    border-radius: var(--r-sm);
    border-left: 2px solid transparent;
    transition:
      color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard);
  }
  .nav-drawer-link:hover {
    color: var(--text);
    background: var(--accent-dim);
  }
  .nav-drawer-link.active {
    color: var(--accent);
    border-left-color: var(--accent);
  }
  .nav-drawer-link:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Mobile feedback launcher ─────────────────────────────
     Sits between .nav-burger and <ThemeToggle /> on mobile. Hidden at
     ≥768px (the floating pill in FeedbackWidget covers desktop). The
     existing FeedbackWidget script binds click to every
     [data-feedback-launcher] in the document. */
  .header-feedback {
    display: none;
    background: transparent;
    border: 0.5px solid var(--border);
    border-radius: var(--r-sm);
    width: 36px;
    height: 32px;
    padding: 0;
    cursor: pointer;
    align-items: center;
    justify-content: center;
    color: var(--muted);
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard);
  }
  .header-feedback:hover {
    color: var(--text);
    border-color: var(--accent);
    background: var(--accent-dim);
  }
  .header-feedback:focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
  }

  /* ── Breakpoint swap ─────────────────────────────────────── */
  @media (max-width: 719px) {
    .nav-scroll { display: none; }
    .nav-burger { display: inline-flex; }
  }
  /* Mirror MobileWorkbench's breakpoint (767px) so the feedback icon
     appears wherever the floating pill is hidden. See FeedbackWidget. */
  @media (max-width: 767px) {
    .header-feedback { display: inline-flex; }
  }
</style>
