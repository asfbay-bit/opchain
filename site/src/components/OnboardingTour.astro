---
/**
 * First-visit overlay tour for /demo.
 *
 * 4-step coachmark sequence:
 *   1. What this page is.
 *   2. Six scenarios + how to switch.
 *   3. Keyboard shortcuts.
 *   4. Inputs / Outputs side drawers.
 *
 * Dismissed = `localStorage.opchain-demo-tour-seen=1`. A small (?) help
 * button above the scenario row re-opens the tour on demand.
 */
---

<div class="tour" id="demo-tour" hidden aria-hidden="true">
  <button class="tour-scrim" id="demo-tour-scrim" tabindex="-1" aria-label="Skip tour"></button>

  <div class="tour-card" role="dialog" aria-labelledby="demo-tour-title" aria-modal="true">
    <header class="tour-head">
      <span class="tour-eyebrow"><span id="demo-tour-step">1</span> / 4</span>
      <button class="tour-close" id="demo-tour-close" aria-label="Skip tour">×</button>
    </header>

    <div class="tour-body">
      <h2 class="tour-title" id="demo-tour-title">What is this?</h2>
      <p class="tour-text" id="demo-tour-text">
        A live walkthrough of six finished opchain sessions — from
        idea-in-a-chat to deployed-to-production, end to end. Every
        line below is actual transcript, not a faked-up demo. No live
        chat, no email gate, no install required.
      </p>
    </div>

    <footer class="tour-foot">
      <button class="tour-btn tour-btn-ghost" id="demo-tour-skip" type="button">Skip</button>
      <div class="tour-foot-right">
        <button class="tour-btn tour-btn-outline" id="demo-tour-prev" type="button" disabled>Back</button>
        <button class="tour-btn tour-btn-primary" id="demo-tour-next" type="button">Next →</button>
      </div>
    </footer>
  </div>
</div>

<script>
  type Step = { title: string; text: string };

  const STEPS: Step[] = [
    {
      title: "What is this?",
      text:
        "A live walkthrough of six finished opchain sessions — from idea-in-a-chat to deployed-to-production, end to end. Every line below is actual transcript, not a faked-up demo. No live chat, no email gate, no install required.",
    },
    {
      title: "Six scenarios",
      text:
        "Each scenario tackles a different problem the skill ecosystem solves: shipping a new app from concept, rescuing a half-finished dashboard, hardening security before release, migrating a legacy stack, reviving abandoned code, and shipping Stripe billing. Click any scenario chip in the row above the chat to switch.",
    },
    {
      title: "Driving it",
      text:
        "Press Enter to advance one step. Space to skip to the end. R to restart. 1–6 to jump straight to a scenario. The Scenario / Chat tabs let you flip between the brief and the live transcript without losing your place.",
    },
    {
      title: "Inputs & Outputs",
      text:
        "The Scenario tab shows the inputs the user gave (left column) and the outputs Claude produced (right column). Click any input or output to open a side drawer with its full content rendered as Markdown — useful when the chat is going by quickly and you want to skim a single artifact.",
    },
  ];

  const STORAGE_KEY = "opchain-demo-tour-seen";

  const tour       = document.getElementById("demo-tour")!;
  const scrim      = document.getElementById("demo-tour-scrim")!;
  const closeBtn   = document.getElementById("demo-tour-close")!;
  const skipBtn    = document.getElementById("demo-tour-skip")!;
  const prevBtn    = document.getElementById("demo-tour-prev")! as HTMLButtonElement;
  const nextBtn    = document.getElementById("demo-tour-next")! as HTMLButtonElement;
  const titleEl    = document.getElementById("demo-tour-title")!;
  const textEl     = document.getElementById("demo-tour-text")!;
  const stepEl     = document.getElementById("demo-tour-step")!;

  let idx = 0;

  function render() {
    const step = STEPS[idx];
    stepEl.textContent  = String(idx + 1);
    titleEl.textContent = step.title;
    textEl.textContent  = step.text;
    prevBtn.disabled = idx === 0;
    nextBtn.textContent = idx === STEPS.length - 1 ? "Got it" : "Next →";
  }

  function open() {
    idx = 0;
    render();
    tour.hidden = false;
    tour.removeAttribute("aria-hidden");
    requestAnimationFrame(() => tour.classList.add("is-open"));
  }

  function close() {
    tour.classList.remove("is-open");
    tour.setAttribute("aria-hidden", "true");
    setTimeout(() => { tour.hidden = true; }, 240);
    try { localStorage.setItem(STORAGE_KEY, "1"); } catch { /* ignore */ }
  }

  function next() {
    if (idx === STEPS.length - 1) {
      close();
      return;
    }
    idx += 1;
    render();
  }

  function prev() {
    if (idx === 0) return;
    idx -= 1;
    render();
  }

  scrim.addEventListener("click", close);
  closeBtn.addEventListener("click", close);
  skipBtn.addEventListener("click", close);
  prevBtn.addEventListener("click", prev);
  nextBtn.addEventListener("click", next);

  document.addEventListener("keydown", (ev) => {
    if (tour.hidden) return;
    if (ev.key === "Escape") { ev.preventDefault(); close(); }
    if (ev.key === "ArrowRight") { ev.preventDefault(); next(); }
    if (ev.key === "ArrowLeft")  { ev.preventDefault(); prev(); }
  });

  // Re-open hook: any element with `data-tour-trigger` opens the tour.
  document.querySelectorAll<HTMLElement>("[data-tour-trigger]").forEach((el) => {
    el.addEventListener("click", (ev) => {
      ev.preventDefault();
      open();
    });
  });

  // First-visit auto-open. Skip if the visitor has dismissed it before.
  let seen = "0";
  try { seen = localStorage.getItem(STORAGE_KEY) || "0"; } catch { /* ignore */ }
  if (seen !== "1") open();
</script>

<style>
  /* Backdrop + centered card. The card is constrained so it never
     overlaps the chat behind it on narrow viewports. */
  .tour {
    position: fixed;
    inset: 0;
    z-index: 80;
    display: grid;
    place-items: center;
    pointer-events: none;
  }
  .tour:not([hidden]) { pointer-events: auto; }
  .tour-scrim {
    position: absolute;
    inset: 0;
    background: rgba(0, 0, 0, 0.55);
    border: 0;
    cursor: pointer;
    opacity: 0;
    transition: opacity var(--dur-base) var(--ease-standard);
  }
  .tour.is-open .tour-scrim { opacity: 1; }

  .tour-card {
    position: relative;
    width: min(34rem, calc(100vw - 2rem));
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-md);
    box-shadow: var(--shadow-xl);
    transform: translateY(8px);
    opacity: 0;
    transition:
      opacity var(--dur-base) var(--ease-standard),
      transform var(--dur-base) var(--ease-standard);
  }
  .tour.is-open .tour-card {
    transform: translateY(0);
    opacity: 1;
  }

  .tour-head {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0.85rem 1.1rem;
    border-bottom: 0.5px solid var(--border);
  }
  .tour-eyebrow {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    letter-spacing: var(--ls-widest);
    text-transform: uppercase;
    color: var(--accent);
  }
  .tour-close {
    appearance: none;
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--muted);
    width: 28px;
    height: 28px;
    border-radius: var(--r-xs);
    cursor: pointer;
    font-size: 18px;
    line-height: 1;
  }
  .tour-close:hover { color: var(--accent); border-color: var(--accent); }

  .tour-body {
    padding: 1.1rem 1.2rem 0.4rem;
  }
  .tour-title {
    margin: 0 0 0.6rem;
    font-family: var(--font-display);
    font-size: var(--fs-xl);
    font-weight: 600;
    color: var(--text);
    letter-spacing: var(--ls-tight);
  }
  .tour-text {
    margin: 0;
    color: var(--muted);
    font-size: var(--fs-base);
    line-height: 1.6;
  }

  .tour-foot {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.5rem;
    padding: 0.85rem 1.1rem 1rem;
  }
  .tour-foot-right {
    display: inline-flex;
    gap: 0.5rem;
  }
  .tour-btn {
    appearance: none;
    font: inherit;
    font-family: var(--font-mono);
    font-size: var(--fs-sm);
    padding: 0.4rem 0.95rem;
    border-radius: var(--r-xs);
    cursor: pointer;
    transition:
      color var(--dur-fast) var(--ease-standard),
      border-color var(--dur-fast) var(--ease-standard),
      background var(--dur-fast) var(--ease-standard);
  }
  .tour-btn:disabled { opacity: 0.4; cursor: not-allowed; }
  .tour-btn-ghost {
    background: transparent;
    border: 0;
    color: var(--subtle);
  }
  .tour-btn-ghost:hover:not(:disabled) { color: var(--muted); }
  .tour-btn-outline {
    background: transparent;
    border: 0.5px solid var(--border);
    color: var(--muted);
  }
  .tour-btn-outline:hover:not(:disabled) {
    color: var(--accent);
    border-color: var(--accent);
  }
  .tour-btn-primary {
    background: var(--accent);
    border: 0.5px solid var(--accent);
    color: #1c1710;
    font-weight: 600;
  }
  .tour-btn-primary:hover:not(:disabled) {
    filter: brightness(1.05);
  }
</style>
