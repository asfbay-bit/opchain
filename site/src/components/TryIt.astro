---
/**
 * Live Try-It chat. Runs client-side, talks to the Worker via
 *   POST /api/try/start  → session token
 *   POST /api/try/chat   → SSE stream
 *
 * Keyboard:
 *   Cmd/Ctrl+Enter  — send
 *   Esc             — abort the in-flight stream (if any)
 */
import Eyebrow from "./ui/Eyebrow.astro";
import Button from "./ui/Button.astro";
import Input from "./ui/Input.astro";
import Textarea from "./ui/Textarea.astro";
import Pill from "./ui/Pill.astro";
import Alert from "./ui/Alert.astro";
import Icon from "./Icon.astro";
import { getTryablePrompts } from "../lib/skills";

interface Props {
  preselect?: string;
}
const { preselect: preselectProp } = Astro.props;

const tryable = await getTryablePrompts();
const preselect = preselectProp || tryable[0]?.id || "";
---

<section class="tryit" data-max-exchanges="5">
  <!-- Email gate (visible until a session is created). -->
  <div class="gate" id="tryit-gate">
    <p class="gate-label">Enter your email to start a free demo session.</p>
    <form class="gate-form" id="tryit-gate-form" autocomplete="off">
      <Input
        type="email"
        name="email"
        id="tryit-email"
        placeholder="you@example.com"
        required
        autocomplete="email"
        ariaLabel="Email address"
      />
      <Button type="submit" variant="primary" label="Start demo">start</Button>
    </form>
    <p class="gate-fine">
      Email is used to rate-limit the demo and (with your permission) follow up.
      <a href="/privacy">Privacy</a>.
    </p>
    <div class="gate-alert" id="tryit-gate-alert" hidden>
      <Alert variant="danger"><span id="tryit-gate-alert-msg"></span></Alert>
    </div>
  </div>

  <!-- Skill selector — always visible. -->
  <div class="picker">
    <div class="picker-head">
      <Eyebrow>pick a skill</Eyebrow>
    </div>
    <div class="skill-pills" id="tryit-skills" role="group" aria-label="Select a skill">
      {tryable.map((s) => (
        <Pill
          pressed={s.id === preselect}
          class="tryit-skill-pill"
          {...({
            "data-skill-id": s.id,
            "data-skill-name": s.displayName,
            "data-skill-prompt": s.prompt,
          } as any)}
        >
          {s.displayName}
        </Pill>
      ))}
    </div>
    <!-- 5.6.2 — One-line starter copy in lieu of the auto-played skill
         intro prompt. Tells the user how to begin. -->
    <p class="starter-hint">
      Pick a skill, then describe what you're trying to do — like
      <em>“build me a recipe app”</em> or <em>“audit this code”</em> — and Claude takes it from there.
    </p>
  </div>

  <!-- Transcript. Client script populates the initial assistant message
       via renderSafeMarkdown so initial + re-selection render identically. -->
  <div class="chat-shell" aria-live="polite" aria-label="Conversation">
    <div class="messages" id="tryit-messages"></div>
  </div>

  <form class="input-row" id="tryit-input-form" autocomplete="off">
    <Textarea
      name="message"
      id="tryit-message"
      placeholder="type your message… (Cmd/Ctrl+Enter to send)"
      rows={2}
      ariaLabel="Your message"
    />
    <Button type="submit" variant="primary" label="Send">
      send
      <Icon name="arrow-right" size={12} />
    </Button>
  </form>

  <div class="status-row">
    <p class="counter" id="tryit-counter">5 of 5 exchanges remaining</p>
    <label class="autoscroll">
      <input type="checkbox" id="tryit-autoscroll" checked />
      <span>auto-scroll</span>
    </label>
  </div>

  <div id="tryit-error-row" hidden>
    <Alert variant="danger">
      <span id="tryit-error-msg"></span>
      <button type="button" id="tryit-retry" class="retry">retry</button>
    </Alert>
  </div>
</section>

<script>
  import { renderSafeMarkdown } from "../lib/markdown";

  interface GateResponse {
    session_token?: string;
    remaining?: number;
    error?: string;
    code?: string;
  }

  interface ChatDelta { text?: string; done?: boolean; remaining?: number; error?: string; code?: string; }

  const root = document.querySelector<HTMLElement>(".tryit");
  if (root) bootstrap(root);

  function bootstrap(root: HTMLElement) {
    const MAX = Number(root.dataset.maxExchanges || 5);

    const gate         = root.querySelector<HTMLElement>("#tryit-gate")!;
    const gateForm     = root.querySelector<HTMLFormElement>("#tryit-gate-form")!;
    const gateEmail    = root.querySelector<HTMLInputElement>("#tryit-email")!;
    const gateAlert    = root.querySelector<HTMLElement>("#tryit-gate-alert")!;
    const gateAlertMsg = root.querySelector<HTMLElement>("#tryit-gate-alert-msg")!;

    const pillsWrap    = root.querySelector<HTMLElement>("#tryit-skills")!;
    const pills        = Array.from(pillsWrap.querySelectorAll<HTMLButtonElement>(".tryit-skill-pill"));

    const messagesEl   = root.querySelector<HTMLElement>("#tryit-messages")!;
    const inputForm    = root.querySelector<HTMLFormElement>("#tryit-input-form")!;
    const messageInput = root.querySelector<HTMLTextAreaElement>("#tryit-message")!;
    const counter      = root.querySelector<HTMLElement>("#tryit-counter")!;
    const autoscrollEl = root.querySelector<HTMLInputElement>("#tryit-autoscroll")!;

    const errorRow     = root.querySelector<HTMLElement>("#tryit-error-row")!;
    const errorMsg     = root.querySelector<HTMLElement>("#tryit-error-msg")!;
    const retryBtn     = root.querySelector<HTMLButtonElement>("#tryit-retry")!;

    let sessionToken: string | null = null;
    let remaining = MAX;

    // Static build — read `?skill=foo` client-side so a link like
    // /tryit?skill=code-auditor still preselects the right pill.
    const qSkill = new URLSearchParams(location.search).get("skill");
    if (qSkill) {
      const qPill = pills.find((p) => p.dataset.skillId === qSkill);
      if (qPill) {
        pills.forEach((p) => p.setAttribute("aria-pressed", "false"));
        qPill.setAttribute("aria-pressed", "true");
      }
    }

    let currentSkill = pills.find((p) => p.getAttribute("aria-pressed") === "true")?.dataset.skillId
                    ?? pills[0]?.dataset.skillId
                    ?? "";
    const transcript: { role: "user" | "assistant"; content: string }[] = [];
    let inFlight: AbortController | null = null;
    let lastUserMessage = "";

    // 5.6.1 — No auto-played intro prompt anymore; the transcript starts
    // empty. The starter-hint above the input tells the user what to type.
    // We still keep the skill-prompt data-attributes around in case we
    // wire it back as an opt-in later.

    function setCounter() {
      counter.textContent = `${remaining} of ${MAX} exchanges remaining`;
    }

    function showGateError(msg: string) {
      gateAlertMsg.textContent = msg;
      gateAlert.hidden = false;
    }

    function clearGateError() {
      gateAlert.hidden = true;
    }

    function showChatError(msg: string) {
      errorMsg.textContent = msg;
      errorRow.hidden = false;
    }

    function clearChatError() {
      errorRow.hidden = true;
    }

    function autoscroll() {
      if (!autoscrollEl.checked) return;
      messagesEl.parentElement?.scrollTo({ top: 9e9, behavior: "smooth" });
    }

    function renderMessage(role: "user" | "assistant", text: string, label?: string) {
      const wrap = document.createElement("div");
      wrap.className = `msg msg--${role}`;
      const labelEl = document.createElement("div");
      labelEl.className = "msg-label";
      labelEl.textContent = role === "user" ? "you" : (label || "assistant");
      const content = document.createElement("div");
      content.className = "msg-content markdown";
      if (role === "user") {
        content.textContent = text;
      } else {
        content.innerHTML = renderSafeMarkdown(text);
      }
      wrap.append(labelEl, content);
      messagesEl.append(wrap);
      autoscroll();
      return content;
    }

    // ── Gate ─────────────────────────────────────────────────────
    gateForm.addEventListener("submit", async (ev) => {
      ev.preventDefault();
      clearGateError();
      const value = gateEmail.value.trim();
      if (!value) {
        showGateError("Please enter your email.");
        return;
      }
      const btn = gateForm.querySelector<HTMLButtonElement>("button[type=submit]");
      if (btn) btn.disabled = true;
      try {
        const res = await fetch("/api/try/start", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          body: JSON.stringify({ email: value }),
        });
        const body: GateResponse = await res.json().catch(() => ({}));
        if (!res.ok || !body.session_token) {
          showGateError(body.error || `Couldn't start a session (HTTP ${res.status}).`);
          return;
        }
        sessionToken = body.session_token;
        remaining = Number(body.remaining ?? MAX);
        setCounter();
        gate.setAttribute("hidden", "");
        messageInput.focus();
      } catch (e) {
        showGateError("Network error — please try again.");
      } finally {
        if (btn) btn.disabled = false;
      }
    });

    // ── Skill picker ─────────────────────────────────────────────
    pills.forEach((p) => {
      p.addEventListener("click", () => {
        pills.forEach((x) => x.setAttribute("aria-pressed", "false"));
        p.setAttribute("aria-pressed", "true");
        currentSkill = p.dataset.skillId || "";
        // Reset transcript on skill switch — no auto-intro (5.6.1).
        transcript.length = 0;
        messagesEl.innerHTML = "";
      });
    });

    // ── Send ─────────────────────────────────────────────────────
    inputForm.addEventListener("submit", (ev) => {
      ev.preventDefault();
      send();
    });

    messageInput.addEventListener("keydown", (ev) => {
      if ((ev.metaKey || ev.ctrlKey) && ev.key === "Enter") {
        ev.preventDefault();
        send();
      }
      if (ev.key === "Escape" && inFlight) {
        inFlight.abort();
      }
    });

    retryBtn.addEventListener("click", () => {
      clearChatError();
      if (lastUserMessage) {
        messageInput.value = lastUserMessage;
        send();
      }
    });

    async function send() {
      clearChatError();
      if (!sessionToken) {
        showChatError("Session expired. Please re-enter your email.");
        gate.removeAttribute("hidden");
        return;
      }
      if (remaining <= 0) {
        showChatError("No exchanges remaining. Install opchain for unlimited access.");
        return;
      }
      const text = messageInput.value.trim();
      if (!text) return;
      if (inFlight) return; // one at a time

      const activePill = pills.find((p) => p.getAttribute("aria-pressed") === "true");
      const label = activePill?.dataset.skillName || "assistant";

      lastUserMessage = text;
      transcript.push({ role: "user", content: text });
      renderMessage("user", text);
      messageInput.value = "";

      const assistantEl = renderMessage("assistant", "", label);
      assistantEl.textContent = "…";

      inFlight = new AbortController();
      let buffer = "";
      let streamed = "";
      try {
        const res = await fetch("/api/try/chat", {
          method: "POST",
          headers: { "Content-Type": "application/json" },
          signal: inFlight.signal,
          body: JSON.stringify({
            session_token: sessionToken,
            skill: currentSkill,
            messages: transcript,
          }),
        });
        if (!res.ok) {
          const body = await res.json().catch(() => ({}));
          assistantEl.remove();
          transcript.pop();
          showChatError(body.error || `Chat failed (HTTP ${res.status}).`);
          inFlight = null;
          return;
        }
        const reader = res.body!.getReader();
        const decoder = new TextDecoder();
        assistantEl.textContent = "";
        while (true) {
          const { value, done } = await reader.read();
          if (done) break;
          buffer += decoder.decode(value, { stream: true });
          const lines = buffer.split("\n");
          buffer = lines.pop() || "";
          for (const line of lines) {
            if (!line.startsWith("data: ")) continue;
            const raw = line.slice(6).trim();
            if (!raw) continue;
            let evt: ChatDelta;
            try { evt = JSON.parse(raw); } catch { continue; }
            if (evt.error) {
              showChatError(evt.error);
              break;
            }
            if (evt.text) {
              streamed += evt.text;
              assistantEl.innerHTML = renderSafeMarkdown(streamed);
              autoscroll();
            }
            if (evt.done) {
              if (typeof evt.remaining === "number") remaining = evt.remaining;
              setCounter();
            }
          }
        }
        if (streamed) {
          transcript.push({ role: "assistant", content: streamed });
        } else {
          assistantEl.remove();
          transcript.pop();
        }
      } catch (e: any) {
        if (e?.name === "AbortError") {
          // Preserve alternating user/assistant roles: either keep both
          // messages (partial response was streamed) or drop both
          // (nothing arrived). Two consecutive user messages would break
          // the next /chat call (Bugbot PR23#L378).
          if (streamed) {
            assistantEl.innerHTML = renderSafeMarkdown(streamed);
            transcript.push({ role: "assistant", content: streamed });
          } else {
            assistantEl.remove();
            transcript.pop();
          }
        } else {
          assistantEl.remove();
          transcript.pop();
          showChatError("Network error — please try again.");
        }
      } finally {
        inFlight = null;
      }
    }
  }
</script>

<style>
  .tryit {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .gate {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.5rem;
    max-width: 30rem;
    box-shadow: var(--glow-md);
  }
  .gate-label { margin: 0 0 0.85rem; color: var(--muted); font-size: var(--fs-sm); }
  .gate-form { display: flex; gap: 0.5rem; }
  .gate-form > :first-child { flex: 1; }
  .gate-fine {
    margin: 0.6rem 0 0;
    font-size: var(--fs-xs);
    color: var(--subtle);
  }
  .gate-fine a { color: var(--accent); }
  .gate-alert { margin-top: 0.75rem; }

  .picker-head { margin-bottom: 0.75rem; }
  .skill-pills { display: flex; flex-wrap: wrap; gap: 0.4rem; }
  .starter-hint {
    margin: 0.75rem 0 0;
    font-size: var(--fs-sm);
    color: var(--muted);
    line-height: var(--lh-base);
  }
  .starter-hint em {
    color: var(--ember);
    font-style: italic;
  }

  .chat-shell {
    background: var(--surface);
    border: 0.5px solid var(--border);
    border-radius: var(--r-lg);
    padding: 1.1rem;
    min-height: 11rem;
    max-height: 26rem;
    overflow-y: auto;
    box-shadow: var(--glow-md);
  }
  .messages { display: flex; flex-direction: column; gap: 0.85rem; }
  .msg { max-width: 90%; }
  .msg--assistant { align-self: flex-start; }
  .msg--user      { align-self: flex-end; }
  .msg-label {
    font-family: var(--font-mono);
    font-size: 9px;
    font-weight: 500;
    letter-spacing: var(--ls-wider);
    text-transform: uppercase;
    color: var(--subtle);
    margin-bottom: 0.3rem;
  }
  .msg-content {
    background: var(--card);
    border: 0.5px solid var(--border);
    color: var(--text);
    padding: 0.7rem 0.95rem;
    border-radius: var(--r-md);
    font-size: var(--fs-sm);
    line-height: var(--lh-base);
    white-space: pre-wrap;
    word-wrap: break-word;
  }
  .msg--assistant .msg-content { border-bottom-left-radius: var(--r-xs); }
  .msg--user .msg-content {
    border-bottom-right-radius: var(--r-xs);
    background: var(--accent-dim);
    border-color: var(--accent);
  }

  /* Markdown child styles */
  :global(.msg-content.markdown p) { margin: 0 0 0.5rem; }
  :global(.msg-content.markdown p:last-child) { margin-bottom: 0; }
  :global(.msg-content.markdown pre) {
    background: var(--ribbon);
    border: 0.5px solid var(--border);
    padding: 0.55rem 0.7rem;
    border-radius: var(--r-sm);
    overflow-x: auto;
    font-size: 12px;
  }
  :global(.msg-content.markdown code) {
    font-family: var(--font-mono);
    font-size: 12px;
  }
  :global(.msg-content.markdown ul),
  :global(.msg-content.markdown ol) {
    margin: 0 0 0.5rem 1.2rem;
  }
  :global(.msg-content.markdown a) { color: var(--accent); }

  .input-row { display: flex; gap: 0.5rem; align-items: flex-start; }
  .input-row > :first-child { flex: 1; }

  .status-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 0.75rem;
  }
  .counter {
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
    letter-spacing: var(--ls-wide);
    margin: 0;
  }
  .autoscroll {
    display: inline-flex;
    align-items: center;
    gap: 0.4rem;
    font-family: var(--font-mono);
    font-size: var(--fs-xs);
    color: var(--subtle);
    letter-spacing: var(--ls-wide);
    cursor: pointer;
  }
  .autoscroll input { accent-color: var(--accent); cursor: pointer; }

  .retry {
    margin-left: 0.75rem;
    font: inherit;
    background: transparent;
    color: inherit;
    border: 0.5px solid currentColor;
    border-radius: var(--r-xs);
    padding: 0.15rem 0.55rem;
    cursor: pointer;
  }
</style>
