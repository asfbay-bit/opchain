---
/**
 * Mobile architecture diagram — static, self-contained, no JS.
 *
 * Companion to the desktop interactive diagram in /architecture. Renders
 * the same 5-phase / 17-skill pipeline at iPhone Pro width (390pt) as
 * collapsible <details>/<summary> bands. Inline SVGs for each phase, no
 * external resources, no animation.
 *
 * Theme: defaults to the site's dark theme. Light mode kicks in via the
 * existing site theme system (`[data-theme="light"]` on <html>) — no
 * prefers-color-scheme inside this component since Base.astro already
 * resolves OS preference + localStorage at boot. CSS variables are
 * scoped to `.mobile-architecture` so they never collide with the
 * site-wide tokens in tokens.css.
 *
 * Mounted at /architecture beneath the desktop diagram and shown via a
 * CSS-breakpoint swap at 767px (see architecture.astro `<style is:global>`).
 */

import packsCatalog from "../../../src/generated/packs-catalog.json";

type PackData = {
  id: string;
  displayName: string;
  kind: "language" | "framework" | "deploy-target" | "mobile";
};

const allPacks = packsCatalog as PackData[];
const packLanguages    = allPacks.filter((p) => p.kind === "language").map((p) => p.id);
const packFrameworks   = allPacks.filter((p) => p.kind === "framework").map((p) => p.id);
const packMobile       = allPacks.filter((p) => p.kind === "mobile").map((p) => p.id);
const packDeployTargets = allPacks.filter((p) => p.kind === "deploy-target").map((p) => p.id);
const packCounts = {
  total: allPacks.length,
  language: packLanguages.length,
  framework: packFrameworks.length,
  mobile: packMobile.length,
  deploy: packDeployTargets.length,
};
---

<section class="mobile-architecture" aria-label="opchain architecture (mobile)">
  <!-- Shared SVG defs for glow filters and arrowheads (visual only, no animation). -->
  <svg class="ma-defs" aria-hidden="true">
    <defs>
      <filter id="ma-glow-ember" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="3" result="b"/>
        <feFlood flood-color="#e05c18" flood-opacity="0.55" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="s"/>
        <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="ma-glow-yellow" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="3" result="b"/>
        <feFlood flood-color="#fbbf24" flood-opacity="0.45" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="s"/>
        <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="ma-glow-cyan" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="3" result="b"/>
        <feFlood flood-color="#38bdf8" flood-opacity="0.45" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="s"/>
        <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="ma-glow-mint" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="3" result="b"/>
        <feFlood flood-color="#14b8a6" flood-opacity="0.45" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="s"/>
        <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <filter id="ma-glow-rose" x="-40%" y="-40%" width="180%" height="180%">
        <feGaussianBlur stdDeviation="3" result="b"/>
        <feFlood flood-color="#fb7185" flood-opacity="0.45" result="c"/>
        <feComposite in="c" in2="b" operator="in" result="s"/>
        <feMerge><feMergeNode in="s"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <marker id="ma-ah-ember" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#e05c18"/>
      </marker>
      <marker id="ma-ah-ember-rev" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto-start-reverse">
        <polygon points="0 0, 8 3, 0 6" fill="#e05c18"/>
      </marker>
      <marker id="ma-ah-sand" markerWidth="7" markerHeight="5" refX="6" refY="2.5" orient="auto">
        <polygon points="0 0, 7 2.5, 0 5" fill="#c4b89e"/>
      </marker>
      <marker id="ma-ah-mint" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#14b8a6"/>
      </marker>
      <marker id="ma-ah-rose" markerWidth="8" markerHeight="6" refX="7" refY="3" orient="auto">
        <polygon points="0 0, 8 3, 0 6" fill="#fb7185"/>
      </marker>
    </defs>
  </svg>

  <div class="ma-container">

    <!-- Header -->
    <div class="ma-header">
      <div class="ma-header-eyebrow">SKILLS · ARCHITECTURE · v2 · MOBILE</div>
      <h1>opchain skills ecosystem</h1>
      <p class="ma-subtitle">Checkpoint-driven pipeline · 18 skills · 5 phases · 5 tri-agent · 3 audit gates · spine ordinals</p>
    </div>

    <!-- Diagram container -->
    <div class="ma-diagram-container">

      <!-- Foundation (CP + Orchestrator, stacked) -->
      <details class="ma-foundation" open aria-label="Foundation layer: checkpoint-protocol and orchestrator">
        <summary>
          <div class="ma-foundation-label">Foundation · cross-cutting</div>
        </summary>
        <div class="ma-foundation-pill">
          <div class="ma-fp-row">
            <span class="ma-fp-tag">PROTOCOL</span>
            <span class="ma-fp-name">checkpoint-protocol</span>
          </div>
          <div class="ma-fp-desc">JSON schema written by every skill: phase · progress · blockers · next_actions. Single source of truth — no database, no vendor lock-in.</div>
        </div>
        <div class="ma-foundation-pill">
          <div class="ma-fp-row">
            <span class="ma-fp-tag">ORCH</span>
            <span class="ma-fp-name">orchestrator</span>
          </div>
          <div class="ma-fp-desc"><code>/ops</code> · routing · cross-project status · gate enforcement.</div>
        </div>
      </details>

      <!-- BAND 1: DISCOVER -->
      <details class="ma-band" open style="--ma-phase-color: var(--ma-text-secondary)">
        <summary class="ma-band-header">
          <span class="ma-band-num">1</span>
          <span class="ma-band-title">Discover</span>
          <span class="ma-band-of">Phase 1 of 5</span>
        </summary>
        <div class="ma-band-svg-wrap">
          <svg viewBox="0 0 330 110" role="img" aria-label="Discover phase: reverse-spec specialist with spine ordinal 1">
            <rect x="40" y="20" width="250" height="72" rx="6" fill="#1c1710" stroke="#14b8a6" stroke-width="1.8" filter="url(#ma-glow-mint)"/>
            <rect x="40" y="20" width="250" height="72" rx="6" fill="rgba(20,184,166,.06)" stroke="#14b8a6" stroke-width="1"/>
            <rect x="148" y="10" width="34" height="20" rx="4" fill="#1c1710"/>
            <rect x="148" y="10" width="34" height="20" rx="4" fill="rgba(20,184,166,.22)" stroke="#14b8a6" stroke-width="1.2" filter="url(#ma-glow-mint)"/>
            <text x="165" y="24" fill="#14b8a6" font-size="13" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">1</text>
            <circle cx="278" cy="30" r="3" fill="#e05c18"/>
            <circle cx="270" cy="30" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="51" fill="#e8dfd0" font-size="15" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">reverse-spec</text>
            <text x="165" y="68" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Specialist · Workflow</text>
            <text x="165" y="84" fill="#14b8a6" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/rev-spec · /rev-full</text>
          </svg>
        </div>
        <div class="ma-band-caption">
          <p>Reverse-engineer existing codebases into structured spec documents. The output feeds <code>app-architect</code> as a Phase 2 baseline so the orchestrator never starts from a cold context. Optional — greenfield projects skip this band entirely.</p>
          <div class="ma-bc-cp"><span class="ma-bc-cp-badge">CP</span><span>phase · codebase_scan · spec_output</span></div>
        </div>
      </details>

      <!-- BAND 2: PLAN -->
      <details class="ma-band" open style="--ma-phase-color: var(--ma-ember)">
        <summary class="ma-band-header">
          <span class="ma-band-num">2</span>
          <span class="ma-band-title">Plan</span>
          <span class="ma-band-of">Phase 2 of 5</span>
        </summary>
        <div class="ma-band-svg-wrap">
          <svg viewBox="0 0 330 540" role="img" aria-label="Plan phase: scale-ops and stack-forge advise app-architect; migration-ops paired bidirectionally">
