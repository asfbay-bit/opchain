            <rect x="40" y="14" width="250" height="68" rx="6" fill="rgba(56,189,248,.06)" stroke="#38bdf8" stroke-width="1"/>
            <circle cx="278" cy="24" r="3" fill="#e05c18"/>
            <circle cx="270" cy="24" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="40" fill="#e8dfd0" font-size="15" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">scale-ops</text>
            <text x="165" y="56" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Advisor</text>
            <text x="165" y="72" fill="#38bdf8" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/scale · perf · capacity</text>
            <line x1="140" y1="82" x2="140" y2="120" stroke="#e05c18" stroke-width="1.8" stroke-dasharray="6,3" marker-end="url(#ma-ah-ember)"/>
            <text x="118" y="104" fill="#e05c18" font-size="11" font-family="JetBrains Mono,monospace" text-anchor="end">auto-invoke ↓</text>
            <line x1="190" y1="120" x2="190" y2="82" stroke="#c4b89e" stroke-width="1.5" stroke-dasharray="6,3" marker-end="url(#ma-ah-sand)"/>
            <text x="212" y="104" fill="#c4b89e" font-size="11" font-family="JetBrains Mono,monospace">↑ advisory</text>
            <rect x="40" y="128" width="250" height="68" rx="6" fill="#1c1710" stroke="#38bdf8" stroke-width="1.8" filter="url(#ma-glow-cyan)"/>
            <rect x="40" y="128" width="250" height="68" rx="6" fill="rgba(56,189,248,.06)" stroke="#38bdf8" stroke-width="1"/>
            <circle cx="278" cy="138" r="3" fill="#e05c18"/>
            <circle cx="270" cy="138" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="154" fill="#e8dfd0" font-size="15" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">stack-forge</text>
            <text x="165" y="170" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Advisor</text>
            <text x="165" y="186" fill="#38bdf8" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/stack · /stack-decide</text>
            <line x1="140" y1="196" x2="140" y2="234" stroke="#e05c18" stroke-width="1.8" stroke-dasharray="6,3" marker-end="url(#ma-ah-ember)"/>
            <text x="118" y="218" fill="#e05c18" font-size="11" font-family="JetBrains Mono,monospace" text-anchor="end">auto-invoke ↓</text>
            <line x1="190" y1="234" x2="190" y2="196" stroke="#c4b89e" stroke-width="1.5" stroke-dasharray="6,3" marker-end="url(#ma-ah-sand)"/>
            <text x="212" y="218" fill="#c4b89e" font-size="11" font-family="JetBrains Mono,monospace">↑ advisory</text>
            <rect x="20" y="244" width="290" height="138" rx="7" fill="#1c1710" stroke="#fbbf24" stroke-width="2.2" filter="url(#ma-glow-yellow)"/>
            <rect x="20" y="244" width="290" height="138" rx="7" fill="rgba(251,191,36,.06)" stroke="#fbbf24" stroke-width="1"/>
            <rect x="148" y="234" width="34" height="20" rx="4" fill="#1c1710"/>
            <rect x="148" y="234" width="34" height="20" rx="4" fill="rgba(20,184,166,.22)" stroke="#14b8a6" stroke-width="1.2" filter="url(#ma-glow-mint)"/>
            <text x="165" y="248" fill="#14b8a6" font-size="13" font-weight="700" font-family="JetBrains Mono,monospace" text-anchor="middle">2</text>
            <circle cx="298" cy="254" r="3" fill="#e05c18"/>
            <circle cx="290" cy="254" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="278" fill="#e8dfd0" font-size="17" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">app-architect</text>
            <text x="165" y="298" fill="#c4b89e" font-size="13" font-family="JetBrains Mono,monospace" text-anchor="middle">Tri-agent · Orchestrator</text>
            <text x="165" y="316" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Generator / Evaluator · QA ≥ 7/10</text>
            <text x="165" y="338" fill="#fbbf24" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/app · /discover · /spec</text>
            <text x="165" y="354" fill="#fbbf24" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/design · /build · /launch</text>
            <text x="165" y="372" fill="#e05c18" font-size="11" font-style="italic" font-family="JetBrains Mono,monospace" text-anchor="middle">auto-invokes: stack-forge · ux-engineer</text>
            <line x1="140" y1="382" x2="140" y2="420" stroke="#e05c18" stroke-width="1.8" stroke-dasharray="6,3" marker-end="url(#ma-ah-ember)"/>
            <text x="118" y="404" fill="#e05c18" font-size="11" font-family="JetBrains Mono,monospace" text-anchor="end">auto-invoke ↓</text>
            <line x1="190" y1="420" x2="190" y2="382" stroke="#c4b89e" stroke-width="1.5" stroke-dasharray="6,3" marker-end="url(#ma-ah-sand)"/>
            <text x="212" y="404" fill="#c4b89e" font-size="11" font-family="JetBrains Mono,monospace">↑ advisory</text>
            <rect x="40" y="428" width="250" height="68" rx="6" fill="#1c1710" stroke="#14b8a6" stroke-width="1.8" filter="url(#ma-glow-mint)"/>
            <rect x="40" y="428" width="250" height="68" rx="6" fill="rgba(20,184,166,.06)" stroke="#14b8a6" stroke-width="1"/>
            <circle cx="278" cy="438" r="3" fill="#e05c18"/>
            <circle cx="270" cy="438" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="454" fill="#e8dfd0" font-size="15" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">migration-ops</text>
            <text x="165" y="470" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Specialist</text>
            <text x="165" y="486" fill="#14b8a6" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/migrate · schema · platform</text>
            <line x1="165" y1="504" x2="165" y2="528" stroke="#14b8a6" stroke-width="2" marker-end="url(#ma-ah-mint)"/>
            <text x="165" y="538" fill="#14b8a6" font-size="11" font-weight="600" font-family="JetBrains Mono,monospace" text-anchor="middle">↓ spine 2 → 3 (build)</text>
          </svg>
        </div>
        <div class="ma-band-caption">
          <p><code>app-architect</code> anchors the spine, auto-invoking <code>stack-forge</code> for platform decisions, taking advisory input from <code>scale-ops</code> on capacity, and routing <code>migration-ops</code> when a live system needs a schema, framework, or platform change. The plan checkpoint is the master record downstream skills consume.</p>
          <div class="ma-bc-cp"><span class="ma-bc-cp-badge">CP</span><span>phase · stack_decision · capacity · migration_plan</span></div>
        </div>
      </details>

      <!-- PACK FABRIC (cross-cutting, v1.4) — sits between Plan and Build. -->
      <details class="ma-band ma-pack-fabric" open aria-label="Pack fabric: stack-forge packs (v1.4)">
        <summary class="ma-band-header ma-pack-fabric-header">
          <span class="ma-band-num">✦</span>
          <span class="ma-band-title">Pack fabric</span>
          <span class="ma-pack-fabric-badge"><span class="ma-pf-dot"></span>v1.4 · {packCounts.total}</span>
        </summary>
        <div class="ma-pack-fabric-body">
          <p class="ma-pack-fabric-sub">
            <code>stack-forge</code> owns the registry; 5 skills consume it.
            Source: <code>skills/stack-forge/packs/&lt;id&gt;/pack.yml</code>
          </p>
          <div class="ma-pack-fabric-cells">
            <div class="ma-pf-cell ma-pf-lang">
              <div class="ma-pf-cell-head">
                <span class="ma-pf-cell-kind">LANGUAGES</span>
                <span class="ma-pf-cell-count">{packCounts.language}</span>
              </div>
              <div class="ma-pf-chips">
                {packLanguages.map((id) => <span class="ma-pf-chip">{id}</span>)}
              </div>
            </div>
            <div class="ma-pf-cell ma-pf-fw">
              <div class="ma-pf-cell-head">
                <span class="ma-pf-cell-kind">FRAMEWORKS</span>
                <span class="ma-pf-cell-count">{packCounts.framework}</span>
              </div>
              <div class="ma-pf-chips">
                {packFrameworks.map((id) => <span class="ma-pf-chip">{id}</span>)}
              </div>
            </div>
            <div class="ma-pf-cell ma-pf-mob">
              <div class="ma-pf-cell-head">
                <span class="ma-pf-cell-kind">MOBILE</span>
                <span class="ma-pf-cell-count">{packCounts.mobile}</span>
              </div>
              <div class="ma-pf-chips">
                {packMobile.map((id) => <span class="ma-pf-chip">{id}</span>)}
              </div>
            </div>
            <div class="ma-pf-cell ma-pf-dep">
              <div class="ma-pf-cell-head">
                <span class="ma-pf-cell-kind">DEPLOY</span>
                <span class="ma-pf-cell-count">{packCounts.deploy}</span>
              </div>
              <div class="ma-pf-chips">
                {packDeployTargets.map((id) => <span class="ma-pf-chip">{id}</span>)}
              </div>
            </div>
          </div>
          <div class="ma-pack-fabric-foot">
            <span class="ma-pf-fanout">
              consumed by <b>stack-forge</b> · <b>app-architect</b> · <b>migration-ops</b> · <b>api-dev</b> · <b>deploy-ops</b>
            </span>
            <a class="ma-pf-cta" href="/coverage">View /coverage →</a>
          </div>
        </div>
      </details>

      <!-- BAND 3: BUILD -->
      <details class="ma-band" open style="--ma-phase-color: var(--ma-triagent)">
        <summary class="ma-band-header">
          <span class="ma-band-num">3</span>
          <span class="ma-band-title">Build</span>
          <span class="ma-band-of">Phase 3 of 5</span>
        </summary>
        <div class="ma-band-svg-wrap">
          <svg viewBox="0 0 330 600" role="img" aria-label="Build phase: ux-engineer hands to dash-forge; api-dev and integrations-engineer both branch to code-auditor downstream">
            <rect x="20" y="14" width="290" height="92" rx="6" fill="#1c1710" stroke="#fbbf24" stroke-width="1.8" filter="url(#ma-glow-yellow)"/>
            <rect x="20" y="14" width="290" height="92" rx="6" fill="rgba(251,191,36,.06)" stroke="#fbbf24" stroke-width="1"/>
            <circle cx="298" cy="24" r="3" fill="#e05c18"/>
            <circle cx="290" cy="24" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="42" fill="#e8dfd0" font-size="16" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">ux-engineer</text>
            <text x="165" y="60" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Tri-agent · Planner / Generator / Eval</text>
            <text x="165" y="78" fill="#fbbf24" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/uxe · /design</text>
            <text x="165" y="96" fill="#14b8a6" font-size="12" font-style="italic" font-family="JetBrains Mono,monospace" text-anchor="middle">branches → dash-forge</text>
            <line x1="165" y1="106" x2="165" y2="128" stroke="#14b8a6" stroke-width="2" marker-end="url(#ma-ah-mint)"/>
            <rect x="20" y="136" width="290" height="86" rx="6" fill="#1c1710" stroke="#14b8a6" stroke-width="1.8" filter="url(#ma-glow-mint)"/>
            <rect x="20" y="136" width="290" height="86" rx="6" fill="rgba(20,184,166,.06)" stroke="#14b8a6" stroke-width="1"/>
            <circle cx="298" cy="146" r="3" fill="#e05c18"/>
            <circle cx="290" cy="146" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="164" fill="#e8dfd0" font-size="16" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">dash-forge</text>
            <text x="165" y="182" fill="#c4b89e" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">Specialist · Tufte-density UI</text>
            <text x="165" y="200" fill="#14b8a6" font-size="12" font-family="JetBrains Mono,monospace" text-anchor="middle">/data-forge · /dashboard</text>
            <text x="165" y="216" fill="#c4b89e" font-size="11" font-style="italic" font-family="JetBrains Mono,monospace" text-anchor="middle">parallel build track ↓</text>
            <line x1="60" y1="240" x2="270" y2="240" stroke="#5a5040" stroke-width="1" stroke-dasharray="3,3"/>
            <text x="165" y="256" fill="#c4b89e" font-size="11" font-weight="600" letter-spacing="0.1em" font-family="JetBrains Mono,monospace" text-anchor="middle">PARALLEL · API + INTEGRATIONS</text>
            <rect x="20" y="270" width="290" height="92" rx="6" fill="#1c1710" stroke="#fbbf24" stroke-width="1.8" filter="url(#ma-glow-yellow)"/>
            <rect x="20" y="270" width="290" height="92" rx="6" fill="rgba(251,191,36,.06)" stroke="#fbbf24" stroke-width="1"/>
            <circle cx="298" cy="280" r="3" fill="#e05c18"/>
            <circle cx="290" cy="280" r="3" fill="#e05c18" opacity="0.55"/>
            <text x="165" y="298" fill="#e8dfd0" font-size="16" font-weight="600" font-family="Outfit,system-ui,sans-serif" text-anchor="middle">api-dev</text>
