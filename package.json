{
  "name": "opchain-dev",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "npm run prebuild && wrangler dev",
    "build": "node build.mjs",
    "deploy": "npm run prebuild && wrangler deploy",
    "deploy:staging": "npm run prebuild && wrangler deploy --env staging",
    "deploy:skip-build": "wrangler deploy --config wrangler.jsonc --no-build",
    "sync-docs": "bash scripts/sync-docs.sh",
    "make-zip": "bash scripts/make-skills-zip.sh",
    "gen-catalog": "node scripts/gen-skills-catalog.mjs",
    "build-site": "bash scripts/build-site.sh",
    "prebuild": "npm run gen-catalog && npm run sync-docs && npm run make-zip && npm run build-site",
    "pretest": "npm run gen-catalog",
    "test": "vitest run",
    "test:watch": "vitest",
    "site:install": "cd site && npm install",
    "site:dev": "cd site && npm run dev",
    "site:build": "cd site && npm run build"
  },
  "devDependencies": {
    "esbuild": "^0.28.0",
    "gray-matter": "^4.0.3",
    "vitest": "^4.1.5",
    "wrangler": "^4.85.0"
  },
  "dependencies": {
    "zod": "^4.3.6"
  }
}
