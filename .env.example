# opchain.dev — environment variable template.
# Copy this file to .dev.vars for local `wrangler dev` use.
# For production, set these via the Cloudflare dashboard or `wrangler secret put`.

# ── Linear (feedback widget) ────────────────────────────────────────────────
# Linear API key — used by POST /api/feedback to create issues.
# Get one at https://linear.app/settings/api
LINEAR_API_KEY=
# Override default team/project if deploying against a different Linear workspace.
# LINEAR_TEAM_ID=
# LINEAR_PROJECT_ID=
# Set FEEDBACK_DRY_RUN="true" to accept submissions without writing to Linear
# (returns a synthetic 201 with id "STAGING-DRY-RUN"). Already wired into
# wrangler.jsonc env.staging — production leaves it unset.
# FEEDBACK_DRY_RUN=

# ── Notify (install/download soft-gate capture) ─────────────────────────────
# Storage is a KV namespace, not an env var. Provision once with:
#   wrangler kv:namespace create NOTIFY
#   wrangler kv:namespace create NOTIFY --preview
# then drop the IDs into wrangler.jsonc › kv_namespaces. The handler
# accepts submissions even when the binding is missing (just doesn't
# persist them) so local dev works without provisioning.

# ── Email (pipeline-builder → Resend) ──────────────────────────────────────
# Resend API key — used by POST /api/email-pipeline to ship the rich HTML
# pipeline summary to whoever submits the Step 5 form.
# Get one at https://resend.com/api-keys. Verify the opchain.dev sending
# domain in the Resend dashboard before flipping this on in production.
# Set via `wrangler secret put RESEND_API_KEY` — never commit the value.
# Unset → /api/email-pipeline returns 503 not_configured (form stays usable).
# RESEND_API_KEY=
#
# From-address override. Defaults to "opchain.dev <pipeline@opchain.dev>"
# which is set in wrangler.jsonc › vars. Override here only if running
# against a different verified sender locally.
# EMAIL_FROM="opchain.dev <pipeline@opchain.dev>"

# ── Analytics (PostHog server-side capture) ────────────────────────────────
# If POSTHOG_PROJECT_API_KEY is unset, analytics is a no-op.
# POSTHOG_PROJECT_API_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com

# Client-side PostHog (consent-gated). Exposed via site/src/components/ConsentBanner.astro.
#
# These are baked into the deploy scripts in package.json — staging uses
# https://t.staging.opchain.dev and prod uses https://t.opchain.dev (managed
# reverse proxies that dodge most ad blockers). The key is public by design
# (PostHog client keys are safe to commit) and the same project on both envs.
#
# Override here for local dev only — Astro reads .env at build time. To run
# `npm run site:dev` against a real PostHog project, set both:
# PUBLIC_POSTHOG_KEY=phc_m4mpaJBA3EsEFRiGeVQWESFX8pz6CtS6B8y85Va6rmJV
# PUBLIC_POSTHOG_HOST=https://t.opchain.dev

# ── Feature flags ──────────────────────────────────────────────────────────
# Runtime flag values come from PostHog's /decide API (uses the same
# POSTHOG_PROJECT_API_KEY/POSTHOG_HOST as analytics). When PostHog is
# unconfigured, every flag falls back to the default declared in
# src/lib/flags/registry.js — the source of truth.
#
# Wrangler env-var overrides win over PostHog and the default. The naming
# convention is FLAG_<UPPER_SNAKE>: e.g. site.ops.api-feedback.kill →
# FLAG_SITE_OPS_API_FEEDBACK_KILL. Booleans accept "true"/"false"/"1"/"0".
# Useful for staging-only kill switches and forcing a value in tests.
# FLAG_SITE_OPS_API_FEEDBACK_KILL=true
# FLAG_SITE_OPS_API_NOTIFY_KILL=true
# FLAG_SITE_OPS_API_HEALTH_DETAILED=true
