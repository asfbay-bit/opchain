# opchain.dev — environment variable template.
# Copy this file to .dev.vars for local `wrangler dev` use.
# For production, set these via the Cloudflare dashboard or `wrangler secret put`.

# Linear API key — used by POST /api/feedback to create issues.
# Get one at https://linear.app/settings/api
LINEAR_API_KEY=

# Anthropic API key — used by POST /api/try/chat to stream Claude responses.
# Get one at https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# HMAC signing secret for Try-It session tokens. Must be a long, random string.
# Generate with:  openssl rand -hex 32
DEPLOY_API_TOKEN=

# Optional — override the Anthropic model used by the Try-It demo.
# Defaults to claude-haiku-4-5-20251001 if unset.
# ANTHROPIC_MODEL=

# Optional — TTL in days for lead KV entries. Defaults to 365 if unset.
# LEAD_TTL_DAYS=365

# Analytics (Sprint 4+). Both client-visible; safe to check into a preview env.
# POSTHOG_PROJECT_API_KEY=
# POSTHOG_HOST=https://eu.i.posthog.com
