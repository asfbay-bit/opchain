site/blob-report/

# Sprint 6 — public/ is now a build artifact (Astro output + sync'd docs + zip).
# `scripts/build-site.sh` rebuilds it on every prebuild. Nothing in public/ is
# source-of-truth any more; source lives in site/ (pages/components) and skills/.
public/
src/generated/

# Allow ad-hoc layout-preview HTML pages under site/public/dev-preview/. These
# are static-asset files Astro will serve at /dev-preview/* and are committed
# only while a design review is in progress; remove once the choice is made.
!site/public/dev-preview/
!site/public/dev-preview/**

# Cloudflare
.wrangler/
.dev.vars
.dev.vars.*

