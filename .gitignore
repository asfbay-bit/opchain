# Secrets — never commit. `scripts/gen-did.mjs` writes the did:web PRIVATE key
# under .secrets/; move it to a password manager / Cloudflare secret and delete it.
.secrets/

# Dependencies
node_modules/

# Build output
dist/
site/dist/
site/.astro/

# Playwright
site/playwright-report/
site/test-results/
site/blob-report/

# Sprint 6 — /public/ is now a build artifact (Astro output + sync'd docs + zip).
# `scripts/build-site.sh` rebuilds it on every prebuild. Nothing in /public/ is
# source-of-truth any more; source lives in site/ (pages/components) and skills/.
# Anchored to project root so Astro's site/public/ static-asset folder still
# tracks design previews and other source-of-truth files committed there.
/public/
src/generated/*

# Baseline emitted by scripts/gen-stack-packs.mjs. Tracked so a fresh checkout
# can import it via src/lib/flags/registry.js before any prebuild has run; the
# build overwrites it on every run.
!src/generated/coverage-flags.json

# Baseline emitted by scripts/gen-api-dev-adapters.mjs (v1.4 PR 3). Same
# pattern as coverage-flags.json — tracked so api-dev can import the typed
# adapter list without a build-first dependency; the build overwrites it.
!src/generated/api-dev-adapters.json

# Baseline emitted by scripts/gen-packs-catalog.mjs (v1.4 PR 8). Same
# pattern — tracked so the site's /coverage page can import the catalog
# without a build-first dependency; the build overwrites it.
!src/generated/packs-catalog.json

# Baseline emitted by scripts/gen-mcp-catalog.mjs. Same pattern — tracked so
# the Worker can import it for the /mcp endpoint before any prebuild has run;
# the build overwrites it.
!src/generated/mcp-catalog.json

# Codegen — regenerated on every prebuild from src/lib/flags/registry.js
site/src/lib/flags/registry.ts

# Build-time Linear roadmap pull (scripts/gen-roadmap.mjs). Regenerated
# on every prebuild; checked-out tree starts empty when LINEAR_API_KEY
# isn't set. The TypeScript loader (roadmap-types.ts) returns an empty
# shape when this file is missing so Astro builds stay green either way.
site/src/data/roadmap.json

# Cloudflare
.wrangler/
.dev.vars
.dev.vars.*

# Claude Code parallel-agent worktrees — temporary, per-session
.claude/worktrees/

# .claude/skills/ holds ONLY symlinks to ../../skills/<name> (CI enforces this).
# Stray zipped bundles get drag-dropped here via the GitHub web UI — keep them
# out so they can't break the symlink-integrity check.
.claude/skills/*.zip

# Env
.env
.env.local
.env.*.local
!.env.example

# Checkpoints (opchain skills write here).
# Tracked in git as living "session state docs" so they survive across
# sessions and machines (incl. Claude Code on the web). Schema + tooling
# in .checkpoints/README.md and scripts/checkpoint.mjs.
#
# Exception: bug-check is local-only. By its own SKILL.md contract it
# "always runs fresh — no continue/restart prompt," so there's no
# session-resume value in tracking it. Its run telemetry (updated_at,
# step, last_run.*, run_history, streak) rewrites on every pre-commit
# gate run, which generates 2-3 false merge conflicts per PR. The
# pre-commit hook reads the file locally and handles the missing-file
# case (it just prompts you to run /bugcheck first).
#
# NOTE: this pattern previously read `.checkpoints/bug-check.checkpoint.json`
# (missing the `oc-` prefix), so the real file `oc-bug-check.checkpoint.json`
# was never actually ignored — it stayed tracked and kept producing the very
# merge conflicts this exception exists to prevent. Fixed to the correct name.
.checkpoints/oc-bug-check.checkpoint.json

# Telemetry store (oc-telemetry-ops, v1.6). Local-only, opt-in usage metering.
# Unlike the tracked checkpoint JSONs, this raw SQLite store NEVER leaves the
# machine — only the anonymized aggregate export (no PII) is ever published.
.checkpoints/usage.sqlite
.checkpoints/usage.sqlite-*

# Playwright (Sprint 7a)
site/test-results/
site/playwright-report/
site/.playwright/

# LHCI (Sprint 7b)
.lighthouseci/

# Logs
*.log
npm-debug.log*

# Editor
.vscode/
.idea/
.DS_Store

# Python bytecode from reports/token-usage/generate.py
reports/token-usage/__pycache__/
