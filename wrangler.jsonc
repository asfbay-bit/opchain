{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "opchain-dev",
  "main": "dist/index.js",
  "compatibility_date": "2026-03-01",
  "compatibility_flags": ["nodejs_compat"],
  "no_bundle": true,
  "observability": { "enabled": true },
  "build": {
    "command": "node build.mjs"
  },
  // Production custom domain. `custom_domain: true` lets Cloudflare manage
  // the DNS record automatically on `wrangler deploy` (no CNAME to maintain
  // by hand).
  //
  // Do NOT pre-create a DNS record for opchain.dev — wrangler will refuse
  // with `error 100117 Hostname ... already has externally managed DNS
  // records` if one exists.
  //
  // Deploys run from a developer laptop with `wrangler login`. The local
  // OAuth session has full account access, which is required to write the
  // zone's DNS record on first deploy. CI deploys are not configured for
  // this reason — see CLAUDE.md › Deployment.
  "routes": [{ "pattern": "opchain.dev", "custom_domain": true }],
  // EMAIL_FROM is the From header used by POST /api/email-pipeline. The
  // verified Resend domain is opchain.dev — change this without redeploy
  // by overriding the env var in the Cloudflare dashboard. The Resend API
  // key itself (RESEND_API_KEY) is a secret; set it with
  // `wrangler secret put RESEND_API_KEY` rather than declaring it here.
  "vars": {
    "EMAIL_FROM": "opchain.dev <pipeline@opchain.dev>"
  },
  "assets": {
    "directory": "./public/",
    "binding": "ASSETS",
    "not_found_handling": "404-page",
    "run_worker_first": true
  },
  // /api/notify writes lead records to the NOTIFY KV namespace. The
  // handler in src/index.js degrades gracefully if the binding is
  // unset — submission accepted, persistence skipped — so removing
  // these blocks doesn't break deploys; it only disables persistence.
  //
  // Wrangler 4.x rejects `id: ""` at config-parse time, so the entries
  // must contain real namespace IDs (or the arrays must be omitted
  // entirely). Provision via the Cloudflare dashboard (Workers & Pages →
  // KV → Create namespace) or:
  //   wrangler kv namespace create NOTIFY            (production)
  //   wrangler kv namespace create NOTIFY --preview  (local `wrangler dev`)
  //   wrangler kv namespace create NOTIFY-staging    (staging)
  //
  // The previous `DATA` namespace was used by the now-removed Try-It
  // chat; Cloudflare retains it if you need to read old leads.
  "kv_namespaces": [
    {
      "binding": "NOTIFY",
      "id": "6a7121cf34354a9991727187311b6264",
      "preview_id": "2b5cb8f0733e4cb88a89b0dc8b1dd3d7"
    }
  ],
  "env": {
    "staging": {
      "name": "opchain-staging",
      // Staging custom domain. Same shape as the prod `routes` above —
      // see that comment for DNS / wrangler-login notes.
      "routes": [{ "pattern": "staging.opchain.dev", "custom_domain": true }],
      // Disable Linear writes from staging. The /api/feedback handler
      // accepts the submission, logs the FEEDBACK_DRY_RUN event, and
      // returns a synthetic 201 with id "STAGING-DRY-RUN" — no Linear
      // call, so LINEAR_API_KEY isn't required here. Keeps test
      // submissions out of the prod Linear backlog.
      "vars": { "FEEDBACK_DRY_RUN": "true" },
      "kv_namespaces": [
        {
          "binding": "NOTIFY",
          "id": "a76010c99fc346f4b3fe0e532ff4398f",
          "preview_id": "2b5cb8f0733e4cb88a89b0dc8b1dd3d7"
        }
      ]
    }
  }
}
